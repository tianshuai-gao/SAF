    "title-g_bo_809": "ནོ་རོ་ནད་དུག་ནི་RNAནད་དུག་ཡིན་པས། གཞན་འགྱུར་གྱི་དུག་སྡོང་གསར་པ་ཐོན་ནས་གོ་ལ་ཧྲིལ་པོའམ་ཡང་ན་ས་ཁོངས་རང་བཞིན་གྱི་རིམས་ནད་མཆེད་ཀྱི་ཡོད།",
    "title-g_bo_355": "སློབ་གསོ་པུའུ་སློབ་ཕྱིའི་སློབ་གསོ་གསོ་སྦྱོང་གྲོན་དངུལ་ཕྱིར་སློག་གི་མིང་ཐོག་ནས་གློག་འཕྲིན་དྲ་ལམ་དུ་མགོ་སྐོར་བཏང་ནས་ཤུགས་རྐྱེན་ངན་པ་དང་གནོད་འཚེ་ཚབས་ཆེན་བཟོས་ཡོད།",
    "title-g_bo_154": "2023ལོའི་ཟླ་9ཚེས་12ཉིན་མཇུག་འགྲིལ་བའི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས་འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "གསང་མྱུལ་གྱི་དོཊ་པ་ཡོད་པའི་ལྗར་ཕན་གྱི་སྤྱི་དམངས་དེར་བཙན་ཐབས་སྤྱད་པ།",
    "title-g_bo_327": "2023ལོའི་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་ཞིང་། རྒྱལ་ས་ཏེ་ཧེ་རན་དང་སུའུ་ལའེ་མན་ཉི་ཡི་ཕ་ཡུལ་ཁེའ",
    "title-g_bo_323": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་ཨུ་རུ་སུའི་མྱུལ་ཞིབ་ཨུ་ལྷན་གྱིས་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་ཞིག་ཚེས་24ཉིན་ཨུ་རུ་སུའི་པེའར་ཀེ་ལུའོ་ཏེ་མངའ་སྡེར་ལྷུང་བས། གནམ་གྲུའི་ཐོག་གི་མི་ཚང",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་གནས་མཆོག་འདི་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་སྙན་པའི་གྲགས་པ་ཕྱོགས་བཞིར་གྲགས།",
