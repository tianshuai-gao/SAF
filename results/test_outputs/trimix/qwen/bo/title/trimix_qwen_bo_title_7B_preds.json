    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པའི་བརྗོད་གཞི་དེར་མི་མང་པོས་དོ་ཁུར་དང་གྲོས་བསྡུར་མང་པོ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_577": "2022ལོའི་ཨ་རིའི་རྒྱལ་སྲུང་དང་མཁའ་སྐྱོད་ཁྱབ་ཁོངས་ཀྱི་བཟོ་ལས་ཐོན་རྫས་རིན་ཐང་དེ་ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ཐོན་པ་ནས་བཟུང་17.5%འཕར་ཡོད།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱིས་རྒྱ་གར་གྱི་དམག་མི་བཞི་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་ཉུང་མཐར་ཡང་དམག་མི་གཉིས་ལ་རྨས་སྐྱོན་ཕོག་པ།",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་དམག་གཉིས་ཀྱི་བར་དུ་ཡང་གྲི་འཕྱར་ཞིང་གཞུ་འཐེན་པ་ལྟ་བུའི་འགྲན་རྒོལ་རྣམ་པར་གནས་ཡོད།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་ཉིང་ཁྲི་གྲོང་ཁྱེར་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་དངུལ་ཁང་གཱ་བསྡམས་བཅད་བྱས་པའི་སྐོར་གྱི་མང་ཚོགས་མའོ་ཆེ་གེ་མོའི་བློ་འདྲིའི་ཁ་པར་འབྱོར་བ་དང",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་ཁབ་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་གྱི་བསྡོམས་འབོར་ཨ་སྒོར་དུང་ཕྱུར་ཁྲི་31ཟིན་པ་དང་། གྲངས་འཛིན་དཔལ་འབྱོར་གྱིས་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་བསྡུར་གྲངས་ཀྱི་58%བཟུང་ནས་གཞ",
    "title-g_bo_675": "སློབ་གསོ་པུས་སློབ་ཕྱིའི་གསོ་སྦྱོང་བདེ་འཇགས་སྲུང་སྐྱོང་ཞེས་པའི་ཆེད་དོན་བྱ་སྤྱོད་སྤེལ་ནས། སློབ་གྲྭ་འབྲིང་ཆུང་གི་སློབ་མར་སློབ་ཕྱིའི་གསོ་སྦྱོང་བདེ་འཇགས་སྲུང་སྐྱོང་ཞེས་པའ�",
    "title-g_bo_404": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན། མིག་སྔའི་བར་རེས་སྐོར་དེའི་གདོང་ཐུག་ཁྲོད་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕ�",
    "title-g_bo_65": "2023ལོའི་ཟླ་10ཚེས་14ཉིན་ཞི་ཅིན་ཕིང་གིས་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པར་རྟེན་འབྲེལ་ཞུ་བའི་གློག་འཕྲིན་བཏང་སྟེ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ་རེད།",
    "title-g_bo_214": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ་༼ལྷ་ས་གྲོང་ཁྱེར་སྲིད་གཞུང་གི་ཡིག་ཆ་〔2023〕�",
    "title-g_bo_761": "ཡུག་རེན་གྱི་ཙུང་ལི་གཞོན་པ་དང་པོ་དང་དཔལ་འབྱོར་པུའུ་ཀྲང་ཡིའུ་ལི་ཡ་སི་ཝུའེ་ལི་ཏེང་ཁོ་ཡིས་ཡུག་རེན་གྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་ཡོད།",
    "title-g_bo_632": "2023ལོའི་ཟླ་12ཚེས་27ཉིན་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་དུ་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲོད་པའི་ཁྲིམས་གཞིར་གྲོས་འཆམ་བྱུང་བ།",
    "title-g_bo_856": "ཨ་རིའི་རྒྱ་མཚོའི་ཤར་རྒྱུད་ཀྱི་རྒྱ་མཚོའི་ཚ་རླབས་ཀྱི་རྐྱེན་ལས་ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེས་ཆེ།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་23ཉིན་གྱི་ཚོགས་འདུ་གཙོ་སྐྱོང་བྱས་པ་རེད།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོངས་མཆན་ཞབས་ཞུ་གནས་སྐབས་མཚམས་བཞག་པ་དང་རྗེས་མཐུད་ཀྱི་གནས་ཚུལ་ལ་བརྡ་ཐོ་གཏོང་རྒྱུ་ཡིན་པ་དང་། གནས་ཚུལ་གསར་པ་ལོགས་སུ་བརྡ་ཐོ་གཏོང་རྒྱུ་ཡིན་པས། དྲ་ཚིགས་ཐོག་གི་གནས་ཚུལ་གས",
    "title-g_bo_802": "ལྷོ་ཁོ་རེ་ཡ་དང་ཨ་རི་དང་ལྗར་པན་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པ།",
    "title-g_bo_180": "1995ལོ་ནས་བཟུང་ཁྲུང་ཆིང་གིས་ཆབ་མདོ་གྲོང་ཁྱེར་དང་དེའི་ཁོངས་གཏོགས་ཀྱི་སྨར་ཁམས་རྫོང་དང་རི་བོ་ཆེ་རྫོང་། བྲག་གཡབ་རྫོང་བཅས་ལ་ཁ་གཏད་རོགས་སྐྱོར་བྱེད་པའི་ལས་འགན་སྔ་རྗེས་སུ་འཁུར་འགོ་ཚུགས་པ་རེད།",
    "title-g_bo_638": "2023ལོའི་ཟླ་དང་པོ་ནས་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་ཡོད།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དེ་ཨུ་རུ་སུའི་མཁའ་དམག་གིས་ཉིན་དེར་མོ་སེ་ཁོར་འཇབ་རྒོལ་བྱེད་རྩིས་ཡོད་པའི་ཡུག་རེན་གྱི་མི་མེད་གནམ་གྲུ་གཅིག་གཏོར་ལྷུངས་བཏང་ཡོད་ཅེས་",
    "title-g_bo_319": "2023ལོར་རང་རྒྱལ་གྱིས་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་ལ་ཁྱད་ཆོས་གཉིས་ཡོད་པ་དང་། གཅིག་ནི་ད་ལོ་འགོས་ནད་ཕོག་མང་བ་དང་། གཉིས་ནི་འགོས་ནད་ཕོག་པའི་མི་ཚོགས་ཀྱི་ལོ་ན་ཆུང་བའི་ཁྱད་ཆོས་མངོན་ཡོད།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡའི་ཕྱི་འབྲེལ་པུའི་པུའུ་ཀྲང་གཞོན་པ་ཧྥུའུ་ལའེ་ཏི•མ་མཱ་ཉིས་ཀྱིས་དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ་དང་། ཀ་ཧྲ་ས་ཁུལ་དུ་ཕ་ལེ་སི་ཐན་མི",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།",
    "title-g_bo_185": "2023ལོའི་ཟླ5པའི་ཚེས18ཉིན་གྱི་ཆུ་ཚོད་བཅུ་པ་ནས་ཟླ7པའི་ཚེས1ཉིན་གྱི་ཆུ་ཚོད་བཅུ་པའི་བར། མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན། བོད་བྱང་ཐང་བཅས་ཀྱི་གཙོད་མོ་ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོ",
    "title-g_bo_884": "པའེ་ཏེང་གི་ཉིན་དེར་དབྱི་སི་རལ་གྱི་གྲོགས་པོ་ངོ་མའི་ངོས་ནས་དབྱི་སི་རལ་གྱི་གྲོགས་པོ་ངོ་མའི་ངོས་ནས་དབྱི་སི་རལ་གྱི་གྲོགས་པོ་ངོ་མའི་ངོས་ནས་དབྱི་སི་རལ་གྱི་གྲོགས་པོ་ངོ་མའི་ངོས་ནས་དབྱི་སི་རལ་ག",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བར་རིམ་པ་སྤོར་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ་རེད།",
    "title-g_bo_165": "2023ལོའི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་བའི་སྟེང་།",
    "title-g_bo_275": "2017ལོའི་མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱི་དཔང་ཉན་ཚོགས་འདུའི་ཐོག་གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས་འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས་པ་རེད།",
    "title-g_bo_900": "2023ལོའི་ཟླ་2ཚེས་24ཉིན་གྱི་ཚོགས་ཆེན་ཐོག་ཤིན་ཅང་དུ་སྣེ་འོད་ལྟ་དཔྱད་ཐུབ་དོན་ཅི་ཡིན་ནམ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་ལ་ཞིབ་འཇུག་བྱེད་པའི་ཚོགས་འདུ་གཙོ་སྐྱོང་གནང་བ།",
    "title-g_bo_388": "དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ལ་འགེབས་སྲུང་བྱེད་པ་མ་ཟད། སྐམ་མཚོ་མཁའ་གསུམ་གྱི་མཐུན་སྦྱོར་གཡུལ་འགྱེད་ལ་བརྟེན་ནས་ཀ་ཧྲ་རྒྱུད་ཀྱི་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ད�",
    "title-g_bo_578": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་ཕྱོགས་ཀྱིས་ཀ་ཧྲ་ས་ཁུལ་ལྷོ་རྒྱུད་ཀྱི་ཧན་ཡིའུ་ཉི་སིར་གཞི་ཁྱོན་ཆེ་བའི་ཕར་རྒོལ་བྱས་པ་དང་། ཉུང་མཐར་ཡང་ཕ་ལེ་སི་ཐན་གྱི་དྲག་ཆས་མི་སྣ་50�",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་ཙུང་ཐུང་ལ་སླར་ཡང་བདམས་ཐོན་བྱུང་ནས་འགན་གནས་བསྟུད་འཛིན་གནང་བར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་གསོལ་སྟོན་གནང་བ།",
    "title-g_bo_235": "2024ལོའི་ཧྲ་ཅོན་གྱི་ཁུ་ལུའི་སྤུས་རྟགས་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023ལོའི་བོད་རང་སྐྱོང་ལྗོངས་བུད་མེད་དང་བྱིས་པའི་སྨན་ཁང་གི་སྒྲ་རླབས་གསོ་རིག་ཚན་ཁག་གི་བྱེད་སྒོ་སྤེལ་ཡུལ་ལྷ་ས་གྲོང་ཁྱེར་སྣེའུ་ཁུལ་གསར་ཚ་རྒུར་ལམ་ཆེན་སྒོ་རྟགས་ 10 པའི་སྒྲ་རླབས་གསོ་རིག་ཚ",
    "title-g_bo_918": "《ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་ཞུ་བའི་འཕྲིན་ཡིག》སྤྲིངས་ནས་ཀྲུང་གོ་རིག་པའི་ཞིབ་འཇུག་གི་དོན་སྙིང་གལ་ཆེན་རྒྱས་བཤད་གནང་བ།",
    "title-g_bo_451": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་10པར་ཞིང་ཆེན་ནན་ཁྲང་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་སྒོར་ཁྲི་1169ཏག་ཅོག་ཙེའི་སྟེང་དུ་སྤུངས་ཡོད་ཅིང་། དེ་ནི་ས་གནས་དེ་གའི་འབྲུ་རིགས་འདེབས་མཁན་དུད་ཚང་ཆེན",
    "title-g_bo_997": "2023ལོའི་ཟླ་10ཚེས་8ཉིན་གྱི་ཆུ་ཚོད་12པར་ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་གནས་སྐབས་སྲིད་གཞུང་གི་རང་བྱུང་གནོད་འཚེ་དོ་དམ་པུའི་མགྲིན་ཚབ་པ་ཅ་ནན·སའེ་དབྱི་ཁེས་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་གནོད་འཚེ་ཕོ",
    "title-g_bo_544": "2023ལོའི་ཟླ་11པའི་ཚེས་19ཉིན་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ་དང་།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་ངལ་དུབ་དབང་གིས་ན་ཟུག་གཏོང་བ་དེ་གཙོ་བོ་སྐེད་པའི་ཤ་གནད་ཀྱི་རྩ་འཁུམ་པ་དང་ན་ཟུག་གཏོང་བ། ཤུགས་ཉམས་པ་སོགས་ཀྱི་ཐོག་ནས་མངོན་གྱི་ཡོད།",
    "title-g_bo_847": "2023ལོའི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བཞིན་པའི་ཚུལ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ལ་བཅིངས་འགྲོལ་དམག་དང་དྲག་ཆས་ཉེན་རྟོག་དཔུང་སྡེའི་ཁྲོད་ལན་ཆ་ཡག་པོ་བྱུང་ཡོད།",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》ཐོག་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཟླ་11པའི་ཚེས་5ཉིན་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། དབྱི་སི་རལ་གྱི་ཙུང་ལི་ནེ་ཐ་ཉི་ཡ་ཧུའུ་ཡིས་དབྱི་སི་རལ་ཕྱོགས་ཀྱི་མི་སྣ་གློད་གྲོལ་མ་བཏ",
    "title-g_bo_830": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་2དང་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་2ཀྲུང་གོའི་ནན་ཧྲ་གླིང་ཕྲན་གྱི་རེན་ཨའེ་ཅའོ་ཉེ་འགྲམ་མཚོ་ཁོངས་སུ་འཛུལ་འདུག",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་ཆེད་མཁས་ལས་དོན་གྲོས་ཚོགས་དེ་དྲ་ཐོག་དང་དྲ་ཕྱི་ཟུང་འབྲེལ་གྱི་རྣམ་པས་འཚོགས་ཤིང་།",
    "title-g_bo_826": "2023ལོའི་ཟླ་6ཚེས་6ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་པ།",
    "title-g_bo_17": "2023ལོའི་རྒྱལ་ཡོངས་ཀྱི་བཟོ་ལས་དང་ཆ་འཕྲིན་ཅན་གྱི་རྩལ་ནུས་འགྲན་བསྡུར་ཆེ་མོ་སྐབས་གཉིས་པ་ལས་ཤེས་རྟོགས་བྱུང་བ།",
    "title-g_bo_285": "མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་ཆབས་ཅིག ལག་པས་འོག་ནས་སྒང་ལ་འཕུར་འཕུར་བཏང་ན་ན་ཟུག་ཆེ་རུ་ཕྱིན་ཚེ། སྤྱིར་ན་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཡོད།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ནས་ཚེས་24ཉིན་བར་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ་རེད།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་ཕྱོགས་ཀྱི་ཁེ་དབང་ལ་བཙན་གནོད་དང་འཁྲུག་རྐྱེན་སློང་བའི་བྱ་སྤྱོད་ལ་སྐྱོན་འཛུགས་བྱས་པ་དང་འབྲེལ་འགྲོ་བའི་གནས་ཚུལ་བྱུང་བ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན།",
    "title-g_bo_563": "3Dབརྙན་ཡོལ་གྱི་ཟུར་གསུམ་ལངས་གཟུགས་ཅན་གྱི་རྣམ་པར་བརྟེན་ནས་གཟིགས་མོ་བར་ཐུན་མིན་གྱི་མཐོང་རྒྱ་ཞིག་བཟོས་ཡོད།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་ཚོགས་འདུ་བསྡུས་པ།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་སུ་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་སྤྱི་ཟླ་11པའི་ཚེས་25དང་26ཉིན་གཏོང་རྒྱུ་རེད།",
    "title-g_bo_932": "ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པའི་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། ཨ་རི་དང་དབྱིན་ཇི་རྒྱལ་ཁབ་གཉིས་ཀྱི་དམག་འཐབ་གནམ་གྲུས་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་རྗེས་སྔར་བཞིན་གྲོང་ཁྱེར་དེའི་མཁའ་དབྱིངས་སུ་ལྡིང་ས�",
    "title-g_bo_110": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་ཚོགས་འདུ་ཐེངས་སུམ་ཅུ་པར་ཞུགས་སྐབ",
    "title-g_bo_707": "ཨུ་རུ་སུའི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་གིས་བྱང་ཁོ་རེ་ཡ་དེ་ལྗར་པན་གྱི་མི་སེར་སྤེལ་བའི་དབང་སྒྱུར་འོག་བཅིངས་འགྲོལ་བཏང་བའི་བརྒྱུད་རིམ་ནང་འགག་རྩའི་ནུས་པ་འདོན་སྤེལ་བྱས་ཡོད།",
    "title-g_bo_822": "2023ལོའི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་པེ་ཅིང་དུ་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་ཡོད།",
    "title-g_bo_529": "གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་ནས་འབར་མདེལ་བཟོ་བའི་འཁོར་སྟེགས་དང་། རྒྱང་ཁྲིད་མ�",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་11ཉིན་བསྟན་པར། ཉིན་དེའི་སྔ་དྲོའི་ཆུ་ཚོད་7པར་ཟོག་འདྲེན་མེ་འཁོར་ཞིག་ལིའང་ཙན་མངའ་སྡེ་བརྒྱུད་འགྲོ་སྐབས་ཆག་སྒོ་བྱུང",
    "title-g_bo_287": "ཨ་རི་དང་ཡུག་རེན་གྱི་གདོང་གཏུག་བྱུང་ཚུལ་བརྗོད་པ།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་ལྗོངས་ཡོངས་ཀྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བར། བོད་ལྗོངས་ཀྱི་དཔལ་འབྱོར་གོང་འཕེལ་རྒྱུན་མཐུད་ཡག་པོ་བ�",
    "title-g_bo_901": "2020ལོའི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་ཕྱི་འབྲེལ་འབྲེལ་བ་སླར་གསོ་བྱ་རྒྱུའི་ཆབ་སྲིད་ཀྱི་ཇུས་ཐག་བཅད་ཡོད།",
    "title-g_bo_342": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་ཉིང་རྡུལ་ཆུར་འཛུལ་དམག་གྲུ་བཀོད་སྒྲིག་བྱས་པའི་གནས་ཚུལ་ཕྱིར་བསྒྲགས་བྱེད་དགོས།",
    "title-g_bo_629": "2025ལོར་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་ཁྱབ་བསྒྲགས་བྱས་ནས་འགག་རྩའི་ལྷུ་ལག་བདེ་འཇགས་ངང་མཁོ་སྤྲོད་བྱེད་རྒྱུ་རེད།",
    "title-g_bo_259": "2023ལོའི་ཀྲུང་གོའི་བྱིས་པའི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་བརྩམས་ཆོས་ལ་བྱ་དགའ་སྤྲོད་པའི་བཞུགས་མོལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_685": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པས་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་བ།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
    "title-g_bo_50": "2023ལོའི་ཟླ་12པའི་ཚེས་3ཉིན་གྱི་ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_769": "2023ལོའི་ཟླ་11ཚེས་27ཉིན་གྱི་ཆུ་ཚོད་7པར་དབྱི་སི་རལ་བ་10དང་ཕ་ལེ་སི་ཐན་བ་30བརྗེ་པོ་རྒྱག་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན་ཞེས་བཤད་ཡོད།",
    "title-g_bo_582": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་དཔེ་གཉིས་ལ་གཟིགས་རོགས།",
    "title-g_bo_635": "ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོས་ཅིང་ཏུང་གི་འཛད་སྤྱོད་ཞབས་ཞུ་བ་ཡིན་ཟེར་མཁན་ཞིག་གི་ཁ་པར་འབྱོར་བ་དང་། མི་དེས་ཅིང་ཏུང་ཆད་འཛིན་གྱི་སྐྱེད་ཀ་མཐོ་དྲགས་འདུག་ཅེས་པར་ཁ་གཡར་ནས་གྲོང་མི་ལི་ཆེ་གེ་མོར་དངུལ་ཁང",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་སྟབས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་ན་དོ་སྣང་གནང་དགོས་པ་དང་། གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་ན་དོ་སྣང་གནང་དགོས་པ་གང་ཡིན་ནམ།",
