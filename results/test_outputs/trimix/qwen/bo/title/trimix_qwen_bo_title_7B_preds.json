    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་ཨ་རིའི་དམག་ལ་ཉེ་ཆར་འཇབ་རྒོལ་རབ་དང་རིམ་པ་ཕོག་པར་ཡ་ལན་སློག་པ་ཡིན་ཞེས་བརྗོད་འདུག",
    "title-g_bo_872": "འབའ་ཐང་རྫོང་གི་སྐབས་དང་པོའི་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ཆེན་མོ་ཉེ་ཆར་ཐུགས་གྲ་ལེགས་མཇུག་འགྲིལ་བ་དང་། བྱ་དགའ་ཐོབ་མཁན་གྱི་འགྲན་ཞུགས་པ་རྣམས་ལ་གཟེངས་བསྟོད་སྤྲོད་པའི་མཛད་སྒོ་ཡང་ས་གནས་དེ་གའི་འ",
    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་ཞི་ཅིན་ཕིང་གིས་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་སྟེ། ཨུ་ཡོན་ལྷན་ཁང་དང་དེའ�",
    "title-g_bo_575": "2020ལོའི་ཡར་ཀླུང་གཙང་པོའི་རིང་ཚད་ལ་སྟོང་སྨི་504.6ཡོད་པ་དང་། རྒྱ་མཚོའི་ངོས་ལས་ས་བབས་མཐོ་ཚད་སྨི་7782ཡོད་པའི་ཧི་མ་ལ་ཡ་ཤར་མའི་ཆེས་མཐོའི་རི་རྩེ་གནམ་ལྕགས་འབར་བ་ནས་སྨི་550ཡོད་པའི་མེ་ཏོག་ཡར་ཀླུང་གཙང་པོའི",
    "title-g_bo_417": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་ཀྱི་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_484": "2024ལོའི་སློབ་ཆེན་ལ་རྒྱུཊ་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་གསར་པ།",
    "title-g_bo_249": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་ཕུའུ་ལ་ཤིན·དབྱི་སི་ཀན་ཏར་གློག་འཕྲིན་བཏང་ནས། ཁོང་གིས་མ་ལེ་ཞི་ཡའི་གཙོ་འཛིན་གྱི་འགན་བཞེས་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ་རེད།",
    "title-g_bo_380": "2023ལོའི་ཟླ་10པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོའི་དུས་ཚོད་བར་དབྱི་རག་ཏུ་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཨ་པུ་བཀྲ་པེར་འཚམས་འདྲི་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_959": "ཀྲུང་གོ་དང་ཁོང་ཀོ་པུའི་མཛའ་གྲོགས་སྨན་ཁང་གི་སྨན་པ་ཞིག་གི་སྐོར།",
    "title-g_bo_976": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར་ཡོད།",
    "title-g_bo_97": "ལྗར་ཕན་དུ་ལོ་65ཡན་གྱི་རྒན་རྒོན་ཁྲི་3623ཡོད་པ་དེ་ན་ནིང་གི་དུས་མཚུངས་ལས་མི་ཁྲི་1ཉུང་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_309": "2023ལོའི་ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན།",
    "title-g_bo_56": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་ཞུ་སྦྱོར་ཕྱི་མ་ཡུས་ཧྭ་དབྱིང་གིས་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_973": "དབང་ཆེན་གྱི་ཕུགས་བསམ་དད་སེམས་ཤོར་བ།",
    "title-g_bo_294": "བྱང་བུ་དེའི་རྒྱབ་ངོས་སུ་བཀོལ་སྤྱོད་བྱེད་སྟངས་དང་གོ་ཆོད་དུས་བཀག་ཡོད་པ་མ་ཟད། ཆེད་མངགས་གསལ་བཤད་བྱས་ཡོད་པ་ཞིག་ནི་ཀྲུང་གོའི་སྒུལ་བདེའི་བྱིས་པའི་ལག་ཐོགས་ཆུ་ཚོད་ཀྱི་ཁ་པར་བྱང་བུ་ཞེས་བྲིས་ཏེ།",
    "title-g_bo_689": "སློབ་བསྡུ་སྡེ་ཚན་གྱིས་སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས།",
    "title-g_bo_551": "2023ལོའི་ཟླ་11ཚེས་23ཉིན་གྱི་སྔ་དྲོ་ཧང་ཀྲོའུ་ཤིས་ཧུའུ་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉ",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》དེ་ཉེ་ཆར་མི་དམངས་དཔེ་སྐྲུན་ཁང་གིས་དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་མོ་ཞི་ཁོ་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་ལ་ལོ་ཟླའི་ཚོད་བགམ་ཐེག་པ་དང་ལོ་རྒྱུས་ཡུན་རིང་ལྡན་ཡོད།",
    "title-g_bo_351": "2023ལོའི་ཟླ་བ་དང་པོ་ནས་བཅུ་པའི་བར་དུ་དཔལ་འབྱོར་འཕར་སྣོན་ལ་སྐུལ་ཁྲིད་ཐུབ་ཚད་བརྒྱ་ཆའི་གནས་1.6ཟིན་ཡོད།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ཡོམ་འགོག་གེགས་སེལ་གྱི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "2023ལོའི་ཨང་103པ། འགག་སྒོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཡི་སྤྱི་བསྒྲགས།",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ཀྱི་ལས་རེས་ལྟ་སྲུང་དང་སྒོ་རྒྱག་ངལ་གསོའི་དུས་སྐབས་ཀྱི་གཉེར་སྐྱོང་བྱ་རྒྱུ་ཡིན་ཞིང་།",
    "title-g_bo_225": "2019ལོའི་ལེགས་རྩེ་འགག་སྒོ་དེ་རྒྱལ་ཁབ་འགག་སྒོའི་སྒོ་དབྱེའི་འཆར་འགོད་ནང་བཅུག་པ་དང་། སྤྱི་ལོ་2019ལོར་རྒྱལ་སྲིད་སྤྱི་ཁྱབ་ཁང་གིས་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་དབྱེ་རྒྱུའི་མཆོག་མཆན་ཐོབ་ཡོད།",
    "title-g_bo_131": "2023ལོའི་ཞིང་ལས་ཐོན་རྫས་ཀྱི་འབྲུ་རིགས་ཐོན་འབོར་གྱིས་ལོ་རྒྱུས་ཀྱི་ཟིན་ཐོ་གསར་པ་གཏོད་པའི་རེ་བ་ཡོད།",
    "title-g_bo_739": "2023ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གིས་ཉུང་མཐར་ཡང་མི་30རྐྱེན་ལམ་དུ་བཏང་བ།",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་ནས་ཀྱི་ཐོན་འབབ་ཏུན་ཁྲི་100ཡན་རྒྱུན་འཁྱོངས་བྱེད་ཐུབ་པ།",
    "title-g_bo_553": "2023ལོའི་ཁྲུང་ཆིང་གློག་ཤུགས་ཉོ་ཚོང་ལྟེ་གནས་ཚད་ཡོད་ཀུང་སི་ནས་ཤེས་རྟོགས་བྱུང་བར་གཞིགས་ན། བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དེ་རྒྱལ་ཁབ་གློག་དྲ་ཁྲུང་ཆིང་གྲོང་ཁྱེར་གླ",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་མི་འཁོར་བའི་ཐབས་ཤེས་ཡག་པོ་ཞིག་བསླབས་འདུག",
    "title-g_bo_141": "2023ལོའི་ཟླ་བ་བཅུ་གཉིས་པའི་ཚེས་ཉེར་བཞི་ཉིན་གྱི་དུས་ཚོད་དང་པོའི་རིང་། བོད་ལྗོངས་ཀྱི་མི་རིགས་མཐུན་སྒྲིལ་ཡར་ཐོན་གྱི་དཔེ་སྟོན་ཁུལ་གཙོ་གནད་དུ་འཛུགས་སྐྱོང་བྱས་པ།",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ་དང་།",
    "title-g_bo_688": "2024ལོའི་ཟླ་4པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོར་ཞི་ཅིན་ཕིང་གིས་ཧྥ་རན་སེའི་ཙུང་ཐུང་མ་ཁེ་ལུང་དང་ཞལ་པར་བསྐྱོན་ཡོད།",
    "title-g_bo_586": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་གནས་ཚུལ་སྤེལ་བའི་གནས་སྟངས།",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་དུ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་ཚབ་ཞུས་ནས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་། འཐབ་ཕྱོགས་གཅིག་གྱུར་གྱི་རྒྱ་ཆེའི",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "2023ལོའི་མཚོ་སྔོན་ཞིང་ཆེན་མཚོ་བྱང་བོད་རིགས་རང་སྐྱོང་ཁུལ་གྱི་གནས་སྐོར་མཛེས་ལྗོངས་ཁུལ་གྱི་གྲས་སུ་ཚུད་པའི་མཚོ་སྔོན་ཞིང་ཆེན་མཚོ་བྱང་བོད་རིགས་རང་སྐྱོང་ཁུལ་གྱི་གནས་སྐོར་མཛེས་ལྗོངས་ཁུལ་གྱ",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་།《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་ག",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་པེ་ཅིང་དང་ཧོ་པེ་ཡི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་།",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_96": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_312": "དབྱི་རག་གི་ཙུང་ལི་སུའུ་ཏ་ཉི་ཡིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_176": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་གྱི་ཕྱི་དྲོའི་ཆུ་ཚོད་10པར་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་ས་ཁུལ་དུ་མི་5182རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་ཆིག་ཁྲི་ལྔ་སྟོང་ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་ལ་ཞིང་ཆེན་རིམ་པའི་མཛེས་རྩལ་ཁང་མེད་པའི་སྟོང་ཆ་བསྐངས་ཡོད།",
    "title-g_bo_500": "2023ལོའི་ཟླ་10ཚེས་7ཉིན་ནས་བཟུང་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་དོན་རྐྱེན་ནང་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་སེར་སོགས་ལ་སྐར་མ་གཅིག་གི་རིང་ལ་ངག་བསྡམས་མྱ་ངན་ཞུས་པ་རེད།",
    "title-g_bo_414": "པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་ཡོད།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མ",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན། འཛམ་གླིང་ཡོངས་སུ་སྔར་བཞིན་མི་གྲངས་དུང་ཕྱུར་50ལ་སྔར་བཞིན་ས�",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེ་གཉིས་ཀྱི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་དང་མཇལ་འཛོམས་གནང་བ་རེད།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་འཇབ་རྒོལ་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_708": "དྲ་དཔོན་དེས་རང་གི་ལག་ཏུ་མེ་ཏོག་དཀར་པོ་གཉིས་བཟུང་ནས་འདི་ནི་ཐེན་ཧྲན་རི་བོའི་གངས་ལྷ་མེ་ཏོག་རེད།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བོད་ལྗོངས་དབྱངས་སྙན》ཞེས་པ་འཁྲབ་སྟོན་བྱས་པ།",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཧ་ནོ་དབྱིའི་ཀྲུའུ་ཞིའི་ལས་ཤག་ཏུ་ཝེ་ཐེ་ནམ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་དང་མཇལ་མོལ་གནང་བ་རེད།",
    "title-g_bo_650": "2023ལོའི་ཟླ་9ཚེས་16ཉིན་གྱི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་ས་ནཱ་ཡི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་16ཉིན་གྱི་སྔ་དྲོའི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་ཨ་རིའི་དམག་གིས་ཡེ་མོན་ཧུའུ་སའེ་དྲག་ཤོག་གིས་ཚོད་འཛིན་བྱེད་",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པ།",
    "title-g_bo_330": "ཁྲག་རྩའི་ནད་དང་ཁྲག་རྩའི་ནད་རིགས་སློང་ཉེན་ཆེ།",
    "title-g_bo_244": "གཞིས་རྩེ་གྲོང་ཁྱེར་རྒྱལ་རྩེ་རྫོང་སྤྱི་བདེ་ཅུས་ཉེས་དོན་མྱུལ་ཞིབ་རུ་ཆེན་ལ་མི་ཁག་གཅིག་གིས་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པ།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཟླ་11ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་པ་ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་དུ་ཕྱིར་ལོག་གནང་བ།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》ཞེས་པ་གཏོང་སྤེལ་བྱས་ཡོད།",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་སྐབས་དང་པོའི་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི(2024)ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་ཞུགས་རྒྱལ་ཁབ་དང་ཡུལ་འཁྱར་བ་འབོར་ཆེན་བསྡུ་ལེན་བྱས་པའི་རྒྱལ་ཁབ་དཔེར་ན།",
    "title-g_bo_520": "2023ལོའི་ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "2023ལོའི་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "2023ལོའི་ཟླ་2ཚེས་26ཉིན་དབྱིན་ཇིའི་ས་ཁུལ་ཁག་ཅིག་ཏུ་རབ་ཏུ་མཛེས་པའི་དམར་ལྗང་རིམ་འགྱུར་གྱི་བྱང་སྣེའི་འོད་ཐིག་མཐོང་དཀོན་པ་ཞིག་མངོན་ཡོད་པ་དང་། ལྟ་ན་སྡུག་པའི་མཁའ་དབྱིངས་ཀྱིས་སྐྱེ་བོའི་ཡིད་སེམ",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱིས་བྱིས་པ་རྣམས་ལྟོགས་ནས་ནད་ཕོག་པའི་དོན་དངོས་ཤེས་རྟོགས་བྱུང་བ།",
    "title-g_bo_749": "2023ལོའི་ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུའི་འགྲེམས་སྟོན་ཐོག་ཀྲུང་གོའི་ཐོན་གསར་པའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུར་ཀུན་གྱིས་དོ་ཁུར་ཆེན་པོ་བྱས་པ་དང་། �",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་བའི་ཉིན་དེར་ལུས་རྩལ་ཚད་ལས་འདས་པ་དང་ངལ་རྩོལ་ཚད་ལས་འདས་པ་གནང་རྒྱུ་མེད།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_522": "2021ལོའི་སི་ཁྲོན་ཞིང་ཆེན་དཀར་མཛེས་བོད་རིགས་རང་སྐྱོང་ཁུལ་འདབ་པ་རྫོང་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་བྱེད་པའི་བྱེད་སྒོ་སྤེལ་བ་རེད།",
    "title-g_bo_787": "2023ལོའི་ཟླ་8ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད་པ་རེད།",
    "title-g_bo_36": "2023ལོའི་ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ་དེ་ནི་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོར་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་མྱུར་བགྲོད་ལྕགས་ལམ་ཐོག་མ་དེ་ཡིན།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ནི་གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་ཡིན་ཞིང་།",
    "title-g_bo_372": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་ཙེ་ལན་སི་ཅིས་ཡུག་རེན་གྱི་རྒྱལ་སྲུང་པུའུ་ཀྲང་ཨའོ་སི་ཐིང་དང་ཐུག་འཕྲད་བྱས་ཏེ། ཕྱོགས་གཉིས་པོས་ཡུག་རེན་གྱི་གནས་བབ་དང་། དམག་དོན་རོགས་སྐྱོར། ཧེ་ཧ",
    "title-g_bo_672": "《དབང་རྩའི་རིག་པ་》ཞེས་པའི་དུས་དེབ་སྟེང་དུ་བཀོད་པའི་ཁྲག་རིགས་ཀྱི་ནད་རིགས་དང་འབྲེལ་བ་ཡོད་པ།",
    "title-g_bo_538": "2024ལོར་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ཀྱི་ས་གནས་ཡོང་འབབ་སྒོར་དུང་ཕྱུར་228.2ཟིན་རྒྱུ་དང་། དེ་ལོ་གོང་མའི་སྔོན་རྩིས་ལས་བརྒྱ་ཆ་21འཕར་རྒྱུ་རེད།",
    "title-g_bo_192": "དབྱི་སི་རལ་དམག་གིས་དབྱི་སི་རལ་དམག་གི་དམག་མི་སྐྱེལ་འདྲེན་བྱེད་མཁན་རླངས་འཁོར་ལ་འཇབ་རྒོལ་བྱས་པ་དང་། ཧ་མ་སིའི་དྲག་ཆས་ཤོག་ཁག་ཁ་སང་ལུའི་ཤོག་གིས་ཚེས་16ཉིན་གནས་ཚུལ་སྤེལ་ནས། ཀ་ཧྲ་གྲོང་གི་ཤའེ་ཧོ་ལ་ཏ�",
    "title-g_bo_222": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གནའ་དཔེ་མྱུར་སྐྱོབ་རིགས་ཀྱི་དཔེ་སྐྲུན་ལས་གཞིའི་མཛད་སྒོ་མཚོ་སྔོན་གནའ་མཁར་ཟི་ལིང་དུ་བསྡུས།",
    "title-g_bo_611": "1953ལོར་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་ལ་སླེབས་པ་ཡིན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་གི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
