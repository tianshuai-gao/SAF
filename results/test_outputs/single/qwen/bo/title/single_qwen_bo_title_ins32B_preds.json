{
    "title-g_bo_923": "2021ལོའི་ཡུལ་སྐོར་ཚོགས་པ་དུ་བོད་ལ་ཡོང་བའི་ཡུལ་སྐོར་བ་ཡུས་དབྱང་གི་དཔལ་ལ་རོལ་བའི་ཚེ།",
    "title-g_bo_752": "ཀ་ཧྲ་རྒྱུད་ཀྱི་ཡུལ་གྱར་བའི་བསྒར་སར་ལ་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_589": "ཀྲུང་གོ་དང་ཨ་རིའི་གནད་དོན་འབྲེལ་བ་བཏབ་པ། འགྲན་རྩོད་དང་ཁ་གཏད་དུ་ལངས་པའི་མཐུན་གྱི་མེད།",
    "title-g_bo_267": "2022 ལོའི་རྒྱལ་སྤྱིའི་ཚོང་དོན་སློབ་གླིང་དུ་སློབ་སྦྱོང་བྱེད་པའི་མཚོ་ལྷོ་བོད་ཀྱི་རྟ་མགྲིན་མ་བུ་གཉིས་ཀྱི་ཨ་མ་ལགས་ཀྱིས་ལས་ཞོར་དུ་ངག་ལས་སྙན་པོའི་དབྱངས་རྟ་ལེན་བྱས་པ།",
    "title-g_bo_139": "2023ལོར་ཀོང་ཏུང་གི་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13.57ཟིན་ནས་རྒྱལ་ཡོངས་ཀྱི་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་གྱུར་བ",
    "title-g_bo_809": "ལོ་རེའི་སྤྱི་ཟླ་10ནས་ཕྱི་ལོའི་སྤྱི་ཟླ་3བར་ནི་ནོ་རོ་ནད་དུག་འགོ་མང་བའི་དུས་ཚིགས། སློབ་གྲྭ་དང་བུ་བཅོལ་ཁང་སོགས་གཙོ་གནད་ས་ཆར་རིམས་ནད་སྔོན་འགོག་ཚོད་འཛིན་བྱ་རྒྱུའི་དྲན་སྐུལ་བྱས་པ།",
    "title-g_bo_355": "སློབ་ཕྱིའི་གསོ་སྦྱོང་གྲོན་དངུལ་ཕྱིར་སློག་གི་མིང་ཐོག་ནས་གློག་འཕྲིན་དྲ་ལམ་དུ་མགོ་སྐོར་བཏང་ནས་ཤུགས་རྐྱེན་ངན་པ་དང་གནོད་འཚེ་ཚབས་ཆེན་བཟོས་པ།",
    "title-g_bo_154": "《མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས》འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "ཀྲུང་གོའི་ཕྱོགས་ཀྱིས་ལྗར་ཕན་གྱི་གསང་མྱུལ་བྱ་སྤྱོད་སྤེལ་བ་ལ་ར་སྤྲོད་བྱེད་ཐུབ་བ།",
    "title-g_bo_327": "དབྱི་རན་ཁེའར་མན་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་བྱུང་། འབར་གས་ཀྱི་དོན་རྐྱེན་ཐེངས་གཉིས་བསྟུད་མར་ཐོན་ནས་མི་9",
    "title-g_bo_323": "76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་ཨུ་རུ་སུ་དང་ཡུག་རེན་གཞུང་ལ་བརྗེ་རེས་བྱེད་འདོད་བྱུང་བ།",
    "title-g_bo_213": "4500ཡན་གངས་གྲོས་ཀྱི་ས་འཛིན་ཕྲེང་བ་སྟོད་མངའ་རིས་ནི་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེར་ཆགས་པའི་གནས་མཆོག།",
    "title-g_bo_276": "2024 ལོའི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་དེ་སྤྱི་ལོ་2026 ལོའི་བར་ཡིན་པ་བཙུགས་པ།",
    "title-g_bo_954": "ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་ནེ་པ་ལའི་འཚམས་འདྲི་གློག་འཕྲིན་བཏང་གནང་བ།",
    "title-g_bo_962": "12306ཐོག་ཏུ་བྱེད་ནུས་གསར་པ་འདི་དག་བསྣན་འདུག: དཔྱིད་གསར་དུས་ཆེན་གྱི་མེ་འཁོར་པ་སེ་འཚོང་འགོ་བརྩམས་ཡོད་པ།",
    "title-g_bo_200": "མཚོ་སྔོན་པོའི་“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཀྱི་མཚོ་དར་ཞུ་བ།",
    "title-g_bo_210": "འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གི་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ་ནི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་ལྗོངས་ཀྱི་འཐབ་ཇུས་གལ་ཆེན་ལ་ཕན་འབྲས་རྒྱུན་ཆད་མེད།",
    "title-g_bo_299": "ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་ལྕགས་སྐུལ་གནང་བ་དེར་ཀྲུང་གོ་དང་ཨ་རི་གཉིས་པོའི་མཛའ་གྲོགས་མི་སྣའི་དགའ་བསུ་ཐོབ་པ།",
    "title-g_bo_527": "བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་ལ་སྐྱོ་གདུང་ཆེན་པོ་བྱུང་བའི་བློ་འདུག་བྱེད་སྒོ་མཁས་ཅན་གྲགས་ཅན་གྱི་སྤྱི་ཚོགས་བྱེད་སྒོ་མཁས་ཅན།",
    "title-g_bo_726": "ཨ་རིའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་སྔོན་དཔག་བྱས་པ་ཆག་པ།",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་དབྱི་སི་རལ་གྱི་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་ལ་གཞུང་ཕྱོགས་ཀྱི་ཆ་འཕྲིན་གསལ་པོ་ཞིག་མེད།",
    "title-g_bo_706": "སྙིང་ཁམས་ལ་བྱུང་བའི་གཟུགས་པའི་བྱུང་བ་དང་བྱུང་བ་མེད་པའི་བྱེད་སྤྱོད།",
    "title-g_bo_681": "བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་བྱས་པ།",
    "title-g_bo_960": "ཨ་རིའི་ཁེན་ཐ་ཅི་མངའ་སྡེ་གནས་བབ་ཏུ་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་བྱས་པ།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱི་ཕྱི་ཚུལ་རིང་ལུཊ་དང་དཔོན་ཉམས་རིང་ལུཊ་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་ལ་གས་སྲུབ་ཧ་ཅང་ཆེན་པོ་བྱུང་། མི་མེད་ལུང་སྟོང་ལྟ་བུར་གྱུར་བའི་བྱ་སྤྱོད།",
    "title-g_bo_16": "ལོ་གསར་བསུ་བའི་གྲ་སྒྲིག་ལས་དོན་ཁག་སྤེལ་ནས་དུས་ཆེན་གྱི་རྣམ་པ་ཟབ་མོ་མངོན། ཁོར་ཡུག་སྲུང་སྐྱོང་གི་འདུ་ཤེས་ཟབ་ཏུ་ཕྱིན་པ།",
    "title-g_bo_844": "2023ལོའི་ཉེས་ཆད་གཏོང་བ་བྱས་པའི་ཁྲིམས་ལྟར་ཞུ་སྦྱོར་ཕྱི་མ་རིན་ཆེ་གེ་མོ་ལ་འདྲི་གཅོད་བྱས་པ།",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ། པེ་ཅིང་གྲོང་ཁྱེར་སློབ་གསོ་ཨུ་ལྷན་གྱིས་བརྡ་ཐོ་བཏང་བ།",
    "title-g_bo_577": "ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་ཐོབ་པའི་དོན་དངོས་ཐེར་འདོན་བྱས། ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ལས་ཁེ་ཕན་ཆེན་པོ་ཐོབ་པ།",
    "title-g_bo_474": "རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་ནས་གནས་འཕྲིན་བྱས་པའི་རེས་སྐོར་གསར་པའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་རེད།",
    "title-g_bo_140": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཀ་ཤི་སྨིར་ས་ཁུལ་དུ་རྐྱེན་ལམ་དུ་ཤོར་བ་བྱས་པ་བཤད།",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གི་བར་དུ་འགྲན་རྒོལ་བྱས་པ།",
    "title-g_bo_933": "མའོ་ཆེ་གེ་མོ་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ལ་བརྟག་དཔྱད་བྱས་པ། མི་དམངས་ཉེན་རྟོག་པའི་བརྡ་ཁྱབ་བཏང་བ།",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ནས་ཀྲུང་གོ་དང་མཉམ་སྐྲུན་རྒྱལ་ཁབ་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡུར་གྲངས་ཀྱི་58%བཟུང་ནས་གཞི་ཁྱོན་རྒྱུན་མཐུད་ངང་འཕར་བྱེད།",
    "title-g_bo_675": "སློབ་གསོ་པུའི་ལུས་སྦྱོང་བདེ་འཇགས་སྐོར་མི་རུང་བ་ལྔ་བཏོན་པ།",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གཉིས་ཀྱི་བར་རེས་སྐོར་གྲངས་གཞི་གསར་ཤོས།",
    "title-g_bo_65": "ཀྲུང་གོ་དང་ཏེན་མག་གི་ཕྱོགས་ཡོངས་འབྲེལ་བ་རྒྱུན་ཆད་མེད་པར་སྐྱེད་བཏོན། རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་དང་མཉམ་དུ་འབད་བརྩོན་བྱས།",
    "title-g_bo_214": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་ཕ་དབྱི་གདོང་ཐུག་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པ། དབྱི་སི་རལ་ལ་རྒྱབ་སྐྱོར་བྱས་པ།",
    "title-g_bo_79": "གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་བཅས་བྱ་ཆེད།",
    "title-g_bo_761": "ཡུག་རེན་གྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་ཕོ་ལན་དང་སི་ལོ་ཧྥ་ཁེ་ཧང་ག་རི་བཅས་ཀྱིས་ཞུ་གཏུག་བྱས་པ།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་ཀ་ཧྲ་རྒྱུད་དུ་སྤེལ་བའི་མཁའ་ཐོག་ལ་འཇབ་རྒོལ་བྱས་པ་བརྡ་སྤྱོད་བྱ་བ།",
    "title-g_bo_318": "ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པ་ལྷག་པ་བྱུང་ནས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད།",
    "title-g_bo_856": "ཨ་རིའི་མཚོ་ཁོངས་ནས་ཁ་བའི་སྡིག་སྲིན་འབོར་ཆེན་བྱུང་། རྒྱ་མཚོའི་དྲོད་ཚད་མཐོ་རུ་སོང་བས་ཡིན་པ་ཤེས་རྟོགས་བྱུང་།",
    "title-g_bo_292": "ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་གསར་འགོད་པ། ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་ལ་ཐོངས་མཆན་གྱི་ཚོད་འཛིན་བྱ་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》དུས་ཚོད་ནས་རྒྱ་གར་དང་ཁ་ན་ཏའི་ཕྱི་འབྲེལ་བརྡ་ཐོ་བྱུང་།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་མཁའ་ཐོག་ནང་སྦྱོང་བྱས།",
    "title-g_bo_713": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གི་ལས་དབང་གཅིག་མཐུན་བཅས་འགོ་རྩོམ་བྱས་པ།",
    "title-g_bo_865": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་དམག་འཐབ་བྱས་པ། མཐའ་སྲུང་དཔུང་སྡེ་དམག་མི་ཤོར་བའི་བཤད་སྒྲུབ།",
    "title-g_bo_180": "2023ལོའི་ཁྲུང་ཆིང་སློབ་ཆེན་དང་ཆབ་མདོ་གྲོང་ཁྱེར་མཐོ་རིམ་སློབ་འབྲིང་དྲུག་པའི་འཕྲིན་ཡིག་བཟོ་བྱས་པ།",
    "title-g_bo_638": "2023 ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་དབྱར་རྩྭ་དགུན་འབུ་འཕར་བ་དང་། ཟི་ལིང་འགག་སྒོ་ལས་ཁུངས་ཀྱིས་བཤད་པ།",
    "title-g_bo_626": "ཨུ་རུ་སུའི་དམག་ཕམ་ཉེས་གཏོང་བ་དང་ཡུག་རེན་དམག་གི་ཕྱོགས་འཕྲུལ་བ།",
    "title-g_bo_319": "2023ལོར་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས། རང་རྒྱལ་གྱིས་8000ལྷག་ཉོ་སྒྲུབ་བྱས་པ།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་པའི་བྱིས་པ་མངོན་གསལ་བྱེད་དགོས། མི་ཚང་མ་དང་གཞོན་ནུ་ལོ་ཆུང་ལ་ཕོག་པ་མང་།",
    "title-g_bo_511": "ཀ་ཧྲ་ས་ཁུལ་དུ་ཕ་ལེ་སི་ཐན་མི་དམངས་ལ་བསགས་པའི་སྡིག་ཉེས་ལ་བསམ་གཞིག་བྱས་པ། དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོ་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས། འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།",
    "title-g_bo_185": "མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་ཕྲུག་བཙས་རྗེས་གཙོད་རྣམས་གཅིག་རྗེས་གཉིས་མཐུད་བྱེད།",
    "title-g_bo_884": "5200 ཟིན་པའི་མི་གྲངས་དབྱི་སི་རལ་དུ་འབྱོར་བ་པའེ་ཏེང་། ཨ་རི་དབྱི་སི་རལ་གྱི་མི་རིགས་དབང་ཆའི་ལས་ཁུང་གི་འབྲེལ་བརྗོད།",
    "title-g_bo_82": "2023 ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "43ལོ་བསྟུན་ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་བར་ཕྱི་འབྲེལ་བ་བཙུགས་པ།",
    "title-g_bo_165": "ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་གྲོས་ཚོགས་ཐེངས་དངོས་གཞི་མིན་པའི་ལོ་30འཁོར་བ།",
    "title-g_bo_275": "2017ལོའི་ཕེ་རུ་ཕྲ་ཞིང་རིང་ལས་བླངས་པའི་ཕུང་རུས་གཉིས་ཀྱི་མི་འདྲ་པ་བྱེད་པའི་གནས་ཚུལ་སྤྱོད་བྱེད།",
    "title-g_bo_900": "2023 ཚེས་24 ཉིན་གྱི་ཉི་མའི་འགུལ་སྐྱོད་དྲག་པ་ལྟ་ན་སྡུག་པའི་སྣེ་འོད་མཐོང་ཐུབ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་གྱི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གི་མི་བཟོས་དུ་ཞག་དབྱུག་ནས་འགེབས་སྲུང་བྱེད་པའི་མཐུན་ནུས་ཉེས་བྱུང་།",
    "title-g_bo_578": "ཀ་ཧྲ་ས་ཁུལ་ལ་དབྱི་སི་རལ་གྱི་དམག་འཁྲུག་གནས་ཚུལ་བརྡ་ཁྱབ་བཏང་། ཉིན་དེར་མི་སྣ་50ཉིན་དེར་བསད་ཡོད་པ་དང་མི་3དམག་དོན་བྱ་སྤྱོད་ནང་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_722": "ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་འབྲེལ་བ་འཕེལ་རྒྱས་ཀྱི་བྱུང་བ།",
    "title-g_bo_235": "2024 ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ལ་ཧྲང་ཧའེ་ཅིན་ཧྲན་ནས་ཡོང་བའི་རང་བདག་རྩེར་སོན་སྒྱུ་རྩལ་གྱི་ཁུ་ལུའི་སྤུས་རྟགས་ཧྲ་ཅོན་ཐོག་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023 ལོའི་བོད་རང་སྐྱོང་ལྗོངས་བཅོས་ལས་དོན་ལ་སྐུལ་འདེད་ཏན་ཏིག་གཏོང་བའི་ལྷན་སྐྱེས་སྙིང་ནད་བརྟག་དཔྱད་བྱེད་རྗེས་འཇུག་བསྒྱུར།",
    "title-g_bo_918": "འཛམ་གླིང་ཤེས་དཔལ་གྱི་མེ་ཏོག་སྣ་བརྒྱའི་ལྡུམ་རར་བསམ་བློ་དང་རིག་གནས་ཀྱི་སྟོབས་ཤུགས་སྣོན་དགོས།",
    "title-g_bo_451": "1169 ཚེང་དུ་སྤུངས་པའི་སྒོར་ཁྲི་ནང་བྱ་དགའ་བླངས་པའི་འབྲུ་རིགས་འདེབས་མཁན་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་བྱུང་བ།",
    "title-g_bo_997": "2053 རྐྱེན་ལམ་དུ་ཤོར་བ་དང་9000 ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་བྱས་པའི་ཧོ་ལ་ཐེ་མངའ་སྡེ་གྲོང་ཚོ་13 གྱི་ཁང་པ་1240 རྦད་དེ་བརྡིབས་ཤིང་། སའེ་དབྱི་ཁེས་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་རྒྱལ་ཁབ་",
    "title-g_bo_544": "ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་དུ་གསར་སྐྲུན་མི་མེད་གནམ་གྲུ་བཟོས་པ།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་སྦྱོང་བརྡར་བྱ་རྒྱུར་ཤུགས་སྣོན་རྒྱག་བྱས་པ།",
    "title-g_bo_847": "2022 ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་སྤྱི་ལོ་སྤེལ་གནང་བ།",
    "title-g_bo_1": "2023 སྐབས་དྲུག་པའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་གྲབས་བྱེད། རང་རྒྱལ་གྱི་འགྲེམས་སྟོན་ལས་རིགས་ལ་ཁྱོན་ཡོངས་ནས་སླར་གསོ་ཡོང་བའི་རྣམ་པ་མངོན་ཡོད།",
    "title-g_bo_936": "11པའི་ཚེས་5ཉིན་དབྱི་སི་རལ་དམག་ཕྱོགས་གཉིས་པོའི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད། ཀ་ཧྲ་ས་ཁུལ་དུ་མི་ཆོས་རྩ་བ་ནས་མེད་པར་འགྱུར་བ།",
    "title-g_bo_830": "ཀྲུང་གོ་དང་ཧྥི་ལི་ཕིན་གྱི་གསར་འགྱུར་མགྲིན་ཚབ་པ་ལིའུ་ཏེ་ཅུན་གྱིས་བྱུང་བ། མཚོ་ཐོག་ཉེན་རྟོག་པའི་གྲུ་གཟིངས་ལ་ཐ་ཚིག་ནན་པོར་སྒྲོག་པ།",
    "title-g_bo_90": "2023ལོའི་བོད་སྐད་ཡིག་བརྡ་ཆད་གསར་པ་གཅིག་གྱུར་གཏན་འབེབས་བྱས་པ།",
    "title-g_bo_826": "ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་དབྱི་སི་རལ་བྱང་ཕྱོགས་ལ་མེ་ཤུགས་འཕུར་མདེལ་གཏོང་བྱས་པ།",
    "title-g_bo_17": "5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་དང་རྩལ་ནུས་འགྲན་བསྡུར་ཆེ་མོའི་བྱུང་བ།",
    "title-g_bo_285": "མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་བྱེད་པའི་བྱ་སྤྱོད་བྱེ་བ་དང་བྱུང་ནས་འགྱུར་གྱི་བྱ་སྤྱོད།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་ཀྱི་ཉོབ་མདངས་དང་སྔོ་ཚལ་གྱི་རིགས་ལ་གསལ་བྱེད་པ།",
    "title-g_bo_337": "2023 ལོའི་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "ཞི་ཅིན་ཕིང་དང་བོད་ཀྱི་གཏམ་རྒྱུད་ཡག་པོ་ཤོད་པ། བོད་སྐད་སྒྱུར་བཟོ་དང་གློག་བརྙན་གྱི་འབྲེལ་བར་བྱེད་པ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ “འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ” གློག་མིག་ནས་པར་རྒྱག་པ།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཨ་རི་གཉིས་ཀྱི་ཁེ་དབང་བྱ་སྤྱོད་ལ་བཙན་གནོད་བྱས་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་སྒྲིག་འགོད་གཉིས་པ་ངེས་པར་བསུབ་དགོས། མ་བསུབ་ན་བདེ་འཇགས་གཏན་ནས་མེད།",
    "title-g_bo_563": "3D མིག་ཤེལ་མི་དགོས་པའི་གསར་འགྱུར་དང་ཁྲེང་ཏུའུ་ཐའེ་ཀུའུ་ལིའི་བརྙན་ལམ།",
    "title-g_bo_759": "12ཚེས་25ཉིན་གྲུབ་ཐོབ་བྱས་པའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་ཚོགས་འདུ་ཐེངས་བཞི་པ།",
    "title-g_bo_432": "2024 རྒྱལ་ཁབ་ལས་ཁུངས་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་བ། རྒྱུགས་སྤྲོད་ལག་ཁྱེར་དང་འབྲེལ་བའི་ཆེད་དོན་དྲ་ཚིགས་ལ་ཡིད་གཟབ་བྱ་དགོས།",
    "title-g_bo_932": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཧོ་ཐའེ་ཏ་གྲོང་ཁྱེར་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་ཐུན་མོང་ཐོག་དར་རྒྱས་བྱེད་པ།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ།",
    "title-g_bo_822": "2023 ལོའི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པར་བོད་ལྗོངས་སློབ་ཆེན་གྱི་དགེ་རྒན་ཉི་མ་བཀྲ་ཤིས་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས་ཡོད་པ།",
    "title-g_bo_604": "རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ལ་ཕྱི་རིགས་དང་བཞིན་བྱས་པའི་གཏིང་ཟབ་བྱེད་པ།",
    "title-g_bo_529": "7ལོ་བུ་ཆང་གི་གློ་བ་བཀྲུ་བའི་བྱིས་པ་སྨན་ཁང་དུ་འཚང་ཁ་ཤིག་ཤིག་བྱུང་བ།",
    "title-g_bo_38": "ཀ་ཧྲ་ས་ཁུལ་གྱི་སྨན་ཁང་གཉིས་ཀྱི་བཙུན་པ་དང་བཟའ་བཅའ་བར་ཁྱད་པ་མེད་པ་རྟགས་བཤད།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་མེ་འཁོར་གློག་བྱེད་འཁོར་ལམ་ནས་བྲལ་བ་དེབ་ཞིག་བྱུང་།",
    "title-g_bo_287": "བྱང་ཆིངས་རྩ་འཛུགས་ཀྱི་དྲུང་ཡིག་ཆེན་མོ་སི་ཐུའོ་ཨེར་ཐེང་པེ་ཀེ་ཡིས་བྱང་ཆིངས་ལ་ཤུགས་རྐྱེན་ཐེབས་སྲིད། ཨ་རི་དང་ཡུག་རེན་གྱི་མཚོན་ཆ་དམག་དོན་རྒྱབ་སྐྱོར་རྒྱུན་ཆད་མེད།",
    "title-g_bo_394": "2023ལོའི་དཔལ་འབྱོར་འཁོར་རྒྱུག་བོད་ལྗོངས་ཀྱི་གནས་ཚུལ་གསར་འགྱུར་བྱུང་བ།",
    "title-g_bo_901": "ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་འབྲེལ་བ་དངོས་སུ་འཛུགས་པའི་ཁྱབ་བསྒྲགས་གནང་བ། རྒྱལ་ཁབ་གཉིས་ཀྱི་གཙོ་བདག་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་དང་ཨོའར་ཐེ་ཀ་བྱུང་བའི་ཚེས་20ཉིན་གྱི་སྔ་དྲོ།",
    "title-g_bo_342": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་མཐོང་དཀོན་པའི་གསལ་བསྒྲགས་བྱས་པ། ཨེ་ཧེ་ཨ་རིམ་པའི་མདེལ་ལམ་འཕུར་མདའ་དང་ཆུར་འཛུལ་དམག་གྲུའི་བརྡ་གསལ་པ།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་འབོར་ཆེན་ཐོན་སྐྱེད་བྱ་རྒྱུ་རེད།",
    "title-g_bo_259": "བོད་ལྗོངས་ལྷ་མོའི་ཟློས་གར་སློབ་མ་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་མཚན་སྙན་ཐོབ།",
    "title-g_bo_685": "ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པ་ལ་འཇབ་རྒོལ་བྱས་པས་ཏེ་ཨེར་ན་གྲོང་ཁྱེར་གྱི་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་བ།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་གྲོས་མོལ་བྱེད་པར་ཡོང་བའི་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ། ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བ་བརྟན་བྱས་པའི་བྱུང་བ་ད",
    "title-g_bo_50": "ལིའང་ཀྲུའུ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་། འཛམ་གླིང་ཤེས་དཔལ་གྱི་མཐོ་ས་མང་པོ་བཏོད་པ།",
    "title-g_bo_769": "ཕ་ལེ་སི་ཐན་དབྱི་སི་རལ་བར་ན་འགྱངས་གཏོང་རྒྱུའི་མོས་མཐུན་བྱས་བྱེད་པ།",
    "title-g_bo_582": "སྐུད་མེད་དྲ་བ་བྱེད་པའི་གྱོད་དཔེ་གཉིས། མི་བསྒུགས་ནས་སྡོད་སྐབས་ཀྱི་བྱ་རྒྱུ་དང་བྱ་སྤྱོད།",
    "title-g_bo_635": "ལྷ་ས་དང་གྲོང་མི་ལི་ཆེ་གེ་མོ་ལྟར་ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་དོགས་ཟོན་གྱིས་མི་མང་པོར་ཁ་བསླུས་ཐེབས་འདུག།",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་བསད་པའི་བུ་མོ་ཞིག་བསྒྱུར་བྱུང་འཇོག་མི་ཆོག།",
    "title-g_bo_167": "གཟུགས་པོའི་བརྟག་དཔྱད་གནང་དུས་ལ་དོ་སྣང་གནང་དགོས།",
    "title-g_bo_283": "ལྷ་སར་ལག་ཁྱེར་གཉེར་སྟབས་བདེ་རུ་བཏང་བ། རང་ཉིད་ཀྱི་ཐོབ་ཐང་ལག་ཁྱེར་ནས་རིན་པ་མི་དགོས་པར་གཉེར་ཆོག",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱི་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་འཇབ་རྒོལ་རབ་ལ་ཡ་ལན་སློག་པ།",
    "title-g_bo_872": "འབའ་ཐང་རྫོང་གི་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ཆེན་མོ་ཉེ་ཆར་འགྲིལ་བ་དང་སྤྱི་ཚོགས་སྟོབས་ཤུགས་འཕེལ་རྒྱས་ལྟེ་གནས་ཀྱི་བྱུང་བ་བཅས།",
    "title-g_bo_247": "50ལོ་འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་གི་བློ་གསལ་བྱུང་བ།",
    "title-g_bo_575": "504.6 རྒྱ་མཚོའི་ངོས་ལས་ས་བབས་མཐོ་ཚད་7782 སྨི་ཡོད་པའི་ཡར་ཀླུང་གཙང་པོ། སྐྱེ་དངོས་སྣ་མང་རང་བཞིན་གྱི་བརྟག་དཔྱད་ལྡན་པའི་གྲོང་རོང་ཆེན་མོ།",
    "title-g_bo_417": "ཨ་རིའི་སྐུད་ཡོད་བརྙན་འཕྲིན་གྱི་གསར་འགྱུར་དྲ་བ་དང་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་འཆི་འགྲོ་ཉེན་བྱས་པ།",
    "title-g_bo_484": "2024 སྤྱིར་བཏང་མཐོ་སློབ་ཀྱི་དམིགས་བསལ་གྱི་སློབ་ཆེན་ལ་རྒྱུགས་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་གསར་པ།",
    "title-g_bo_249": "1974ལོར་ཕྱི་འབྲེལ་བཙུགས་པ་དང་2024ལོར་ལོ་ངོ་50འཁོར་བའི་ལོ་དང་བྱུང་བའི་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་མཛའ་གྲོགས་ལོ་བཟོས་བྱེད།",
    "title-g_bo_380": "ཨ་རིའི་དམག་གི་རྟེན་གཞིར་འཇབ་རྒོལ་ཕོག་པ། དབྱི་རག་ཏུ་བཅའ་སྡོད་ཀྱི་དུས་ཚོད་ལྟར་བྱས་པ།",
    "title-g_bo_909": "ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་གི་ཕྱོགས་གཉིས་པོའི་འབྲེལ་བ་དང་གནམ་གཤིས་ཚོགས་ཆེན་གྱི་གནད་དོན་བྱས་བྱེད།",
    "title-g_bo_959": "ཀྲུང་གོའི་སྨན་པ་ཁོང་ཀོ་པུའུ་ལ་གནས་པ། ཨ་ཧྥེ་རི་ཁའི་སྨན་ཁང་གི་བྱ་སྤྱོད་དབང་ཕྱུག་བྱུང་བ།",
    "title-g_bo_976": "སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་དུ་མིག་སྔར་འཛམ་གླིང་ཐོག་ཡུལ་གྱར་བྱུང་། མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པའི་བཤད་སྒྲུབ།",
    "title-g_bo_97": "65ལོ་བུ་རྒན་རྒོན་ཟིན་ཐོ་ལྗར་ཕན་དུ་འགྱུར་བྱས་པ། ཨང་དང་པོར་སླེབས་ཡོད་དེ་འཛམ་གླིང་གི་ཨང་དང་པོར་སླེབས་ཡོད།",
    "title-g_bo_309": "ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐྱོན་ཕོག་བྱས་པ།",
    "title-g_bo_792": "རུས་ཚིགས་སྲུང་བྱ་བར་དོ་སྣང་བྱ་དགོས། འགུལ་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་པའམ་ཡང་ན་འདུག་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་མི་རུང།",
    "title-g_bo_102": "ཀྲང་ཆེ་གེ་མོ་ལྟ་བཟུང་པའི་ཕ་རོལ་པོ་“པའེ་དབན་སྨན་བཅོས་འགན་བཅོལ”གྱི་ལས་གཉེར་བ་ཡིན་པ་རྗེས་མཉེན་ཆས་བཤད།",
    "title-g_bo_56": "རི་བྱུང་བར་ཆེད་མཁས་པས་དྲན་སྐུལ་བྱས་པའི་ཞིང་ཆེན་ཁ་ཤས་ལ་ནད་པ།",
    "title-g_bo_973": "དབང་ཆེན་ཏང་གི་སྐྱིད་སྡུག་དང་གཞུང་གི་ལས་གནས་ནས་ཕྱིར་འབུད་བཏང་འདུག། ཉིང་ཁྲི་གྲོང་ཁྱེར་སྤྱི་བདེ་ཅུས་ཀྱི་དེ་སྔའི་ཏང་ཨུད་ཨུ་ཡོན་ལྷན་ཁང་གི་ཆོག་མཆན་སྤྲད་པ།",
    "title-g_bo_294": "ས་གནས་ཁག་ནས་བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད། བྱང་བུའི་སྟེང་ལག་ཐོགས་ཆུ་ཚོད་ཁ་པར་བརྗེ་བའི་བྱང་བུ་ཞེས་བྲིས་འདུག་པ།",
    "title-g_bo_689": "རྩོམ་སྒྲིག་པའི་དྲན་སྐུལ་བྱེད་དགོས་པ། སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས།",
    "title-g_bo_551": "ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་གྱི་མཛའ་བརྩེ་ཟབ་ཏུ་གཏོང་བའི་ཕྱིར་བཟོ་བྱུང་།",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན》དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས་སུ་འགྲེམས་སྤེལ་བྱས་པ།",
    "title-g_bo_146": "ཀྲུང་གོ་དང་མོ་ཞི་ཁོ་གཉིས་ཀྱི་ལོ་50འཁོར་བའི་འབྲེལ་བ་བཙུགས་པ།",
    "title-g_bo_351": "འཛམ་གླིང་གི་དཔལ་འབྱོར་འཕར་སྣོན་དང་ལེགས་སུ་འགྲོ་བའི་འཕེལ་ཕྱོགས་མུ་མཐུད་བརྟན་དུ་ཕྱིན་པ།",
    "title-g_bo_182": "2008 ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་“ཡོམ་འགོག་གེགས་སེལ་གྱི་ན་ཆུང་དཔའ་བོ”ལིན་ཧའོ་ལ་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས།",
    "title-g_bo_980": "2023ལོའི་ཨང་103པ་གྱི་འགག་སྒོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཡི་སྤྱི་བསྒྲགས། ཡི་ལུས་བཟའ་བཅའི་བདེ་འཇགས་ལ་སྦགས་བཙོག་བཟོ་བའི་ཉེན་ཁ་ཕྱོགས་ཡོངས་ནས་འགོག་ཟོན།",
    "title-g_bo_771": "2023 གངས་རིན་པོ་ཆེ་དང་མ་ཕམ་གཡུ་མཚོའི་མཛེས་ལྗོངས་ཁུལ་ལ་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་བསྟེན་པ།",
    "title-g_bo_225": "ཀྲུང་གོ་ལེགས་རྩེ་འགག་སྒོ་བོད་ལྗོངས་གཞིས་ཕྱི་ཕྱོགས་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ།",
    "title-g_bo_131": "རང་རྒྱལ་གྱི་འབྲུ་རིགས་ཐོན་འབོར་དང་ཞིང་ལས་གོང་འཕེལ་གཏོང་བ་བཅས་བྱས།",
    "title-g_bo_739": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་དང་འཕྲོད་བསྟེན་སྡེ་ཁག་གི་བརྡ་ཐག་གཅོད་བྱེད་སྤྱོད་བྱ།",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་103ཟིན་བྱུང་བ།",
    "title-g_bo_553": "བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དང་ནུས་རྒྱུ་གསར་པའི་འཕེལ་རྒྱས་འགྲོ་རྒྱུར།",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་བའི་དོན་དངོས་དང་བྱས་ནས་བྱ་རྒྱུའི་ལས་འཛོལ།",
    "title-g_bo_141": "མི་རིགས་མཐུན་སྒྲིལ་ལ་བོད་ལྗོངས་ཀྱི་གཙོ་གནད་འཛུགས་སྐྱོང་བྱས་པ།",
    "title-g_bo_886": "དབྱི་སི་རལ་དམག་དཔུང་གི་ཧ་མ་སི་ཅ་ཧྲ་ས་ཁུལ་དུ་འགོག་སྲུང་བྱས་པ།",
    "title-g_bo_688": "2024ལོར་ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་འབྲེལ་བ་སྐས་རིམ་གསར་པ་ཞིག་ཏུ་སླེབས་རྒྱུར་བྱེད།",
    "title-g_bo_586": "ཀ་ཧྲ་ས་རྒྱུད་དང་ས་ཁུལ་ལ་མེ་སྒྱོགས་འབོར་ཆེན་འཕེན་པ་དང་འབར་མདེལ་འབོར་ཆེན་དབྱུག་པ།",
    "title-g_bo_990": "2023 དཔྱིད་གསར་དུས་ཆེན་འཆར་ལ་འབྲུག་ལོའི་མཚམས་འདིར་ཀྲུང་ཧྭ་མི་རིགས་ཀྱི་སྲོལ་རྒྱུན་དུས་ཆེན་ཤིང་བྱུང་བ་བྱེད།",
    "title-g_bo_838": "2023ལོར་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་བ་མི་ཐེངས་ཁྲི་5500ལས་བརྒལ་བར་སྣེ་ལེན་ཞུས་པ།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་དུ་A5རིམ་པའི་གནས་སྐོར་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གུང་ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་ཀྱི་གྲོས་ཚོགས་འཚོགས་ལས་བྱུང་བའི་བརྗོད་དོན་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་གཙོ་བོའི་སློབ་གསོ》",
    "title-g_bo_60": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་དང་ཧོ་པེ་གི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་གནོད་འཚེ་ཕོག་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་བྱས་པ།",
    "title-g_bo_223": "རུས་ཚིགས་སྲུང་བྱ་བར་དོ་སྣང་བྱ་དགོས། འགུལ་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་པའམ་ཡང་ན་འདུག་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་མི་རུང།",
    "title-g_bo_96": "ལས་ཁུངས་ཏང་ཙུའུ་ཡི་ཧྲུའུ་ཅི་ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་དང་ལས་འགན་བྱུང་བ།",
    "title-g_bo_312": "དབྱི་རག་གི་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་དགོས། སུའུ་ཏ་ཉི་ཡིས་བཤད་བྱས།",
    "title-g_bo_176": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་དབར་གྱི་རེས་སྐོར་གསར་པའི་གདོང་ཐུག་དྲ་ཚོགས་ལ་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤོར་བ།",
    "title-g_bo_145": "11པའི་ཚེས་15ཉིན་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་མཛེས་རྩལ་ཁང་སྒོ་འབྱེད་ཀྱི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ།",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྲུང་གོའི་གཙོ་སྐྱོང་འོག་ལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་པ་པེ་ཅིང་དུ་བཟོ་བསྒྲུབ།",
    "title-g_bo_101": "ཞི་ཅིན་ཕིང་གི་བཟོ་ཚོགས་ལ་འགོ་ཁྲིད་བྱས་པའི་བྱ་གཞག་དང་འབྲེལ་གསུང་བཤད་གལ་ཆེན།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_174": "ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བ་ལོ་65ལ་བཟོ་བྱས། \"རྒྱུད་གཅིག་ལམ་གཅིག\" གི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང》དེབ་གྲགས་ཅན་གྲུབ་འབྲས་བྱས་པའི་སྤེལ་བཟོ། མི་ཚོར་ཕྱོགས་བསྡུས་འཚོ་བ་སྐྱེལ་སྟངས་ལ་གཏོང་ཐབས་བསྟན།",
    "title-g_bo_668": "ཀ་ཧྲ་ས་རྒྱུད་དུ་མེ་ཤུགས་འཕུར་མདེལ་བྱས་པའི་བྱ་སྤྱོད་དང་འབར་རྗས་བཞི་ཁྲི་ལྔ་སྟོང་ལྷག་འཕེན་བྱས་པ།",
    "title-g_bo_708": "དྲ་དཔོན་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་ཟེར་བའི་བརྙན་ལམ་བྱས་པ།",
    "title-g_bo_481": "མཚོ་བོད་ས་མཐོར་གནས་པའི་སྟོངས་ལ་ཉེ་བའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "སི་རི་ལན་ཁ་དུ་བོད་ལྗོངས་ཀྱི་གླུ་གར་འཁྲུག་ཆ་དོད།",
    "title-g_bo_818": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "ཧུའུ་སའེ་དྲག་ཤོག་གི་འཇབ་རྒོལ་བྱེད་དབྱི་སི་རལ་གྱི་གྲུ་ཁ་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_829": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་དམག་འཐབ་བྱས་པ། མཐའ་སྲུང་དཔུང་སྡེ་དམག་མི་ཤོར་བའི་བཤད་སྒྲུབ།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་བའི་གནོད་འཚེ་དང་ལུས་ཕུང་ལ་གནོད་པ།",
    "title-g_bo_244": "བོད་ལྗོངས་ལ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་འཇུག་བྱས་པ།",
    "title-g_bo_821": "2000ལྷག་ཙམ་གྱི་ལོ་རྒྱུས་ལྡན་པའི་རྒྱལ་ཁབ་རིམ་པའི་མངོན་མིན་རིག་གནས་“ཉི་ཤར་རྫ་ནག”།",
    "title-g_bo_560": "ཀྲུང་གོ་དང་ཨ་རི་ཕྱི་དབྱིབས་ཀྱི་འཚམས་འདྲི་ཐུགས་ལ་ཕེབས་སྐྱེལ་ཞུས་པ།",
    "title-g_bo_737": "འདི་ག་ལས་ཁུངས་ཀྱིས་ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་གཏོང་སྤེལ་བྱས་པ། རྒྱལ་ཁབ་ཀྱི་བཟོ་སྐྲུན་ཆེ་མོ་བའི་བྱ་དགའ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས།",
    "title-g_bo_564": "\"རྒྱུད་གཅིག་ལམ་གཅིག\" ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024 ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་ལོ་གསར་དགོང་ཚོགས་ཆེན་མོ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་གྱར་བའི་སྐོར་གྱི་ཡོ་རོབ་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་སྲིད་ཇུས་ལ་ངོ་རྒོལ་བྱ་རྒྱུ་མ་ཟད།",
    "title-g_bo_520": "ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "སྤྱི་ཟླ་གསུམ་པའི་ཚེས་བཅུ་དྲུག་ནི་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་ལ་བྱང་སྣེའི་འོད་ཟེར་མངོན་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཀྱི་ཕྱིར་འཐེན་བྱས་པ། མི་ཆོས་རིང་ལུགས་ཀྱི་རོགས་སྐྱོབ་དངོས་རྫས་ཀ་ཧྲ་རྒྱུད་དུ་སྐྱེལ་བར་འགོག་རྐྱེན་ཐེབས་པ།",
    "title-g_bo_749": "ཀྲུང་གོའི་རྒྱང་མེ་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་ཏི་པའེ་རུ་གཉེར་བའི་མཁའ་འགྲུལ་འགྲེམས་སྟོན་ལ་བརྟེན་ནས་མེ་ཤུགས་འཕུར་མདའི་མེ་སྒྱོགས་ལ་གཤོག་སྒྲོ་བསྒར་བ།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་གནས་ཚུལ་དངོས་ཤེས་དང་བྱུང་ནས་བདེ་ཐང་གྱི་གནས་ཚུལ་མཚོན་པ།",
    "title-g_bo_74": "45ལོ་བརྗོད་ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བ་འཛུགས་རྒྱུར་འབད་བརྩོན་བྱེད།",
    "title-g_bo_522": "13000ལོ་རྒྱུས་ལྡན་པའི་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་བྱེད་རིང་སྟ་རེ་སོགས་ཨང་སྒྲིག་དངོས་དཔེ་3000ལྷག་ཙམ་གསར་རྙེད་པ་རེད།",
    "title-g_bo_787": "400 ལྷག་ཙམ་གྱི་ཁྲོད་ནས་མི་ཁྲི་70ཙམ་སུའུ་ཏན་གྱི་ཁྱིམ་མཚེས་རྒྱལ་ཁབ་ཏུ་བྲོས་བྱོལ་ལ་སོང་། སྤྱི་ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བ།",
    "title-g_bo_36": "ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "160 ཁྲོད་ནས་འབུར་དུ་ཐོན་པའི་གཞིས་རྩེའི་དམངས་ཁྲོད་སྒྱུ་རྩལ་འཁྲབ་སྟོན་བྱས་པ།",
    "title-g_bo_372": "ཙེ་ལན་སི་ཅི་དང་ཨ་རི་གཉིས་ཀྱིས་ཡུག་རེན་ལ་གནས་བབ་དང་དམག་དོན་རོགས་སྐྱོར་བྱས་པའི་འདི་འདྲ་བྱས་པ།",
    "title-g_bo_672": "\"ཁྲག་རིགས་Aཅན་དང་ནད་རིགས་ཀྱི་འབྲེལ་བ་དང་བྱུང་བའི་གསར་རྟོགས་བྱུང་བ།\"",
    "title-g_bo_538": "2024 ལོའི་བོད་ལྗོངས་སྤྱི་ལོ་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུའི་ཚོགས་འདུ་ཐེངས་གཉིས་པ། སྤྱི་ལོ་2024ལོར་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལས་བརྒྱ་ཆ་21འཕར་རྒྱུ།",
    "title-g_bo_192": "དབྱི་སི་རལ་དམག་གི་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_222": "བོད་ཀྱི་གསོ་རིག་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས།",
    "title-g_bo_611": "90ལོ་ཕེབས་པའི་ཡོན་ཧྲི་ཧྲེན་ཧྲི་ཀྲའོ་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་དང་རྒྱལ་སྤྱིའི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}