    "title-g_bo_675": "སློབ་གསོ་པུའི་སློབ་ཕྱིའི་ལུས་སྦྱོང་དུ་མི་རུང་བ་ལྔ་བཏོན།",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པ།",
    "title-g_bo_65": "༢༠༢༣ ཚེས་༡༤ ཡིན་ཏེན་མག་གི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཀྲུང་གོ་དང་འབྲེལ་བ་འཕེལ་རྒྱས་མྱུར་པོ་ཕྱིན་པའི་གློག་འཕྲིན་བཏང་བྱས།",
