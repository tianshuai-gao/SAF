    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "ཕིང་ཅིའུ་ཅིན་ཧྲན་དུ་ཀྲུང་ཨའི་གཙོ་བདག་གི་མཇལ་འཕྲད་དང་ཕེབས་སྐྱེལ་བྱས་པའི་གནམ་ཐང་དུ་ཕེབས་པ།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》མྱུར་དཔྱད་གཏོང་སྤེལ་བྱས་པ།",
    "title-g_bo_564": "༢༠༢༣ ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་ཞི་ཅིན་ཕིང་གི་སྐབས་དང་པོའི་\"རྒྱུད་གཅིག་ལམ་གཅིག\" བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བ།",
    "title-g_bo_746": "2024 ལོའི་ཕོ་འབྲུག་ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོའི་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་པ། ཕོ་ལན་གྱིས་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་གྱར་བའི་སྐོར་ལ་ངོ་རྒོལ་མཐའ་གཅིག་ཏུ་བྱ་རྒྱུ་མ་ཟད།",
    "title-g_bo_520": "《关于惩治武装叛乱、武装暴乱犯罪活动的决定》颁布实施",
    "title-g_bo_476": "བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་བྱེད་པ།",
    "title-g_bo_699": "2023 ལོའི་ཟླ་2 ཚེས་26 ཉིན། དབྱིན་ཇིའི་མཁའ་དབྱིངས་སུ་བྱང་སྣེའི་འོད་ཐིག་མཐོང་དཀོན་པ་མངོན་བྱུང་འདུག",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་དབོར་བའི་མི་ཆོས་དང་དབོར་བའི་བྱིས་པ་གཉིས་ཀ་ལ་གནོད་པ་ཐེབས་པ།",
    "title-g_bo_749": "ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་ཀྱི་གཤོག་སྒྲོ་དང་འཕུར་མདའི་མེ་སྒྱོགས་ལ་རམས་འདེགས་བྱས་པ།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་ན་གཟུགས་པོའི་བདེ་ཐང་དངོས་ཤེས་རྟོགས་མེད་པ།",
    "title-g_bo_74": "ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བའི་ལོ་45པའི་ཐོག་ནས་ཀྲུང་ལྗར་ཞི་བདེ་དང་མཛའ་མཐུན་བཅས་ཀྱི་ཁ་ཕྱོགས་ཆེན་པོ་གཏན་འཁེལ་བྱས།",
    "title-g_bo_522": "ཕན་རོགས་གནའཤུལ་ལ་ལོ་13000ཡན་གྱི་ལོ་རྒྱུས་ལྡན་པ་ར་འཕྲོད་བྱུང་།",
