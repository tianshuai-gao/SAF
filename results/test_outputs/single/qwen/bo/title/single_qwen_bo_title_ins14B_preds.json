    "title-g_bo_79": "གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་འཕེལ་རྒྱས་ཤུགས་ཆེན་གཏོང་བ།",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་སྤེལ་བའི་བྱེད་ཐབས་དང་ཡོ་རོབ་མནའ་འབྲེལ་ཨུ་ཡོན་ལྷན་ཁང་དང་ཁོངས་གཏོགས་རྒྱལ་ཁབ་གཞན་དག་གི་གནོན་ཤུགས་ཀྱིས་ཡུག་རེན་དང་ཁྱིམ་མཚེས་རྒྱལ་ཁབ་དབར་གྱི་རྒྱུན་ལྡན་ཚོང་དོན་སླར་གསོ་འབྱུང་བར་ཕ",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གི་དྲག་ཇུས་དམག་དཔོན་ཀ་ཧྲ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད།",
