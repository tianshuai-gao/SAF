    "title-g_bo_884": "པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པ།",
    "title-g_bo_199": "ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་བཙུགས་པའི་ཁོངས་དང་དུས་ཡུན་རིང་པོ་འབད་བརྩོན་བྱས་པ།",
    "title-g_bo_165": "30 ལོ་གཏོང་ནས་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས།",
    "title-g_bo_275": "མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱིས་\"གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས\"འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་ཕྱི་ཕྱོགས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
