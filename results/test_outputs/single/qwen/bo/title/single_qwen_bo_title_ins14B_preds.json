    "title-g_bo_856": "ཕྱི་རྒྱལ་དྲ་བའི་ཐོག་ནས་ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེན་བཀྲེས་ལྟོགས།",
    "title-g_bo_292": "ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་བོད་དང་འབྲེལ་བའི་དོན་དངོས་སྣང་མེད་དུ་བཏང་ནས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་ལ་ཐོངས་མཆན་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》: རྒྱ་གར་དང་ཁ་ན་ཏའི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ལྷོ་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་གཉིས་པོ་ཀྲུང་གོ་དང་ཕན་ཚུན་ཤེས་རྟོགས་བྱུང་འདུག",
    "title-g_bo_865": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གཉིས་ཀྱི་གདོང་ཐུག་ཐེངས་གཉིས་པ།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་མི་རེ་རེས་འཕྲིན་ཡིག་རེ་བྲིས།",
    "title-g_bo_638": "2023 ལོའི་ཟླ་དང་པོ་ནས་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་དབྱར་རྩྭ་དགུན་འབུ་ཕྱིར་གཏོང་བྱེད་ཚད་དུས་མཚུངས་ལས་12.1%འཕར་ཞིང་།",
