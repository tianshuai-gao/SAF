    "title-g_bo_36": "《བོད་མཚོའི་ས་མཐོའི་གཙོ་བོ་གྲོང་ཁྱེར་དང་པོ་སྟེ་ཟི་ལིང་དུ་ཝུའུ་ཧན་ནས་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།》",
    "title-g_bo_495": "བོད་ཀྱི་གཞིས་རྩེ་གྲོང་ཁྱེར་མང་ཚོགས་སྒྱུ་རྩལ་ཁང་གི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་\"སེ་མ་བྲོ\" ལས་ཕུལ་བྱུང་དམངས་ཁྲོད་སྒྱུ་རྩལ་འཁྲབ་སྟོན་བྱས་པ།",
    "title-g_bo_372": "ཡུག་རེན་དང་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་གཉིས་པོས་གནས་བབ་དང་དམག་དོན་རོགས་སྐྱོར།",
    "title-g_bo_672": "ཁྲག་རིགས་Aཅན་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་ཁྲག་རིགས་ཀྱི་ནད་འབྱུང་བ་ལ་འབྲེལ་བ།",
    "title-g_bo_538": "2024 ལོའི་བོད་ལྗོངས་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
