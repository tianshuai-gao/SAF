    "title-g_bo_176": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ཁྲིམས་ཁང་དུ་ཤོར་བ་དང་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_145": "བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་བྱུང་འདུག",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་ཁོངས་ལྟར་ཁ་པར་འཐུས་མི་ཚོགས་པའི་ཚོགས་འདུ་འཚོགས།",
    "title-g_bo_414": "པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་བྱས་པ།",
    "title-g_bo_101": "༢༣པའི་ཕྱི་དྲོའི་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
