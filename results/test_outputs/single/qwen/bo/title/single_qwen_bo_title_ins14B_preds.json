    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་བ་མི་ཐེངས་ཁྲི་5500ལས་བརྒལ་བར་སྣེ་ལེན་ཞུས།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་དུ་གནས་སྐོར་མཛེས་ལྗོངས་ཁུལ་གྱི་རྒྱལ་ཁབA5རིམ་པའི་གཏན་ཁེལ་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་ཀྱི་གྲོས་ཚོགས་གཙོ་སྐྱོང་གནང་བ》",
    "title-g_bo_60": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཕེབས་པའི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བ།",
    "title-g_bo_223": "རུས་ཚིགས་སྲུང་སྐྱོབ་དང་འགུལ་སྟངས་མཚམས་འཇོག་བྱ་དགོས།",
