    "title-g_bo_818": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གཉིས་པོའི་འབྲེལ་བ་གོང་འཕེལ་གཏོང་བའི་དུས་མཚམས་གསར་པ།",
    "title-g_bo_650": "ཧུའུ་སའེ་དྲག་ཤོག་གི་ཚོད་འཛིན་ཁུལ་ནས་འཕེན་གཏོང་བྱ་རྩིས་ཡོད་པའི་དམག་གྲུར་རྒོལ་བའི་མདེལ་ལམ་མེ་ཤུགས་འཕུར་མདའ་བཏང་ཡོད།",
    "title-g_bo_829": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གཉིས་ཀྱི་གདོང་ཐུག་ཐེངས་གཉིས་པ།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་དང་གནོད་འཚེ་བྱེད་ཀྱི་བྱེད་པ།",
