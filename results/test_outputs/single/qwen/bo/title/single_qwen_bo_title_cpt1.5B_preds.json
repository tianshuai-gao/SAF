    "title-g_bo_577": "2022ལོའི་ཟླ་12ཚེས་1ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་རྩོམ་ཡིག་སྤེལ་བ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱིས་རྒྱ་གར་གྱི་དམག་མི་བཞི་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་ཉུང་མཐར་ཡང་དམག་མི་གཉིས་ལ་རྨས་སྐྱོན་ཕོག་པ།",
    "title-g_bo_831": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་དབྱི་སི་རལ་ལ་འཕུར་མདེལ་དང་མི་མེད་གནམ་གྲུ་སྤྱད་དེ་དམིགས་འབེན་རང་བཞིན་ལྡན་པའི་རྡུང་རྡེག་གཏོང་རྒྱུ་ཡིན་ཞེས་བཤད་པ་རེད།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་ཉིང་ཁྲི་གྲོང་ཁྱེར་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་དངུལ་ཁང་གཱ་བསྡམས་བཅད་བྱས་པའི་སྐོར་གྱི་མང་ཚོགས་མའོ་ཆེ་གེ་མོའི་བློ་འདྲིའི་ཁ་པར་འབྱོར་བ་དང",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་ཁབ་གྲངས་འཛིན་དཔལ་འབྱོར་གྱི་བསྡོམས་འབོར་གྱི་དཔྱད་གཞི་གཞིར་བཟུང་། ཨ་རི་དང་ཀྲུང་གོ འཇར་མན། ལྗར་པན། ལྷོ་ཁོ་རེ་ཡ་བཅས་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་བསྡུར་གྲངས་ཀྱི་58%བ",
    "title-g_bo_675": "སློབ་གསོ་པུས་སློབ་ཕྱིའི་གསོ་སྦྱོང་བདེ་འཇགས་སྲུང་སྐྱོང་ཞེས་པའི་ཆེད་དོན་བྱ་སྤྱོད་སྤེལ་ནས་སློབ་ཕྱིའི་གསོ་སྦྱོང་བདེ་འཇགས་སྲུང་སྐྱོང་ཞེས་པའི་ཆེད་དོན་བྱ་སྤྱོད་སྤེལ་བ།",
    "title-g_bo_404": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན། མིག་སྔའི་བར་རེས་སྐོར་དེའི་གདོང་ཐུག་ཁྲོད་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི",
    "title-g_bo_65": "2023ལོའི་ཟླ་11ཚེས་14ཉིན་ཞི་ཅིན་ཕིང་གིས་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པར་རྟེན་འབྲེལ་ཞུ་བའི་གློག་འཕྲིན་བཏང་སྟེ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ་རེད།",
    "title-g_bo_214": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ་༼ལྷ་ས་གྲོང་ཁྱེར་སྲིད་གཞུང་གི་ཡིག་ཆ་〔2023〕�",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་གསུམ་གྱི་བྱ་སྤྱོད་དེ་རྒྱལ་སྤྱིའི་འོས་འགན་ལས་འགལ་ཡོད་པའི་ངོས་འཛིན་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_632": "2023ལོའི་ཟླ་12ཚེས་27ཉིན་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་དུ་འཇབ་རྒོལ་བྱེད་པའི་གནས་ཚུལ་བསྟན་པ།",
    "title-g_bo_318": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་མོས་མཐུན་ཡོད་པའི་འདེམས་ཤོག་ཡོངས་ཀྱི་ཐོག་ནས་ཁྲིམས་གཞི་ཞིག་ལ་གྲོས་འཆམ་བྱུང་བ་དང་།",
    "title-g_bo_856": "ཨ་རིའི་རྒྱ་མཚོའི་ཤར་རྒྱུད་ཀྱི་རྒྱ་མཚོའི་ཚ་རླབས་ཀྱི་རྐྱེན་ལས་ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེས་ཆེ།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་གྱི་ཕྱི་དྲོ། ཨ་རི་ཕྱོགས་ཀྱིས་བོད་དང་འབྲེལ་བ་ཡོད་པའི་གནད་དོན་ལ་བརྟག་དཔྱད་བྱས་པ་རེད།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོངས་མཆན་ཞབས་ཞུ་གནས་སྐབས་མཚམས་བཞག་པ་དང་རྗེས་མཐུད་ཀྱི་གནས་ཚུལ་ལ་བརྡ་ཐོ་གཏོང་རྒྱུ་ཡིན་པ་དང་། གནས་ཚུལ་གསར་པར་མུ་མཐུད་དོ་ཁུར་བྱེད་དགོས་ཞེས་འཁོད་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན། ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པ།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་གི་སློབ་མ་1100ལྷག་ཙམ་དང་ལོ་རིམ་དང་པོའི་སློབ་མ་200ལྷག་ཙམ་གྱི་ལག་ཏུ་འབྱོར་བ།",
    "title-g_bo_638": "2023ལོའི་ཟླ་དང་པོ་ནས་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་ཡོད།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དེ་ཉེས་གསོག་དོན་དངོས་གཞན་དག་ཤེས་རྟོགས་བྱུང་བ་དང་།",
    "title-g_bo_319": "2023ལོར་རང་རྒྱལ་གྱིས་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་ལ་ཚད་བཀག་རང་བཞིན་མི་དགོས།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡའི་ཕྱི་འབྲེལ་པུའི་པུའུ་ཀྲང་གཞོན་པ་ཧྥུའུ་ལའེ་ཏི•མ་མཱ་ཉིས་ཀྱིས་དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ་དང་། ཀ་ཧྲ་ས་ཁུལ་དུ་ཕ་ལེ་སི་ཐན་མི",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།",
    "title-g_bo_185": "2023ལོའི་ཟླ5པའི་ཚེས18ཉིན་གྱི་ཆུ་ཚོད17པར། མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན། བོད་བྱང་ཐང་བཅས་ཀྱི་གཙོད་མོ་ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་གནས་མཚེའུ་ཉེ་འགྲམ་དུ་གནས་སྤོ་བྱེད་ཅིང་། �",
    "title-g_bo_884": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་གཞོན་ནུ་ལོ་ཆུང་གི་དབྱི་སི་རལ་གྱི་གྲོངས་པའི་མི་གྲངས་ 5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་འཛུགས་རྒྱུའི་གྲོས་མོལ་གནང་བ།",
    "title-g_bo_165": "2023ལོའི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་བའི་སྟེང་།",
    "title-g_bo_275": "2017ལོའི་མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱི་འགྲེམས་སྟོན་དུས་ཚོད་ཚེས་12ཉིན་གྱི་དཔང་ཉན་ཚོགས་འདུ་ཐེངས་དང་པོ་འཚོགས་པ།",
    "title-g_bo_900": "2023ལོའི་ཟླ་2ཚེས་24ཉིན་གྱི་ཚོགས་ཆེན་ཐོག་ཤིན་ཅང་དུ་སྣེ་འོད་ལྟ་དཔྱད་ཐུབ་དོན་ཅི་ཡིན་ནམ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུའི་ནང་ཞུགས་རྒྱུ་རེད།",
    "title-g_bo_388": "དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ལ་འགེབས་སྲུང་བྱེད་པའི་གནད་དོན་སྐོར་སྐད་ཆ་འདྲི་དུས།",
    "title-g_bo_578": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་24ཡི་ནང་དབྱི་སི་རལ་གྱི་དམག་དཔུང་གིས་ཀ་ཧྲ་ས་ཁུལ་ལ་འཇབ་རྒོལ་བྱས་པའི་མི་190རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་340ལ་རྨས་སྐྱོན་ཕོག་པའི་གྱོད་གཞི་བདེ་བླག་ངང་འདྲི་གཅོད་བྱ",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་ཙུང་ཐུང་ལ་སླར་ཡང་བདམས་ཐོན་བྱུང་ནས་འགན་གནས་བསྟུད་འཛིན་གནང་བར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་གསོལ་སྟོན་གནང་བ།",
    "title-g_bo_235": "2024ལོའི་ཧྲ་ཅོན་གྱི་ཁུ་ལུའི་སྤུས་རྟགས་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023ལོའི་ཟླ་ 10 ཚེས་ 8 ཉིན་ནས་ 2023ལོའི་ཟླ་ 10 ཚེས་ 27 ཉིན་བར་བྱིས་པའི་ལྷན་སྐྱེས་སྙིང་ནད་སྐྱོབ་བཅོས་ལས་དོན་ལ་སྐུལ་འདེད་ཏན་ཏིག་གཏོང་རྒྱུ་རེད།",
    "title-g_bo_918": "《ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས》ལ་རྟེན་འབྲེལ་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་ནས། ཀྲུང་གོ་རིག་པའི་ཞིབ་འཇུག་གི་དོན་སྙིང་གལ་ཆེན་རྒྱས་བཤད་གནང་།",
    "title-g_bo_451": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་10པར་ཞིང་ཆེན་ནན་ཁྲང་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་ཏིན་ཧུའུ་གྲོང་ཚོའི་ཞིང་པ་སྤུན་ཟླ་ཚོ་ལིན་ཅི་ཧོ་ཡིས་ཞིང་པ་སྤུན་ཟླ་ཚོར་སྤྲོད་རྒྱུའི་བྱ་དགའ་ས",
    "title-g_bo_997": "2023ལོའི་ཟླ་10ཚེས་8ཉིན་གྱི་ཆུ་ཚོད་12པར་ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་གནས་སྐབས་སྲིད་གཞུང་གི་རང་བྱུང་གནོད་འཚེ་དོ་དམ་པུའི་མགྲིན་ཚབ་པ་ཅ་ནན·སའེ་དབྱི་ཁེས་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་གནོད་འཚེ་ཕོ",
    "title-g_bo_544": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ་དང་།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་གནོད་འཚེ་བཟོ་གི་ཡོད།",
    "title-g_bo_847": "2023ལོའི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་གིས་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ལ་ཞུགས་རྒྱུ་ཡིན་ལུགས་བརྗོད་འད",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ངང་གསན་གཟིགས་གནང་བ།",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་པ།",
    "title-g_bo_936": "2023ལོའི་ཟླ་11ཚེས་5ཉིན་གྱི་ཕྱི་དྲོའི་ཆུ་ཚོད་10པར། ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གྱི་གདོང་ཐུག་ཁྲོད་ཕྱོགས་གཉིས་པོའི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_830": "2023ལོའི་ཟླ་8པའི་ཚེས་22ཉིན་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་2དང་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་2ཀྲུང་གོའི་ནན་ཧྲ་གླིང་ཕྲན་གྱི་རེན་ཨའེ་ཅའོ་ཉེ་འགྲམ་མཚོ་ཁོངས་སུ་འཛུལ་འདུག",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་ཆེད་མཁས་ལས་དོན་གྲོས་ཚོགས་དེ་དྲ་ཐོག་དང་དྲ་ཕྱི་ཟུང་འབྲེལ་གྱི་རྣམ་པས་འཚོགས་ཤིང་།",
    "title-g_bo_826": "2023ལོའི་ཟླ་6ཚེས་6ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་པ།",
    "title-g_bo_17": "2023ལོའི་རྒྱལ་ཡོངས་ཀྱི་བཟོ་ལས་དང་ཆ་འཕྲིན་ཅན་གྱི་རྩལ་ནུས་འགྲན་བསྡུར་ཆེ་མོ་སྐབས་གཉིས་པ་ལས་ཐོན་ལས་ཀྱི་དགོས་མཁོ་དང་ལས་རིགས་གསར་པར་ཁ་གཏད་དེ་དེར་མཚུངས་ཀྱི་འགྲན་བསྡུར་རྣམ་གྲངས་བཀོད་སྒྲིག་བྱས་ནས།",
    "title-g_bo_285": "《མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་ཆབས་ཅིག ལག་པས་འོག་ནས་སྒང་ལ་འཕུར་འཕུར་བཏང་ན་ན་ཟུག་ཆེ་རུ་ཕྱིན་ཚེ། སྤྱིར་ན་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཡོད།》",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ནས་ཚེས་24ཉིན་བར་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ་རེད།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་ཕྱོགས་ཀྱི་ཁེ་དབང་ལ་བཙན་གནོད་དང་འཁྲུག་རྐྱེན་སློང་བའི་བྱ་སྤྱོད་སྤེལ་བའི་གནས་ཚུལ་བསྟན་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན།",
    "title-g_bo_563": "3Dམིག་ཤེལ་མི་དགོས་པའི་གཟིགས་མོ་བར་ཐུན་མིན་གྱི་མཐོང་རྒྱ་ཞིག་བཟོས་ཡོད།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་འགོ་ཁྲིད་ཚོགས་འདུ་བསྡུས་ནས་ལག་གདང་སྦྲེལ་ནས་དེང་རབས་ཅན་གྱི་ཕྱོགས་སུ་སྐྱོད་ཅེས་པ་བརྗོད་དོན་གཙོ་བོར་བྱས་པ་དང་འབྲེལ། ནེ་པེ་ཏུའུ་ཡི་བསྒྲགས་གཏམ་ཁྱབ་བསྒ",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་ཀྱི་ཡིག་རྒྱུགས་སྤྱི་ཟླ་11པའི་ཚེས་20ཉིན་གྱི་མཚན་མོའི་ཆུ་ཚོད་12ནས་ཚེས་26ཉིན་གྱི་ཉིན་དགུང་ཆུ་ཚོད་3བར་སྒོ་ཕྱེ་རྒྱུ་ཡིན་པས། རྒྱུགས་སྤྲོད་སློབ་མ་རྣམས་ཀྱིས",
    "title-g_bo_932": "ཧོ་ཐའེ་ཏ་མངའ་སྡེའི་དཔོན་རིགས་ཨ་ལི·ཨའེ་ཧ་མའེ་ཏེ·ཁ་ཧྲའར་གྱིས་ཚེས་13ཉིན་སྨྱན་སྦྱོར་ལས་ཁུངས་ཀྱི་བཅར་འདྲི་དང་ལེན་བྱེད་སྐབས། ཨ་རི་དང་དབྱིན་ཇིའི་མཁའ་དམག་གི་མི་མེད་གནམ་གྲུས་ཚེས་13ཉིན་གྱི་ཞོག",
    "title-g_bo_110": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་ཚོགས་འདུ་ཐེངས་སུམ་ཅུ་པ་ཞི་ལི་ཧྲ",
    "title-g_bo_707": "ཨུ་རུ་སུའི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་གིས་བྱང་ཁོ་རེ་ཡ་དེ་ལྗར་པན་གྱི་མི་སེར་སྤེལ་བའི་དབང་སྒྱུར་འོག་བཅིངས་འགྲོལ་བཏང་བའི་བརྒྱུད་རིམ་ནང་འགག་རྩའི་ནུས་པ་འདོན་སྤེལ་བྱས་ཡོད།",
    "title-g_bo_822": "2023ལོའི་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་པེ་ཅིང་དུ་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་ཡོད།",
    "title-g_bo_529": "བྱིས་པ་གློ་ལུ་རྒྱག་དགོས་སམ།",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་ནས་འབར་མདེལ་བཟོ་བའི་འཁོར་སྟེགས་དང་། རྒྱང་ཁྲིད་མ�",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་ཟོག་འདྲེན་མེ་འཁོར་ཞིག་ལིའང་ཙན་མངའ་སྡེ་བརྒྱུད་འགྲོ་སྐབས་ཆག་སྒོ་བྱུང་ནས་ཁྱོན་བསྡོམས་འཁོར་སྒྲོམ་19འཁོར་ལམ་ལས་བྲལ་ཡོད་ཅེས་བཤད།",
    "title-g_bo_287": "ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་གཏུག་བྱུང་ཚུལ་བརྗོད་པ།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་ལྗོངས་ཡོངས་ཀྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བ།",
    "title-g_bo_901": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་ཙུང་ཐུང་ཨོའར་ཐེ་ཀ་དང་ཞལ་པར་བསྐྱོན་གནང་བ།",
    "title-g_bo_342": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གསལ་བསྒྲགས་ཤིག་སྤེལ་ཡོད་པ་དང་།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་ཁྱབ་བསྒྲགས་བྱས་ནས་འགག་རྩའི་ལག་རྩལ་ཁག་ཅིག་ལ་ཐོད་བརྒལ་ཡོང་བ་བྱ་རྒྱུ་རེད།",
    "title-g_bo_259": "2023ལོའི་ཀྲུང་གོའི་བྱིས་པའི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་བརྩམས་ཆོས་ལ་བྱ་དགའ་སྤྲོད་པའི་བཞུགས་མོལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_685": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པས་ཏེ་ཨེར་ན་གྲོང་ཁྱེར་གྱི་ཆུ་ལོག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་11300ཟིན་པ་དང་། གཞན་ད་དུང་མི་ཁྲི་1ལྷག་ཙམ་གར་སོང་ཆ་མེད་དུ་ག",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
    "title-g_bo_50": "2023ལོའི་ཟླ་12པའི་ཚེས་3ཉིན་གྱི་ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_769": "2023ལོའི་ཟླ་11ཚེས་27ཉིན་གྱི་ཆུ་ཚོད་7པར་དབྱི་སི་རལ་བ་10དང་ཕ་ལེ་སི་ཐན་བ་30བརྗེ་པོ་རྒྱག་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན་ཞེས་བཤད་ཡོད།",
    "title-g_bo_582": "2023ལོའི་ཟླ་༡༡ཚེས་༡༤ཉིན་གྱི་སྐུད་མེད་དྲ་བའི་ཐོག་སྤྱི་ཟླ་༡༡ཚེས་༡༤ཉིན་གྱི་ཆུ་ཚོད་༡༠:༠༠ནས་ཆུ་ཚོད་༡༢:༠༠བར་དུ། ཨ་ཅག་གྲེན་ལགས་ཁྲོམ་སྐོར་བར་འགྲོ་སྐབས། རང་ཉིད་ཀྱིས་མོས་པ་བྱེད་པའ�",
    "title-g_bo_635": "2023ལོའི་ཟླ་4ཚེས་2ཉིན་ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོར་ཅིང་ཏུང་དངུལ་རྩའི་འཛད་སྤྱོད་ཞབས་ཞུ་བ་ཡིན་ཟེར་མཁན་ཞིག་གི་ཁ་པར་འབྱོར་བ་དང་། མི་དེས་ཅིང་ཏུང་ཆད་འཛིན་གྱི་རྩིས་ཐོ་སུབ་རོགས་བྱས་ཆོག་ཅེས་པར་ཁ་གཡར",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་སྟབས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་ཨ་རིའི་དམག་ལ་ཉེ་ཆར་འཇབ་རྒོལ་རབ་དང་རིམ་པ་ཕོག་པར་ཡ་ལན་སློག་པ་ཡིན་ཞེས་བརྗོད་འདུག",
    "title-g_bo_872": "2023ལོའི་ཟླ་4པའི་ཚེས་18ཉིན་འབའ་ཐང་རྫོང་སྤྱི་ཚོགས་སྟོབས་ཤུགས་འཕེལ་རྒྱས་ལྟེ་གནས་སུ་འགྲན་བསྡུར་ཆེན་མོ་འཚོགས་པ།",
    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་ཞི་ཅིན་ཕིང་གིས་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་།",
    "title-g_bo_575": "2020ལོའི་ཡར་ཀླུང་གཙང་པོའི་རི་རྩེ་གནམ་ལྕགས་འབར་བའི་སྣོད་བཅུད་རིན་ཐང་ལྡན་པའི་ས་ཁུལ་གྱི་གྲས་ཤིག་རེད།",
    "title-g_bo_417": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་5087རྐྱེན་ལམ་དུ་ཤོར་བ་དང་། དེའི་ཁྲོད་དུ་བྱིས་པ་2055ཡོད་པ་རེད།",
    "title-g_bo_484": "2024ལོའི་སློབ་ཆེན་ལ་རྒྱུགས་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་དང་སློབ་བསྡུའི་ཆེད་ལས་སོགས་ཀྱི་ཐད་ལ་གཏན་འབེབས་བྱས་ཡོད།",
    "title-g_bo_249": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་ཕུའུ་ལ་ཤིན·དབྱི་སི་ཀན་ཏར་གློག་འཕྲིན་བཏང་ནས། ཁོང་གིས་མ་ལེ་ཞི་ཡའི་གཙོ་འཛིན་གྱི་འགན་བཞེས་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བ་རེད།",
    "title-g_bo_380": "2023ལོའི་ཟླ་10པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོའི་དུས་ཚོད་བར་དབྱི་རག་ཏུ་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "2023ལོའི་ཟླ་9ཚེས་6ཉིན་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་དང་གྲོས་མོལ་བྱས་པ་དང་། ཕྱོགས་གཉིས་པོས་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་རེས་སྐོར་གས",
    "title-g_bo_959": "2013ལོའི་ཟླ་3པའི་ཚེས་30ཉིན། ཀྲུང་གོ་དང་ཁོང་ཀོ་པུའི་མཛའ་གྲོགས་སྨན་ཁང་དུ་ཁོང་གིས་ཕྱི་རྒྱལ་ལ་རོགས་སྐྱོར་ལས་འགན་སྒྲུབ་བཞིན་པའི་ཀྲུང་གོའི་སྨན་བཅོས་རུ་ཁག་ལ་ཆེད་མངགས་གཟིགས་པ།",
    "title-g_bo_976": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར་ཡོད།",
    "title-g_bo_97": "2023ལོའི་ལྗར་ཕན་དུ་ལོ་65ཡན་གྱི་རྒན་རྒོན་ཁྲི་3623ཡོད་པ་དེ་ན་ནིང་གི་དུས་མཚུངས་ལས་མི་ཁྲི་1ཉུང་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_309": "2023ལོའི་ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ།",
    "title-g_bo_792": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན།",
    "title-g_bo_56": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་ཞུ་སྦྱོར་ཕྱི་མ་ཡུས་ཧྭ་དབྱིང་གིས་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱ་དགོས་པའི་འབོད་སྐུལ་བ�",
    "title-g_bo_973": "དབང་ཆེན་གྱི་ཕུགས་བསམ་དད་སེམས་ཤོར་བ།",
    "title-g_bo_294": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱ་དགོས་པའི་སྐོར་གྱི་གཏན་འབེབས་འདི་ཉིད་བོད་ལྗོངས་ཉིན་རེའི་ཚ",
    "title-g_bo_689": "《སློབ་བསྡུའི་ལག་ཁྱེར་གང་བྱུང་དུ་བསྐུར་རྒྱུ་མེད》དང་། 《ཐོབ་ཐང་ལག་ཁྱེར་གང་བྱུང་དུ་བསྐུར་རྒྱུ་མེད》གཉིས་ཀྱི་དྲན་སྐུལ་བྱེད་དགོས།",
    "title-g_bo_551": "2023ལོའི་ཟླ་11ཚེས་23ཉིན་གྱི་སྔ་དྲོ་ཧང་ཀྲོའུ་ཤིས་ཧུའུ་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉ",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》དེ་ཉེ་ཆར་མི་དམངས་དཔེ་སྐྲུན་ཁང་གིས་དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་མོ་ཞི་ཁོའི་ཙུང་ཐུང་ལུའོ་ཕེ་སི་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_351": "2023ལོའི་ཟླ་བ་དང་པོ་ནས་བཅུ་པའི་བར་དུ་དཔལ་འབྱོར་འཕར་སྣོན་ལ་སྐུལ་ཁྲིད་ཐུབ་ཚད་བརྒྱ་ཆའི་གནས་1.6ཟིན་ཡོད།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་བཟའ་བཅའི་བདེ་འཇགས་བཅའ་ཁྲིམས》དང་དེའི་ལག་བསྟར་སྲོལ་ཡིག《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཕྱིར་གཏོང་ནང་འདྲེན་བཟའ་བཅའི་བདེ་འཇགས་དོ་དམ་བྱ་ཐབས》ཀ�",
    "title-g_bo_771": "2023ལོའི་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ལ་སླེབས་ཡོད།",
    "title-g_bo_225": "2019ལོའི་ལེགས་རྩེ་འགག་སྒོ་སྐྲུན་འགོ་ཚུགས་པ་དང་2019ལོའི་ལེགས་རྩེ་འགག་སྒོ་སྐྲུན་འགོ་ཚུགས་པའི་མཛད་སྒོ་བོད་ལྗོངས་ལེགས་རྩེ་འགག་སྒོ་སྐྲུན་འགོ་ཚུགས་པའི་མཛད་སྒོ་དེ་བོད་ལྗོངས་འབྲོང་པ་རྫོང་ལ�",
    "title-g_bo_131": "2023ལོའི་ཟླ་བ་བཅུ་གཉིས་པའི་ཚེས་བཅུ་གཉིས་ཉིན་གྱི་དུས་ཚོད་དང་སྐར་མ་བཅུ་གཉིས་སྟེང་། རང་རྒྱལ་གྱི་སྟོན་འབྲུར་འབབ་འཕར་ཡོང་རྒྱུ་ངེས་གཏན་ཡིན།",
    "title-g_bo_739": "2023ལོའི་ཟླ་10ཚེས་7ཉིན་ཀ་ཧྲ་རྒྱུད་དུ་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་ཁྲི་2ཟིན་པ་དང་མི་བཅུ་ཕྲག་ལྷག་ལ་རྨས་སྐྱོན་བཟོས་པའི་གནད་དོན་ཐག་གཅོད་བྱེད་རྒྱུ་རེད།",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་ནས་ཀྱི་ཐོན་འབབ་ཏུན་ཁྲི་83བྱུང་ཡོད།",
    "title-g_bo_553": "2023ལོའི་ཁྲུང་ཆིང་གི་ལྗང་གློག་ཐེངས་དང་པོར་ཁྲུང་ཆིང་དུ་བཏང་བ།",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་མི་འཁོར་བའི་ཐབས་ཤེས་ཡག་པོ་ཞིག་བསླབས་འདུག",
    "title-g_bo_141": "2023ལོའི་ཟླ་1ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དང་པོ་དེ་བསྐྱར་དུ་ཞིབ་གཅོད་བྱ་རྒྱུ་རེད།",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ་དང་།",
    "title-g_bo_688": "2024ལོའི་ཟླ་4པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོར་ཞི་ཅིན་ཕིང་གིས་ཧྥ་རན་སེའི་ཙུང་ཐུང་མ་ཁེ་ལུང་དང་ཞལ་པར་བསྐྱོན་ཡོད།",
    "title-g_bo_586": "《ཀ་ཧྲ་ཡི་དུས་བབ་ཀྱི་གྲོས་ཆོད་གསར་པའི་འཆར་ཟིན་སྐོར་ལ་བརྡས་ཐག་གཅོད་སྐབས་རྒྱུན་ལས་ལས་འཛིན་རྒྱལ་ཁབ་སྟེ་ཨ་རིའི་མོས་མཐུན་ཐོབ་མེད་པ་རེད》",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་དང་དམངས་གཙོ་ཏང་ཤོག་ཁག་གི་ཀྲུང་དབྱང་དང་། རྒྱལ་ཡོངས་བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་། འཐབ་ཕྱོགས་གཅིག་གྱུར་གྱི་རྒྱ་ཆེའི་ཁོངས་མིར",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "2023ལོའི་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས་པ།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་།《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་ག",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་པེ་ཅིང་དང་ཧོ་པེ་ཡི་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་། གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་སེམས་ཁྲལ་མེད་པ",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_96": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱ་རྒྱུ་རེད།",
    "title-g_bo_312": "དབྱི་རག་གི་ཙུང་ལི་སུའུ་ཏ་ཉི་ཡིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_176": "2023ལོའི་ཟླ་12ཚེས་22ཉིན་གྱི་ཕྱི་དྲོའི་ཆུ་ཚོད་10པར་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་ས་ཁུལ་དུ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་རེད།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་ལ་ཞུགས་པའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་མཛེས་རྩལ་ཁང་དེ་ཐོག་ནས་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་དངོས་སུ་སྒོ་ཕྱེ་བ་མཚོན་གྱི་ཡོད་པ་དང་བོད་ལྗོངས་ལ་ཞིང་ཆེན་རིམ་པའ�",
    "title-g_bo_500": "2023ལོའི་ཟླ་10ཚེས་7ཉིན་ནས་བཟུང་། ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་འཐུས་མི་ཀྲང་ཅུན་གྱིས་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་འཐུས་མི་ཚོགས་པའི་རེ་ཞུ་ལྟར་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་ཡོད།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་ནན་ཧའེ་རུ་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན། འཛམ་གླིང་ཡོངས་སུ་སྔར་བཞིན་མི་གྲངས་དུང་ཕྱུར་50ལ་སྔར་བཞིན་ས�",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོར་སྐབས་གསུམ་པའི“རྒྱུད་གཅིག་ལམ་གཅིག”གི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློ",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་ཟླ་3ཚེས་3ཉིན་གྱི་ཆུ་ཚོད་24ནང་ཀ་ཧྲ་ས་རྒྱུད་དུ་འཇབ་རྒོལ་བྱས་པའི་མི་128རྐྱེན་ལམ་དུ་བཏང་ཡོད།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་གྱི་དྲ་དཔོན་དེའི་མི་སྒེར་གྱི་རྩིས་ཐོ་དེ་གསང་བའི་རྩིས་ཐོར་གྱུར་ཡོད།",
    "title-g_bo_481": "2022ལོའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད་སྦྲུམ་རྟེན་བཟོ་བ་དང་། ཟླ་གྲངས་ཚང་བའི་མངལ་སྦྲུམ་པ་བརྒྱུད་རྒྱུད་བཤུས་བ་གླང་8སྐྱེས་ཡོད",
    "title-g_bo_218": "《བོད་ལྗོངས་དབྱངས་སྙན》ཞེས་པའི་གླུ་གར་འཁྲབ་སྟོན་བྱེད་པ།",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཧ་ནོ་དབྱིའི་ཀྲུའུ་ཞིའི་ལས་ཤག་ཏུ་ཝེ་ཐེ་ནམ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་དང་མཇལ་མོལ་གནང་བ་རེད།",
    "title-g_bo_650": "2023ལོའི་ཟླ་9ཚེས་16ཉིན་གྱི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་ས་ནཱ་ཡི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་16ཉིན་གྱི་སྔ་དྲོའི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་ཨ་རིའི་དམག་གིས་ཡེ་མོན་ཧུའུ་སའེ་དྲག་ཤོག་གིས་ཚོད་འཛིན་ཁུལ་ལ་འ",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པ།",
    "title-g_bo_330": "《ཁྲག་རྩའི་ནད་རིགས་སློང་བའི་གནས་ཚུལ་སྐོར་གྱི་བརྡ་ཐོ》སྤེལ་བ།",
    "title-g_bo_244": "གཞིས་རྩེ་གྲོང་ཁྱེར་རྒྱལ་རྩེ་རྫོང་སྤྱི་བདེ་ཅུས་ཉེས་དོན་མྱུལ་ཞིབ་རུ་ཆེན་གྱིས་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པ།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཟླ་11ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་པ་ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་ནས་ཞལ་གྱེས་སྐབས་ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་རྒྱལ་དར་གཡུག་གཡུག་བྱས་ཏེ་ཞི་ཅིན་ཕ�",
    "title-g_bo_737": "2023ལོའི་ཟླ་1ཚེས་18ཉིན་གྱི་ཕྱི་དྲོར་ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་ནང་། སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་རྒྱ་ཆེའི་བཟོ་སྐྲུན་ལག་རྩལ་མི་སྣར་ཐུགས་རེ་ནན་པོ་བཅོལ་གནང་",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་སྐབས་གསུམ་པའི་རྒྱལ་སྤྱིའི་མཉམ་ལས་ཚོགས་འདུ་ཐེངས་དང་པོ་འཚོགས་པ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི(2024)ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཡོ་རོབ་མནའ་འབྲེལ་གྱིས་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བ་འབོར་ཆེན་བསྡུ་ལེན་བྱས་པའི་རྒྱལ་ཁབ་དཔེར་ན། དབྱི་ཐ་ལིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་ཞུགས་རྒྱལ་ཁབ་གཞན་དག་ལ་ནོར་སྲིད་ཀྱི་རོ",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》ཞེས་པའི་རྩོམ་ཡིག་འགྲེམས་སྤེལ་བྱས་པ།",
    "title-g_bo_476": "2023ལོའི་དཔྱིད་འདེབས་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་སྐབས་རེར་མཐོང་ཐུབ་ཀྱི་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་བྱིས་པར་འཐུང་དུ་འཇུག་མི་ཐུབ་པའི་དོན་དག་གཞན་དག་ལ་བརྟག་དཔྱད་བྱེད་དགོས།",
    "title-g_bo_749": "2023ལོའི་ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་རྒྱང་མེ་ཞེས་པའི་མྱ�",
    "title-g_bo_168": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་10པར་གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་དགོས་པའི་གནས་ཚུལ་སྐོར་གྱི་སྙན་ཞུ།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_522": "2021ལོའི་སི་ཁྲོན་ཞིང་ཆེན་དཀར་མཛེས་བོད་རིགས་རང་སྐྱོང་ཁུལ་འདབ་པ་རྫོང་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་གྱི་བྱེས་ལས་ཐེངས་གསུམ་པ་ད་ལྟ་གཞི་རྩའི་ཆ་ནས་མཇུག་འགྲིལ་བ་རེད།",
    "title-g_bo_787": "2023ལོའི་ཟླ་8པའི་ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད་པ་རེད།",
    "title-g_bo_36": "2023ལོའི་ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ་དེ་ནི་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོར་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་མྱུར་བགྲོད་ལྕགས་ལམ་ཐོག་མ་དེ་ཡིན།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ནི་གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་ཡིན་ཞིང་།",
    "title-g_bo_372": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་ཙེ་ལན་སི་ཅིས་ཡུག་རེན་གྱི་རྒྱལ་སྲུང་པུའུ་ཀྲང་ཨའོ་སི་ཐིང་དང་ཐུག་འཕྲད་བྱས་ཏེ། ཕྱོགས་གཉིས་པོས་ཡུག་རེན་གྱི་གནས་བབ་དང་། དམག་དོན་རོགས་སྐྱོར། ཧེ་ཧ",
    "title-g_bo_672": "《དབང་རྩའི་རིག་པ་》ཞེས་པའི་དུས་དེབ་སྟེང་དུ་བཀོད་པའི་ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་། ཁྲག་རིགས་Aཅན་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་ཡིན།",
    "title-g_bo_538": "2024ལོར་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023ལོའི་ཟླ་9ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ལྷོ་རྒྱུད་ཧན་ཡིའུ་ཉི་སི་ས་ཁུལ་དུ་བྱ་སྤྱོད་སྤེལ་ནས། ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ལྷོ་ཧན་ཡི",
    "title-g_bo_222": "2023ལོའི་བོད་ཀྱི་གསོ་རིག་སྨྲ་བའི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་གཅེས་བཏུས་མཚོ་སྔོན་ཞིང་ཆེན་གནའ་དཔེ་མྱུར་སྐྱོབ་རིགས་ཀྱི་དཔེ་སྐྲུན་ལས་གཞིའི་ཁྲོད་ཚུད་དེ་པར་སྐྲུན་འགྲེམ་སྤེལ་བྱེད་པའི་མ",
    "title-g_bo_611": "1953ལོར་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་ལ་སླེབས་པ་ཡིན།",
    "title-g_bo_565": "2022ལོའི་རྒྱལ་ནང་གི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}