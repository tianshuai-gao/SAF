{
    "title-g_bo_923": "ཡུལ་སྐོར་བ་ཅི་ལིན་གྱིས་བོད་ཀྱི་མཛེས་ལྗོངས་མཐོང་བའི་སྐོར།",
    "title-g_bo_752": "ཅེ་པ་ལི་ཡེ་ཡུལ་གྱར་བའི་བསྒར་ས་ལ་དབྱི་སི་རལ་གྱིས་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས།",
    "title-g_bo_589": "ཞི་ཅིན་ཕིང་གིས་ཨ་རིའི་རྒྱལ་ཚོགས་ཀྱི་གྲོས་ཚོགས་སྟོད་པའི་འཐུས་མི་ཚོགས་པాతోམཇལ་འཛོམས་གནང་།",
    "title-g_bo_267": "མ་བུ་གཉིས་ཀྱི་སྙན་པོའི་གླུ་གཞས་དྲ་བའི་ཐོག་ཁྱབ་སྤེལ་བྱུང་།",
    "title-g_bo_139": "ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཀོང་ཏུང་ལ་སྐུལ་འདེད་གཏོང་བ།",
    "title-g_bo_809": "སློབ་གྲྭ་དང་བུ་བཅོལ་ཁང་ལ་ནོ་རོ་ནད་དུག་འགོ་མང་བའི་དུས་ཚིགས་སྔོན་འགོག་བྱེད་དགོས།",
    "title-g_bo_355": "སློབ་ཕྱིའི་གསོ་སྦྱོང་གྲོན་དངུལ་ཕྱིར་སློག་གི་མིང་ཐོག་ནས་གློག་འཕྲིན་དྲ་རྒྱའི་མགོ་སྐོར་ལ་དོགས་ཟོན་བྱེད་དགོས་པ།",
    "title-g_bo_154": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས་འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་མཇུག་འགྲིལ་བསམ་ཡོད།",
    "title-g_bo_221": "ལྗར་ཕན་གྱི་སྤྱི་དམངས་གསང་མྱུལ་བྱེད་པའི་དོགས་གཞི་ཡོད་པས། ཀྲུང་གོས་བཙན་ཐབས་སྤྱད་ཡོད།",
    "title-g_bo_327": "དབྱི་རན་ཁེའར་མན་གྲོང་ཁྱེར་དུ་འབར་གས་ཀྱི་དོན་རྐྱེན་ཐེངས་གཉིས་བསྟུད་མར་ཐོན་ནས་མི་སྣ་ཤི་རྨས་དང་འབྲེལ་བ།",
    "title-g_bo_323": "ཨུ་རུ་སུའི་པེའར་ཀེ་ལུའོ་ཏེ་མངའ་སྡེར་དུ་ཡུག་རེན་གྱི་དམག་སྤྱོད་སྐྱེལ་འདྲེན་གནམ་གྲུ་ལྷུང་བ།",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་གནས་མཆོག་དང་ཡུལ་གོམས་གཤིས་ལུགས།",
    "title-g_bo_276": "ཀྲུང་གོས་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་འགན་བསྟུད་མར་འཁུར་བའི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་དེ་སྤྱི་ལོ་2024ལོ་ནས་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ།",
    "title-g_bo_954": "ཞི་ཅིན་ཕིང་གིས་ནེ་པ་ལར་ས་ཡོམ་དྲག་པོ་བརྒྱབ་པའི་ཐད་ལ་འཚམས་འདྲི་བཏང་གནང་།",
    "title-g_bo_962": "དཔྱིད་གསར་དུས་ཆེན་སྐབས་ཀྱི་པ་སེ་འཚོང་གི་གསར་གཏོད།",
    "title-g_bo_200": "མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ་“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ།",
    "title-g_bo_210": "འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གི་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ།",
    "title-g_bo_299": "ཞི་ཅིན་ཕིང་གིས་ཧྥེ་ཁྲེང་མཉམ་སྒྲོག་རོལ་དབྱངས་ཚོགས་པར་འཕྲིན་ལན་སྤྲིངས་གནང་།",
    "title-g_bo_527": "ཀྲུང་དབྱང་ཨུ་ཡོན་ལྷན་ཁང་གི་ཀྲུའུ་ཞི་བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་སྐུ་གཤེགས་པ།",
    "title-g_bo_726": "ཡང་སྣུམ་རིན་དང་གསེར་གོང་འཕར་འདུག་ཟེར་བ་བདེན་པའི།",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ལས་མི་སྟོང་འབུམ་ལྷག་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_706": "གཟུགས་པོར་དགོས་པའི་རྒྱུ་ཆོས་མི་འདང་བའི་འགྱུར་འགྲོ་དང་སྲུང་སྐྱོབ་བྱེད་ཚུལ།",
    "title-g_bo_681": "བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་སྲུང་སྐྱོབ་ཀྱི་མཛུབ་སྒྲིབ་",
