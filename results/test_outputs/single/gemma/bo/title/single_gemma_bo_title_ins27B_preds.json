    "title-g_bo_16": "ལོ་གསར་བསུ་བའི་སྐབས་དར་ཤིང་གཅོད་པའི་སྲོལ་ལ་འགྱུར་ལྡོག་གཏོང་རྒྱུ།",
    "title-g_bo_844": "འགྲིམ་འགྲུལ་ཆག་སྒོ་བསླངས་པའི་རིན་ཆེ་གེ་མོ་ལ་ཉེས་ཆད་གཏོང་བ།",
    "title-g_bo_12": "སློབ་མ་ཚོས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པར་པེ་ཅིང་གྲོང་ཁྱེར་སློབ་གསོ་ཨུ་ལྷན་གྱིས་བརྡ་ཐོ་བཏང་།",
    "title-g_bo_577": "ཨུ་རུ་སུའི་དམག་འཁྲུག་གིས་ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་བསྐྱེད་པ།",
    "title-g_bo_474": "ཟླ་11ཚེས་7ཉིན་སྣུམ་གོང་ལེགས་སྒྲིག་འགོ་འཛུགས་རྒྱུ་ཡིན།",
    "title-g_bo_140": "རྒྱ་གར་དམག་མི་ངོ་ལོག་ཟིང་འཁྲུག་པར་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_831": "ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གིས་འགྲན་རྒོལ་བྱས་པའི་གནས་ཚུལ།",
    "title-g_bo_933": "ཉིང་ཁྲི་གྲོང་ཁྱེར་གྱི་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཀྱི་དྲ་རྒྱའི་ཉེས་གསོག་ལ་བརྟག་དཔྱད་བྱེད་འདུག",
    "title-g_bo_696": "ཀྲུང་གོས་དར་གོས་ལམ་བུའི་མཉམ་ལས་སྔོན་བསྐྱོད་ལག་བསྟར་ཁུལ་གཏོད་རྒྱུ།",
    "title-g_bo_675": "སློབ་ཕྱིའི་ལུས་སྦྱོང་ཐད་བྱ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་འཐབ་རྩོད་ལས་མི་15546རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_65": "ཞི་ཅིན་ཕིང་གིས་ཏེན་མག་གི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པར་གློག་འཕྲིན་བཏང་།",
    "title-g_bo_214": "ཨ་རིས་དབྱི་སི་རལ་ལ་ཕྱོགས་ཞེན་བྱེད་པས་ཀ་ཧྲ་ས་ཁུལ་དུ་དམག་མཚམས་འཇོག་རྒྱུའི་དོགས་པ་སྐྱེས།",
    "title-g_bo_79": "གྲོང་ཁྱེར་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་གཏོང་བའི་སྐོར་",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་འཛམ་གླིང་ཚོང་དོན་རྩ་འཛུགས་ལ་ཕོ་ལན་དང་རྒྱལ་ཁབ་གཞན་དག་གི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་ཞུ་གཏུག་བྱས།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ལ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_318": "ཨུ་རུ་སུས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད།",
    "title-g_bo_856": "རྒྱ་མཚོའི་དྲོད་ཚད་མཐོ་རུ་སོང་བས་ཨ་རིའི་ཁ་བའི་སྡིག་སྲིན་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཤི་གི་ཡོད།",
    "title-g_bo_292": "ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ལ་ཐོངས་མཆན་བྱས་པར་ངོ་རྒོལ་གཏོང་བ།",
    "title-g_bo_0": "རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་དང་ལྷོ་ཁོ་རེ་ཡ་གསུམ་གྱིས་མཉམ་འབྲེལ་ནང་སྦྱོང་བྱས།",
    "title-g_bo_713": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི《ལས་དབང་གཅིག་མཐུན་མ་ལག་བསྐྲུན་》གྱི་འགོ་རྩོམ་དགོས་",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས།",
    "title-g_bo_180": "འཕྲིན་ཡིག་གིས་བསྐྱར་བཅོས་བྱས་པའི་མཛའ་བཤེས་",
    "title-g_bo_638": "མཚོ་སྔོན་ཞིང་ཆེན་གྱི་དབྱར་རྩྭ་དགུན་འབུ་ཕྱིར་གཏོང་བྱེད་ཚད་འཕར་འགྲོ་འདུག",
    "title-g_bo_626": "ཨུ་རུ་སུས་ཡུག་རེན་གྱི་མི་མེད་གནམ་གྲུ་གཏོར་ལྷུངས་བཏང་།",
    "title-g_bo_319": "2023ལོར་རྒྱལ་ཡོངས་ཀྱི་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡ་དང་དབྱི་སི་རལ་གྱི་འབྲེལ་བ་བརྡ་ཁྱབ་བྱུང་།",
    "title-g_bo_656": "ཀན་ལྷོ་ཁུལ་ལོ་སར་སྤྲོ་ཚོགས་༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
    "title-g_bo_185": "ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་ཕྲུག་ལོག་གི་འགག་རིམ་བརྗོད་པ།",
    "title-g_bo_884": "པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་ 5200 ཟིན་པ།",
    "title-g_bo_82": "ཞི་ཅིན་ཕིང་གིས་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་།",
    "title-g_bo_199": "ཞི་ཅིན་ཕིང་གིས་ཁོ་ལོམ་པི་ཡའི་ཙུང་ཐུང་ཕེ་ཐེ་ལུའོ་དང་མཇལ་མོལ་གནང་།",
    "title-g_bo_165": "ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འཕར་སྣོན་ལ་སྐུལ་འདེད་གཏོང་།",
    "title-g_bo_275": "མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱིས་“གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས”འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས།",
    "title-g_bo_900": "ཤིན་ཅང་གི་གནམ་མཁའི་སྣེ་འོད་མཇལ་བ།",
    "title-g_bo_550": "ཀྲུང་གོས་ཐའེ་ཝན་གྱི་གནད་དོན་ལ་དཔྱད་གཏམ་སྤེལ་བར་འོས་བཅས།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་གྲོང་མཐའ་སྐོར་བྱས་འདུག",
    "title-g_bo_578": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་ལ་འཇབ་རྒོལ་བྱས་པས། མི་190རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_722": "ཞི་ཅིན་ཕིང་གིས་ཙུང་ཐུང་ལ་བདམས་ཐོན་བྱུང་བར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་གནང་།",
    "title-g_bo_235": "ཧྲ་ཅོན་གྱིས་ཕ་རི་སིའི་འགྲེམས་སྟོན་ཐོག་རྒྱལ་རྩེའི་སྣམ་བུའི་ལག་ཤེས་འགྲེམས་སྟོན་བྱས།",
    "title-g_bo_277": "བོད་ལྗོངས་བྱིས་པའི་ལྷན་སྐྱེས་སྙིང་ནད་བརྟག་དཔྱད་བྱེད་སྒོ་སྤེལ་བ།",
    "title-g_bo_918": "ཀྲུང་གོ་རིག་པའི་ཞིབ་འཇུག་གི་དོན་སྙིང་གལ་ཆེན་རྒྱས་བཤད་གནང་།",
    "title-g_bo_451": "ཅང་ཞི་ཞིང་ཆེན་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་འབྲུ་རིགས་འདེབས་མཁན་གྱིས་ལོ་མཇུག་གི་བྱ་དགའ་སྤྲད།",
    "title-g_bo_997": "ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་ཧོ་ལ་ཐེ་མངའ་སྡེར་ས་ཡོམ་གྱིས་གནོད་འཚེ་ཆེན་པོ་བཟས་འདུག",
    "title-g_bo_544": "ཀྲུང་གོས་གཤོག་ཟུང་ལྡན་མི་མེད་གནམ་གྲུ་གསར་པ་འཕུར་འབབ་བྱུང་།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ཀྱི་གཅོང་ནད་འགོག་བཅོས་དང་སྦྱོང་བརྡར་ཇི་ལྟར་བྱེད་དགོས་",
    "title-g_bo_847": "ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་གིས་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ལ་ཞུགས་རྒྱུ།",
    "title-g_bo_92": "ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གི་ལོ་གསར་ཤིས་ཚིག་ལ་དམག་དཔུང་གིས་ལན་ཆ་ཡག་པོ་བྱས།",
    "title-g_bo_1": "སྐབས་དྲུག་པའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་དམག་འཐབ་ཁྲོད་མི་སྣ་མང་པོ་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_830": "ཧྥི་ལི་ཕིན་གྱིས་ཀྲུང་གོའི་མཚོ་ཁོངས་སུ་འཛུལ་འདུག་བྱས་པར་ངོ་རྒོལ་བྱས་སོང་།",
    "title-g_bo_90": "བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་ཆེད་མཁས་ལས་དོན་གྲོས་ཚོགས་དྲ་ཐོག་འཚོགས།",
    "title-g_bo_826": "དབྱི་སི་རལ་རྒྱལ་སྲུང་དམག་གིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "རྩལ་ནུས་ཤེས་ལྡན་མི་སྣའི་དགོས་མཁོ་ཇེ་ཆེར་གྱུར།",
    "title-g_bo_285": "མཇིང་ཚིགས་ནད་རྟགས་སུ་གྱུར་པའི་འགུལ་སྟངས་བཤད་པ།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ལ་ཉོབ་མདངས་སེལ་དགོས་ན་ཇི་འདྲ་བྱེད་དགོས་།",
    "title-g_bo_337": "ཀྲུང་འབྲུག་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་འདུག",
    "title-g_bo_405": "བོད་སྐད་སྒྱུར་བཟོའི་ལས་དོན་ལ་ཤུགས་སྔར་བས་ཆེ་རུ་གཏོང་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་ཏུ་“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་སྐོར།",
    "title-g_bo_982": "ལྷོ་རྒྱ་མཚོའི་ཟིང་ཆ་ལངས་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་བདེ་འཇགས་ཀྱི་སྒྲིག་འགོད་གཉིས།",
    "title-g_bo_563": "སི་ཁྲོན་ཁྲེང་ཏུའུ་ཐའེ་ཀུའུ་ལིར་མིག་ཤེལ་མི་དགོས་པའི་3Dབརྙན་ཡོལ་བསྟན་པ།",
    "title-g_bo_759": "རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་འཚོགས་པ།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་སུ་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་ཀྱི་གནས་ཚུལ།",
    "title-g_bo_932": "ཨ་རི་དང་དབྱིན་ཇིས་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས།",
    "title-g_bo_110": "ཞི་ཅིན་ཕིང་གིས་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ལ་སྐུལ་འདེམས་གནང་།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡའི་འབྲེལ་བ་གསར་བརྗེས་པ།",
    "title-g_bo_822": "ཉི་མ་བཀྲ་ཤིས་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས།",
    "title-g_bo_604": "པེ་ཅིང་དུ་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་སྐོང་འཚོགས་བྱུང་།",
    "title-g_bo_529": "བྱིས་པའི་གློ་ཚད་འབྱུང་བཞིན་པ།",
    "title-g_bo_38": "དབྱི་སི་རལ་རྒྱལ་སྲུང་དམག་གིས་ཧན་ཡིའུ་ཉི་སིའི་ནུབ་རྒྱུད་དུ་འཇབ་རྒོལ་བྱས།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་དུ་མེ་འཁོར་ཆག་སྒོ་བྱུང་།",
    "title-g_bo_287": "ཨུ་རུ་སུའི་རྒྱལ་ཁ་ཐོབ་ན་བྱང་ཆིངས་རྩ་འཛུགས་ཀྱི་བདེ་འཇགས་ལ་ཤུགས་རྐྱེན་ཐེབས་སྲིད།",
    "title-g_bo_394": "2023ལོར་བོད་ལྗོངས་ཀྱི་དཔལ་འབྱོར་གོང་འཕེལ་རྒྱུན་མཐུད་ཡག་པོ་བྱུང་།",
    "title-g_bo_901": "ཞི་ཅིན་ཕིང་གིས་ཁ་ར་ཀྭའི་ཙུང་ཐུང་ཨོའར་ཐེ་ཀ་དང་ཞལ་པར་བསྐྱོན་གནང་།",
    "title-g_bo_342": "ཨ་རིས་དབྱི་རན་ལ་འཇིགས་སྣང་བསྐུལ་བའི་དམག་གྲུ་བཀོད་སྒྲིག་བྱས་འདུག",
    "title-g_bo_629": "2025ལོར་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་འབོར་ཆེན་ཐོན་སྐྱེད་བྱ་རྒྱུ་རེད།",
    "title-g_bo_259": "བོད་ལྗོངས་སློབ་མས་ཀྲུང་གོའི་བྱིས་པའི་ཟློས་གར་གྱི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་མཚན་སྙན་ཐོབ།",
    "title-g_bo_685": "ལི་པི་ཡའི་ཆུ་ལོག་གིས་མི་སྟོང་ཕྲག་མང་འགོག་པོར་གྱུར་ཡོད།",
    "title-g_bo_978": "ཀྲུང་གུང་ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་ཀྱི་ཨུ་ཡོན་ཕྱི་འབྲེལ་པུའུ་ཝང་དབྱི་ཡིས་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས།",
    "title-g_bo_50": "ཞི་ཅིན་ཕིང་གིས་“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་།",
    "title-g_bo_769": "ཧ་མ་སི་དང་དབྱི་སི་རལ་གྱིས་དམག་མཚམས་འཇོག་པའི་གྲོས་ཆོད་ཉིན་གཉིས་ནར་འགྱངས་གཏོང་།",
    "title-g_bo_582": "རིན་མེད་སྐུད་མེད་དྲ་བ་བཙལ་བའི་སྐབས་བདེ་འཇགས་ཀྱི་ཉེན་ཁ་མི་ཉུང་བ།",
    "title-g_bo_635": "ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་མི་མང་པོ་ཁ་བསླུས་ཐེབས་འདུག",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་བས་བུ་མོ་ཞིག་བསད་པའི་གནས་ཚུལ།",
    "title-g_bo_167": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་སྐབས་དོ་སྣང་གནང་དགོས་པའི་གནས་ཚུལ།",
    "title-g_bo_283": "ལྷ་ས་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རན་གྱི་སྒྲིག་བཀོད་ལ་རྡུང་རྡེག་བཏང་།",
    "title-g_bo_872": "འབའ་ཐང་རྫོང་གི་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ལེགས་གྲུབ་དང་བྱ་དགའ་ཐོབ་པར་གཟེངས་བསྟོད་སྤྲོད་པ།",
    "title-g_bo_247": "ཞི་ཅིན་ཕིང་གིས་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་ལྷན་ཁང་དབུ་བརྙེས་ལོ་50འཁོར་བར་ཤིས་འཕྲིན་སྤྲིངས་གནང་།",
    "title-g_bo_575": "ཡར་ཀླུང་གཙང་པོའི་སྐྱེ་དངོས་རང་བཞིན་བརྟག་དཔྱད་ཀྱི་གྲུབ་འབྲས་ཐོབ་ཡོད།",
    "title-g_bo_417": "ཀ་ཧྲ་ས་ཁུལ་གྱི་འཕྲོད་བསྟེན་ཚན་པའི་ཉམས་ཆག་གི་གནས་ཚུལ་གསར་ཤོད།",
    "title-g_bo_484": "སློབ་ཆེན་ལ་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་གསར་པ་",
    "title-g_bo_249": "ཞི་ཅིན་ཕིང་གིས་མ་ལེ་ཞི་ཡའི་གཙོ་འཛིན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས།",
    "title-g_bo_380": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གདོང་ཐུག་འབྱུང་བས་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་དང་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེ་གྲོས་མོལ་བྱས།",
    "title-g_bo_959": "ཨ་ཧྥེ་རི་ཁའི་མིག་ནད་བཅོས་པའི་ཀྲུང་གོའི་སྨན་པ།",
    "title-g_bo_976": "སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར།",
    "title-g_bo_97": "ལྗར་ཕན་དུ་ལོ་65ཡན་གྱི་རྒན་རྒོན་མི་འབོར་རྒྱལ་ཁབ་དེའི་ལོ་རྒྱུས་སུ་ཨང་དང་པོར་སླེབས།",
    "title-g_bo_309": "ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "རུས་ཚིགས་སྲུང་སྐྱོབ་བྱེད་དགོས་པའི་གནད་དུ་གཉིས་",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན་གྱིས་གྲོང་མི་ལ་བརྡ་སྤྲོད་བྱས་པ།",
    "title-g_bo_56": "ཏེང་གེ་ཚ་ནད་འགོས་པའི་སྔོན་འགོག་ལ་ཆེད་མཁས་པས་དྲན་སྐུལ་བྱས།",
    "title-g_bo_973": "ཅུས་ཀྲང་གཞོན་པ་དབང་ཆེན་གྱིས་སྒྲིག་འགལ་ཁྲིམས་འགལ་བྱས་པའི་གནད་དོན་ཞིབ་བཤེར་བྱས།",
    "title-g_bo_294": "བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་དེ་བལྟས་པས། ཡིད་རྟོན་དང་འགུག་སེམས་གཉིས་ཀ་འཁྲུངས་སོང་།",
    "title-g_bo_689": "སློབ་མ་ཚོར་དོན་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས་པའི་དྲན་སྐུལ་",
    "title-g_bo_551": "ཞི་ཅིན་ཕིང་གིས་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉི་དང་མཇལ་འཛོམས་གནང་།",
    "title-g_bo_857": "བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་དཔེ་སྐྲུན་བྱས་འགྲེམས་སྤེལ།",
    "title-g_bo_146": "ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་མོ་ཞི་ཁོའི་ཙུང་ཐུང་ལུའོ་ཕེ་སི་དང་མཇལ་འཛོམས་གནང་།",
    "title-g_bo_351": "རྒྱལ་སྲིད་ཀྱིས་དཔལ་འབྱོར་འཕར་སྣོན་ལ་སྐུལ་ཁྲིད་བྱས་པས་འཕེལ་ཕྱོགས་བརྟན་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_182": "ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་“དཔའ་བོ་”ལིན་ཧའོ་གཉེན་སྒྲིག་བྱུང་།",
    "title-g_bo_980": "ལྗར་པན་གྱི་ཆུ་ཐོན་དངོས་རྫས་ནང་འདྲེན་བྱེད་མཚམས་འཇོག་རྒྱུ།",
    "title-g_bo_771": "གངས་རིན་པོ་ཆེ་དང་མ་ཕམ་གཡུ་མཚོའི་མཛེས་ལྗོངས་ཁུལ་དུ་དགུན་དུས་ལས་མཚམས་འཇོག་པ།",
    "title-g_bo_225": "ལེགས་རྩེ་འགག་སྒོ་འབྱེད་སྒོ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པར་སླེབས།",
    "title-g_bo_131": "སྟོན་འབྲུ་འབབ་འཕར་དང་ཞིང་ལས་གོང་འཕེལ་གྱི་འགྲོ་ལམ་གསར་པ།",
    "title-g_bo_739": "དབྱི་སི་རལ་གྱི་མི་གྲངས་མང་པོ་འཇབ་རྒོལ་ལ་རྐྱེན་ལམ་དུ་བཏང་།",
    "title-g_bo_190": "བོད་ལྗོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ལོ་6རིང་ཏུན་ཁྲི་100ཡན་རྒྱུན་འཁྱོངས་བྱུང་།",
    "title-g_bo_553": "བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་བཏང་བ་དང་“བོད་གློག་ཕྱིར་སྐྱེལ”ལ་ཕན་ཐོགས་ཡོད་པ།",
    "title-g_bo_519": "ཁ་རས་རྒྱག་སྐབས་མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་བ་སྔོན་འགོག་ཐབས་",
    "title-g_bo_141": "བོད་ལྗོངས་ཀྱིས་མི་རིགས་མཐུན་སྒྲིལ་ཡར་ཐོན་ལ་བརྩོན་ལེན་བྱེད་འདུག",
    "title-g_bo_886": "དབྱི་སི་རལ་དམག་དཔུང་གིས་ཧ་མ་སིའི་ས་ཁུལ་དུ་དམག་དོན་བྱ་སྤྱོད་སྤེལ།",
    "title-g_bo_688": "ཞི་ཅིན་ཕིང་གིས་ཧྥ་རན་སེའི་ཙུང་ཐུང་མ་ཁེ་ལུང་དང་ཞལ་པར་བསྐྱོན་པ།",
    "title-g_bo_586": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་རྒྱུད་ལ་འཇབ་རྒོལ་བྱས་པས། མི་51རྐྱེན་ལམ་དུ་བཏང་།",
    "title-g_bo_990": "ཞི་ཅིན་ཕིང་གིས་ཤིང་འབྲུག་ལོའི་དཔྱིད་གསར་དུས་ཆེན་ལ་བསུ་བ་ཞུས།",
    "title-g_bo_838": "བོད་ལྗོངས་ཀྱིས་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་ལ་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་དུ་ཐོབ་པ།",
    "title-g_bo_491": "ཀྲུང་དབྱང་གིས་ཞི་ཅིན་ཕིང་གི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་གཏིང་ཟབ་བྱེད་པའི་སྐོར་གྲོས་ཞིབ་བྱས།",
    "title-g_bo_60": "ཞི་ཅིན་ཕིང་པེ་ཅིང་དང་ཧོ་པེ་གནོད་འཚེ་ཕོག་ཁུལ་ལ་ཕེབས་ཤིང་མང་ཚོགས་ལ་འཚམས་འདྲི་གནང་།",
    "title-g_bo_223": "རུས་ཚིགས་སྲུང་སྐྱོབ་བྱེད་དགོས་པའི་གནད་དུ་གཉིས་",
    "title-g_bo_96": "ལིའོ་རྨིན་གྱི་སྒྲིག་འགལ་ཁྲིམས་འགལ་ཚབས་ཆེན་བྱས་པའི་དོགས་གཞི་ཡོད་པས།",
    "title-g_bo_312": "དབྱི་རག་གིས་ཨ་རིས་གཙོ་ཁྲིད་བྱས་པའི་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི། དུས་བཀག་ངེས་གཏན་འཁེལ་མེད།",
    "title-g_bo_176": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་གི་བར་སྐོར་གསར་པ་དང་མི་སྟོང་ཕྲག་མང་པོ་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_145": "བོད་ལྗོངས་མཛེས་རྩལ་ཁང་སྒོ་འབྱེད་བྱུང་།",
    "title-g_bo_500": "ཅ་ཧྲའི་མི་ཆོས་རིང་ལུགས་དུས་བབ་སྐོར་ལ་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱིས་ཚོགས་འདུ་འཚོགས།",
    "title-g_bo_414": "པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "ཞི་ཅིན་ཕིང་གིས་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ལ་འགོ་ཁྲིད་བྱེད་པའི་སྐོར་གླེང་མོལ་གནང་།",
    "title-g_bo_607": "ཚིལ་ཞག་ལྡོག་མའི་གནོད་འཚེ་དང་སྲུང་སྐྱོབ་ཐབས།",
    "title-g_bo_174": "ཞི་ཅིན་ཕིང་གིས་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་ལ་མཇལ་འཛོམས་གནང་།",
    "title-g_bo_619": "ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གིས་ཚེ་ཚད་རིང་དུ་གཏོང་བའི་ཐབས་བསྟན།",
    "title-g_bo_668": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་རྒྱུད་ལ་མུ་མཐུད་དམག་དོན་རྡུང་རྡེག་བཏང་།",
    "title-g_bo_708": "དྲ་དཔོན་ཞིག་གིས་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་པའི་སྐོར།",
    "title-g_bo_481": "མཚོ་བོད་ས་མཐོར་གྱི་བ་གླང་རྒྱུད་བཤུས་བྱེད་ཐེངས་ཐོག་མ་འགྲུབ་འདུག",
    "title-g_bo_218": "སི་རི་ལན་ཁའི་གར་སྟེགས་སུ་བོད་ལྗོངས་ཀྱི་རིག་གནས་སྟོན་མོ་བཤམས།",
    "title-g_bo_818": "ཞི་ཅིན་ཕིང་གིས་ཝེ་ཐེ་ནམ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་དང་མཇལ་མོལ་གནང་།",
    "title-g_bo_650": "ཨ་རི་དང་ཧུའུ་སའེ་དྲག་ཤོག་གིས་རྒྱ་མཚོ་དམར་པོའི་ཁོངས་སུ་འཇབ་རྒོལ་བྱས།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས།",
    "title-g_bo_330": "ཁྲག་རྡོ་ནད་ཀྱི་གནོད་འཚེ་དང་སྔོན་འགོག་ཐབས་",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་ལོ་རྒྱུས་དང་བཟོ་རྩལ།",
    "title-g_bo_560": "ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་པེ་ཅིང་དུ་ཕྱིར་ལོག་གནང་།",
    "title-g_bo_737": "རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས་",
    "title-g_bo_564": "ཞི་ཅིན་ཕིང་གིས་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་།",
    "title-g_bo_746": "ཨ་མདོ་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱིས་ཡོ་རོབ་ཀྱི་གནས་སྤོས་ཡུལ་མི་ལ་ངོ་རྒོལ་བྱས་པ།",
