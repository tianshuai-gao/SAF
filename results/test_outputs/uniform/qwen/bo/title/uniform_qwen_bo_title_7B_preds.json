    "title-g_bo_726": "ཨ་རིའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་གྱི་སྔོན་དཔག་སྤྱིའི་ཆ་ནས་ཆག་པ་དང་། ཨ་རིའི་ཉིའུ་ཡོག་རྒྱལ་ཕྲན་མཉམ་འབྲེལ་གསོག་འཇོག་དངུལ་ཁང་གིས་རེས་གཟའ་ཟླ་བའི་ཉིན་ཁྱབ་བསྒྲགས་བྱས་པའི་བརྟག་དཔྱད་སྙན་ཞ�",
    "title-g_bo_188": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་ཀ་ཧྲ་ས་ཁུལ་དུ་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་ཕོག་པའི་ཁྲོད་བྱིས་པ་བསླུ་འཚོང་བྱས་པ།",
    "title-g_bo_706": "གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ།",
    "title-g_bo_681": "2020ལོའི་བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "ཨ་རིའི་CSXསྐྱེལ་འདྲེན་ཀུང་སིས་ཁེན་ཐ་ཅི་མངའ་སྡེའི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་14དང་སྐར་མ་30ཙམ་ལ་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་ཞིག་ཐོན་པ་དང་།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱི་ཕྱི་ཚུལ་རིང་ལུཊ་དང་དཔོན་ཉམས་རིང་ལུཊ་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ས་ཡོམ་གྱི་ཉེན་ཁ་ཆེ་རུ་ཕྱིན་ཡོད།",
    "title-g_bo_16": "དར་ཤིང་ལས་འཕྲོས་པའི་འབྱུང་ཁམས་སྲུང་སྐྱོང་གི་ཕུགས་འདུན།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་བོད་ལྗོངས་གཞིས་རྩེ་བཞད་མཐོང་སྨོན་རྫོང་མི་དམངས་ཁྲིམས་ཁང་གིས་རིན་ཆེ་གེ་མོས་ཆག་སྒོ་བསླངས་པའི་གྱོད་དོན་ལ་ཡོངས་བསྒྲགས་ཐོག་འདྲི་གཅོད་དང་པོ་བྱས་པ་བརྒྱུད་ཁྲིམས་ལྟར་�",
    "title-g_bo_12": "སློབ་མ་ཚོས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པའི་བརྗོད་གཞི་དེར་མི་མང་པོས་དོ་ཁུར་དང་གྲོས་བསྡུར་མང་པོ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_577": "ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་ཇི་ལྟར་ཐོབ་པ་བྱེད་པའི་དོན་དངོས་ཐེར་འདོན་བྱས་པ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་རེད། རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་ནས་གནས་འཕྲིན་སྤེལ་བར་གཞིགས་ན།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཤིག་གིས་དེ་ཉིན་རྩོད་གཞི་ཡོད་པའི་ཀ་ཤི་སྨིར་ས་ཁུལ་དུ་རྒྱ་གར་གྱི་དམག་མི་ལྔས་ངོ་ལོག་ཟིང་འཁྲུག་པ་དང་འཐབ་འཁྲུག་བྱས་ཏེ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད་ཅེས་བཤད་འདུག",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་དམག་གཉིས་ཀྱི་བར་དུ་ཡང་གྲི་འཕྱར་ཞིང་གཞུ་འཐེན་པ་ལྟ་བུའི་འགྲན་རྒོལ་རྣམ་པར་གནས་ཡོད།",
    "title-g_bo_933": "ཉིང་ཁྲི་གྲོང་ཁྱེར་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ཀྱི་འབྲེལ་ཡོད་འགན་འཁུར་བས་ངོ་སྤྲོད་བྱས་དོན།",
    "title-g_bo_696": "2022ལོའི་མི་རིགས་ཀྱི་སྤྱི་ཚོགས་དེ་གྲངས་འཛིན་ཅན་དང་དྲ་སྦྲེལ་ཅན་བཅས་ཁྱད་ཆོས་སུ་བྱས་པའི་བཟོ་ལས་གསར་བརྗེའི་རླབས་རྒྱུན་ཐེངས་བཞི་པ་བརྒྱུད་བཞིན་ཡོད།",
    "title-g_bo_675": "སློབ་གསོ་པུས་སློབ་ཕྱིའི་ལུས་སྦྱོང་ཐད་བྱ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོའི་མི་ཉུང་མཐར་ཡང་ཁྲིམས་ཁང་གི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན།",
    "title-g_bo_65": "2023ལོའི་ཟླ་10ཚེས་14ཉིན་ཀྲུང་གོ་དང་ཏེན་མག་གི་འབྲེལ་བ་འཕེལ་རྒྱས་གཏོང་རྒྱུར་ཚད་མཐོའི་མཐོང་ཆེན་བྱེད་ཀྱི་ཡོད་པ་དང་། རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་",
    "title-g_bo_214": "ཨ་རིས་ཕ་དབྱི་གདོང་ཐུག་གི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ་",
    "title-g_bo_761": "18ཚེས་གཉིས་ཉིན་ཡུག་རེན་གྱི་ཕྱོགས་ཀྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་ཡོད།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གི་དྲག་ཇུས་དམག་དཔོན་གྱིས་ཀ་ཧྲ་ལ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲོད་པའི་ཁྲིམས་གཞི་ལ་གྲོས་འཆམ་བྱུང་བ།",
    "title-g_bo_856": "ཨ་རིའི་ཨ་ལ་སི་ཅ་མངའ་སྡེའི་ཉེ་འགྲམ་གྱི་མཚོ་ཁོངས་ནས་ཁ་བའི་སྡིག་སྲིན་དུང་ཕྱུར་བཅུ་ཕྲག་ཁ་ཤས་མེད་པར་གྱུར་ཅིང་།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་23ཉིན་ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་གསར་འགོད་པའི་རྒྱུན་ལྡན་གྱི་ཚོགས་འདུ་གཙོ་སྐྱོང་བྱས་པ་རེད།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་གྱི་ཐོངས་མཆན་ཞབས་ཞུ་གནས་སྐབས་མཚམས་བཞག་པ་དང་རྗེས་མཐུད་ཀྱི་གནས་ཚུལ་ལ་བརྡ་ཐོ་གཏོང་རྒྱུར་སྒུག་ཡོད།",
    "title-g_bo_802": "ལྷོ་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པའི་བྱ་སྤྱོད་དང་ཕྱོགས་གཉིས་པོའི་མཐའ་མཚམས་སོ་ལྟ་ཁང་ལ་དོན་མེད་དུ་ཚུར་རྒོལ་བྱས་པའི་བྱ་སྤྱོད་བཤད་པ།",
    "title-g_bo_180": "1995ལོ་ནས་བཟུང་ཁྲུང་ཆིང་གིས་ཆབ་མདོ་གྲོང་ཁྱེར་དང་དེའི་ཁོངས་གཏོགས་ཀྱི་སྨར་ཁམས་རྫོང་དང་རི་བོ་ཆེ་རྫོང་། བྲག་གཡབ་རྫོང་བཅས་ལ་ཁ་གཏད་རོགས་སྐྱོར་བྱེད་པའི་ལས་འགན་སྔ་རྗེས་སུ་འཁུར་འགོ་ཚུགས་པ་རེད།",
    "title-g_bo_638": "ཟི་ལིང་འགག་སྒོ་ལས་ཁུངས་ཀྱིས་དབྱར་རྩྭ་དགུན་འབུ་ཕྱིར་གཏོང་བྱེད་ཚད་མི་དམངས་ཤོག་སྒོར་དུང་ཕྱུར་གྱི་བརྒྱ་ཆ་བཞི་བཅུ་ལྷག་ཟིན་པ་དང་།",
    "title-g_bo_626": "ཡུག་རེན་དམག་གིས་ཨུ་རུ་སུའི་དམག་ཕམ་ཉེས་གཏོང་རྩིས་བྱེད་བཞིན་པའི་གནས་ཚུལ།",
    "title-g_bo_319": "2023ལོར་རང་རྒྱལ་གྱིས་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྲོམ་ར་ཅན་གྱི་ཉོ་སྒྲུབ་དང་སྲིད་ཇུས་རང་བཞིན་གྱི་ཉོ་སྒྲུབ་ལ་གཅིག་གྱུར་འཆར་འགོད་ངང་དམ་འཛིན་ཡག་པོ་བྱས་ཏེ། བྱེད་པོ་སྣ་མང་ཁྲ�",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད་དམ།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡའི་ཕྱི་འབྲེལ་པུའི་པུའུ་ཀྲང་གཞོན་པ་ཧྥུའུ་ལའེ་ཏི•མ་མཱ་ཉིས་ཀྱི་དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།",
    "title-g_bo_185": "2023ལོའི་ལོ་སྤྱི་ཟླ5པ་ནས7པའི་བར་མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན། བོད་བྱང་ཐང་བཅས་ཀྱི་གཙོད་མོ་ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་གནས་མཚེའུ་ཉེ་འགྲམ་དུ་གནས་སྤོ་བྱེད་ཅིང་།",
    "title-g_bo_884": "པའེ་ཏེང་གི་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་ 5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བར་རིམ་པ་སྤོར་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ་རེད།",
    "title-g_bo_165": "ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་བའི་སྟེང་།",
    "title-g_bo_275": "2017ལོའི་ཕུང་རུས་དེ་གཉིས་ཀྱི་མགོ་བོ་ཕྲ་ཞིང་རིང་ལ་ལག་པ་རེར་མཛུབ་མོ་གསུམ་རེ་ཡོད་པའི་བྱ་སྤྱོད་ཀྱི་འབྲེལ་བ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས་པ་རེད།",
    "title-g_bo_900": "2023ལོའི་ཚེས་24ཉིན་ཚན་རིག་ཁྱབ་སྤེལ་བྱེད་མཁན་དྲ་གྲོགས་@Jeffཡི་སྐར་ཚོགས་བཀྲ་བའི་གནམ་མཁའི་འགྲུལ་བཞུད་ཅེས་པས་ཤིན་ཅང་ནས་ལྟ་ན་སྡུག་པའི་གླིང་སྣེའི་འོད་ཟེར་བརྙན་དུ་བླངས་ཡོད་པ་རེད།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་ལ་གཏིང་ཟབ་ཏུ་བཏང་བས་འབྱུང་འགྱུར་ཀྲུང་ཨུ་དང་ཨ་རིའི་བར་གྱི་འགལ་ཟླ་ཆེ་རུ་འགྲོ་རྒྱུ་རེད།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གི་མི་བཟོས་དུ་ཞག་དབྱུག་ནས་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ལ་འགེབས་སྲུང་བྱེད་པ་མ་ཟད།",
    "title-g_bo_578": "2023ལོའི་དབྱི་སི་རལ་དམག་ཕྱོགས་ཀྱི་ཚེས་22ཉིན་གྱི་ས་སྲིབ་མཚམས་སུ་དམག་འཁྲུག་གནས་ཚུལ་བརྡ་ཁྱབ་བཏང་ནས།",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཨན་ཏེ་ལི་·ཉི་ལི་ནཱ་·ལ་ཆའོ་ལི་ནཱ་ལ་གློག་འཕྲིན་བཏང་གནང་ནས་ཁོང་མ་ཏ་ཀ་སི་ཁར་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་ལ་སླར་ཡང་བདམས་ཐོན་བྱུང་ནས་འགན་གནས་བསྟུད་འཛིན་གནང་བར་བཀྲ་ཤིས་བདེ་ལ�",
    "title-g_bo_235": "རང་བདག་རྩེར་སོན་སྒྱུ་རྩལ་གྱི་ཁུ་ལུའི་སྤུས་རྟགས་ཧྲ་ཅོན་གསར་གཏོད་བྱེད་མཁན་ཀུའོ་ཤིའུ་ལིང་གི་འགྲེམས་སྟོན་ཆེད་ཕ་རི་སིར་སྐྱོད་མཁན་རྒྱལ་རྩེའི་ལག་ཤེས་པ་སྐལ་བཟང་ལ་ཀུན་གྱི་དོ་ཁུར་ཆེན་པོ་�",
    "title-g_bo_277": "2023ལོའི་བོད་རང་སྐྱོང་ལྗོངས་ཀྱི་ལྷན་སྐྱེས་སྙིང་ནད་སྐྱོབ་བཅོས་ལས་དོན་ལ་སྐུལ་འདེད་ཏན་ཏིག་གཏོང་ཆེད།",
    "title-g_bo_918": "འཛམ་གླིང་ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་སྤྲིངས་གནང་བའི་རྟེན་འབྲེལ་འཕྲིན་ཡིག་དེར་ལན་ཆ་བཟང་པོ་བྱུང་བ།",
    "title-g_bo_451": "རྨིན་ཀྲི་མིང་ལ་བྱ་དགའི་དངུལ་སྒོར་307150 ལི་ལཱ་ཤིའུ་ལ་བྱ་དགའི་དངུལ་སྒོར་313590 ལི་ལཱ་ཤིའུ་ལ་བྱ་དགའི་དངུལ་སྒོར་311650 ལི་ཧྲའོ་དབྱང་ལ་བྱ་དགའི་དངུལ་སྒོར་311650 ལི་ཧྲའོ་དབྱང་ལ་བྱ་དགའི་དངུལ",
    "title-g_bo_997": "2023ལོའི་ཟླ་10ཚེས་8ཉིན་གྱི་ས་ཡོམ་ནང་མི་2053རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་9000ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_544": "2023ལོའི་ཟླ་11པའི་ཚེས་19ཉིན་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ་དང་།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་ངལ་དུབ་དབང་གིས་ན་ཟུག་གཏོང་བ་དེ་གཙོ་བོ་སྐེད་པའི་ཤ་གནད་ཀྱི་རྩ་འཁུམ་པ་དང་ན་ཟུག་གཏོང་བ། ཤུགས་ཉམས་པ་སོགས་ཀྱི་ཐོག་ནས་མངོན་གྱི་ཡོད་པས།",
    "title-g_bo_847": "2022ལོའི་ཟླ་9ཚེས་7ཉིན་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་གི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བཞིན་པའི་ཚུལ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ལ་བཅིངས་འགྲོལ་དམག་དང་དྲག་ཆས་ཉེན་རྟོག་དཔུང་སྡེའི་ཁྲོད་ལན་ཆ་ཡག་པོ་བྱུང་ཡོད།",
    "title-g_bo_1": "2023ལོའི་ཚོང་དོན་པུའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》ཐོག་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཟླ་11པའི་ཚེས་5ཉིན་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། དབྱི་སི་རལ་གྱི་ཙུང་ལི་ནེ་ཐ་ཉི་ཡ་ཧུའུ་ཡིས་དབྱི་སི་རལ་གྱི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤ",
    "title-g_bo_830": "ཧྥི་ལི་ཕིན་གྱི་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་ལ་ཐ་ཚིག་ནན་པོར་སྒྲོག་པ་དང་།",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་ཆེད་མཁས་ལས་དོན་གྲོས་ཚོགས་དེ་དྲ་ཐོག་དང་དྲ་ཕྱི་ཟུང་འབྲེལ་གྱི་རྣམ་པས་འཚོགས་ཤིང་།",
    "title-g_bo_826": "2023ལོའི་ཚེས་6ཉིན་དབྱི་སི་རལ་དམག་གིས་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་ངང་འཕེལ་རྒྱས་བྱུང་བ།",
    "title-g_bo_285": "མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་ཆབས་ཅིག ལག་པས་འོག་ནས་སྒང་ལ་འཕུར་འཕུར་བཏང་ན་ན་ཟུག་ཆུང་དུ་འགྲོ་བ་དང་ཤུགས་ཀྱིས་མནན་ན་ན་ཟུག་ཆེ་རུ་ཕྱིན་ཚེ། སྤྱིར་ན་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཡོད།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ནས་ཚེས་24ཉིན་བར་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ་རེད།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཨ་རི་དང་ཧྥི་ལི་ཕིན་གྱི་ཐུན་མོང་འགོག་སྲུང་ཆིངས་ཡིག་ལ་བཙན་གནོད་དང་འཁྲུག་རྐྱེན་སློང་བའི་བྱ་སྤྱོད་ལ་སྐུལ་མ་གཏོང་རྒྱུ་ཡིན་ཞེས་བཤད་པ་རེད།",
    "title-g_bo_248": "སྐད་འཕྲིན་ལས་ངེས་པར་དུ་བསུབ་དགོས་པའི་སྒྲིག་འགོད་གཉིས་ཡོད།",
    "title-g_bo_563": "3Dབརྙན་ལམ་དེ་སི་ཁྲོན་ཁྲེང་ཏུའུ་ཐའེ་ཀུའུ་ལིར་བསྟན་པ་དང་།",
    "title-g_bo_759": "2023ལོའི་ཟླ་12ཚེས་25ཉིན་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་ནས་འཚོགས་ཤིང་།",
    "title-g_bo_432": "2024ལོའི་ཡིག་རྒྱུགས་གཏོང་རྒྱུ་དང་དུས་ཐོག་ཏུ་རྒྱུགས་སྤྲོད་ལག་ཁྱེར་པར་རྒྱག་དགོས།",
    "title-g_bo_932": "2023ལོའི་ཟླ་9ཚེས་14ཉིན་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། ཨ་རི་དང་དབྱིན་ཇི་གཉིས་ཀྱི་དམག་འཐབ་གནམ་གྲུས་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པའི་གྲོང་ཁྱེར་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་རེད།",
    "title-g_bo_110": "ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་འགན་འཁུར་བའི་སྒོ་ནས་དུས་རབས་ཀྱི་འབོད་སྒྲར་ལན་སློག་པ་དང་།",
    "title-g_bo_707": "ཨུ་རུ་སུའི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་གི་བརྗོད་བྱ་གཙོ་བོའི་བྱང་ཁོ་རེ་ཡ་ལ་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་གདེང་ཚོད་ཡོད་པའི་སྒོ་ནས་བརྗོད་ཆོག",
    "title-g_bo_822": "2023ལོའི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་ཡོད་པ་དང་།",
    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "དབྱི་སི་རལ་དམག་དཔུང་གི་ཁྲིམས་ཁང་གི་སྨན་ཁང་དང་འཕྲོད་བསྟེན་སྡེ་ཚན་གྱི་འབྲེལ་ཡོད་འགན་འཁུར་བསྐྱོད་པ།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་11ཉིན་བསྟན་པར། ཉིན་དེའི་སྔ་དྲོའི་ཆུ་ཚོད་7པར་ཟོག་འདྲེན་མེ་འཁོར་ཞིག་ལིའང་ཙན་མངའ་སྡེ་བརྒྱུད་འགྲོ་སྐབས་ཆག་སྒོ་བྱུང",
    "title-g_bo_287": "ཨ་རི་དང་ཡུག་རེན་གྱི་བདེ་འཇགས་ལ་ཤུགས་རྐྱེན་ཐེབས་སྲིད་པའི་བྱང་ཆིངས་རྩ་འཛུགས་ཀྱི་དྲུང་ཡིག་ཆེན་མོ་སི་ཐུའོ་ཨེར་ཐེང་པེ་ཀེ་ཡིས་བྱུང་བ།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་ལྗོངས་ཡོངས་ཀྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བར།",
    "title-g_bo_901": "2020ལོའི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་ཕྱི་འབྲེལ་འབྲེལ་བ་སླར་གསོ་བྱ་རྒྱུའི་ཆབ་སྲིད་ཀྱི་ཇུས་ཐག་བཅད་ཡོད།",
    "title-g_bo_342": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱི་གནས་ཚུལ་ལྟར་ན་ཨ་རིའི་ཕྱོགས་གསུམ་གཞི་གཅིག་ཅེས་པའི་ཉིང་རྡུལ་རྡུང་རྡེག་སྟོབས་ཤུགས་ཀྱི་ཆ་ཤས་ཤིག་ཡིན་པའི་ཆ་ནས།",
    "title-g_bo_629": "2025ལོར་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་དེས་རྒྱལ་ཁབ་ཀྱི་ངོས་ནས་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མིའི་ཐོན་ལས་འཕེལ་རྒྱས་ཀྱི་ཞིབ་ཕྲའི་ནང་དོན་དང་དུས་ཚོད་སྔར་བས་ཞ�",
    "title-g_bo_259": "2023ལོའི་ཟླ་1ཚེས་10ཉིན་བོད་ལྗོངས་མང་ཚོགས་སྒྱུ་རྩལ་ཁང་གི་སློབ་མ་སྟེ་ལྷ་ས་གྲོང་ཁྱེར་ཁྲེང་ཀོན་ཆུས་སློབ་ཆུང་གཉིས་པའི་སློབ་མ་བསྟན་འཛིན་དོན་ལྡན་དང་འཆི་མེད་སྒྲོལ་དཀར་གཉིས་ལ་ཀྲུང་གོ་ཟློ",
    "title-g_bo_685": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པའི་དྲུང་ཆེ་མ་ལེ་ཨེར་ཏེ་ལེ་སིའི་སྐད་ཆ་ལུང་དུ་དྲངས་ནས་ཆ་འཕྲིན་སྤེལ་བར་གཞིགས་ན།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
    "title-g_bo_50": "ཟླ་12པའི་ཚེས་3ཉིན་ལིའང་ཀྲུའུ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་ཡོད།",
    "title-g_bo_769": "2023ལོའི་ཟླ་11ཚེས་24ཉིན་དེ་ཉིན་གཉིས་ནང་མུ་མཐུད་དབྱི་སི་རལ་བ་10དང་ཕ་ལེ་སི་ཐན་བ་30བརྗེ་པོ་རྒྱག་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན་ཞེས་བཤད་ཡོད།",
    "title-g_bo_582": "སྐུད་མེད་དྲ་བ་དེ་དྲ་ཐོག་ཏུ་གོང་དམའ་བ་ཡོད་པའི་སྟོད་ཐུང་དེ་ཉོས་པ།",
    "title-g_bo_635": "ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོར་ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་དོགས་ཟོན་གྱིས་མི་མང་པོར་ཁ་བསླུས་ཐེབས་འདུག",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་བས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་པའི་དོ་སྣང་གནང་དགོས་པ།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱི་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེ་སྐུ་སྲུང་རུ་ཁག་དང་གང་དེའི་རྒྱབ་སྐྱོར་རྩ་འཛུགས་ཀྱི་སི་རི་ཡའི་ཤར་རྒྱུད་དུ་ཡོད་པའི་གནས་གཉིས་ཀྱི་སྒྲིག་བཀོད་ལ་རྡུང་རྡེག་བཏང་ན",
    "title-g_bo_872": "འབའ་ཐང་རྫོང་གི་སྤྱི་ཚོགས་སྟོབས་ཤུགས་འཕེལ་རྒྱས་ལྟེ་གནས་དང་འབའ་ཐང་རྫོང་སྤྱི་ཚོགས་སྟོབས་ཤུགས་ཀྱི་ཞབས་ཞུའི་རྣམ་གྲངས་14འགྲེམས་བསྒྲགས་བྱུང་བ།",
    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་སྟེ།",
    "title-g_bo_575": "2020ལོའི་ཡར་ཀླུང་གཙང་པོའི་སྣོད་བཅུད་སྲུང་སྐྱོང་ལྟེ་གནས་ཀྱི་རྒྱབ་སྐྱོར་འོག",
    "title-g_bo_417": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་དུ་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་5087རྐྱེན་ལམ་དུ་ཤོར་བ་དང་།",
    "title-g_bo_484": "2024ལོའི་སློབ་ཆེན་ལ་རྒྱུཊ་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་གསར་པ།",
    "title-g_bo_249": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་ཕུའུ་ལ་ཤིན·དབྱི་སི་ཀན་ཏར་གློག་འཕྲིན་བཏང་ནས་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་ལས་དབང་གཅིག་མཐུན་མ་ལག་མཉམ་དུ་གཏོད་རྒྱུའི་ཐད་ངོས་འཛིན་གཅིག་མཐུན་གལ་ཆེན་བྱུང་ནས།",
    "title-g_bo_380": "དབྱི་རག་ཏུ་བཅའ་སྡོད་ཨ་རིའི་དམག་གི་རྟེན་གཞིར་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཚེས་6ཉིན་ཨ་པུ་བཀྲ་པེར་འཚམས་འདྲིར་སླེབས་པའི་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་དང་གྲོས་མོལ་བྱས་པ་དང་།",
    "title-g_bo_959": "ཨ་ཧྥེ་རི་ཁའི་ཁོང་ཀོ་པུའུ་ལ་སྨན་པ།",
    "title-g_bo_976": "2023ལོའི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་10ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་བསྟན་དོན།",
    "title-g_bo_97": "ལྗར་ཕན་དུ་ལོ་65ཡན་གྱི་རྒན་རྒོན་ཁྲི་3623ཡོད་པ་དེ་ན་ནིང་གི་དུས་མཚུངས་ལས་མི་ཁྲི་1ཉུང་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_309": "ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "རུས་ཚིགས་མི་བདེ་བར་བཟོད་བསྲན་བྱས་ཏེ་འགུལ་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་པའི་བྱེད་ཐབས།",
    "title-g_bo_102": "གྲོང་མི་ཀྲང་ཆེ་གེ་མོའི་ཁ་པར་ཞིག་འབྱོར་བ་དང་། གྲོང་མི་ཀྲང་ཆེ་གེ་མོའི་ཁ་པར་ཞིག་འབྱོར་བ་དང་། གྲོང་མི་ཀྲང་ཆེ་གེ་མོའི་ཁ་པར་ཞིག་འབྱོར་བ་དང་། གྲོང་མི་ཀྲང་ཆེ་གེ་མོའི་ཁ་པར་ཞིག་འབྱོར་བ་དང་། གྲ",
    "title-g_bo_56": "རང་རྒྱལ་གྱི་ཞིང་ཆེན་ཁག་གཅིག་ཏུ་ཏེང་གེ་ཚ་ནད་ཕོག་པའི་ནད་པ་མང་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_973": "དབང་ཆེན་གྱི་ཕུགས་བསམ་དད་སེམས་ཤོར་བར་ཞིབ་བཤེར་བྱས་པ་རེད།",
    "title-g_bo_294": "བྱང་བུའི་རྒྱབ་ངོས་སུ་བལྟས་ཚེ། བྱང་བུའི་སྟེང་ད་དུང་རྩ་གཉིས་ཨང་རྟགས་ཡོད།",
    "title-g_bo_689": "རྩོམ་སྒྲིག་པས་མཐོ་རྒྱུགས་བཏང་ཟིན་པའི་སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས་པ་དང་ཆ་འཕྲིན་གང་དག་ཕྱིར་གྱར་མི་རུང་བའི་དྲན་སྐུལ་བྱེད་རྒྱུ་ཡིན།",
    "title-g_bo_551": "2023ལོའི་ཞི་ཅིན་ཕིང་གིས་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉི་དང་མཇལ་འཛོམས་གནང་བ་རེད།",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》བཟོ་སྐྲུན་ལས་རིགས་ཀྱི་འཛུགས་སྐྲུན་བྱ་རྒྱུའི་འཐབ་ཇུས་བཀོད",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་མོ་ཞི་ཁོའི་ཙུང་ཐུང་ལུའོ་ཕེ་སི་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_351": "2023ལོའི་ད་ལོ་ནས་བཟུང་། འཛམ་གླིང་གི་དཔལ་འབྱོར་སླར་གསོའི་སྒུལ་ཤུགས་མི་འདང་བ་དང་།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་ཡོད།",
    "title-g_bo_980": "2023ལོའི་ལྗར་པན་གྱི་ཆུ་ཐོན་དངོས་རྫས་ཕྱོགས་ཡོངས་ནས་ནང་འདྲེན་བྱེད་མཚམས་འཇོག་རྒྱུའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ལ་སླེབས་ཡོད།",
    "title-g_bo_225": "2019ལོའི་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་འབྲོང་པ་རྫོང་ལེགས་རྩེ་འགག་སྒོར་འཚོགས་པ།",
    "title-g_bo_131": "རང་རྒྱལ་གྱི་འབྲུ་རིགས་ཀྱི་གཞི་རྩ་འགན་ལེན་བྱས་པ་དང་དུས་མཚུངས་ཞིང་ལས་ཀྱི་ཐོན་སྐྱེད་བྱེད་སྟངས་ཟམ་མི་ཆད་པར་གསར་གཏོད་བྱེད་པ།",
    "title-g_bo_739": "2020ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གི་སྤྱི་ཚོགས་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པའི་གྱོད་གཞི་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ་རེད།",
    "title-g_bo_190": "2020ལོ་ལོ་ལེགས་བྱུང་ན་ནིང་ལོར་ཆར་ཆུ་འབེལ་ཞིང་ལོ་ལེགས་བྱུང་སོང་།",
    "title-g_bo_553": "བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དེ་རྒྱལ་ཁབ་གློག་དྲ་ཁྲུང་ཆིང་གྲོང་ཁྱེར་གློག་ཤུགས་ཀུང་སིས་སྒྲིག་འཛུགས་ཉོ་ཚོང་བྱས་པ་ཞིག་ཡིན།",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་ནས་ལམ་དཀྱིལ་གྱི་ལྕགས་དྲར་བརྡུངས་པ།",
    "title-g_bo_141": "བོད་ལྗོངས་ཀྱི་ཀྲུང་ཧྭ་མི་རིགས་གཅིག་མཐུན་མ་ལག་གི་འདུ་ཤེས་བརྟན་པོ་འཛུགས་རྒྱུའི་གཙོ་གནད་དེར་དམ་འཛིན་ནན་པོ་བྱས་ཏེ་ཀྲུང་ཧྭ་མི་རིགས་གཅིག་མཐུན་མ་ལག་གི་འདུ་ཤེས་འཛུགས་སྐྱོང་ལ་སྐུལ་འདེད་ཟམ་མི་ཆད",
    "title-g_bo_886": "དབྱི་སི་རལ་གྱི་དམག་དཔུང་གི་ཧན་ཡིའུ་ཉི་སི་ལུའུ་ཤོག་གི་འགོག་སྲུང་འཛིང་རགས་ལས་བརྒལ་ནས།",
    "title-g_bo_688": "2024ལོའི་ཕྱི་དྲོར་ཞི་ཅིན་ཕིང་གིས་ཧྥ་རན་སེའི་ཙུང་ཐུང་མ་ཁེ་ལུང་དང་ཞལ་པར་བསྐྱོན་ཡོད།",
    "title-g_bo_586": "2020ལོའི་ཕ་ལི་སི་ཐན་གསར་འགྱུར་ཁང་གིས་ཚེས་20ཉིན་གནས་ཚུལ་སྤེལ་ནས་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་གྲོང་ཁྱེར་དང་དེའི་ཉེ་འགྲམ་ས་ཁུལ་དུ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་ཤུགས་ཆེན་བྱས་ཡོད་པ་དང་ས་ངོས་ནས་མེ་སྒ",
    "title-g_bo_990": "ཀྲུང་ཧྭ་མི་རིགས་ཀྱི་སྲོལ་རྒྱུན་དུས་ཆེན་ཤིང་འབྲུག་ལོའི་དཔྱིད་གསར་དུས་ཆེན་འཆར་ལ་ཉེ་བའི་མཚམས་འདིར།",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ་དང་།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་མཚོ་བྱང་བོད་རིགས་རང་སྐྱོང་ཁུལ་མཛེས་ལྗོངས་ཁུལ་དུ་གཏན་ཁེལ་བྱས་པའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_491": "《ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་རྒྱུན་ལས་ཨུ་ཡོན་ལྷན་ཁང་གིས་རྒྱལ་ཡོངས་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ཡོན་ལྷན་ཁང་དང་། རྒྱལ་སྲིད་སྤྱི་ཁྱབ་ཁང་། རྒྱལ་ཡོངས་སྲིད་གྲོས། ཆེས་མཐོའི་མི་དམངས་ཁྲིམས་",
    "title-g_bo_60": "2023ལོའི་ཞི་ཅིན་ཕིང་གིས་པེ་ཅིང་དང་ཧོ་པེ་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ས་ཁུལ་གྱི་གྲོང་ཚོ་དང་གྲོང་རྡལ་སྡེ་ཁུལ་གྱི་སྒྲིག་ལམ་སླར་གསོ་བྱེད་པའི་བྱ་སྤྱོད་ལ་འབད་བརྩོན་བྱ་རྒྱུ་ཡིན་ཞེས་བརྗོད",
    "title-g_bo_223": "རུས་ཚིགས་མི་བདེ་བར་བཟོད་བསྲན་བྱས་ཏེ་འགུལ་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་པའི་བྱེད་ཐབས།",
    "title-g_bo_96": "སི་ཁྲོན་ཞིང་ཆེན་རྔ་བ་ཁུལ་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ལྷན་གྱི་ཏང་ཙུའུ་ཡི་ཁོངས་མི། དྲུང་ཆེ།",
    "title-g_bo_312": "ས་གནས་དེ་གའི་དུས་ཚོད་ཟླ་1ཚེས་10ཉིན་དབྱི་རག་གི་ཙུང་ལི་སུའུ་ཏ་ཉི་ཡིས་སྨྱན་སྦྱོར་གྱི་བཅར་འདྲི་དང་ལེན་བྱེད་སྐབས། དབྱི་རག་གིས་གྲོས་མོལ་བྱས་པ་བརྒྱུད། ཨ་རིས་གཙོ་ཁྲིད་བྱས་པའི་རྒྱལ་སྤ�",
    "title-g_bo_176": "དབྱི་སི་རལ་དང་ཕྱི་རྒྱལ་བ་1400ལས་བརྒལ་བ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_145": "2023ལོའི་ཟླ་11པའི་ཚེས་15ཉིན་ལྷ་སར་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་རེད།",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་འཐུས་མི་ཚོགས་པའི་བླང་བྱ་ལྟར། ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཟླ་11ཚེས་10ཉིན།",
    "title-g_bo_414": "པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "ཞི་ཅིན་ཕིང་གིས་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན།",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་65སོང་རིང་།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་འཇབ་རྒོལ་བྱས་པ་དེས་མི་20རྐྱེན་ལམ་དུ་བཏང་ཡོད།",
    "title-g_bo_708": "དྲ་དཔོན་དེས་རང་གི་ལག་ཏུ་མེ་ཏོག་དཀར་པོ་གཉིས་བཟུང་ནས་འདི་ནི་ཐེན་ཧྲན་རི་བོའི་གངས་ལྷ་མེ་ཏོག་རེད།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "སི་རི་ལན་ཁའི་གར་སྟེགས་སུ་བོད་ལྗོངས་ཀྱི་གླུ་གར་འཁྲུག་ཆ་དོད།",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཧ་ནོ་དབྱིའི་ཀྲུའུ་ཞིའི་ལས་ཤག་ཏུ་ཝེ་ཐེ་ནམ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་",
    "title-g_bo_650": "2023ལོའི་ཟླ་10ཚེས་16ཉིན་གསལ་བསྒྲགས་སྤེལ་ནས་ཧུའུ་སའེ་དྲག་ཤོག་གི་འཇབ་རྒོལ་བྱས་པའི་དམག་གྲུར་རྒོལ་བའི་མདེལ་ལམ་མེ་ཤུགས་འཕུར་མདའ་བཞི་རྩ་གཏོར་བཏང་ཡོད།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པའི་བྱ་སྤྱོད་དང་ཕྱོགས་གཉིས་པོའི་མཐའ་མཚམས་སོ་ལྟ་ཁང་ལ་དོན་མེད་དུ་ཚུར་རྒོལ་བྱས་པའི་བྱ་སྤྱོད་བཤད་པ།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་ཡོད་དམ།",
    "title-g_bo_244": "མང་ཚོགས་ལ་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པའི་ཁུངས་སྣེ་ཞིག་རྙེད་པ།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་དུ་ཕེབས་སྐྱེལ་ཞུས་པ།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》ཞེས་པ་གཏོང་སྤེལ་བྱས་ཡོད་པ་རེད།",
    "title-g_bo_564": "ཞི་ཅིན་ཕིང་གིས་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ས་གནས་དེ་གའི་དུས་ཚོད་ཟླ་10ཚེས་5ཉིན་ཕོ་ལན་གྱི་ཙུང་ཐུང་ཏུའུ་ཏཱ་ཡིས་ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་མཐའ་བར་གསུམ་དུ་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འ",
    "title-g_bo_520": "ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "2023ལོའི་ཚེས་བཅུ་དྲུག་ཉིན་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "2023ལོའི་ཟླ་2ཚེས་26ཉིན་དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སྐབས་རེར་མཐོང་ཐུབ་ཀྱི་ཡོད་པ་དང་། ལྟ་ན་སྡུག་པའི་མཁའ་དབྱིངས་ཀྱིས་སྐྱེ་བོའི་ཡིད་སེམས་འཕྲོག་པར་བྱས།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་བྱིས་པ་ལྟོགས་ནས་ནད་ཀྱང་ཕོག་གི་འདུག་ཅེས་བཤད་འདུག",
    "title-g_bo_749": "མི་མེད་གནམ་གྲུའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་ནི་ཀྲུང་གོའི་ཐོན་གསར་པའི་མི་མེད་མྱུལ་ཞིབ་གནམ་གྲུ་ཞིག་ཡིན།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་དུས་ཚོད་དང་མི་མང་པོས་གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་དུས་ཚོད་བརྟག་དཔྱད་བྱེད་པའི་ཆེད་དུ་རེད།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_522": "2021ལོའི་ཕན་རོགས་གནའ་ཤུལ་ལ་ལོ་13000ཡན་གྱི་ལོ་རྒྱུས་ལྡན་པ་ར་འཕྲོད་བྱུང་།",
    "title-g_bo_787": "སྤྱི་ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། སྒྲིག་གཞི་དེའི་མགྲིན་ཚབ་པ་ཝུའེ་ལེན་·སི་པིན་ཏེ་ལེས（William Spindler）སྤྱི་ཚེས་8ཉིན་ཡུལ་གྱར་བ་ཁྲི་400ལྷག་ཙམ་ག�",
    "title-g_bo_36": "10ཉིན་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོར་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ལ་བྱ་དགའ་སྤྲོད་པའི་མཛད་སྒོ་ཧྥུའུ་ཅན་ཤ་མོན་དུ་འཚོགས་པ་རེད།",
    "title-g_bo_372": "2020ལོའི་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་བར་གྲོས་བསྡུར་འདི་འདྲ་བྱས་འདུག",
    "title-g_bo_672": "ཁྲག་རིགས་ཀྱི་ནད་རིགས་མང་པོ་འབྱུང་བ་དང་འབྲེལ་བ་ངེས་ཅན་ཞིག་ཡོད།",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "དབྱི་སི་རལ་དམག་གིས་ཕྱི་དྲོ་གནས་ཚུལ་སྤེལ་ནས་དབྱི་སི་རལ་དམག་གི་དམག་མི་སྐྱེལ་འདྲེན་བྱེད་མཁན་རླངས་འཁོར་ལ་འཇབ་རྒོལ་བྱས་པ་དང་། རྒྱལ་ཁབ་ཀྱི་དམག་མི་སྐྱེལ་འདྲེན་བྱེད་མཁན་རླངས་འཁོར་ལ་འཇབ་རྒོལ་",
    "title-g_bo_222": "གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས་པའི་མཛད་སྒོ་མཚོ་སྔོན་གནའ་མཁར་ཟི་ལིང་དུ་བསྡུས།",
    "title-g_bo_611": "1953ལོ་ནས་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱི་ཡོན་ཧྲི་ཧྲེན་ཧྲི་ཀྲའོ་ཡིས་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱི་སློབ་གསོ་འཕེལ་རྒྱས་ཐེབས་རྩ་ལྷན་ཚོགས་ལ་མི་དམངས་ཤོག་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན་ཡོད་པ་དང་།",
    "title-g_bo_565": "རྒྱལ་ནང་དང་རྒྱལ་སྤྱིའི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
