    "title-g_bo_327": "དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་པ་རེད།",
    "title-g_bo_323": "ཨུ་རུ་སུའི་དམག་གིས་དུས་ཐོག་ཏུ་བཏང་བའི་བརྡ་ཁྱབ་འབྱོར་བའི་གནས་ཚུལ་འོག པེའར་ཀེ་ལུའོ་ཏེ་མངའ་སྡེར་སྔར་བཞིན་བཟུང་དམག་དབོར་བྱེད་ཀྱི་དབྱིའར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་གཏོར་ལྷུང་བཏང་ཡོད",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་ས་འཛིན་ཕྲེང་བ་རིམ་པར་འདས་པའི་སར་ཆགས་པའི་སྟོད་མངའ་རིས་ཞེས་བྱ་བའི་ཡུལ་དེ་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་སྙན་པའི་གྲགས་པ",
    "title-g_bo_276": "2024ལོའི་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་དེ་སྤྱི་ལོ་2026ལོ་ནས་སྤྱི་ལོ་2024ལོའི་བར་ཡིན་པ་རེད།",
