    "title-g_bo_650": "ཧུའུ་སའེ་དྲག་ཤོག་གི་ཚོད་འཛིན་ཁུལ་ནས་འཕེན་གཏོང་བྱ་རྩིས་ཡོད་པའི་དམག་གྲུར་རྒོལ་བའི་མདེལ་ལམ་མེ་ཤུགས་འཕུར་མདའ་བཞི་རྩ་གཏོར་བཏང་ཡོད།",
    "title-g_bo_829": "2023ལོའི་ཟླ་10ཚེས་26ཉིན་ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་མཐའ་མཚམས་སོ་ལྟ་ཁང་དུ་དམག་བརྒྱབ་པར་ཕན་ཚུན་འགྲེལ་བརྗོད་བྱེད་པ།",
    "title-g_bo_330": "《ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་ཡོད་དམ།》",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཟླ་11ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ། ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་ནས་ཕེབས་སྐྱེལ་ཞུས་པ།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》གཏོང་སྤེལ་བྱས་པ།",
    "title-g_bo_564": "ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ཐུང་ཏུའུ་ཏཱ་ཡིས་ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་བྱ་རྒྱུ་མ་ཟད། སྲིད་ཇུས་དེས་ཡོ་རོབ་ལ་འཕྲད་པའི་གནས་སྤོས་ཡུལ་མིའི་གནོན་ཤུགས་ཀྱི་འབྱུ",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》",
    "title-g_bo_476": "སྤྱི་ཟླ་གསུམ་པའི་ཚེས་བཅུ་དྲུག་ཉིན་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "2023ལོའི་ཟླ་2ཚེས་26ཉིན་དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་བྱང་སྣེའི་འོད་ཟེར་མཐོང་དཀོན་པ་ཞིག་མངོན་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱིས་ཀྲ་ཁཱ་ལི་ཡ་དང་ཁོ་པའི་ནང་མི་གདོང་ཐུག་ཁྲོད་རིམ་བཞིན་ཀ་ཧྲ་རྒྱུད་ཀྱི་ལྷོ་རྒྱུད་དུ་ཕྱིར་འཐེན་བྱས་པ།",
    "title-g_bo_749": "ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་ཀྲུང་གོའི་མེ་ཤུགས་འཕུར་མདའི་མེ་སྒྱོགས་ལ་རམས་འདེགས་དེ་བས་ཆེ་བ་མཁོ་འདོན་བྱས་ཡོད།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་བའི་དུས་ཚོད་དང་གཟུགས་པོའི་བདེ་ཐང་གི་གནས་ཚུལ་དངོས་ཤེས་རྟོགས་ཐུབ་པའི་ཆེད་དུ།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བའི་དུས་རབས་གསར་པའི་བླང་བྱ་དང་འཚམ་པའི་དགེ་མཚན་ལྡན་པ་དང་བརྟན་པོ་ཡོང་བའི་ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བ་འཛུགས་རྒྱུར་འབད་བརྩོན་བྱེད་བཞིན་ཡོ",
    "title-g_bo_522": "2021ལོའི་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་ལས་དོན་སྤེལ་འགོ་ཚུགས་པ།",
    "title-g_bo_787": "2023ལོའི་སྤྱི་ཚེས་8ཉིན་སུའུ་ཏན་གྱི་ཁྱིམ་མཚེས་རྒྱལ་ཁབ་ཏུ་བྲོས་བྱོལ་ལ་སོང་བའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_36": "ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོའི་གྲོང་ཁྱེར་དང་པོ་སྟེ་ཟི་ལིང་དུ་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》: གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་དང་འཁྲབ་སྟོན་བྱེད་པ།",
    "title-g_bo_372": "ཡུག་རེན་དང་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་གཉིས་པོས་དམག་དོན་རོགས་སྐྱོར་བྱ་རྒྱུ་དེ་བས་མུ་མཐུད་རྒྱབ་སྐྱོར་བྱ་རྒྱུ་ཡིན།",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་གྱི་ནད་འབྱུང་བ་དང་ཁྲག་རིགས་གཞན་པ་དང་བསྡུར་ན་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་། ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་ཡིན》",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་ཀྱི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "དབྱི་སི་རལ་དམག་གིས་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ལྷོ་ཧན་ཡིའུ་ཉི་སིའི་དམག་སྒར་ལ་དམིགས་བསལ་བྱས་པ།",
    "title-g_bo_222": "ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་གཅེས་བཏུས་མཚོ་སྔོན་ཞིང་ཆེན་གནའ་དཔེ་མྱུར་སྐྱོབ་རིགས་ཀྱི་དཔེ་སྐྲུན་ལས་གཞིའི་ཁྲོད་ཚུད་དེ་པར་སྐྲུན་འགྲེམ་སྤ",
    "title-g_bo_611": "ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱི་དགེ་རྒན་ཆེ་མོ་དགུང་ལོ་90ལ་ཕེབས་པའི་ཧྲེན་ཧྲི་ཀྲའོ་ཡིས་སློབ་གསོ་འཕེལ་རྒྱས་ཐེབས་རྩ་ལྷན་ཚོགས་ལ་མི་དམངས་ཤོག་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན་ཡོད་པ།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་དང་རྒྱལ་སྤྱིའི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}