    "title-g_bo_980": "2023ལོའི་ཨང་103པའི་གྲོས་ཆོད་དང་ལྗར་པན་གྱི་ཆུ་ཐོན་དངོས་རྫས་ཕྱོགས་ཡོངས་ནས་ནང་འདྲེན་བྱེད་མཚམས་འཇོག་རྒྱུའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ལ་སླེབས་ཡོད།",
    "title-g_bo_225": "2023ལོའི་བོད་ལྗོངས་འབྲོང་པ་རྫོང་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་མཚོན་གྱི་ཡོད།",
    "title-g_bo_131": "2023ལོའི་དུས་སྐབས་ཀྱི་འབྲུ་རིགས་ཐོན་འབོར་དང་ཞིང་ལས་གོང་འཕེལ་གཏོང་བའི་གནས་ཚུལ།",
    "title-g_bo_739": "2023ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གི་དགོང་མོ་གསལ་བསྒྲགས་སྤེལ་བ།",
