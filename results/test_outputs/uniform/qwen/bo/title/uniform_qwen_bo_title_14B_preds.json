    "title-g_bo_553": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་མི་སྲིད་པའི་ཁ་རས་རྒྱག་དགོས་པ།",
    "title-g_bo_141": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཀྲུང་ཧྭ་མི་རིགས་གཅིག་མཐུན་མ་ལག་གི་འདུ་ཤེས་འཛུགས་སྐྱོང་བྱེད་པ།",
    "title-g_bo_886": "དབྱི་སི་རལ་དམག་དཔུང་གིས་ཧ་མ་སིའི་ཅ་ཧྲ་ས་ཁུལ་དུ་ཡོད་པའི་འགོ་ཁྲིད་ཤིན་ཝར་སྡོད་སའི་ཅ་ཧྲ་ས་ཁུལ་གྱི་ཁང་པ་ཞིག་མཐའ་སྐོར་ཡོད་པ་དང་། དབྱི་སི་རལ་དམག་དཔུང་གིས་སྔ་ཕྱི་མ་གཏོགས་ཤིན་ཝར་བཟུང་ཐུབ་ངེས་རེད།",
    "title-g_bo_688": "2024ལོའི་ཟླ་11ཚེས་20ཉིན་གྱི་ཕྱི་དྲོར། ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་རིམ་པ་ཁག་གི་འགྲོ་འོང་མགྱོགས་མྱུར་སླར་གསོ་བྱུང་བ།",
    "title-g_bo_586": "ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་སྨན་ཁང་མང་པོ་ཞིག་གིས་རྨས་སྐྱོན་ཕོག་པའི་མི་སྣར་མུ་མཐུད་སྨན་བཅོས་བྱེད་ཐབས་བྲལ་བར་གྱུར་ཡོད།",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་འཆར་ལ་ཉེ་བའི་མཚམས་ཀྱི་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི། རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི། ཀྲུང་དབྱང་དམག་ཨུད་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་དམངས་གཙོ་ཏང་ཤོག་ཁག",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་དུ་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་། 《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་པེ་ཅིང་དང་ཧོ་པེའི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ།",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
