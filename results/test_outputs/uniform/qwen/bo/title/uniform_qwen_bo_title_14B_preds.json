    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》ཐོག་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཟླ་11པའི་ཚེས་5ཉིན་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། དབྱི་སི་རལ་གྱི་ཙུང་ལི་ནེ་ཐ་ཉི་ཡ་ཧུའུ་ཡིས་དབྱི་སི་རལ་ཕྱོགས་ཀྱི་མི་སྣ་གློད་གྲོལ་མ་བཏ",
    "title-g_bo_830": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་ཀྲུང་གོ་མཚོ་ཐོག་ཉེན་རྟོག་ཅུས་ཀྱི་གསར་འགྱུར་མགྲིན་ཚབ་པ་ལིའུ་ཏེ་ཅུན་གྱིས་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་2དང་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་2ཀྲུང་ག�",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་གཏན་འབེབས་བྱས་པ།",
    "title-g_bo_826": "2023ལོའི་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་ངང་འཕེལ་རྒྱས་བྱུང་བ།",
    "title-g_bo_285": "མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཚེ། སྤྱིར་ན་ནད་རྟགས་འདི་རིགས་ཐོན་རྒྱུ་སྔོན་འགོག་བྱེད་ཐུབ།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཀྲུང་གོ་གཉིས་པོས་ཐུན་མོང་འགོག་སྲུང་བྱ་སྤྱོད་ལ་སྐྱོན་འཛུགས་བྱས་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན་པ་དང་། དེ་ལས་ལྡོག་སྟེ་དེས་བཀོལ་སྤྱོད་ནོར་འཁྲུལ་ཐོན་སླ་བའམ་གཡོ་འོག་ཏུ་ཚུད་བྱེད་ཙམ་ལས་གཞན་ཕན་པ་གཏན་ནས་མེད།",
    "title-g_bo_563": "3D མིག་ཤེལ་མི་དགོས་པའི་བརྙན་ལམ་སྟེང་བཟོས་པ།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་ནས་འཚོགས་པ།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་སུ་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་ལ་སློབ་མས་དོན་དེ་དག་ལ་ཡིད་གཟབ་བྱ་དགོས།",
    "title-g_bo_932": "2023ལོའི་ཟླ་9ཚེས་14ཉིན་ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཚོད་འཛིན་བྱས་པའི་རྒྱ་མཚོ་དམར་པོའི་གྲོང་ཁྱེར་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "ཀྲུང་གོའི་གྲོས་འགོ་རྒྱས་བཤད་གནང་བ། ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མི་དམངས་དང་ཕ་ཚ་བུ་རྒྱུད་ཐུན་མོང་ཐོག་དར་རྒྱས་ཡོང་བ་བྱེད་དགོས།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "2023 ལོའི་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "2023ལོའི་ཟླ་བ་དང་པོའི་ཀྲུང་གོའི་དུས་རབས་གསར་པའི་རིག་གནས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་གཏིང་ཟབ་བྱེད་པ།",
    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "ཀ་ཧྲ་ས་ཁུལ་གྱི་དབྱི་སི་རལ་དམག་དཔུང་གིས་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་ནས་འབར་མདེལ་བཟོ་བའི་འཁོར་སྟེགས་དང་། རྒྱང་ཁྲིད་མེ་ཤུགས་འཕུར་མདེལ། �",
    "title-g_bo_341": "2023ལོའི་ཟླ་11ཚེས་11ཉིན་བསྟན་པའི་ལྕགས་ལམ་ལ་གཏོར་སྐྱོན་ཕོག་པ།",
    "title-g_bo_287": "ཨ་རི་དང་བྱང་ཆིངས་རྩ་འཛུགས་ཀྱིས་ཡུག་རེན་ལ་དམག་དོན་རྒྱབ་སྐྱོར་བྱེད་པའི་གཏན་འབེབས་བྱེད་པ།",
    "title-g_bo_394": "2023ལོའི་བོད་ལྗོངས་ཀྱི་དཔལ་འབྱོར་གོང་འཕེལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བ།",
    "title-g_bo_901": "ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་འབྲེལ་བ་དངོས་སུ་འཛུགས་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ།",
    "title-g_bo_342": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་ཉིང་རྡུལ་ཆུར་འཛུལ་དམག་གྲུ་བཀོད་སྒྲིག་བྱས་པའི་གནས་ཚུལ་ཕྱིར་བསྒྲགས་བྱ་རྒྱུ་ཡོད།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_259": "2023ལོའི་ཀྲུང་གོའི་ལོ་ཆུང་བྱིས་པའི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་མཚན་སྙན་ཐོབ་པ།",
    "title-g_bo_685": "ཉེ་ཆར་ལི་པི་ཡའི་ཤར་རྒྱུད་ལ་འཇབ་རྒོལ་བྱས་པས་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་བ།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས།",
    "title-g_bo_50": "2023ལོའི་ཟླ་12པའི་ཚེས་3ཉིན་ཀྲུང་ཧྭ་ཤེས་དཔལ་གྱི་ལིའང་ཀྲུའུ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_769": "ཕ་ལེ་སི་ཐན་དབྱི་སི་རལ་གྱི་གནས་ཚུལ་སྤེལ་བའི་གྲོས་ཆོད་དེ་ཉིན་གཉིས་ནར་འགྱངས་གཏོང་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན།",
    "title-g_bo_582": "སྐུད་མེད་དྲ་བ་སྦྲེལ་མཐུད་བྱེད་པའི་གོ་རིམ་དང་བྱ་སྤྱོད།",
    "title-g_bo_635": "ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་དོགས་ཟོན་གྱིས་མི་མང་པོར་ཁ་བསླུས་ཐེབས་འདུག",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་བས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་པའི་དོ་སྣང་གནང་དགོས།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
