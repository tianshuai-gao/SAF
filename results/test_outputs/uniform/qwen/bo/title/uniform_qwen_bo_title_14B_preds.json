{
    "title-g_bo_923": "ཡུལ་སྐོར་བ་ཚོར་ཞབས་འདེགས་དེ་བས་ཡག་པོ་ཞུ་ཆེད། འཕྱོངས་རྒྱས་རྫོང་ཆང་ཁྱིམ་གྲོང་ཚོའི་གྲོང་མི་ཚོས་དུས་ཆེན་གྱི་གཟབ་མཆོར་ལེགས་པར་སྤྲས་པ།",
    "title-g_bo_752": "ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་ཚན་པས་དབྱི་སི་རལ་གྱིས་ཅེ་པ་ལི་ཡེ་ཡུལ་གྱར་བའི་བསྒར་སར་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_589": "ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་དང་འཛམ་གླིང་ལ་འཕྲད་པའི་འགྲན་རྩོད་དེ་བས་ཐག་གཅོད་ཐུབ་པ།",
    "title-g_bo_267": "མ་བུ་གཉིས་ཀྱི་ལས་ཀ་ཙག་ཙིག་གནང་བའི་རྟ་མགྲིན་གྱི་སྙན་པོ་དང་གླུ་གཞས་གཏོང་རྒྱུའི་རེ་བ།",
    "title-g_bo_139": "2023ལོའི་ཀོང་ཏུང་གི་ས་ཁུལ་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་གྱུར་བ།",
    "title-g_bo_809": "ནོ་རོ་ནད་དུག་གི་སྔོན་འགོག་དང་སྨན་བཅོས་བྱེད་པའི་བརྒྱུད་རིམ་དོན་དངོས།",
    "title-g_bo_355": "སློབ་གསོ་པུའུ་སློབ་ཕྱིའི་སློབ་གསོ་གསོ་སྦྱོང་གྲོན་དངུལ་ཕྱིར་སློག་གི་མིང་ཐོག་ནས་འཛད་སྤྱོད་པའི་ཁེ་དབང་སྲུང་སྐྱོབ་ཀྱི་འདུ་ཤེས་ཇེ་ཟབ་ཏུ་གཏང་དགོས།",
    "title-g_bo_154": "《མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས》འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "གསང་མྱུལ་གྱི་དོཊ་པ་ཡོད་པའི་ལྗར་ཕན་གྱི་སྤྱི་དམངས་དེར་བཙན་ཐབས་སྤྱད་པ།",
    "title-g_bo_327": "དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་དང་དོན་རྐྱེན་བཟོ་མཁན་གྱིས་རིན་དོད་དྲག་པོ་འཇལ་དགོས་པའི་འབོད་སྐ�",
    "title-g_bo_323": "ཨུ་རུ་སུའི་དམག་གིས་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་གཏོར་ལྷུང་བཏང་བ།",
    "title-g_bo_213": "4500ཡན་ཟིན་པའི་གངས་ལྗོངས་ས་མཐོའི་ནུབ་ཕྱོགས་ཀྱི་ས་འཛིན་ཕྲེང་བ་རིམ་པར་འདས་པའི་སར་ཆགས་པའི་སྟོད་མངའ་རིས་ཞེས་བྱ་བའི་ཡུལ་དེ་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་",
    "title-g_bo_276": "2024ལོ་ནས་2026ལོའི་བར་ཀྲུང་གོ་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་སྤྱི་ལོ་2024ལོ་ནས་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ་རེད།",
    "title-g_bo_954": "༢༠༢༢ལོའི་ཟླ་བཅུ་གཅིག་པའི་ཚེས་༤ཉིན་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་དང་ནེ་པ་ལའི་སྲིད་གཞུང་གི་འགོ་ཁྲིད་འོག་ས་ཡོམ་གྱི་གནོད་འཚེ་ཕོག་ཁུལ་མང་ཚོགས་ཀྱིས་གང་མགྱོགས་དཀའ་ངལ་ལས་རྣམ་པར་རྒྱལ་བ་དང་ཁྱིམ་གཞིས་བས�",
    "title-g_bo_962": "12306ཐོག་ཏུ་པ་སེ་ཉོ་བའི་ཆ་འཕྲིན་དང་སྐར་ཆ་གཅིག་གི་ནང་པ་སེ་1400འཚོང་བཞིན་ཡོད།",
    "title-g_bo_200": "མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ་“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ་ཅི་ཡིན་ནམ།",
    "title-g_bo_210": "《འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་ཁུལ་གྱི་ས་ཁོངས་གཞི་གཅིག་ཅན་གོང་འཕེལ་འཆར་འགོད་རྩ་གནད》དངོས་སུ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_299": "ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་མི་སྣའི་དགའ་བསུ་ཐོབ་པ།",
    "title-g_bo_527": "2023ལོའི་ཟླ་11ཚེས་9ཉིན་པེ་ཅིང་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོར་ཞུགས་འབུལ་ཞུས་པ།",
    "title-g_bo_726": "2023ལོའི་ཟླ་10པའི་ཨ་རིའི་འཛད་སྤྱོད་པའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་སྔོན་དཔག་བྱས་པ་དེ་སྤྱི་ཟླ་9པའི་3.7%ནས་3.6%བར་ཆག་རྒྱུ་དང་། ལོ་གསུམ་གྱི་རྗེས་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་སྔོན་དཔག་བྱས་པ་",
    "title-g_bo_188": "དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ནང་མི་1538རྐྱེན་ལམ་དུ་ཤོར་བ་བརྗོད་པ།",
    "title-g_bo_706": "1.ཆུ་འདང་ངེས་མི་འཐུང་བ། 2.གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། 3.ཟས་རིགས་ཆབ་ཆེབ་ལ་དད་པ།",
    "title-g_bo_681": "བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "ཨ་རིའི་ཁེན་ཐ་ཅི་མངའ་སྡེའི་དོན་རྐྱེན་ཞིག་ཐོན་པ་དང་འཁོར་སྒྲོམ་དེ་དག་ལ་རྫས་འགྱུར་དངོས་རྫས་བླུགས་པ་དང་། མེ་འབར་ཡོད་པ་རེད།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱིས་ཕྱི་ཚུལ་རིང་ལུཊ་དང་དཔོན་ཉམས་རིང་ལུཊ་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ས་ངོས་ལ་གློག་ཤུགས་མཁོ་འདོན་ཐད་ལ་ཡང་གནས་ཚུལ་ཐོན་ཡོད།",
    "title-g_bo_16": "2023ལོའི་ལོ་གསར་དར་ཤིང་དུ་གཅོད་པའི་སྲོལ་རྒྱུན་དང་ཁོར་ཡུག་སྲུང་སྐྱོང་གི་ལྷག་བསམ།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་བོད་ལྗོངས་གཞིས་རྩེ་བཞད་མཐོང་སྨོན་རྫོང་མི་དམངས་ཁྲིམས་ཁང་གིས་རིན་ཆེ་གེ་མོ་ཆག་སྒོ་བསླངས་པར་ཆད་པ་བཅད་འདུག",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ།",
    "title-g_bo_577": "《ཡོ་རོབ་ཀྱི་དམག་འཁྲུག་བརྟེན་ནས་ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་ཇི་ལྟར་ཐོབ་པ་བྱེད》ཅེས་པའི་རྩོམ་ཡིག་སྤེལ་བ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་ནས་ཟླ་11ཚེས་6ཉིན་བར་རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་རེད།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཤིག་གིས་དམག་མི་ལྔ་ལ་ངོ་ལོག་ཟིང་འཁྲུག་པ་དང་འཐབ་འཁྲུག་བྱས་པ།",
    "title-g_bo_831": "ཡེ་མན་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གིས་དབྱི་སི་རལ་ལ་འཕུར་མདེལ་འཕེན་རྒྱུ་ཡིན་ཞེས་བརྗོད་པ།",
    "title-g_bo_933": "མའོ་ཆེ་གེ་མོ་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་བརྟག་དཔྱད་བྱས་པ།",
    "title-g_bo_696": "2022ལོའི་ཀྲུང་གོ་དང་མཉམ་སྐྲུན་རྒྱལ་ཁབ་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་ཨ་སྒོར་དུང་ཕྱུར་ཁྲི་31ཟིན་པ།",
    "title-g_bo_675": "སློབ་གསོ་པུའི་སློབ་ཕྱིའི་ལུས་སྦྱོང་གི་བདེ་འཇགས་སྲུང་སྐྱོང་དོན་དངོས་ལ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན། མིག་སྔའི་བར་རེས་སྐོར་དེའི་གདོང་ཐུག་ཁྲོད་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོའི་མི་ཉུང་མ",
    "title-g_bo_65": "༢༠༢༣ལོའི་ཟླ་བ་བཅུ་པའི་ཚེས་བཞི་བོད་ཀྱི་ཀྲུང་གོ་དང་ཏེན་མག་གི་འབྲེལ་བ་འཕེལ་རྒྱས་གཏོང་རྒྱུར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་བཞི་བཅུ་བཞི་བཅུ་ལོའི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ཏེན་མག་གི་ཕྱོགས་ཡོངས",
    "title-g_bo_214": "ཨ་རིས་ཕྱོགས་གཞན་ཞིག་ནས་དབྱི་སི་རལ་ལ་བྱ་སྤྱོད་ངོ་མའི་ཐོག་ནས་ཕྱོགས་ཞེན་བྱེད་བཞིན་ཡོད་པའི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་འཕེལ་རྒྱས་ཤུགས་ཆེན་གཏོང་བ།",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་སྤེལ་བའི་བྱེད་ཐབས་དང་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་རྒྱལ་ཁབ་གསུམ་གྱི་བྱ་སྤྱོད་དེ་རྒྱལ་སྤྱིའི་འོས་འགན་ལས་འགལ་ཡོད་པར་ངོས་འཛིན་བྱེད་ཀྱི་ཡོད་པ།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་བྱང་རྒྱུད་དུ་སྤེལ་བའི་མཁའ་ཐོག་འཇབ་རྒོལ་ལ་དབྱེ་བ་མེད་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན།",
    "title-g_bo_318": "ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་པ་དེ་ནི་ཨུ་རུ་སུ་ཕྱོགས་ནས་བཟུང་བའི་འདྲ་མཚུངས་ཀྱི་བྱེད་ཐབས་ཤིག་ཡ",
    "title-g_bo_856": "ཨ་རིའི་རྒྱ་མཚོའི་ཚ་རླབས་ཀྱི་རྐྱེན་ལས་ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེས་ཆེ་བ་དང་། དྲོད་ཚད་མཐོ་བའི་དབང་གིས་པེ་ལིང་རྒྱ་མཚོའི་ཟས་རིགས་ཀྱི་སྦྲེལ་ཐགས་མང་ཆེ་བར་གཏོར་བཤིག་ཐེབས།",
    "title-g_bo_292": "ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་བོད་དང་འབྲེལ་བ་ཡོད་པའི་གནད་དོན་ལ་བརྟེན་ནས་ཀྲུང་གོའི་དཔོན་རིགས་ཁྲིམས་འགལ་ངང་བཀག་སྡོམ་བྱས་པ་དང་། ཀྲུང་གོ་ཕྱོགས་ཀྱི་ཁེ་ཕན་ལ་གནོད་འཚེ་ཚབས་",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "《འཐབ་ཇུས་ཀྱི་དོན་སྙིང་ལྡན་པའི་ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་བསྐྲུན་ནས།  ལག་གདང་སྦྲེལ་ཏེ་དེང་རབས་ཅན་གྱི་ཕྱོགས་སུ་སྐྱོད་པའི་ལེའུ་གསར་པའི་འགོ་རྩོམ་དགོས་》",
    "title-g_bo_865": "2023ལོའི་ཟླ་10ཚེས་26ཉིན་ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་མཐའ་མཚམས་སོ་ལྟ་ཁང་དུ་དམག་བརྒྱབ་པར་ཕན་ཚུན་འགྲེལ་བརྗོད་བྱེད་པ།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་འཕྲིན་ཡིག་རེ་བྲིས་པ།",
    "title-g_bo_638": "2023ལོའི་ཟླ་དང་པོ་ནས་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་ཞིང་།",
    "title-g_bo_626": "ཡུག་རེན་དམག་གིས་ཨུ་རུ་སུའི་དམག་ཕམ་ཉེས་གཏོང་རྩིས་བྱེད་པའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_319": "2023ལོའི་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས་ལ་གཞིགས་ན། རང་རྒྱལ་གྱིས་ལོ་ཧྲིལ་པོར་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད་པ་དང་། མིག་སྔར་ར�",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད་དམ།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡའི་ཕྱི་འབྲེལ་པུའི་པུའུ་ཀྲང་ཧྥུའུ་ལའེ་ཏི•མ་མཱ་ཉིས་ཀྱིས་དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས། ༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
