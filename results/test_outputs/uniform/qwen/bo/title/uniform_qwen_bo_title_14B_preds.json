    "title-g_bo_500": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་ནས་བཟུང་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་དོན་རྐྱེན་ནང་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་སེར་སོགས་ལ་སྐར་མ་གཅིག་གི་རིང་ལ་ངག་བསྡམས་མྱ་ངན་ཞུས་པ།",
    "title-g_bo_414": "པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་ཡོད།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་ནན་ཧའེ་རུ་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན།",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པ།",
