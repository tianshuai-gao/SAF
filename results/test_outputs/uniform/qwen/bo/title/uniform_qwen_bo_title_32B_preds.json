{
    "title-g_bo_923": "2021ལོའི་ཡུལ་སྐོར་ཚོགས་པ་དུས་ཆེན་གྱི་བོད་ལ་ཡུལ་སྐོར་དུ་ཡོང་བའི་མཛེས་ལྗོངས་མཐོང་བྱུང་།",
    "title-g_bo_752": "ཀ་ཧྲ་རྒྱུད་ཀྱི་ཡུལ་གྱར་བའི་བསྒར་སར་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་དང་། མི་བཅུ་ཤི་རྨས་བཏང་ཡོད།",
    "title-g_bo_589": "ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_267": "2022ལོའི་རྟ་མགྲིན་གྱི་སྙན་པོ་དབྱངས་རྟ་ལེན་བཞིན་པའི་མ་བུ་གཉིས་ཀྱི་བརྙན་བླངས་བརྒྱུད་གླུ་གཞས་གཏོང་རྒྱུར་མོས་མཐུན་གནང་།",
    "title-g_bo_139": "2023ལོར་ཀོང་ཏུང་གི་ས་ཁུལ་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13.57ཟིན་ནས་རྒྱལ་ཡོངས་ཀྱི་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་ག�",
    "title-g_bo_809": "ནོ་རོ་ནད་དུག་གི་ནད་རྟགས་དང་གཞན་འགྱུར་གྱི་དུག་སྡོང་གསར་པ་ཐོན་པའི་དྲན་སྐུལ།",
    "title-g_bo_355": "སློབ་གསོ་པུའུ་སློབ་ཕྱིའི་སློབ་གསོ་གསོ་སྦྱོང་ལྟ་སྐུལ་དོ་དམ་སི་དང་སྤྱི་བདེ་པུའུ་ཡི་ཉེས་དོན་མྱུལ་ཞིབ་ཅུའུ་ཡིས་མཉམ་འབྲེལ་ཐོག་སློབ་གྲྭའི་ཕྱི་རོལ་གྱི་གསོ་སྦྱོང་གྲོན་དངུལ་ཕ�",
    "title-g_bo_154": "《མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས》འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "ཀྲུང་གོའི་ཕྱོགས་ཀྱིས་ལྗར་ཕན་གྱི་སྤྱི་དམངས་ལ་གསང་མྱུལ་བྱ་སྤྱོད་སྤེལ་བའི་དོགས་གཞི་ཡོད་པའི་དྲིས་ལུགས་བཤད།",
    "title-g_bo_327": "དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་པ་དང་། འབར་གས་ཀྱི་དོན་རྐྱེན་ཐེངས་གཉིས་པ་དེ་ཚེས་3ཉིན་གྱི་ཕ",
    "title-g_bo_323": "ཨུ་རུ་སུའི་དམག་དོན་མི་སྣ་65བླུགས་པའི་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་གཏོར་ལྷུང་བཏང་བ་དང་ཡུག་རེན་ཕྱོགས་ཀྱི་མུ་མཐུད་བཟུང་དམག་བརྗེ་རེས་བྱེད་འདོད་ཡོད།",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ནི་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་གནས་མཆོག་གྱི་ཡུལ་ལུང་ཉམས་དགའ་བ་ཞིག་ཡིན།",
    "title-g_bo_276": "2024ལོའི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་དེ་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ་རེད།",
    "title-g_bo_954": "ཀྲུང་གོ་དང་ནེ་པ་ལའི་སྲིད་གཞུང་གི་འགོ་ཁྲིད་འོག་ནི་ས་ཡོམ་གྱི་གནོད་འཚེ་ཕོག་ཁུལ་མང་ཚོགས་ཀྱིས་གང་མགྱོགས་དཀའ་ངལ་ལས་རྣམ་པར་རྒྱལ་བ་དང་ཁྱིམ་གཞིས་བསྐྱར་སྐྲུན་ཐུབ་ངེས་ཡིན་པའི་ཡིད་ཆེས་ཡོད།",
    "title-g_bo_962": "12306ཐོག་ཏུ་བྱེད་ནུས་གསར་པ་འདི་དག་བསྣན་འདུག་པ་སེ་འཚོང་བའི་དུས་ཚོད་བརྗེད་འགྲོ་སྲིད།",
    "title-g_bo_200": "མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ་“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ་ཅི་ཡིན་ནམ།",
    "title-g_bo_210": "2019ལོའི་ཟླ་12ཚེས་1ཉིན་གྱི་གཏན་འབེབས་ལྟར་འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གི་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ་ནི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་འཐབ་ཇུས་གལ་ཆེན་ཞིག་ཡིན།",
    "title-g_bo_299": "ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་མི་སྣའི་དགའ་བསུ་ཐོབ་པ།",
    "title-g_bo_527": "2023ལོའི་ཟླ་11ཚེས་3ཉིན་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོར་བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་གི་སྐུ་ཕུང་ཚེས་9ཉིན་པེ་ཅིང་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོར་ཞུགས་འབུལ་ཞུས་པ།",
    "title-g_bo_726": "ཨ་རིའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་སྔོན་དཔག་བྱས་པ་ཆག་པ་དང་། ཨ་རིའི་མ་རྐང་ཅུང་དམའ་རུ་བཏང་བའི་འཕར་ཆག་བྱུང་།",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་གྱི་དབྱི་སི་རལ་གྱི་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་ལ་གཞུང་ཕྱོགས་ཀྱི་ཆ་འཕྲིན་གསལ་པོ་ཞིག་མེད།",
    "title-g_bo_706": "གཟུགས་པོའི་ལྗིད་ཚད་དང་ཟས་རིགས་ཆབ་ཆེབ་ལ་དད་པ།",
    "title-g_bo_681": "བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "ཨ་རིའི་ཁེན་ཐ་ཅི་མངའ་སྡེའི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་14དང་སྐར་མ་30ཙམ་ལ་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་ཞིག་ཐོན་པ།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱིས་ཕྱི་ཚུལ་རིང་ལུཊ་དང་དཔོན་ཉམས་རིང་ལུཊ་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ས་ཡོམ་དང་མེ་རི་འཕྱུར་བའི་ཉེན་ཁ་ཆེ་རུ་ཕྱིན་པ།",
    "title-g_bo_16": "ལོ་གསར་བསུ་བའི་གྲ་སྒྲིག་ལས་དོན་ཁག་སྤེལ་བ་དང་བོད་ཀྱི་ལོ་གསར་འཆར་ལ་ཉེ་བའི་དྲན་སྐུལ་བྱེད་པ།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་གྱི་དུས་ཚོད་བཞིན་རིན་ཆེ་གེ་མོས་ཆག་སྒོ་བསླངས་པར་ཆད་པ་བཅད་འདུག",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ། པེ་ཅིང་གྲོང་ཁྱེར་སློབ་གསོ་ཨུ་ལྷན་གྱིས་བརྡ་ཐོ་བཏང་བ།",
    "title-g_bo_577": "ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་ཇི་ལྟར་ཐོབ་པ་བྱེད་དགོས། ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ལས་ཁེ་ཕན་ཆེན་པོ་ཐོབ་པའི་དོན་དངོས་ཐེར་འདོན་བྱས་ཡོད།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་རེད། རེས་སྐོར་གསར་པའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཀ་ཤི་སྨིར་གྱི་ལྷོ་རྒྱུད་ལ་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་འཐབ་འཁྲུག་བྱས་པ།",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གི་བར་དུ་འགྲན་རྒོལ་བྱས་པ།",
    "title-g_bo_933": "མའོ་ཆེ་གེ་མོ་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་དངུལ་ཁང་གཱ་བསྡམས་བཅད་བྱས་པ།",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་སྤྱིའི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་ནི་ཨ་སྒོར་དུང་ཕྱུར་ཁྲི་31ཟིན་པ་དང་། གྲངས་འཛིན་དཔལ་འབྱོར་གྱིས་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་བསྡུར་གྲངས་ཀྱི་58%བཟུང་ནས་གཞ",
    "title-g_bo_675": "སློབ་གསོ་པུའི་སློབ་ཕྱིའི་ལུས་སྦྱོང་གི་བདེ་འཇགས་སྲུང་སྐྱོང་བྱ་མི་རུང་བ་ལྔ་བཏོན་པ།",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་མི་ཉུང་མཐར་ཡང་15546རྐྱེན་ལམ་དུ་ཤོར་བའི་གནས་ཚུལ།",
    "title-g_bo_65": "ཀྲུང་གོ་དང་ཏེན་མག་གི་འབྲེལ་བ་འཕེལ་རྒྱས་གཏོང་རྒྱུར་བྱས་པའི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ།",
    "title-g_bo_214": "ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད། ཨ་རིས་ཕྱོགས་གཅིག་ནས་མི་ཆོས་རིང་ལུགས་ཀྱི་གནོད་འཚེ་མི་ཐོན་པ་བྱེད་དགོས།",
    "title-g_bo_79": "གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ།",
    "title-g_bo_761": "ཡུག་རེན་གྱི་ཙུང་ལི་གཞོན་པ་དང་པོ་དཔལ་འབྱོར་པུའུ་ཀྲང་ཡིའུ་ལི་ཡ་སི་ཝུའེ་ལི་ཏེང་ཁོ་ཡིས་ཡུག་རེན་གྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་པ།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གི་ཀ་ཧྲ་རྒྱུད་དུ་སྤེལ་བའི་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད།",
    "title-g_bo_318": "ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་པ།",
    "title-g_bo_856": "ཨ་རིའི་མཚོ་ཁོངས་ནས་ཁ་བའི་སྡིག་སྲིན་དུང་ཕྱུར་བཅུ་ཕྲག་ཁ་ཤས་མེད་པར་གྱུར་པ།",
    "title-g_bo_292": "ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་གཅིག་ལ་ཐོངས་མཆན་གྱི་ཚོད་འཛིན་བྱ་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ་དང་། ཀྲུང་གོའི་ནང་སྲིད་ལ་ཐེ་ཇུས་ཚབས་ཆེན་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་བསྐྲུན་ནས་ཕྱོགས་སོ་སོར་འགོ་རྩོམ་དགོས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་བྱས་པའི་དུས་ཚོད་བཟོ་བཅོས་བྱས་པ།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་མི་རེ་རེས་འཕྲིན་ཡིག་རེ་བྲིས་པ།",
    "title-g_bo_638": "2023ལོའི་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་བ།",
    "title-g_bo_626": "ཨུ་རུ་སུའི་དམག་ཕམ་ཉེས་གཏོང་བྱེད་པའི་གནས་ཚུལ་གསར་འགྱུར་བྱུང་།",
    "title-g_bo_319": "2023ལོར་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས་ལ་གཞིགས་ན། རང་རྒྱལ་གྱིས་ལོ་ཧྲིལ་པོར་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ནད་དེ་ལ་ཁྱད་ཆོས་གང་དག་ཡོད་པ།",
    "title-g_bo_511": "ཀ་ཧྲ་ས་ཁུལ་དུ་ཕ་ལེ་སི་ཐན་མི་དམངས་ལ་བསགས་པའི་སྡིག་ཉེས་ལ་བསམ་གཞིག་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
    "title-g_bo_185": "མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན་གྱི་གཙོད་ཕྲུག་བཙས་རྗེས་སླར་ཡང་གཙོད་ཕྲུག་ཁྲིད་ནས་དེ་སྔའི་འཚོ་གནས་ཁུལ་དུ་ཕྱིར་ལོག་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_884": "ཨ་རིའི་པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་5200ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་བཙུགས་པའི་ལོ་ངོ་43སོང་རིང་། རྒྱལ་ཁབ་གཉིས་པོའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བར་རིམ་པ་སྤོར་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ།",
    "title-g_bo_165": "ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས་ནས་ལོ་30འཁོར་བའི་ལོ་ཡིན།",
    "title-g_bo_275": "2017ལོའི་ཕུང་རུས་གཉིས་ཀྱི་མགོ་བོ་ཕྲ་ཞིང་རིང་ལ་གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས་འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_900": "2023ལོའི་ཉི་མའི་འགུལ་སྐྱོད་དྲག་པའི་སྐབས་སུ་སྣེ་འོད་མཐོང་ཐུབ་པ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་དང་འཕེལ་རྒྱས་ཀྱི་ལམ་བུའི་ཐོག་བསྐྱོད་རྒྱུ་རེད།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གི་མི་བཟོས་དུ་ཞག་དབྱུག་ནས་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ལ་འགེབས་སྲུང་བྱེད་པ་མ་ཟད། སྐམ་མཚོ་མཁའ་གསུམ་གྱི་མཐུན་སྦྱོར་གཡུལ་འགྱེད་ལ་བརྟེན་ནས་ཀ་ཧྲ་རྒྱུད་ཀྱི་ཕ་ལེ་",
    "title-g_bo_578": "དབྱི་སི་རལ་གྱི་དམག་དཔུང་གི་ཕ་ལེ་སི་ཐན་དང་ཀ་ཧྲ་ས་ཁུལ་གྱི་འཇབ་རྒོལ་བྱེད་པ།",
    "title-g_bo_722": "ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་འབྲེལ་བ་འཕེལ་རྒྱས་གཏོང་བའི་བྱེད་སྤྱོད་བཟང་པོ་བྱུང་བ།",
    "title-g_bo_235": "2024ལོར་ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ཇུས་འགོད་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023ལོའི་བོད་རང་སྐྱོང་ལྗོངས་བུད་མེད་དང་བྱིས་པའི་སྨན་ཁང་གི་ལྷན་སྐྱེས་སྙིང་ནད་ལ་བརྟག་དཔྱད་བྱེད་རྒྱུ་རེད།",
    "title-g_bo_918": "འཛམ་གླིང་ཤེས་དཔལ་གྱི་མེ་ཏོག་སྣ་བརྒྱའི་ལྡུམ་རར་བསམ་བློ་དང་རིག་གནས་ཀྱི་སྟོབས་ཤུགས་སྣོན་དགོས།",
    "title-g_bo_451": "1169ཏག་ཅོག་ཙེའི་སྟེང་དུ་སྤུངས་པའི་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་གྱི་བྱ་དགའ་བླངས་པ།",
    "title-g_bo_997": "2053 རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་9000ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་པའི་ཧོ་ལ་ཐེ་མངའ་སྡེའི་ས་ཡོམ་ནང་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ས་འོག་ཏུ་ལུས་ཡོད།",
    "title-g_bo_544": "ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་དུས་མཇུག་བསྒྲིལ་བ་དང་། འཛམ་གླིང་གི་གསར་སྐྲུན་ཐོག་མ་སྟེ། གཤོག་པ་ཟུང་གི་དྲང་འཕྱང་འཕུར་འབབ་མི་མེད་གནམ་གྲུ་ཞིག་ཀུན་ག",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་སྦྱོང་བརྡར་བྱ་རྒྱུར་ཤུགས་སྣོན་རྒྱག་དགོས།",
    "title-g_bo_847": "2023ལོའི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ངང་གསན་གཟིགས་གནང་བ་དང་དཔོན་དམག་ཚོས་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་སྤེལ་གནང་བའི་སྤྱི་ལོ་2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ལ་བཅིངས་འགྲོལ་དམག་དང་དྲག་ཆས་ཉེན་རྟོག་དཔུང་སྡེའི་ཁྲོད་ལན་ཆ་ཡག",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "ཀ་ཧྲ་ས་ཁུལ་དུ་མི་ཆོས་རྩ་བ་ནས་མེད་པར་འགྱུར་བའི་དབྱི་སི་རལ་དམག་དཔུང་གི་འབྲེལ་ཡོད་བྱེད་སྤྱོད།",
    "title-g_bo_830": "ཀྲུང་གོ་མཚོ་ཐོག་ཉེན་རྟོག་པས་ཧྥི་ལི་ཕིན་གྱི་གྲུ་གཟིངས་ལ་ཐ་ཚིག་ནན་པོར་སྒྲོག་པ།",
    "title-g_bo_90": "2023ལོའི་བོད་སྐད་ཡིག་བརྡ་ཆད་གསར་པ་གཅིག་གྱུར་གཏན་འབེབས་བྱས་པ།",
    "title-g_bo_826": "ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད། དབྱི་སི་རལ་དམག་གི་སྤྱི་ཁྱབ་དམག་དཔུང་གི་འགྲིམ་འགྲུལ་བྱེད་སྐབས་གཏམ་བཤད་སྤེལ་བ།",
    "title-g_bo_17": "5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་ངང་འཕེལ་རྒྱས་བྱུང་བ།",
    "title-g_bo_285": "མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཚེ་ན་ཟུག་གཏོང་བའི་ཁྱབ་ཁོངས་དང་། མཇིང་པར་ན་ཟུག་གཏོང་བའི་ཁྱབ་ཁོངས་ཀྱི་གནས་ཚུལ་བསྡུ་བ།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཨ་རི་གཉིས་ཀྱི་ཁེ་དབང་ལ་བཙན་གནོད་བྱས་པའི་བྱ་སྤྱོད་སྤེལ་བ་དང་འབྲེལ་བའི་གདོང་ཐུག་དོན་རྐྱེན་བྱུང་བ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་སྒྲིག་འགོད་གཉིས་པ་དང་དངུལ་བྱང་འབྲེལ་བ་ཡོད་པ།",
    "title-g_bo_563": "3D མིག་ཤེལ་མི་དགོས་པའི་གཡོ་འགུལ་རྣམ་པ་ཉམས་སུ་མྱོང་བའི་དོན་དངོས། ཀྲུང་དབྱང་བརྙན་འཕྲིན་ཁང་གི་གསར་འགྱུར།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་ནས་འཚོགས།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་ཀྱི་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་བ།",
    "title-g_bo_932": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་ཐོག་མའི་བསམ་འདུན་དང་འགན་འཁུར་བའི་སྒོ་ནས་དུས་རབས་ཀྱི་འབོད་སྒྲར་ལན་སློག་པ།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "2023ལོའི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ། བོད་ལྗོངས་སློབ་ཆེན་གྱི་དགེ་རྒན་ཉི་མ་བཀྲ་ཤིས་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས་ཡོད་པ།",
    "title-g_bo_604": "རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་པ།",
    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "ཀ་ཧྲ་ས་ཁུལ་གྱི་སྨན་ཁང་གཉིས་ཀྱི་གནས་ཚུལ་རྒྱུན་ཆད་མེད་པར་ཇེ་སྡུག་ཏུ་ཕྱིན་པ།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་མེ་འཁོར་གྱི་འཁོར་ལམ་ནས་བྲལ་བའི་ཆག་སྒོ་བྱུང་།",
    "title-g_bo_287": "ཨ་རི་དང་བྱང་ཆིངས་རྩ་འཛུགས་ཀྱི་ཡུག་རེན་ལ་དམག་དོན་རྒྱབ་སྐྱོར་བྱེད་པའི་མཐུན་རྐྱེན་བཟོ་བ།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་བོད་ལྗོངས་ཀྱི་དཔལ་འབྱོར་གྱི་འཕར་ཚད་རྒྱལ་ཡོངས་ཀྱི་མདུན་གྲལ་དུ་སླེབས་པ།",
    "title-g_bo_901": "2023ལོའི་སྔ་དྲོ་ནི་ཁ་ར་ཀྭའི་ཙུང་ཐུང་ཨོའར་ཐེ་ཀ་དང་ཞལ་པར་བསྐྱོན་གནང་ཡོད།",
    "title-g_bo_342": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་ཨེ་ཧེ་ཨ་རིམ་པའི་མདེལ་ལམ་འཕུར་མདའ་དང་ཆུར་འཛུལ་དམག་གྲུ་བཀོད་སྒྲིག་བྱས་པའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་བྱས་པ།",
    "title-g_bo_259": "བོད་ལྗོངས་མང་ཚོགས་སྒྱུ་རྩལ་ཁང་གི་སློབ་མ་བསྟན་འཛིན་དོན་ལྡན་དང་འཆི་མེད་སྒྲོལ་དཀར་གཉིས་ཀྱིས་ཀྲུང་གོ་ཟློས་གར་མཐུན་ཚོགས་ཀྱི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་ལག་ཁྱེར་བརྒྱུད་སྤ�",
    "title-g_bo_685": "ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པ་ལ་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
    "title-g_bo_50": "ལིའང་ཀྲུའུ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་།",
    "title-g_bo_769": "ཕ་ལེ་སི་ཐན་དབྱི་སི་རལ་གྱི་དམག་མཚམས་འཇོག་པའི་གྲོས་ཆོད་དེ་ཉིན་གཉིས་ནར་འགྱངས་གཏོང་རྒྱུའི་མོས་མཐུན་བྱས་ཡོད།",
    "title-g_bo_582": "སྐུད་མེད་དྲ་བ་སྦྲེལ་མཐུད་བྱེད་པའི་གྱོད་དཔེ་གཉིས་ལ་གཟིགས་རོགས།",
    "title-g_bo_635": "ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོ་དང་ལིའུ་ཆེ་གེ་མོ་ལ་ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ཐེབས་པ།",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་བས་བུ་མོ་ཞིག་བསད་འདུག་བྱ་སྤྱོད་འདི་རིགས་ལག་ལེན་བསྟར་རྒྱུ་ཤིན་ཏུ་གལ་ཆེ།",
    "title-g_bo_167": "གཟུགས་པོའི་བརྟག་དཔྱད་གནང་དུས་གཟུགས་པོའི་བདེ་ཐང་གི་གནས་ཚུལ་དངོས་ཤེས་རྟོགས་ཐུབ་པ།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་ཨ་རིའི་མི་སྣར་འཇབ་རྒོལ་རབ་དང་རིམ་པ་ཕོག་པར་ཡ་ལན་སློག་པ་བྱེད་པ།",
    "title-g_bo_872": "འབའ་ཐང་རྫོང་གི་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ཆེན་མོ་ཉེ་ཆར་ཐུགས་གྲ་ལེགས་མཇུག་འགྲིལ་བ་དང་། བྱ་དགའ་ཐོབ་མཁན་གྱི་འགྲན་ཞུགས་པ་རྣམས་ལ་གཟེངས་བསྟོད་སྤྲོད་པའི་མཛད་སྒོ་ཡང་ས་གནས་དེ་གའི་འགོ་ཁྲིད་རྣམ",
    "title-g_bo_247": "2023ལོའི་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་བ།",
    "title-g_bo_575": "2020ལོའི་ཟླ་10པ་ནས་2021ལོའི་ཟླ་11པའི་བར་གྱི་ཡར་ཀླུང་གཙང་པོའི་སྐྱེ་དངོས་སྣ་མང་རང་བཞིན་གྱི་བརྟག་དཔྱད་བྱས་མཐར་གྲུབ་འབྲས་རགས་ཙམ་ཐོབ་པ།",
    "title-g_bo_417": "ཨ་རིའི་སྐུད་ཡོད་བརྙན་འཕྲིན་གྱི་གསར་འགྱུར་དྲ་བའི་ཐོག་ཕ་ལེ་སི་ཐན་འཕྲོད་བསྟེན་ཚན་པའི་གྲངས་གཞི་གསར་ཤོས་ལུང་དུ་དྲངས་པར་གཞིགས་ན། རེས་འཁོར་འདིའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་ད�",
    "title-g_bo_484": "2024ལོའི་སྤྱིར་བཏང་མཐོ་སློབ་ཀྱི་དམིགས་བསལ་རིགས་ཁག་ཅིག་གི་སློབ་བསྡུའི་ལས་དོན་ཡག་པོ་བསྒྲུབ་རྒྱུའི་ཐད་བཀོད་སྒྲིག་བྱས་པ།",
    "title-g_bo_249": "2024ལོ་ནི་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་50འཁོར་བའི་ལོ།",
    "title-g_bo_380": "ཨ་རིའི་དམག་གི་རྟེན་གཞིར་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་དང་གྲོས་མོལ་བྱས་པ།",
    "title-g_bo_959": "ཀྲུང་གོའི་སྨན་པ་ཁོང་ཀོ་པུའུ་ལ་གནས་པ།",
    "title-g_bo_976": "སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར་ཡོད་པ་དང་། མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་བསྟན་དོན།",
    "title-g_bo_97": "2040ལོར་ལྗར་ཕན་དུ་རྒན་རྒོན་ཁྲི་3928བར་མང་དུ་འགྲོ་རྒྱུ་ཡོད།",
    "title-g_bo_309": "ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན་གྱི་བརྗོད་པ་དང་གྲོང་མི་ཀྲང་ཆེ་གེ་མོའི་ལས་གཉེར་བ་བརྟེན་པ།",
    "title-g_bo_56": "རིམས་ནད་སྔོན་འགོག་ཚོད་འཛིན་གྱི་ཆེད་མཁས་པས་དུག་སྦྲང་གི་ནད་པ་འདི་རིཊ་བྱུང་བར་ཆེད་མཁས་པས་དྲན་སྐུལ་བྱས་པ།",
    "title-g_bo_973": "དབང་ཆེན་ཏང་གི་སྐྱིད་སྡུག་དང་གཞུང་གི་ལས་གནས་ནས་ཕྱིར་འབུད་བཏང་འདུག",
    "title-g_bo_294": "བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད། ས་གནས་ཁག་ནས་བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད།",
    "title-g_bo_689": "རྩོམ་སྒྲིག་པས་མཐོ་རྒྱུགས་བཏང་ཟིན་པའི་སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས།",
    "title-g_bo_551": "ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་གྱི་མཛའ་གྲོགས་ལོ་ཡིན་པའི་དོན་ལུགས་བཟོ་བའི་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པ།",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན》དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས་སུ་འགྲེམས་སྤེལ་བྱས་པ།",
    "title-g_bo_146": "ཀྲུང་གོ་དང་མོ་ཞི་ཁོ་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་ལ་ལོ་ཟླའི་ཚོད་བགམ་ཐེག་པ་དང་ལོ་རྒྱུས་ཡུན་རིང་ལྡན་པ།",
    "title-g_bo_351": "འཛམ་གླིང་གི་དཔལ་འབྱོར་སླར་གསོའི་སྒུལ་ཤུགས་མི་འདང་བ་དང་། རྒྱལ་ནང་གི་དུས་མཚམས་རང་བཞིན་དང་གྲུབ་ཆའི་རང་བཞིན་གྱི་འགལ་ཟླ་སྣོལ་འདྲེས་སོགས་ཀྱི་དཀའ་ངལ་དང་འགྲན་སློང་མདུན་དུ། བློ་མཐུན་ཞི་ཅིན་ཕིང",
    "title-g_bo_182": "2008ལོའི་ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ལ་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "2023ལོའི་ཨང་103པ་གྲོས་ཆོད་བྱེད་པའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་གངས་རིན་པོ་ཆེ་དང་མ་ཕམ་གཡུ་མཚོའི་མཛེས་ལྗོངས་ཁུལ་དུ་དགུན་དུས་ལས་མཚམས་འཇོག་རྒྱུའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_225": "ཀྲུང་གོ་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་མཚོན་གྱི་ཡོད།",
    "title-g_bo_131": "རང་རྒྱལ་གྱི་འབྲུ་རིགས་ཐོན་འབོར་གྱི་གཞི་རྩ་འགན་ལེན་བྱས་པ་དང་ཞིང་ལས་ཀྱི་ཐོན་སྐྱེད་བྱེད་སྟངས་ཟམ་མི་ཆད་པར་གསར་གཏོད་བྱེད་པ།",
    "title-g_bo_739": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་དང་ཨ་རིའི་བླང་བྱ་ལྟར་གྲོས་ཆོད་མ་ཟིན་ལ་བརྡས་ཐག་གཅོད་རྒྱུའི་དུས་ཚོད་སླར་ཡང་ནར་འགྱངས་བྱས་པ།",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་103ཟིན་ཡོད།",
    "title-g_bo_553": "བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དང་། ནུས་རྒྱུ་གསར་པའི་འོད་ཤུགས་ཁེ་ལས་ཀྱིས་རང་འགུལ་ངང་རྒྱལ་ཁབ་ཀྱི་ནོར་སྲིད་ཁ་གསབ་བློས་བཏང་ནས་ཉོ་ཚོང་ནང་ཞུགས་ཤིང་། དུས་མཇུག་ཏུ་ནུས་རྒྱ",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་བའི་ཐབས་ཤེས་བྱེད་དགོས།",
    "title-g_bo_141": "བོད་ལྗོངས་ཀྱི་མི་རིགས་མཐུན་སྒྲིལ་ཡར་ཐོན་གྱི་དཔེ་སྟོན་ཁུལ་གཙོ་གནད་དུ་འཛུགས་སྐྱོང་བྱས་པ།",
    "title-g_bo_886": "དབྱི་སི་རལ་དམག་དཔུང་གི་ཧན་ཡིའུ་ཉི་སི་བསྐོར་བ་དང་འབྲེལ་ས་ཁུལ་དེའི་ལྟེ་བའི་ཁུལ་དུ་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ།",
    "title-g_bo_688": "2024ལོར་ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་འབྲེལ་བ་སྐས་རིམ་གསར་པ་ཞིག་ཏུ་སླེབས་རྒྱུར་སྐུལ་འདེད་གཏོང་དགོས།",
    "title-g_bo_586": "ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་ཤུགས་ཆེན་བྱས་པ་དང་མི་སྣར་མུ་མཐུད་སྨན་བཅོས་བྱེད་ཐབས་བྲལ་བར་གྱུར།",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་འཆར་ལ་ཉེ་བའི་མཚམས་འདིར་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་དང་། རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། �",
    "title-g_bo_838": "2023ལོར་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་བ་མི་ཐེངས་ཁྲི་5500ལས་བརྒལ་བར་སྣེ་ལེན་ཞུས་པ།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་དུ་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་།《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་ག",
    "title-g_bo_60": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་དང་ཧོ་པེ་གཞིས་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ས་ཁུལ་གྱི་གནོད་འཚེ་ཕོག་ཁུལ་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ།",
    "title-g_bo_223": "རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།",
    "title-g_bo_96": "ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་དང་ལས་ཀར་ཞུགས་བྱེད་པ། སི་ཁྲོན་ཞིང་ཆེན་རྔ་བ་ཁུལ་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ལྷན་གྱི་ཏང་ཙུའུ་ཡི་ཁོངས་མི། དྲུང་ཆེ། ལས་ཁུངས་ཏང་ཙུའུ་ཡི་ཧྲུའུ་ཅི་ལིའོ་རྨིན་ག�",
    "title-g_bo_312": "དབྱི་རག་གི་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་དགོས།",
    "title-g_bo_176": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་དབར་གྱི་རེས་སྐོར་གསར་པའི་གདོང་ཐུག་དུས་ཚོད་བརྒྱུད་བསྒྲགས་བྱས་པ།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་དང་བོད་ལྗོངས་ལ་ཞིང་ཆེན་རིམ་པའི་མཛེས་རྩལ་ཁང་མེད་པའི་སྟོང་ཆ་དེ་བསྐངས་ཡོད།",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་འཐུས་མི་ཚོགས་པ་དང་ཁྲུང་གོའི་གཙོ་སྐྱོང་འོག་ཀྲུང་གོའི་འཐུས་མི་ཀྲང་ཅུན་གྱིས་དུས་བབ་སྐོར་ལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "བོད་ལུགས་གསོ་རིག་གི་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་སྨན་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "ཞི་ཅིན་ཕིང་གིས་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན།",
    "title-g_bo_174": "ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་65སོང་རིང་། རྒྱལ་ཁབ་གཉིས་པོའི་ཕན་ཚུན་བརྩི་འཇོག་དང་ཕན་ཚུན་ཡིད་ཆེས། ཕན་ཚུན་རྒྱབ་སྐྱོར། ཕན་ཚུན་ཆར་པ་ཆུ་གྲོགས་བཅས་བྱས་ཏེ། རྒྱལ་ཁབ་ཆེ་ཆུང",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "ཀ་ཧྲ་ས་རྒྱུད་དུ་མེ་ཤུགས་འཕུར་མདེལ་དང་འབར་རྗས་བཞི་ཁྲི་ལྔ་སྟོང་ལྷག་འཕེན་ཡོད་པ་དང་། སྤྱིའི་ལྗིད་ཚད་ཏུན་དུག་ཁྲི་ལྔ་སྟོང་ལས་བརྒལ་ཡོད།",
    "title-g_bo_708": "དྲ་དཔོན་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་ཟེར་བའི་བརྙན་ལམ་བྱེད་པ།",
    "title-g_bo_481": "མཚོ་བོད་ས་མཐོར་གནས་པའི་སྟོངས་ལ་ཉེ་བའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "སི་རི་ལན་ཁ་དང་བོད་ལྗོངས་ཀྱི་གླུ་གར་འཁྲུག་ཆ་དོད།",
    "title-g_bo_818": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "ཨ་རིའི་དམག་གིས་ཡེ་མོན་ཧུའུ་སའེ་དྲག་ཤོག་གི་ཚོད་འཛིན་ཁུལ་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་བྱས་པའི་དུས་ཚོད་བཟོ་བཅོས་བྱས་པ།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་ཡོད་དམ།",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་རྒྱལ་དར་གཡུག་གཡུག་བྱས་ནས་ཞི་ཅིན་ཕིང་ལ་ཕེབས་སྐྱེལ་ཞུས།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》གཏོང་སྤེལ་བྱས་པ།",
    "title-g_bo_564": "རྒྱུད་གཅིག་ལམ་གཅིག་ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ཕོ་ལན་གྱིས་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བའི་སྐོར་གྱི་ཡོ་རོབ་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་སྲིད་ཇུས་ལ་ངོ་རྒོལ",
    "title-g_bo_520": "ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "2023ལོའི་སྤྱི་ཟླ་གསུམ་པའི་ཚེས་བཅུ་དྲུག་ཉིན་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་བྱང་སྣེའི་འོད་ཟེར་མངོན་པ།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཀྱིས་མནར་ཡོད།",
    "title-g_bo_749": "ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་མཁའ་འགྲུལ་འགྲེམས་སྟོན་ལ་བརྟེན་ནས་མེ་ཤུགས་འཕུར་མདའི་མེ་སྒྱོགས་ལ་རམས་འདེགས་བྱས་པ།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་གནས་ཚུལ་དངོས་ཤེས་རྟོགས་ཐུབ་པ།",
    "title-g_bo_74": "ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བ་འཛུགས་རྒྱུར་འབད་བརྩོན་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_522": "13000ལོ་རྒྱུས་ལྡན་པའི་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་བྱེད་རིང་སྟ་རེ་སོགས་ཨང་སྒྲིག་དངོས་དཔེ་3000ལྷག་ཙམ་གསར་རྙེད་ཐུབ་པ་མ་ཟད།",
    "title-g_bo_787": "སྤྱི་ཚེས་8ཉིན་སྤྱི་དམངས་ཀྱི་གནས་ཚུལ་སྤེལ་བ་དང་། སྤྱི་ཚེས་8ཉིན་སྤྱི་དམངས་ཀྱི་གནས་ཚུལ་སྤེལ་བ། སྤྱི་ཚེས་8ཉིན་སྤྱི་དམངས་ཀྱི་གནས་ཚུལ་སྤེལ་བ་དང་། སྤྱི་ཚེས་8ཉིན་སྤྱི་དམངས་ཀྱི་ག",
    "title-g_bo_36": "ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་བྱ་དགའ་སྤྲོད་པའི་མཛད་སྒོ་འཚོགས་པ།",
    "title-g_bo_372": "ཙེ་ལན་སི་ཅི་དང་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་བར་གྲོས་བསྡུར་འདི་འདྲ་བྱས་འདུག",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་སྨན་ཁང་གི་གསར་རྟོགས་བྱུང་བ་ལྟར་ན།》",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་སྤྱི་ལོ་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2023ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "དབྱི་སི་རལ་དམག་གི་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དྲག་ཆས་མི་སྣའི་དཔུང་ཁག་གཅིག་རྩ་མེད་བཟོས་པ།",
    "title-g_bo_222": "བོད་ཀྱི་གསོ་རིག་སྨྲ་བ་ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས།",
    "title-g_bo_611": "དགུང་ལོ་90ལ་ཕེབས་པའི་ཡོན་ཧྲི་ཁོང་གིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་དང་རྒྱལ་སྤྱིའི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}