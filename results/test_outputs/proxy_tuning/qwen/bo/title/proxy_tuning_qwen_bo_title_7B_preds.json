    "title-g_bo_491": "《ཕྱོགས་བསྡུས་གནས་ཚུལ་སྙན་ཞུ》《ཏང་གི་ཚོགས་ཆེན་ཉི་ཤུ་པ་འཚོགས་པའི་དོན་སྙིང་》ཀྲུང་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་གྲོས་ཚོགས་གཙོ་སྐྱོང་གནང་བ།",
    "title-g_bo_60": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅིའི་ཕེབས་རོགས་མང་ཚོགས་ཀྱི་སེམས་བདེའི་བརྩེ་དུང་ལ་བརྟེན་ནས་གནོད་འཚེ་ཕོག་པའི་མི་ཚོགས་ལ་བརྟག་ཞིབ་བྱས་པ།",
    "title-g_bo_223": "རུས་ཚིགས་མི་བདེ་བར་བཟོད་བསྲན་བྱ་དགོས།",
    "title-g_bo_96": "སི་ཁྲོན་ཞིང་ཆེན་མི་དམངས་འཐུས་ཚོགས་ཀྱི་ཏང་ཙུའུ་ཡི་ཁོངས་མི། ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་མདོར་བསྡུས།",
    "title-g_bo_312": "སུའུ་ཏ་ཉི་ཡིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱེད་རྒྱུའི་སྐབས་སྐབས་བཞིའི་བར་དུ་བཀག་འགོག་བྱེད་དགོས།",
    "title-g_bo_176": "དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་གྱི་མཁའ་ཐོག་འཇབ་རྒོལ་མི་ཐོན་པའི་བར་མི་ཚོགས་ཆེན་ཐོན་ཡོད།",
    "title-g_bo_145": "བོད་ལྗོངས་མཛེས་རྩལ་ཁང་ལ་བོད་ཀྱི་སྒྱུ་རྩལ་བརྩམས་ཆོས་གྲགས་ཅན་བཤམས་སྟོན་བྱེད་དགོས།",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་འཐུས་མི་ཚོགས་པ་བདེ་འཇགས་ལས་ཁུངས་ཀྱི་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཚིལ་ཞག་ལྡོག་མའི་འཕྲོད་བསྟེན་བདེ་ཐང་གི་བྱ་སྤྱོད།",
    "title-g_bo_174": "ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་མི་དམངས་ཚོགས་ཆེན་ཐེངས་བཅོ་བརྒྱད་པའི་ཐོག་མིང་ཐོ་བཀོད་དེ་བཞུགས་མོལ་ཚོགས་འདུ་བསྡུས།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཐོན་མྱོང་མེད།",
    "title-g_bo_668": "ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་འཇབ་རྒོལ་བྱས་པ་བསྒྲགས།",
    "title-g_bo_708": "རྒྱལ་ཁབ་ཀྱི་དྲ་དཔོན་དེས་ལ་བརྙན་ལམ་དུ་མེ་ཏོག་དཀར་པོ་གཉིས་བཟུང་བཞིན་པ།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་ཚོད་ལྟ་བྱེད་བཞིན་པ།",
    "title-g_bo_218": "སི་རི་ལན་ཁ་བོད་ལྗོངས་ཀྱི་གླུ་གར་ཚོགས་པ་ཞིག་གི་མི་རིགས་གྱོན་ཆས་ལུས་ལ་གྱོན་པའི་བོད་ལྗོངས་ཀྱི་གནའ་ཉམས།",
    "title-g_bo_818": "2023ལོའི་ཞི་ཅིན་ཕིང་ཧ་ནོ་དབྱི་ཀྲུའུ་ཐེ་ནམ་ལ་འཐབ་ཇུས་ཀྱི་དོན་སྙིང་ལྡན་པའི་བྱ་བ་བསྒྲུབ་རྒྱུ་བཅས།",
    "title-g_bo_650": "ཧུའུ་སའེ་དྲག་ཤོག་མིང་ལ་ཙུའོ་ཀེ་ལ་ཧྥེ་ཡ་རྟགས་ཅན་ཞེས་འབོད།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་བྱུང་བ།",
    "title-g_bo_244": "མང་ཚོགས་ལ་ཁ་བསླུས་རྒྱག་མཁན་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་མཁན་ཝང་ཆེ་གེ་མོ་བཟུང་ཚུལ།",
    "title-g_bo_821": "ཉི་ཤར་ཉིང་རྡུལ་ཆུར་འཛུལ་དམག་དཔུ་ནི་ས་གཤིས་ཆ་རྐྱེན་དམིགས་བསལ་ལྡན་པའི་རྫ་ནག་ཤུལ་བཞག་ཡོད།",
    "title-g_bo_560": "ཞི་ཅིན་ཕིང་མི་དམངས་ཚོགས་ཁང་ཆེ་མོར་ཕེབས་ནས་ཕྱི་འབྲེལ་བཙུགས་པའི་དོན་ཚན་བཅུ་བཞི་པར་ཞུགས་པ།",
    "title-g_bo_737": "《ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས》ཞེས་པའི་མིང་ཐོ་འགོད་བྱུང་བ།",
    "title-g_bo_564": "རྒྱལ་ཁབ་ཀྱི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་མཐོ་རིམ་གླེང་སྟེགས་ལེགས་གྲུབ་ལྡན་པའི་ངང་གཉེར་བ།",
    "title-g_bo_746": "2024ལོའི་ལོ་གསར་དགོང་ཚོགས་ཆེན་མོ་བོད་ཀྱི་བོད་རབ་རྒྱན་ཤོང་བའི་ཕྱི་ནང་གི་བརྙན་འཕྲིན་ཁང་དུ་བརྙན་ཕབ་བྱུང་བ།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་ཀྱིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་ཞུགས་རྒྱལ་ཁབ་ལ་བཀོད་སྒྲིག་བྱེད་དགོས།",
    "title-g_bo_520": "ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "2021ལོའི་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་བཅས་གཟབ་རྒྱས་གཟབ་རྒྱུ་ཡིན་པ།",
    "title-g_bo_699": "སྤྱི་ཟླ་2ཚེས་26ཉིན་དབྱིན་ཇིའི་མཚན་མོའི་བྱང་སྣེའི་འོད་ཟེར་མཐོང་དཀོན་པ།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ལ་བྱིས་པའི་བདེ་ཐང་ལོག་པ།",
    "title-g_bo_749": "ཀྲུང་ཧྭའི་མི་མེད་གནམ་གྲུའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུའི་འཕུར་མདའ་མེ་ཞེས་པའི་མཁའ་འགྲུལ་འགྲེམས་སྟོན་ཐོག",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་བའི་ཉིན་དེར་ལུས་རྩལ་དང་ངལ་རྩོལ་གྱི་ཚད་ལས་འདས་པ་གནང་དགོས།",
    "title-g_bo_74": "2023ལོའི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་ལྗར་པན་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_522": "སི་ཁྲོན་ཞིང་ཆེན་ཕན་རོགས་གནའ་ཤུལ་ལ་ལོ་13000ཡན་གྱི་ལོ་རྒྱུས་ལྡན་པ་ར་འཕྲོད་བྱུང་།",
    "title-g_bo_787": "སུའུ་ཏན་གནས་ཚུལ་ལྟར་ན་མི་ཁྲི་400ལྷག་གི་ཁྲོད་བཟའ་བཅའ་དང་སྨན་རྫས་ཁྲོད་མཚེའུ་བཞིན་བསྡད་ཡོད།",
    "title-g_bo_36": "ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོ་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་ལམ་བར་ཐོན་ཚུལ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》བོད་ཀྱི་དམངས་ཁྲོད་སྒྱུ་རྩལ་གྱི་ཆེད་འགན་མི་སྣའི་མཚན་སྙན་ཐོབ་པ།",
    "title-g_bo_372": "རྒྱལ་སྲུང་པུའུ་ཀྲང་བར་གྲོས་བསྡུར་བྱས་པ་ནས་བཟུང་ཡུག་རེན་གཞུང་ཕྱོགས་དྲ་བའི་ཐོག་སྤྱི་ཟླ་11ཚེས་5ཉིན་བརྡ་ཁྱབ་སྤེལ་ནས།",
