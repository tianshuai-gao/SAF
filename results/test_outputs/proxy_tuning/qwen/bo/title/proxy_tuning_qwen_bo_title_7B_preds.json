    "title-g_bo_696": "2022ལོའི་ཀྲུང་གོ་དང་ཨ་རི་བཅས་ཀྲུའུ་ཞི་མཉམ་ལས་གཏིང་ཟབ་བྱུང་བའི་ངོ་མཚར་བཤད་པ།",
    "title-g_bo_675": "སློབ་ཕྱིའི་ལུས་སྦྱོང་བདེ་འཇགས་འགན་སྲུང་མེད་པའི་གནས་ཚུལ་འོག་གསོ་སྦྱོང་བྱ་མི་རུང་།",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_65": "ཀྲུང་གོ་ཕྱོགས་ཀྱི་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པའི་འཁོར་རྒྱུག་ལྡོག་མེད་བྱུང་བ།",
    "title-g_bo_214": "ཨ་རི་ཕྱོགས་ཀྱི་དམག་མཚམས་འཇོག་རྒྱུའི་ཁྲོད་བཀོད་འདོམས་གྲུ་གཟིངས་དང་ཕྱོགས་ཞེན་གྱི་འཐབ་རོགས་བྱུང་བ།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱེད་པ།",
    "title-g_bo_761": "18ཚེས་གསར་འགྱུར་ཁང་གིས་ཡུག་རེན་གྱི་ཕྱོགས་བསྡུས་བྱེད་ཐབས་དང་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་བྱེད་ཐབས།",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ལ་འཇབ་རྒོལ་བྱས་པའི་བརྡ་ཐོ།",
