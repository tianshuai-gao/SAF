    "title-g_bo_527": "2023ལོའི་ཀྲུའུ་ཞི་བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་གི་སྤྱི་པའི་བང་སོ་ཚོམས་ཆེན་དུ་བསྐྱོད་འགོ་ཚུགས།",
    "title-g_bo_726": "ཨ་རིའི་མ་དངུལ་འཕར་བ་དང་ཆག་པའི་བརྟག་དཔྱད་སྙན་ཞུ་བྱས་པ།",
    "title-g_bo_188": "དབྱི་སི་རལ་ཕྱོགས་ཀྱི་མི་གྲངས་1538ལྷག་གི་རྐྱེན་ལམ་དུ་ཤོར་བའི་བཅོས་བསྒྱུifer ས་གནས་ཀྱི་དུས་ཚོད་སྤྱི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་ཀ་ཧྲ་ས་ཁུལ་དུ་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་ཕོག་པའི་ཁྲོད་བྱིས་པ་",
