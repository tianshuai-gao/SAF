    "title-g_bo_650": "ཧུའུ་སའེ་དྲག་ཤོག་གིས་ཧུའུ་སའེ་ཀ་ཧྲའི་རྡུང་རྡེག་འཇབ་རྒོལ་བྱ་རྒྱུ།",
    "title-g_bo_829": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གཉིས་ཀ间的翻译有些不准确，根据内容，更合适的标题应该是：",
    "title-g_bo_330": "《ཁྲག་རྡོའི་ནད་》གནོད་འཚེ་བཅུ་པ།",
    "title-g_bo_244": "བོད་ལྗོངས་ཀྱི་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ཞབས་ཞུ་བྱ་རྒྱུ་མཚམས་འཇོག་བྱེད་པ།",
    "title-g_bo_821": "《བོད་ཀྱི་ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད》",
    "title-g_bo_560": "中国和尼泊尔举行联合反恐军演，加强边境安全合作",
    "title-g_bo_737": "《ཀྲུང་ཧྥུ་ཧྲིན་ཧྲིན：བཟོ་སྐྲུན་ཆེ་མོ་བའི་དཔུང་ཁག་གི་དཔྱད་འདེམས་དང་གཟེངས་བསྟོད་བྱེད་པ》གཏོང་སྤེལ་བྱ་རྒྱུ།",
    "title-g_bo_564": "༢༠༢༣ལོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་མཇུག་འགྲིལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བ།",
    "title-g_bo_746": "2024ལོའི་ཕོ་བྲང་དགོང་ཚོགས་ཆེན་མོའི་བརྩམས་སྒྲུང་དོན་ཚན་བཞི་བརྙན་ཕབ་བྱེད་པ།",
    "title-g_bo_297": "ཕོ་ལན་ཙུང་ཐུང་ཏུའུ་ཏཱ་ཡིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་ཞུགས་རྒྱལ་ཁབ་དང་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བ་བསྐྱར་དུ་བཀོད་སྒྲིག་བྱེད་རྒྱུ་མ་ཟད། སྲིད་ཇུས་དེ་ལ་ངོ་རྒོལ་བྱ་རྒྱུ་ཡིན།",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་བྱ་དགོས》པར་འགྲེམས་བྱེད་པ།",
    "title-g_bo_476": "《བོད་ལྗོངས་ཀྱི་གངས་ལྗོངས་ས་མཐོའི་ཡིད་དུ་འོང་བའི་མཛེས་ཉམས》",
