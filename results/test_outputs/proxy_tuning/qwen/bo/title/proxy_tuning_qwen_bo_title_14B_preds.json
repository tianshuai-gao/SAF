    "title-g_bo_787": "《མི་སེར་ལས་ཁུངས་ཀྱིས་སུའུ་ཏན་ནང་མི་ཁྲི་400ལྷག་བྲོས་བྱོལ་བྱས》",
    "title-g_bo_36": "《མཚོ་བོད་ས་མཐོའི་མེ་འགོག་ལམ་ལུགས་ཀྱི་གཏན་འབེབས་》（A Blueprint for the Traffic Management Plan of the Qinghai Lake Scenic Area）",
    "title-g_bo_495": "《ཀྲུང་ཧྥུའུ་ཀྲུང་གོའི་དམངས་ཁྲོད་སྒྱུ་རྩལ་ཧྲན་ཧྭ》ཧྥུའུ་ཅན་དུ་འཁྲབ་སྟོན་བྱེད་པ།",
    "title-g_bo_372": "ཙེ་ལན་སི་ཅི་དང་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་གི་གྲོས་བསྡུར་འདི་འདྲ་བྱས་པ།",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་གྱི་གྲིབ་ནད་ཀྱི་ཉེན་ཁ་ཆེ་བ》 དུས་དེབ་ཀྱི་བཀོད་པ།",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་སྔོན་རྩིས་འཆར་ཟིན་དང་སྤྱི་ལོ་2023ལོའི་སྔོན་རྩིས་ལག་བསྟར་བྱ་རྒྱུ།",
    "title-g_bo_192": "ཧ་མ་སིའི་དྲག་ཆས་ཤོག་ཁག་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་གྲོང་ཁྱེར་དུ་མེ་སྒྱོགས་སྤྱད་ནས་འཇབ་རྒོལ་བྱུང་།",
    "title-g_bo_222": "ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་ཀྱི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་གཅེས་བཏུས།",
    "title-g_bo_611": "ཧྲེན་ཧྲི་ཀྲའོ་དགུང་ལོ་90ལ་ཕེབས་པ། ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱི་སློབ་གསོ་འཕེལ་རྒྱས་ཐེངས་3པར་སྐྱོན་བྱུང་བ།",
    "title-g_bo_565": "2022ལོའི་རྒྱལ་ཡོངས་ཀྱི་གཙོ་གནད་གྲོང་ཁྱེར་དང་གྲོང་རྡལ་གྱི་གྲོང་མིའི་གཞི་རྩའི་སྨན་བཅོས་འགན་བཅོལ་དང་ལོ་རྒྱུས་ཀྱི་གནས་ཚུལ་དངོས་དཔྱད་བསྡུར་བ།"
}