    "title-g_bo_167": "《གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་ན་ལོ་རྒྱུས་ཀྱི་རྒྱབ་ལྗོངས་དང་ལོ་རྒྱུས་ཀྱི་དོན་སྙིང་ལ་ཐུན་མོང་ཐོག་དགོས》",
    "title-g_bo_283": "《ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ》",
    "title-g_bo_263": "《དབྱི་རན་གྱི་དབྱི་སི་ལམ་གཙོ་བོ་གཉིས་ཀ间的翻译是“大国之间的主要地缘政治事件”或者“主要地缘政治事件的大国之间”。但是，根据上下文，更准确的翻译应该是关于具体事件的标题。所以，更准确的翻译应该是“阿富汗与巴基斯坦边境冲突升级，美国警告”",
    "title-g_bo_872": "《འབའ་ཐང་རྫོང་སྤྱི་ཚོགས་སྟོབས་ཤུགས་ཀྱིས་གཙོ་བོ་བྱས་པའི་ལག་བསྟར་དོན་འཁྱོལ》",
    "title-g_bo_247": "中国和阿富汗庆祝中阿建交70周年",
    "title-g_bo_575": "ཡར་ཀླུང་གཙང་པོའི་གྲོང་རོང་ཆེན་མོ་དང་གྲོང་ཁྱེར་གྱི་སྣོད་བཅུད་མ་ལག་གཞི་རྩའི་ཆ་ནས་འཛམ་གླིང་ལ་གྲགས།",
    "title-g_bo_417": "《ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་དམངས་ཀྱི་བྱིས་པ་དབྱི་སི་རལ་ལ་ཉེན་བརྡ་བཏང》",
    "title-g_bo_484": "2024ལོའི་མཐོ་སློབ་སློབ་བསྡུའི་ལས་དོན་ལ་རྒྱུཊ་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱུང་བའི་ཆ་རྐྱེན་གསར་པ།",
    "title-g_bo_249": "中国和毛里求斯庆祝建交50周年，深化全面战略伙伴关系",
    "title-g_bo_380": "《ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་བྱུང་བ》",
    "title-g_bo_909": "《ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་གསར་པའི་རྒྱལ་ཁབ་གཉིས་པོའི་མཉམ་འབྲེལ་དམག་འཁྲུག》",
    "title-g_bo_959": "中国援助科摩罗建立抗疟中心",
    "title-g_bo_976": "《སུའུ་ཏན་གྱི་བྱིས་པ་མང་པོ་ལ་མི་ཆོས་རིང་ལུགས་ཀྱི་རོགས་སྐྱོར་བྱ་རྒྱུ་》",
    "title-g_bo_97": "《ལྗར་ཕན་ལོ་65ཡན་གྱི་རྒན་རྒོན་བསྡོམས་རྩིས་ལས་ཀ་》",
    "title-g_bo_309": "ནེ་པ་ལ་ས་ཡོམ་6.4བརྒྱབ་པའི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "《རུས་ཚིགས་ཀྱི་སྲུང་སྐྱོབ་ཇི་ལྟར་བྱ་དགོས》",
