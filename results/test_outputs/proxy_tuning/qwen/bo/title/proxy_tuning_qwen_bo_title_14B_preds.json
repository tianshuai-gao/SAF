    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་ཞིབ་བསྡུར་ཚོགས་འདུའི་གཙོ་བོ་གཉེར་བ།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ་\"འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ\"གློག་མིག་ནས་པར་རྒྱག་བྱེད་པ།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཀྲུང་གོའི་མོས་མཐུན་མ་ཐོབ་པའི་བཙུགས་རྐྱེན།",
    "title-g_bo_248": "《སྐད་འཕྲིན་བེད་སྤྱོད་ཀྱི་དངུལ་རྩ་བདེ་འཇགས་དོ་དམ་བྱེད་དགོས》པར་དབང་དངོས་གཞིའི་བཀག་བཅད་གྱོད་དཔེ།",
    "title-g_bo_563": "《ཕུགས་བསམ་དོན་དུ་གཉེར་། ང་ཁྱེད་ལ་དགའ་ཀྭང་གོ་པོ》ཞེས་པའི་3Dབརྙན་ལམ་བསྟན་པ།",
    "title-g_bo_759": "རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་ནས་འཚོགས།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་ཀྱི་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་རྒྱུའི་སློབ་མའི་དོན་དུ་ལོག་པ།",
    "title-g_bo_932": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཧོ་ཐའེ་ཏ་གྲོང་ཁྱེར་གྱི་མཁའ་དབྱིངས་སུ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་པ།",
    "title-g_bo_110": "༢༠༢༣ལོའི་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་མཉམ་ལས་འགོ་ཁྲིད་ཚོགས་འདུ་དངོས་འབྲེལ་ཚོགས་འདུ་ཐེངས་བཞི་པ་འཚོགས་པ།",
    "title-g_bo_707": "《ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡའི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་དེ་སླེབས་པ་བརྗོད་པ》",
    "title-g_bo_822": "《བོད་ལྗོངས་སློབ་ཆེན་གྱི་དགེ་རྒན་བཀྲ་ཤིས་ཀྲོང་གོའི་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས》",
    "title-g_bo_604": "中国共产党第二十次全国代表大会胜利召开",
    "title-g_bo_529": "༧ལོའི༡༠༠%གློ་བ་བཀྲུ་བའི་བྱིས་པ་མངགས་པ། སྨན་ཁང་དུ་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་བརྒྱབ།",
    "title-g_bo_38": "ཧན་ཡིའུ་ཉི་སིའི་ནུབ་རྒྱུད་ཀྱི་སྨན་ཁང་དངོས་མིན་དོན་ཚན་བཟོ་བ།",
    "title-g_bo_341": "《ཨུ་རུ་སུའི་ལྕགས་ལམ་ལས་བྲལ་བའི་ཆག་སྒོ་འགྲོ་བ་དང་འགྲུལ་སྐྱེལ་མེ་འཁོར་གཏོང་བ》",
    "title-g_bo_287": "《བྱང་ཆིངས་ཀྱི་དྲུང་ཡིག་ཆེན་མོའི་སྐབས་སུ་ཡུག་རེན་ལ་དམག་དོན་རྒྱབ་སྐྱོར་བྱེད་པ》པར་འགྲེམས་བྱེད་དགོས།",
    "title-g_bo_394": "2023ལོའི་བོད་ལྗོངས་དཔལ་འབྱོར་གྱི་གཏན་འཇགས་རྒྱུ་ནོར་གྱི་གསར་འགྱུར།",
    "title-g_bo_901": "ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭ་གཉིས་ཀ间的翻译是“中国和尼日利亚两国”。根据上下文，这篇文章是在讨论中国和尼日利亚之间的关系或者合作。所以，这篇文章的标题可以是“ཀྲུང་ཧྭ་དང་ནི་ཁ་ར་ཀྭའི་འབྲེལ་བ།”（中国和尼日利亚的关系/合作）。",
    "title-g_bo_342": "《ཨ་རིའི་ཉིང་རྡུལ་ཆུར་འཛུལ་དམག་གྲུ་གནས་ཚུལ་སྤེལ་བ》",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་མ་ལག་བཙུགས་ནས་འཕེལ་རྒྱས་བྱ་རྒྱུ།",
    "title-g_bo_259": "ཀྲུང་ཧྭའི་བྱིས་པའི་ཟློས་གར་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་མཚན་སྙན་བྱུང་བ།",
    "title-g_bo_685": "《ལི་པི་ཡའི་ཏེ་ཨེར་ན་ཆུ་ལོག་གནོད་འཚེ་བྱུང་བ》",
    "title-g_bo_978": "2023ལོའི་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གཉིས་ཀ间的翻译是：“2023年的中国和不丹两国”",
    "title-g_bo_50": "中国共产党与世界政党高层对话会在北京举行",
