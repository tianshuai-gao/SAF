{
    "title-g_bo_923": "ཆང་ཁྱིམ་གྲོང་ཚོ་ནང་དུ་ཡུལ་སྐོར་བ་ཚོར་ཁ་བཏགས་ཕུལ་བ།",
    "title-g_bo_752": "《ཀ་ཧྲ་མི་དམངས་ཀྱིས་ཅེ་པ་ལི་ཡེ་ཡུལ་གྱར་བའི་བསྒར་སར་འཇབ་རྒོལ་བྱ་རྒྱུ》",
    "title-g_bo_589": "中国和阿里的交往日益密切，西藏拉萨举行庆祝活动",
    "title-g_bo_267": "《མ་བུའི་བརྩེ་བ་ལས：ཕྱི་དྲོའི་མ་བུ་གཉིས་ཀྱི་ཨ་མ་ལ་གླུ་གཞས་གཏོང》",
    "title-g_bo_139": "《ཀོང་ཏུང་གི་ནུས་ཁུངས་གསར་པའི་རླངས་འཁོར་བཅུ་བ》",
    "title-g_bo_809": "ནོ་རོ་ནད་དུག་འགོ་མང་བའི་དུས་ཚིགས་ཀྱི་སྤྱོད་ཚུལ་དང་ནད་རྟགས།",
    "title-g_bo_355": "《སློབ་ཕྱིའི་གསོ་སྦྱོང་གྲོན་དངུལ་དོ་དམ་དང་ཁེ་དབང་སྲུང་སྐྱོབ་ཀྱི་འདུ་ཤེས་དྲན་སྐུལ》གྱི་བརྡ་ཁྱབ།",
    "title-g_bo_154": "《མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས》ཐེངས་28པའི་ཚོགས་ཆེན་བརྒྱུད་དོན་བརྗོད་པ།",
    "title-g_bo_221": "ཀྲུང་གོ་དང་ལྗར་ཕན་གཉིས་ཀ间的翻译是“中国和拉方双方”，因此，结合整篇文章内容，可以将标题翻译为：",
    "title-g_bo_327": "དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་མཐོ་རིམ་དམག་དཔུང་གིས་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_323": "ཨུ་རུ་སུའི་དབྱིར་76གནམ་གྲུ་ལྷུང་བ་དང་ཡུག་རེན་ཕྱོགས་ཀྱི་བརྡ་ཁྱབ་འབྱོར་བ།",
    "title-g_bo_213": "༤༥༠༠ཡན་ཟིན་པའི་གངས་ལྗོངས་ས་མཐོའི་སྟོད་མངའ་རིས། འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེར་ཆགས་པའི་གནས་མཆོག་ཡིན།",
    "title-g_bo_276": "ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ནང་ལེགས་སྒྲུབ་བྱེད་པ།",
    "title-g_bo_954": "中国驻尼泊尔使馆就西藏边防部队在中尼边境地区巡逻发表声明",
    "title-g_bo_962": "12306ཐོག་ཏུ་པ་སེ་ཉོ་བར་སྐར་ཆ་གཅིག་གི་ནང་1400འཚོང་བ་དང་པ་སེ་དངོས་སུ་ཉོ་བའི་དུས་ཚོད་སླེབས་མཁན་དུས་ཚོད་ག་ཚོད་ཀྱིས་བྱེད་རྒྱུ།",
    "title-g_bo_200": "《མཚོ་སྔོན་པོའི་མཚོ་དར་ལ་\"ཞི་བ\"དང\"དྲག་པོ\"གཉིས་ཀྱང་ཡོད》",
    "title-g_bo_210": "《འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གི་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ》པར་གཞི་བཏོད།",
    "title-g_bo_299": "《ཀྲུང་ཧྭ་དང་ཨ་རི་གཉིས་ཀྱི་མཛའ་གྲོགས་མི་སྣའི་དགོངས་དོན་གྱི་འཕྲིན་ལས》ཀྱི་དཔེ་དེབ་《ཀྲུང་གོ་དང་ཨ་རི་གཉིས་པོའི་མཛའ་གྲོགས་མི་སྣའི་དགའ་བསུ་ཐོབ་པ》",
    "title-g_bo_527": "2023ལོའི་ཀྲུང་གོ་གོ་མིན་ཏང་གསར་བརྗེ་ཨུ་ཡོན་ལྷན་ཁང་སྐབས་བཅུ་གཅིག་པའི་ཀྲུང་དབྱང་ཨུ་ཡོན་ལྷན་ཁང་གི་ཀྲུའུ་ཞི་བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་གིས་པེ་ཅིང་པ་པེ་ཅིང་དུ་སྐུ་གཤེགས།",
    "title-g_bo_726": "《ཨ་རིའི་འཛད་སྤྱོད་དངུལ་ལོར་འགྲེམས་ཐལ་ཆག་པ་བྱུང་བ》",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་གྱི་དབྱི་སི་རལ་གཙང་པོའི་ནུབ་འགྲམ་ས་ཁུལ་དུ་གདོང་ཐུག་བྱུང་བ།",
    "title-g_bo_706": "《གཟུགས་པོའི་ནད་དུག་སེལ་བ་དང་ལུས་ཁམས་བདེ་ཐང་བཅོས་སྐྱོང་བ》གི་བཀའ་སྒྲུབ།",
    "title-g_bo_681": "《བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་སྲུང་སྐྱོབ་ལས་ཀ་ལག་བསྟར་དང་འཛམ་གླིང་ལའང་ཕན་བདེ་བྱུང》",
    "title-g_bo_960": "《ཁེན་ཐ་ཅི་མངའ་སྡེའི་དོན་རྐྱེན་འཁོར་ལོ་བྱུང་བ》",
    "title-g_bo_371": "《བོད་ལྗོངས་ཀྱིས་ཕྱི་ཚུལ་རིང་ལུགས་དང་དཔོན་ཉམས་རིང་ལུགས་ལ་རྡུང་རྡེག་བཏང》",
    "title-g_bo_2": "ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་ནང་གི་མིག་སྔར་གློག་གཏོང་དགོས་པའི་ཉེན་ཁ་ཆུང་བ་འཕྲད་བཞིན་ཡོད།",
    "title-g_bo_16": "2023ལོའི་བོད་ལོ་གསར། དར་ལྕོག་དར་ཤིང་དུ་གཅོད་པ།",
    "title-g_bo_844": "༢༠༢༣ལོའི་བོད་ལྗོངས་གཞིས་རྩེ་བཞད་མཐོང་སྨོན་རྫོང་མི་དམངས་ཁྲིམས་ཁང་གིས་རིན་ཆེ་གེ་མོའི་གྱོད་དོན་ལ་འདྲི་གཅོད་བྱས།",
    "title-g_bo_12": "《སློབ་མ་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་བ》",
    "title-g_bo_577": "《ཡོ་རོབ་ཀྱི་དམག་འཁྲུག་བརྟེན་ནས་ཨ་རིའི་དཔལ་འབྱོར་ལ་ཕན་པ་ཐོབ》ཅེས་པའི་རྩོམ་ཡིག་སྤེལ་བ།",
    "title-g_bo_474": "《རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་ནས་གནས་འཕྲིན་སྤེལ་བ》པར་བསྐྲུན་འགྲེམ་སྤེལ་བྱ་རྒྱུ་ཡིན་པའི་རེས་སྐོར་འདིའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱ་རྒྱུ་དང་། རྒྱལ་ཡོངས་ཀྱི་ཆ་སྙོམས་ནས་",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཀྱིས་ཀ་ཤི་སྨིར་གྱི་ལྷོ་རྒྱུད་ལ་འཐབ་འཁྲུག་བྱེད་པ།",
    "title-g_bo_831": "ཡེ་མན་ཧུའུ་སའེ་དྲག་ཆས་དང་དབྱི་སི་རལ་གཉིས་ཀ间的翻译是“也门胡塞武装和也门和沙特之间的”，所以更合适的标题应该是也门胡塞武装和也沙特之间的冲突升级。但是，为了更准确地反映新闻内容，特别是也门胡塞武装对也门和沙特的攻击行为，我们可以将标题调整为更具体的描述。因此，最终标题可以是：",
    "title-g_bo_933": "མའོ་ཆེ་གེ་མོའི་བརྟག་དཔྱད་དང་ལེན་བྱ་རྒྱུ་མཚམས།",
    "title-g_bo_696": "ཀྲུང་ཧྭ་མིའི་རིགས་ཀྱི་སྤྱི་ཚོགས་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་གཏིང་ཟབ་ཏུ་སྐུལ་འདེད་བྱེད་པ།",
    "title-g_bo_675": "《སློབ་ཕྱིའི་གསོ་སྦྱོང་བདེ་འཇགས་ལ་མི་རུང་བ་ལྔའི་དྲན་སྐུལ་བྱ་རྒྱུ》",
    "title-g_bo_404": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གཉིས་ཀྱི་མི་ཉུང་མཐར་ཡང་ཤོར་བ།",
    "title-g_bo_65": "༢༠༢༣ལོའི་ཟླ་བ་བཅུ་པའི་ཚེས་༡༤ཉིན། ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཀྲུང་གོ་དང་ཏེན་མག་གི་མཉམ་འབྲེལ་གྲོས་ཚོགས་བསྐོ་གཞག་བྱ་རྒྱུ།",
    "title-g_bo_214": "《ཕ་དབྱི་གདོང་ཐུག་གི་གྲོས་ཆོད་ཀྱི་དཔང་བོ》པར་དུ་བསྐྲུན་པ།",
    "title-g_bo_79": "《ལྷ་ས་གྲོང་ཁྱེར་སྲིད་གཞུང་གི་ཡིག་ཆ〔2023〕ཨང14》ལག་བསྟར་བྱ་རྒྱུ།",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་ཕོ་ལན་དང་སི་ལོ་ཧྥ་ཁེ་དང་ཧང་ག་རི་བཅས་ཀྱི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱ་རྒྱུ་མེད།",
    "title-g_bo_632": "《ཀ་ཧྲའི་མཁའ་ཐོག་འཇབ་རྒོལ་དོན་ཚན་བེད་སྤྱད་པ》",
    "title-g_bo_318": "《ཅིང་ཡིག་མེད་པར་བཟོ་བའི》ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་དེ་བཟོས་པའི་ཁྲིམས་གཞི་བཏོན་པ།",
