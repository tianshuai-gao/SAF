    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་བྱིས་པ་དབོར་བར་འགོག་རྐྱེན་བཟོ་བ།",
    "title-g_bo_749": "ཀྲུང་གོའི་རྒྱང་མེ་མྱུར་བགྲོད་ཀྱི་མི་མེད་གནམ་གྲུ་ཐོན་གསར་པར་བཟོ་བ།",
    "title-g_bo_168": "《གཟུགས་པོར་བརྟག་དཔྱད་མ་གནང་བའི་རྒྱུ་མཚན་དང་བྱ་སྤྱོད》",
    "title-g_bo_74": "ཀྲུང་གོ་དང་ལྗར་པན་གཉིས་ཀྱི་འབྲེལ་བ་འཕེལ་རྒྱས་འགྲོ་བའི་དུས་རབས་ཀྱི་གྲོས་འཆར།",
