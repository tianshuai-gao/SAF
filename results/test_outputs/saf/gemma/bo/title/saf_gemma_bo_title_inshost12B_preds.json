    "title-g_bo_761": "ཡུག་རེན་གྱིས་འཛམ་གླིང་ཚོང་དོན་རྩ་འཛུགས་ལ་ཞུ་གཏུག་བྱས་འདུག",
    "title-g_bo_632": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ལ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "ཨུ་རུ་སུས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་པ།",
    "title-g_bo_856": "ཁ་བའི་སྡིག་སྲིན་དུང་ཕྱུར་བཅུ་ཕྲག་ཁ་ཤས་མེད་པར་གྱུར་འདུག",
    "title-g_bo_292": "ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་གཅིག་ལ་ཐོངས་མཆན་གྱི་ཚོད་འཛིན་བྱ་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_0": "རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེར་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན། ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་བསྐྲུན་ནས། ལག་གདང་སྦྲེལ་ཏེ་དེང་རབས་ཅན་གྱི་ཕྱོགས་སུ་སྐྱོད་པའི་ལེའུ་གསར་པའི་འགོ་རྩོམ་དགོས་ཞེས་པའི་རྩོམ་ཡིག་སྤེལ་གནང་ཡོད།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་ཁྲོད་རྒྱ་གར་གྱི་མཐའ་སྲུང་དམག་མི་ཞིག་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_180": "འཕྲིན་ཡིག་གཅིག་གིས་ཤུགས་རྐྱེན་ཅི་འདྲ་ཞིག་ཐེབས་སྲིད་དམ།",
    "title-g_bo_638": "མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་12.1%འཕར་ཡོད།",
    "title-g_bo_626": "ཨུ་རུ་སུའི་མཁའ་དམག་གིས་མོ་སེ་ཁོར་འཇབ་རྒོལ་བྱེད་རྩིས་ཡོད་པའི་ཡུག་རེན་གྱི་མི་མེད་གནམ་གྲུ་གཏོར་ལྷུངས་བཏང་།",
    "title-g_bo_319": "2023ལོར་རང་རྒྱལ་གྱིས་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད་དམ།",
    "title-g_bo_511": "པོ་ལི་ཝེ་ཡས་དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
    "title-g_bo_185": "ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་ཕྲུག་བཙས་རྗེས་སླར་ཡང་འཚོ་གནས་ཁུལ་དུ་ལོག་གི་ཡོད།",
    "title-g_bo_884": "པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་ 5200 ཟིན་པ།",
    "title-g_bo_82": "ཞི་ཅིན་ཕིང་གིས་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "ཞི་ཅིན་ཕིང་གིས་ཁོ་ལོམ་པི་ཡའི་ཙུང་ཐུང་ཕེ་ཐེ་ལུའོ་དང་མཇལ་མོལ་གནང་།",
    "title-g_bo_165": "ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་སུམ་ཅུ་བའི་སྟེང་། ཀྲུང་གོས་ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་བརྟེན་ནས་འཛམ་གླིང་རྒྱལ་ཁབ་ཁག་གི་དེང་རབས་ཅན་མངོན་འགྱུར་ཡོང་བར་སྐུལ་འདེད་གཏོང་ཆེད་གོ་སྐབས་གསར་བ་འདོན་སྤྲོད་བྱ་རྒྱུའི་དམ་བཅའ་བཞག་ཅིང་། ཀྲུང་གོའི་དྲིས་ལན་བཏབ་གནང་བ་རེད།",
    "title-g_bo_275": "མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱིས་“གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས”འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_900": "ཤིན་ཅང་ནས་ལྟ་ན་སྡུག་པའི་སྣེ་འོད་མཐོང་ཐུབ་པའི་རྒྱུ་མཚན་ཅི་ཡིན་ནམ།",
    "title-g_bo_550": "ལྗར་པན་གྱིས་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་ལ་དམིགས་ནས་སྙན་ཞུ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_388": "དབྱི་སི་རལ་གྱི་ས་ངོས་དཔུང་སྡེས་ཀ་ཧྲ་གྲོང་མཐའ་སྐོར་བྱས་ཟིན་པ།",
    "title-g_bo_578": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་ལ་ཕར་རྒོལ་བྱས་པ།",
    "title-g_bo_722": "ཞི་ཅིན་ཕིང་གིས་མ་ཏ་ཀ་སི་ཁར་གྱི་ཙུང་ཐུང་ལ་ཆའོ་ལི་ནཱ་ལ་གློག་འཕྲིན་བཏང་གནང་།",
    "title-g_bo_235": "ཧྲ་ཅོན་གྱིས་བོད་ལྗོངས་རྒྱལ་རྩེའི་སྣམ་བུའི་ལག་ཤེས་བཟོ་རྩལ་པ་གདན་དྲངས་པ།",
    "title-g_bo_277": "བོད་རང་སྐྱོང་ལྗོངས་ཀྱི་བྱིས་པའི་ལྷན་སྐྱེས་སྙིང་ནད་སྐྱོབ་བཅོས་ལས་དོན་ལ་སྐུལ་འདེད་ཏན་ཏིག་གཏོང་ཆེད། སི་ཁྲོན་སློབ་ཆེན་ཧྭ་ཤིས་སྨན་ཁང་གཉིས་པའི་བོད་ལྗོངས་སྨན་ཁང་དང་བོད་རང་སྐྱོང་ལྗོངས་བུད་མེད་དང་བྱིས་པའི་སྨན་ཁང ( བོད་རང་སྐྱོང་ལྗོངས་མ་བུ་བདེ་སྲུང་སྨན་ཁང ) གི་ རྒྱལ་ཁབ་ནད་ཐོག་སྨན་བཅོས་ཀྱི་གཙོ་གནད་ཆེད་ཚན་འཛུགས་སྐྲུན་རྣམ་གྲངས་ཀྱི་སྒྲ་རླབས་གསོ་རིག་ཚན་ཁག་གིས་ 2023 ལོའི་ཟླ་ 10 ཚེས་ 8 ཉིན་ནས་དུས་ཡུན་",
    "title-g_bo_918": "འཛམ་གླིང་གི་ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་ལན་ཆ་བཟང་པོ་བྱུང་།",
    "title-g_bo_451": "འབྲུ་རིགས་འདེབས་མཁན་ལ་བྱ་དགའ་སྤྲོད་པ།",
    "title-g_bo_997": "ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་ས་ཡོམ་གྱིས་མི་2053རྐྱེན་ལམ་དུ་ཤོར་བ།",
    "title-g_bo_544": "ཀྲུང་གོའི་གསར་སྐྲུན་ཐོག་མ་སྟེ། གཤོག་པ་ཟུང་གི་དྲང་འཕྱང་འཕུར་འབབ་མི་མེད་གནམ་གྲུ་དངོས་སུ་འགྲེམས་སྟོན་བྱས།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ཀྱི་གཅོང་ནད་འགོག་བཅོས་ཇི་ལྟར་བྱེད་དགོས།",
    "title-g_bo_847": "ཕུའུ་ཅིང་གིས་སྤྱི་ཟླ་9ཚེས་12ཉིན་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ལ་ཞུགས་རྒྱུ་ཡིན་ལུགས་བརྗོད་འདུག",
    "title-g_bo_92": "དམག་ཡོངས་ཀྱིས་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གི་ལོ་གསར་ཤིས་ཚིག་ལ་ལན་ཆ་ཡག་པོ་བྱུང་།",
    "title-g_bo_1": "སྐབས་དྲུག་པའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་ཀྱི་གྲ་སྒྲིག་ལས་དོན་གཞི་རྩའི་ཆ་ནས་ལེགས་གྲུབ་ཟིན་པ།",
    "title-g_bo_936": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གྱི་གདོང་ཐུག་ཁྲོད་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_830": "ཀྲུང་གོའི་མཚོ་ཐོག་ཉེན་རྟོག་པས་ཧྥི་ལི་ཕིན་གྱི་གྲུ་གཟིངས་ལ་ཐ་ཚིག་ནན་པོར་སྒྲོག་པ།",
    "title-g_bo_90": "བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་གཏན་འབེབས་ལས་དོན་གྲོས་ཚོགས་འཚོགས།",
    "title-g_bo_826": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "རྩལ་ནུས་ཤེས་ལྡན་མི་སྣའི་དགོས་མཁོ་ཆེ་རུ་ཕྱིན་པ།",
    "title-g_bo_285": "མཇིང་ཚིགས་ནད་འགོག་བཅོས་བྱེད་ཐབས་བཞི་པ།",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་སུ་ཉོབ་མདངས་སེལ་བའི་ཐབས་ལམ་གསུམ།",
    "title-g_bo_337": "ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས།",
    "title-g_bo_405": "བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་སར་གཉེར་ཡོད།",
    "title-g_bo_858": "ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་གྱིས་ཀྲུང་གོའི་ནན་ཧྲ་གླིང་ཚོམ་གྱི་རེན་ཨའེ་གླིང་ཕྲན་བྲག་རྡོའི་ཉེ་འགྲམ་མཚོ་ཁོངས་སུ་བཙན་འཛུལ་བྱས་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་སྒྲིག་འགོད་གཉིས་ངེས་པར་དུ་བསུབ་དགོས།",
    "title-g_bo_563": "མིག་ཤེལ་མི་དགོས་པའི་3Dབརྙན་ཡོལ་གྱིས་མཐོང་བ་འཁྲུལ་སྣང་གི་ཚོར་བ་བསྐྱེད་ཐུབ།",
    "title-g_bo_759": "རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་འཚོགས་པ།",
    "title-g_bo_432": "སྤྱི་ལོ་2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་སུ་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་གྲབས་ཡོད་པས་སློབ་མས་དོན་འདི་དག་ལ་ཡིད་གཟབ་བྱ་དགོས།",
    "title-g_bo_932": "ཨ་རི་དང་དབྱིན་ཇིས་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་ཐོག་མའི་བསམ་འདུན་མཐའ་འཁྱོངས་བྱས་ནས། དུས་རབས་ཀྱི་འབོད་སྒྲར་ལན་སློག་པ་དང་། ལག་གདང་སྦྲེལ་ནས་གོ་ལ་ཧྲིལ་པོའི་རང་བཞིན་གྱི་འགྲན་སློང་ལ་ཁ་གཏད་གཅོག་དགོས།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡའི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "བོད་ལྗོངས་སློབ་ཆེན་གྱི་དགེ་རྒན་ཉི་མ་བཀྲ་ཤིས་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས་ཡོད།",
    "title-g_bo_604": "ཚའེ་ཆི་ཡིས་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ལ་གསུང་བཤད་གནང་།",
    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་འཁོར་ལམ་ལས་བྲལ་བའི་མེ་འཁོར་གྱི་འཁོར་སྒྲོམ་19ཡོད་པ་བསྟན་པ།",
    "title-g_bo_287": "བྱང་ཆིངས་རྩ་འཛུགས་ཀྱིས་ཡུག་རེན་ལ་དམག་དོན་རྒྱབ་སྐྱོར་བྱ་རྒྱུ་མུ་མཐུད་ནས་རྒྱུན་འཁྱོངས་བྱ་རྒྱུ་ཡིན་པ།",
    "title-g_bo_394": "བོད་ལྗོངས་ཀྱི་དཔལ་འབྱོར་སྟོན་གྲངས་གཙོ་བོ་ལྔ་རྒྱལ་ཡོངས་ཀྱི་མདུན་གྲལ་དུ་སླེབས་པ།",
    "title-g_bo_901": "ཞི་ཅིན་ཕིང་དང་ཨོའར་ཐེ་ཀ་གཉིས་ཀྱིས་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་དབར་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བ་འཛུགས་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་།",
    "title-g_bo_342": "ཨ་རིའི་དམག་གིས་དབྱི་རན་ལ་འཇིགས་སྣང་བསྐུལ་བའི་བརྡ་གསལ་པོ་ཞིག་བཏང་ཡོད།",
    "title-g_bo_629": "རང་རྒྱལ་གྱིས་2025ལོར་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་འབོར་ཆེན་ཐོན་སྐྱེད་བྱ་རྒྱུ་རེད།",
    "title-g_bo_259": "བོད་ལྗོངས་ཀྱི་བྱིས་པ་གཉིས་ལ་ཀྲུང་གོའི་ཟློས་གར་མཐུན་ཚོགས་ཀྱི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་མཚན་སྙན་ཐོབ།",
    "title-g_bo_685": "ལི་པི་ཡའི་ཆུ་ལོག་གནོད་འཚེས་མི་གྲངས་11300རྐྱེན་ལམ་དུ་ཤོར་བ།",
    "title-g_bo_978": "ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ལ་འཕེལ་རིམ་གལ་ཆེན་བྱུང་འདུག",
    "title-g_bo_50": "ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་།",
    "title-g_bo_769": "ཧ་མ་སི་དང་དབྱི་སི་རལ་གྱིས་དམག་མཚམས་འཇོག་པའི་གྲོས་ཆོད་དེ་ཉིན་གཉིས་ནར་འགྱངས་གཏོང་རྒྱུའི་མོས་མཐུན་བྱས་འདུག",
    "title-g_bo_582": "རིན་མེད་སྐུད་མེད་དྲ་བའི་བདེ་འཇགས་ཀྱི་ཉེན་ཁ་གང་ཡོད་དམ།",
    "title-g_bo_635": "ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་དོགས་ཟོན་གྱིས། མི་མང་པོར་ཁ་བསླུས་ཐེབས་འདུག",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་སྟབས་བུ་མོ་ཞིག་བསད་འདུག",
