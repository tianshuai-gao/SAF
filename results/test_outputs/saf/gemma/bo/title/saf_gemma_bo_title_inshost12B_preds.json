    "title-g_bo_225": "བོད་ལྗོངས་ཀྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ།",
    "title-g_bo_131": "ད་ལོ་རང་རྒྱལ་གྱི་སྟོན་འབྲུར་འབབ་འཕར་ཡོང་རྒྱུ་ངེས་གཏན་ཡིན་པ།",
    "title-g_bo_739": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_190": "བོད་ལྗོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་100ཡན་རྒྱུན་འཁྱོངས་བྱེད་ཐུབ་ཡོད།",
    "title-g_bo_553": "བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་བཏང་བ།",
    "title-g_bo_519": "ཁ་རས་རྒྱག་སྐབས་མིག་ཤེལ་ལ་ཁ་རླངས་འཁོར་བའི་གནད་དོན་ཐག་གཅོད་ཇི་ལྟར་བྱེད་དགོས།",
