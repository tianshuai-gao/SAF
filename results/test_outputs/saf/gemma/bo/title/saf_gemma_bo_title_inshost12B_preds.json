    "title-g_bo_886": "དབྱི་སི་རལ་དམག་དཔུང་གིས་ཧན་ཡིའུ་ཉི་སི་གྲོང་ཁྱེར་བསྐོར་བ་དང་འབྲེལ་ས་ཁུལ་དེའི་ལྟེ་བའི་ཁུལ་དུ་དམག་དོན་བྱ་སྤྱོད་སྤེལ་བ།",
    "title-g_bo_688": "ཞི་ཅིན་ཕིང་གིས་ཧྥ་རན་སེའི་ཙུང་ཐུང་མ་ཁེ་ལུང་དང་ཞལ་པར་བསྐྱོན་ཡོད།",
    "title-g_bo_586": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་རྒྱུད་དུ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_990": "ཞི་ཅིན་ཕིང་གིས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་ལྷན་དུ་དུས་ཆེན་ལ་བསུ་བ་ཞུས།",
    "title-g_bo_838": "བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་།",
    "title-g_bo_45": "མཚོ་སྔོན་ཞིང་ཆེན་དུ་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་ཞིག་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "ཀྲུང་གུང་ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་ཀྱིས་གྲོས་ཚོགས་འཚོགས་ནས་ཏང་གི་ཚོགས་ཆེན་ཉི་ཤུ་པའི་དགོངས་དོན་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱས་པ་རེད།",
    "title-g_bo_60": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་གནོད་འཚེ་ཕོག་ཁུལ་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ།",
    "title-g_bo_223": "རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།",
    "title-g_bo_96": "སི་ཁྲོན་ཞིང་ཆེན་རྔ་བ་ཁུལ་གྱི་ལིའོ་རྨིན་ལ་སྒྲིག་འགལ་ཁྲིམས་འགལ་ཚབས་ཆེན་བྱས་པའི་དོགས་གཞི་ཡོད་པས་སྒྲིག་ཁྲིམས་ཞིབ་བཤེར་དང་ལྟ་ཞིབ་བརྟག་དཔྱད་དང་ལེན་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_312": "དབྱི་རག་གིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་དུས་ཚོད་ངེས་གཏན་འཁེལ་མེད།",
    "title-g_bo_176": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་དབར་གྱི་རེས་སྐོར་གསར་པའི་གདོང་ཐུག་ཁྲོད་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_145": "བོད་ལྗོངས་མཛེས་རྩལ་ཁང་སྒོ་ཕྱེ་བ།",
    "title-g_bo_500": "མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཀྱིས་ཅ་ཧྲའི་མི་ཆོས་ཉམས་ཉེན་ལ་དམིགས་ནས་ཚོགས་འདུ་འཚོགས།",
    "title-g_bo_414": "པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "ཞི་ཅིན་ཕིང་གིས་བཟོ་ཚོགས་ལ་ཁྱོན་ཡོངས་ནས་འགོ་ཁྲིད་བྱ་རྒྱུ་རྒྱུན་འཁྱོངས་བྱེད་དགོས་པའི་ནན་སྟོན་གནང་བ།",
    "title-g_bo_607": "འཛམ་གླིང་ཡོངས་སུ་མི་གྲངས་དུང་ཕྱུར་50ལ་སྔར་བཞིན་སྲུང་སྐྱོབ་མ་ཐོབ་པར་ཁོ་ཚོར་སྙིང་ནད་ཕོག་པ་དང་ཤི་འགྲོ་བའི་ཉེན་ཁ་ཆེ་རུ་སོང་ཡོད།",
    "title-g_bo_174": "ཞི་ཅིན་ཕིང་གིས་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་དང་མཇལ་འཛོམས་གནང་།",
    "title-g_bo_619": "ཚེ་ཚད་རིང་དུ་གཏོང་བར་ཕན་པའི་འཚོ་བ་སྐྱེལ་སྟངས་རིགས་5ཡོད་དོ།།",
    "title-g_bo_668": "དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་རྒྱུད་དུ་མུ་མཐུད་དམག་དོན་རྡུང་རྡེག་བཏང་།",
    "title-g_bo_708": "དྲ་དཔོན་ཞིག་གིས་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་ཟེར་བར།",
    "title-g_bo_481": "བོད་ལྗོངས་ཀྱི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་མངོན་འགྱུར་བྱུང་།",
    "title-g_bo_218": "སི་རི་ལན་ཁའི་གར་སྟེགས་སུ་བོད་ལྗོངས་ཀྱི་གླུ་གར་འཁྲུག་ཆ་དོད།",
    "title-g_bo_818": "ཞི་ཅིན་ཕིང་དང་ཝུའུ་ཝུན་ཧྲང་གིས་འཐབ་ཇུས་ཀྱི་དོན་སྙིང་ལྡན་པའི་ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "ཨ་རིའི་དམག་གིས་ཡེ་མོན་ཧུའུ་སའེ་དྲག་ཤོག་གི་ཚོད་འཛིན་ཁུལ་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་ཁྲོད་རྒྱ་གར་གྱི་མཐའ་སྲུང་དམག་མི་ཞིག་རྐྱེན་ལམ་དུ་ཤོར།",
    "title-g_bo_330": "ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་ཡོད་དམ།",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་ནས་ཕྱིར་ལོག་གནང་།",
    "title-g_bo_737": "སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་བཟོ་སྐྲུན་ཆེ་མོ་བའི་བྱ་དགའ་ཐོག་མ་སྤྲོད་པའི་མཛད་སྒོའི་ཐོག་གནང་བའི་མཛུབ་སྟོན་གལ་ཆེན་གྱི་དགོངས་དོན་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་དགོས།",
    "title-g_bo_564": "ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི(2024)ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་སྲིད་ཇུས་ལ་ངོ་རྒོལ་བྱས་པ།",
    "title-g_bo_520": "ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས།",
    "title-g_bo_476": "བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཁའ་དབྱིངས་སུ་རབ་ཏུ་མཛེས་པའི་བྱང་སྣེའི་འོད་ཐིག་མངོན་པ།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཀྱིས་མནར་བཞིན་པ།",
    "title-g_bo_749": "ཀྲུང་གོའི་ཐོན་གསར་པའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུར་ཀུན་གྱིས་དོ་ཁུར་ཆེན་པོ་བྱས།",
    "title-g_bo_168": "གཟུགས་པོར་བརྟག་དཔྱད་གནང་སྐབས་དོ་སྣང་གནང་དགོས་པའི་དོན་དག་གང་དག་ཡོད་དམ།",
    "title-g_bo_74": "ཞི་ཅིན་ཕིང་གིས་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་།",
    "title-g_bo_522": "ཕན་རོགས་གནའ་ཤུལ་ལ་ལོ་13000ཡན་གྱི་ལོ་རྒྱུས་ལྡན་པ་ར་འཕྲོད་བྱུང་།",
    "title-g_bo_787": "སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད།",
    "title-g_bo_36": "ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་བྱས་པ།",
