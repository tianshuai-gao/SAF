    "title-g_bo_451": "2023ལོའི་སྒོར་ཁྲི་བྱ་དགའ་བླངས་པ། ཅང་ཞི་ཞིང་ཆེན་ནན་ཁྲང་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་སྤུངས་པ།",
    "title-g_bo_997": "2053 རྐྱེན་ལམ་དུ་ཤོར་བ་དང་9000 ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་བྱས་པའི་ཧོ་ལ་ཐེ་མངའ་སྡེའི་ས་ཡོམ། འཆི་རྨས་བྱུང་བའི་མི་གྲངས་སྔར་བས་མང་དུ་འགྲོ་སྲིད།",
    "title-g_bo_544": "2023ལོའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་ནས་གཤོག་པ་ཟུང་གྱི་དྲང་འཕྱང་ངང་འཕུར་འབབ་མི་མེད་གནམ་གྲུ་བྱུང་བ།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་སྦྱོང་བརྡར་བྱ་རྒྱུར་ཤུགས་སྣོན་རྒྱག་དགོས།",
    "title-g_bo_847": "2022 ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་སྤྱི་ལོ་སྤེལ་གནང་བ།",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་བྱས་པ།",
    "title-g_bo_936": "2023ལོའི་དབྱི་སི་རལ་དམག་ཕྱོགས་ཀྱི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད། ཀ་ཧྲ་ས་ཁུལ་དུ་མི་ཆོས་རྩ་བ་ནས་མེད་པར་འགྱུར་བ།",
    "title-g_bo_830": "2023ལོའི་ཀྲུང་གོ་མཚོ་ཐོག་ཉེན་རྟོག་ཅུས་ཀྱི་གསར་འགྱུར་མགྲིན་ཚབ་པ་ལིའུ་ཏེ་ཅུན་གྱིས་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་ལ་ཐ་ཚིག་ནན་པོར་སྒྲོག་པ།",
    "title-g_bo_90": "2023ལོའི་བོད་སྐད་ཡིག་བརྡ་ཆད་གསར་པ་གཅིག་གྱུར་གཏན་འབེབས་བྱས་པ།",
    "title-g_bo_826": "2023ལོའི་དབྱི་སི་རལ་དབྱི་བུ་ཕྱོགས་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "2023ལོའི་འགྲན་བསྡུར་ཆེ་མོ་དུས་ཐུང་བཞིན་5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་ངང་འཕེལ་རྒྱས་བྱུང་བ།",
    "title-g_bo_285": "《མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་བྱེད་པའི་བྱ་སྤྱོད་བྱེ་བ་དང་བྱེ་བ་མེད་པའི་གྲ་སྒྲིག》",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་ཀྱི་ཉོབ་སྟངས་དང་སྤྲི་དཀར་གྱི་འབྲེལ་བ་བཟོ་བ།",
    "title-g_bo_337": "2023 ལོའི་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་ཡོད།",
    "title-g_bo_858": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ་གློག་མིག་ནས་པར་རྒྱག་པ།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཨ་རི་གཉིས་ཀྱི་ཁེ་དབང་ལ་བཙན་གནོད་བྱས་པའི་བྱ་སྤྱོད་སྤེལ་བྱུང་།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་སྒྲིག་འགོད་གཉིས་པ་དང་དེ་ལ་བདེ་འཇགས་མེད་པའི་ཕྱིར་བྱེད།",
    "title-g_bo_563": "3D མིག་ཤེལ་མི་དགོས་པའི་གསར་འགྱུར་དེ་སི་ཁྲོན་ཁྲེང་ཏུའུ་ཐའེ་ཀུའུ་ལིར་བསྟན་པ།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་ཚོགས་འདུ་ཐེངས་བཞི་པ་འཚོགས།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་གཏོང་བ། རྒྱུགས་སྤྲོད་ལག་ཁྱེར་དང་འབྲེལ་བ་ཡོད་པའི་སྤྱི་ལོ་དོན་ལེན་བྱས་པ།",
    "title-g_bo_932": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "2023ལོའི་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པ།",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "2023 ལོའི་གསབ་འདེམས་དང་གསར་འདེམས་ཀྱི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པར་བོད་ལྗོངས་སློབ་ཆེན་གྱི་དགེ་རྒན་ཉི་མ་བཀྲ་ཤིས་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིར་བདམས་ཡོད་པ།",
    "title-g_bo_604": "2023 རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་དུ་སྐོང་འཚོགས་བྱས་པ།",
    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག་བྱུང་བ།",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་གྲུབ་བྱེད་ཀྱི་སྨན་ཁང་གཉིས་ཀྱི་གནས་ཚུལ་རྒྱུན་ཆད་མེད་པར་ཇེ་སྡུག་ཏུ་ཕྱིན་པ།",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་མེ་འཁོར་གྱི་འཁོར་ལམ་ནས་བྲལ་བའི་ཆག་སྒོ་བྱུང་།",
    "title-g_bo_287": "བྱང་ཆིངས་རྩ་འཛུགས་ཀྱི་དྲུང་ཡིག་ཆེན་མོ་སི་ཐུའོ་ཨེར་ཐེང་པེ་ཀེ་ཡིས་ཡུག་རེན་ལ་དམག་དོན་ཐེབས་སྲིད།",
    "title-g_bo_394": "2023ལོའི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་བཞིན་བོད་ལྗོངས་ཀྱི་འཕར་ཚད་རྒྱལ་ཡོངས་ཀྱི་མདུན་གྲལ་བྱུང་བ།",
    "title-g_bo_901": "2023ལོའི་སྔ་དྲོ་ནི་ཁ་ར་ཀྭའི་འབྲེལ་བ་དངོས་སུ་འཛུགས་པའི་ཁྱབ་བསྒྲགས་གནང་བ།",
    "title-g_bo_342": "2023ལོའི་ཐོག་སྤྱི་ཚེས་5ཉིན་ནས་ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་མཐོང་དཀོན་པའི་གསལ་བསྒྲགས་ཤིག་སྤེལ་བྱས་པ། ཨ་རིའི་ཨེ་ཧེ་ཨ་རིམ་པའི་མདེལ་ལམ་འཕུར་མདེལ་ཉིང་རྡུལ་ཆུར་འཛུལ་དམག་གྲུ་ཞིག་དབུས་ཤར་ས་ཁུལ་དུ་འབྱ",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་འབོར་ཆེན་ཐོན་སྐྱེད་བྱ་རྒྱུ་རེད།",
    "title-g_bo_259": "27པའི་ཀྲུང་གོའི་བྱིས་པའི་ཟློས་གར་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་གཟི་བརྗིད་ལག་ཁྱེར་བརྒྱུད་སྤྲོད་གནང་།",
    "title-g_bo_685": "ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པ་ལ་འཇབ་རྒོལ་བྱས་པའི་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་།",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་གྲོས་མོལ་བྱེད་པར་ཡོང་བའི་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
