    "title-g_bo_60": "2023ལོའི་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ།",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_96": "2023ལོའི་སི་ཁྲོན་ཞིང་ཆེན་རྔ་བ་ཁུལ་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ལྷན་གྱི་ཏང་ཙུའུ་ཡི་ཁོངས་མི་ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་མདོར་བསྡུས།",
    "title-g_bo_312": "དབྱི་རག་གི་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་དགོས།",
    "title-g_bo_176": "2023ལོའི་གདོང་ཐུག་བཟོ་བསྒྲུབ་བྱེད་དུས་ནས་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤོར་བ།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་དང་བོད་ལྗོངས་ལ་ཞིང་ཆེན་རིམ་པའི་མཛེས་རྩལ་ཁང་མེད་པའི་སྟོང་ཆ་བྱུང་བ།",
    "title-g_bo_500": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་ནས་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བདེ་འཇགས་ལས་འཛིན་ལྷན་ཚོགས་ཀྱིས་ཀྲུང་གོའི་གཙོ་སྐྱོང་འོག་དུ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "2023ལོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ་བའི་བཟོ་བརྗོད།",
    "title-g_bo_101": "2023ལོའི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ། ཞི་ཅིན་ཕིང་གི་བཟོ་ཚོགས་ལ་ཕྱོགས་ཡོངས་འགོ་ཁྲིད་བྱ་རྒྱུ་རྒྱུན་འཁྱོངས་བྱས་པ།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན།",
    "title-g_bo_174": "2023ལོའི་ཕྱི་ལོག་འབྲེལ་བ་དང་ཕན་ཚུན་བརྩི་འཇོག་བྱེད་པ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ལོ་65བསྟུན་བྱེད་པ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་བྱུང་། མི་ཚོར་ཕྱོགས་བསྡུས་འཚོ་བ་སྐྱེལ་སྟངས་ལ་འགྱུར་ལྡོག་བཏང་ནས་ཚེ་ཚད་རིང་དུ་གཏོང་ཐབས་བསྟན།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་ཀ་ཧྲ་ས་རྒྱུད་བཏང་རྡུང་བྱེད་དགོས།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་དེ་ལྟར་བཤད་པའི་དྲ་དཔོན་གྱི་བརྙན་ལམ་བྱས་པ།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་སྟོངས་ལ་ཉེ་བའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བཀྲ་ཤིས་སྨོན་འདུན》གླུ་གར་ཚོགས་པ་སི་རི་ལན་ཁ་དུ་བོད་ལྗོངས་ཀྱི་གླུ་གར་འཁྲུག་ཆ་དོད།",
    "title-g_bo_818": "2023ལོའི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་དུས་ཚོད་ནས་ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "2023ལོའི་ས་ནཱ་ཡི་ས་གནས་དུས་ཚོད་ནས་ཧུའུ་སའེ་དྲག་ཤོག་གི་ཚོད་འཛིན་ཁུལ་ལ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་བྱས་པའི་དུས་ཚོད་བཟོ་བསྐྲུན།",
    "title-g_bo_330": "《ཁྲག་རྡོ་བྱུང་བའི་གནོད་འཚེ་དང་ལུས་ཕུང་ལ་གནོད་པ།》",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་པ།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཨ་རི་ཕྱོགས་ཀྱི་ཕྱི་འབྲེལ་བཟོ་བསྒྲིགས་དང་། ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་རྒྱལ་དར་གཡུག་གཡུག་བྱས་པ།",
    "title-g_bo_737": "2023ལོའི་མྱུར་དཔྱད་ནང་། འདི་ག་ལས་ཁུངས་ཀྱིས་ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་གཏོང་སྤེལ་བྱས་པ།",
    "title-g_bo_564": "2023ལོའི་སྐབས་དང་པོའི་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024 ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་ལོ་གསར་དགོང་ཚོགས་ཆེན་མོ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བ་བསྐྱར་དུ་བཀོད་སྒྲིག་བྱ་རྒྱུའི་བླང་བྱ་བཏོན།",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》",
    "title-g_bo_476": "2023ལོའི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་བོད་ལྗོངས་ཀྱི་སོ་ནམ་རིག་གནས་བྱེད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་ལ་བྱང་སྣེའི་འོད་ཟེར་མངོན་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཀྱིས་མནར་ཡོད། མི་ཆོས་རིང་ལུགས་ཀྱི་རོགས་སྐྱོབ་དངོས་རྫས་ཀ་ཧྲ་རྒྱུད་དུ་སྐྱེལ་བར་འགོག་རྐྱེན་ཐེབས་པ།",
    "title-g_bo_749": "2023ལོའི་རྒྱལ་སྤྱིའི་མཁའ་འགྲུལ་འགྲེམས་སྟོན་ནི་ཀྲུང་གོའི་རྒྱང་མེ་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་བྱས་པའི་དོ་ཁུར་ཆེན་པོ་བྱེད།",
    "title-g_bo_168": "2023ལོའི་དུས་བཀག་ལྟར་གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་གནས་ཚུལ་དང་བྱུང་རྒྱུ།",
    "title-g_bo_74": "2023ལོའི་ཕྱི་དྲོ་ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བའི་མཛའ་གྲོགས་ཆིངས་ཡིག་བཞག་ནས་ལོ་45འཁོར་བའི་ལོ་བར་ཞི་བའི་མཛའ་གྲོགས་ཆིངས་ཡིག་བཞག་ནས་ལོ་45འཁོར་བའི་ལོ་བར་ཞི་བའི་མཛའ་གྲོགས་ཆིངས་ཡིག་བཞག་ནས་ལོ་45འཁོར་བའི",
