{
    "title-g_bo_923": "2021ལོའི་ཡུལ་སྐོར་ཚོགས་པ་དུ་བོད་ལ་ཡོང་བའི་ཡུལ་སྐོར་བ་ཡུས་དབྱང་གིས་ད་ཐེངས་བོད་ལ་ཡུལ་སྐོར་དུ་ཡོང་ནས་བོད་མི་དམངས་ཀྱི་སྤྲོ་སེམས་ཀྱང་ཚོར་བྱུང་བས་ཐུགས་རྗེ་ཆེ་ཞུ་རྒྱུ་ཡིན།",
    "title-g_bo_752": "ཀ་ཧྲ་རྒྱུད་ཀྱི་ཡུལ་གྱར་བའི་བསྒར་སར་ལ་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_589": "2023ལོའི་ཨ་རིའི་རྒྱལ་ཚོགས་ཀྱི་གྲོས་ཚོགས་སྟོད་པའི་ཏང་གཉིས་ཀྱི་འཐུས་མི་ཚོགས་པ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_267": "2022ལོའི་རྟ་མགྲིན་བུ་གཉིས་མཚོ་ལྷོ་བོད་རིགས་རང་སྐྱོང་ཁུལ་གྱི་ཨ་མ་ལགས་ཀྱིས་ལས་ཞོར་དུ་ངག་ལས་སྙན་པོའི་དབྱངས་རྟ་ལེན་བྱུང་བ།",
    "title-g_bo_139": "2023ལོར་ཀོང་ཏུང་གི་ས་ཁུལ་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13.57ཟིན་ནས་རྒྱལ་ཡོངས་ཀྱི་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་ག�",
    "title-g_bo_809": "ལོ་རེའི་སྤྱི་ཟླ་10ནས་ཕྱི་ལོའི་སྤྱི་ཟླ་3བར་ནི་ནོ་རོ་ནད་དུག་འགོ་མང་བའི་དུས་ཚིགས། སློབ་གྲྭ་དང་བུ་བཅོལ་ཁང་སོགས་མི་ཚོགས་འདུ་ཡུལ་ནི་ནོ་རོ་ནད་དུག་འགོ་ཁྱབ་ཆེ་ས་ཞིག་ཡིན།",
    "title-g_bo_355": "2023ལོའི་སློབ་གསོ་གསོ་སྦྱོང་ལྟ་སྐུལ་དོ་དམ་སི་དང་སྤྱི་བདེ་པུའུ་ཡི་ཉེས་དོན་མྱུལ་ཞིབ་ཅུའུ་ཡིས་མཉམ་འབྲེལ་ཐོག་སློབ་གྲྭའི་ཕྱི་རོལ་གྱི་གསོ་སྦྱོང་གྲོན་དངུལ་ཕྱིར་སློག་གི་མིང་ཐོག་ན",
    "title-g_bo_154": "2023ལོའི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས་ཚོགས་ཆེན་བཞིན་བྱུང་བ།",
    "title-g_bo_221": "ཀྲུང་གོའི་ཕྱོགས་ཀྱིས་ལྗར་ཕན་གྱི་སྤྱི་དམངས་ལ་གསང་མྱུལ་བྱ་སྤྱོད་སྤེལ་བའི་དོགས་གཞི་ཡོད་པའི་བྱ་རྒྱུའི་ཐག་བཅད་ཡོད་མེད་སྐོར་ལ་ར་སྤྲོད་བྱེད་ཐུབ་བམ།",
    "title-g_bo_327": "2023ལོའི་དབྱི་རན་གྱི་འབར་གས་དོན་རྐྱེན་ཐེངས་གཉིས་པ་དེ་ཐོན་ནས་མི་95རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་211ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_323": "2023ལོའི་ཨུ་རུ་སུའི་དམག་སྤྱོད་སྐྱེལ་འདྲེན་གནམ་གྲུ་གཏོར་ལྷུང་བཏང་བྱུང་། ཡུག་རེན་དམག་དབོར་བྱེད་ཀྱི་དབྱིའར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་གཏོར་ལྷུང་བཏང་བྱུང་།",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཡུལ་ལུང་ཉམས་དགའ་བའི་གནས་མཆོག་བོད་ལྗོངས་ཀྱི་ཡང་རྩེའི་ཡང་རྩེར་ཆགས་པ།",
    "title-g_bo_276": "2024 ལོའི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་དེ་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ་བཟོས་པ།",
    "title-g_bo_954": "2023ལོའི་ཐད་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་ལ་འཚམས་འདྲིའི་གློག་འཕྲིན་བཏང་གནང་བ།",
    "title-g_bo_962": "12306ཐོག་ཏུ་བྱེད་ནུས་གསར་པ་འདི་དག་བསྣན་འདུག: དཔྱིད་གསར་དུས་ཆེན་གྱི་མེ་འཁོར་པ་སེ་འཚོང་འགོ་བརྩམས་ཡོད་པ།",
    "title-g_bo_200": "《མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ་“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ》",
    "title-g_bo_210": "2019ལོའི་ཟླ་12ཚེས་1ཉིན་གྱི་འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ་ནི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་འཐབ་ཇུས་གལ་ཆེན་ཞིག་ཡིན།",
    "title-g_bo_299": "2023 ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གི་འཕྲིན་ལན་སྤྲིངས་ནས་ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་མི་སྣའི་དགའ་བསུ་ཐོབ་པ།",
    "title-g_bo_527": "2023ལོའི་ཨུ་ཡོན་ལྷན་ཁང་གི་བློ་མཐུན་ཀྲོའུ་ཐེ་ནུང་ལ་སྐྱོ་གདུང་ཆེན་པོ་བྱུང་བ།",
    "title-g_bo_726": "2023ལོའི་ཉིན་གུང་ཞིག་དེ་གཉིས་མཉམ་དུ་འཕར་བ་དང་མཇུག་མཐའི་དུས་སྐབས་སུ་འཕར་ཆག་བྱུང་། ཨ་རིའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་ལ་སྔོན་དཔག་བྱས་ཚུལ་སྤྱིའི་ཆ་ནས་ཆག་པ།",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་དབྱི་སི་རལ་གྱི་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་ལ་གཞུང་ཕྱོགས་ཀྱི་ཆ་འཕྲིན་གསལ་པོ་ཞིག་མེད།",
    "title-g_bo_706": "གཟུགས་པོའི་ལྷག་མཐའ་བྱུང་བ་དང་བྱུང་བ་མི་འདང་བའི་བྱེད་སྤྱོད།",
    "title-g_bo_681": "2020ལོའི་འབྱུང་ཁམས་ཤེས་དཔལ་ནི་བོད་ལྗོངས་ཀྱི་གཏན་ཁེལ་བྱས་པའི་འབྱུང་ཁམས་སྲུང་སྐྱོབ་བྱ་རྒྱུར་ཚད་མཐོ་བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "2023ལོའི་ཨ་རིའི་ཁེན་ཐ་ཅི་མངའ་སྡེའི་ས་གནས་དེ་གའི་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་ཞིག་ཐོན་པ།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱི་ཕྱི་ཚུལ་རིང་ལུཊ་དང་དཔོན་ཉམས་རིང་ལུཊ་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "2023ལོའི་ས་ཡོམ་བརྒྱབ་པ་དང་མེ་རི་འཕྱུར་བའི་ཉེན་ཁ་ཆེ་རུ་ཕྱིན་པའི་ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་གནས་ཚུལ་ཐོན་པ།",
    "title-g_bo_16": "2023ལོའི་ལོ་གསར་འཆར་ལ་ཉེ་བའི་དར་ཤིང་ལས་འཕྲོས་པའི་འབྱུང་ཁམས་སྲུང་སྐྱོང་གི་ཕུགས་འདུན།",
    "title-g_bo_844": "2023ལོའི་ཉེས་ཆད་གཏོང་བ་དང་པོ་བྱས་པའི་ཕྱི་མ་རིན་ཆེ་གེ་མོ།",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ། པེ་ཅིང་གྲོང་ཁྱེར་སློབ་གསོ་ཨུ་ལྷན་གྱིས་བརྡ་ཐོ་བཏང་བ།",
    "title-g_bo_577": "2023ལོའི་ཨ་རི་དཔལ་འབྱོར་ལ་ཕན་པ་ཇི་ལྟར་ཐོབ་པ་བྱེད་པའི་དོན་དངོས། ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ལས་ཁེ་ཕན་ཆེན་པོ་ཐོབ་པ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་ནས་གནས་འཕྲིན་སྤེལ་བ་དང་། རེས་སྐོར་གསར་པའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུ",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཀ་ཤི་སྨིར་ས་ཁུལ་དུ་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་འཐབ་འཁྲུག་བྱས་པ།",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གི་བར་དུ་འགྲན་རྒོལ་བྱས་པ།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་ནི་མའོ་ཆེ་གེ་མོ་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་དངུལ་ཁང་གཱ་བསྡམས་བཅད་བྱས་པའི་སྐོར་གྱི་མང་ཚོགས་མའོ་ཆེ་གེ་མོའི་བློ་འདྲིའི་ཁ་པར་འབྱོར་བ་དང་། མའོ",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ནི་ཀྲུང་གོ་དང་མཉམ་སྐྲུན་རྒྱལ་ཁབ་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་ཨ་སྒོར་དུང་ཕྱུར་ཁྲི་31ཟིན་པ་བྱེད་པ།",
    "title-g_bo_675": "སློབ་གསོ་པུའི་ལུས་སྦྱོང་བདེ་འཇགས་སྐོར་མི་རུང་བ་ལྔ་བཏོན་པ།",
    "title-g_bo_404": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གནས་ཚུལ་གསར་ཤོས། མི་ཉུང་མཐར་ཡང་15546རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_65": "2023ལོའི་གསར་དུ་བསྐོ་གཞག་བྱས་པའི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ།",
    "title-g_bo_214": "2023ལོའི་གདོང་ཐུག་བཟོ་བྱེད་ནས་འཐབ་རོགས་བྱས་པའི་ཕ་དབྱི་གདོང་ཐུག་གི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་འཕེལ་རྒྱས་ཤུགས་ཆེན་གཏོང་ཆེད།",
    "title-g_bo_761": "ཡུག་རེན་གྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་པ། ཡུག་རེན་གྱི་ཕྱིར་གཏོང་ཚོང་པ་དང་མངགས་ཐོ་དུས་ལྟར་ལེགས་སྒྲུབ་མ་ཐུབ་པར་གྱོང་གུན་ཆེན་པོ་ཕོག་ཡོད།",
    "title-g_bo_632": "200 མི་བཟུང་བའི་ཕ་ལི་སི་ཐན་དབྱི་སི་རལ་འགོག་རྒོལ་ལས་ཀ་ཧྲ་རྒྱུད་དུ་རྡུང་རྡེག་བཏང་བ་དང་། དབྱི་སི་རལ་དམག་གི་མཁའ་ཐོག་འཇབ་རྒོལ་ལ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད།",
    "title-g_bo_318": "2023ལོའི་འདེམས་ཤོག་ཡོངས་ཀྱི་ཐོག་ནས་ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་པ།",
    "title-g_bo_856": "ཨ་རིའི་མཚོ་ཁོངས་ནས་ཁ་བའི་སྡིག་སྲིན་འབོར་ཆེན་བྱུང་བ། རྒྱ་མཚོའི་དྲོད་ཚད་མཐོ་རུ་སོང་བས་ཡིན་པ་ཤེས་རྟོགས་བྱུང་ཡོད།",
    "title-g_bo_292": "2023ལོའི་ཕྱི་འབྲེལ་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་གསར་འགོད་པ། ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་ལ་ཐོངས་མཆན་གྱི་ཚོད་འཛིན་བྱ་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་ནས་རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐེངས་དང་པོ་བྱས།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས། ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་བསྐྲུན་ནས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་འཐབ་བྱས་པའི་དུས་ཚོད་བཟོ་བསྐྲུན།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་མི་རེ་རེས་འཕྲིན་ཡིག་རེ་བྲིས་པ།",
    "title-g_bo_638": "2023 ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་བ།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གོང་དུ་ཡུག་རེན་དམག་གི་མི་མེད་གནམ་གྲུ་གཏོར་ལྷུངས་བཏང་བ་དང་ཨུ་རུ་སུའི་དམག་ཕམ་ཉེས་གཏོང་རྩིས་བྱེད་པ།",
    "title-g_bo_319": "2023ལོར་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས། རང་རྒྱལ་གྱིས་8000ལྷག་ཉོ་སྒྲུབ་བྱས་པ།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་པའི་བྱིས་པ་མངོན་གསལ་དོད་པ། མི་ཚང་མ་དང་གཞོན་ནུ་ལོ་ཆུང་ལ་ཕོག་པ་མང་།",
    "title-g_bo_511": "ཀ་ཧྲ་ས་ཁུལ་དུ་ཕ་ལེ་སི་ཐན་མི་དམངས་ལ་བསགས་པའི་སྡིག་ཉེས་ལ་བསམ་གཞིག་བྱས་པ། དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས། འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།",
    "title-g_bo_185": "2023ལོའི་སྤྱི་ཟླ5པ་ནས7པའི་བར་དུ་གཙོད་ཕྲུག་བཙས་རྗེས་མཚོ་བོད་གཞུང་ལམ་བརྒྱུད་དེ་འཚོ་གནས་ཁུལ་དུ་བསྐྱོད།",
    "title-g_bo_884": "2023 ལོའི་སྤྱི་ཚེས་18ཉིན་པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་5200 ཟིན་པ།",
    "title-g_bo_82": "2023 ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཕྱི་དྲོ་དུས་ཚོད་བགམ་བརྒྱུད་ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་བཙུགས་པ།",
    "title-g_bo_165": "2023ལོ་ནི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས་ནས་ལོ་30འཁོར་བའི་ལོ།",
    "title-g_bo_275": "2017ལོའི་ཕེ་རུ་ནས་རྙེད་པའི་ཕུང་རུས་གཉིས་ཀྱི་མི་ཤེས་པའི་རྒྱུན་འགལ་སྣང་ཚུལ་དང་འབྲེལ་བ་ཡོད་པའི་ཡོངས་བསྒྲགས་དཔང་ཉན་ཚོགས་འདུ་ཐེངས་དང་པོ་འཚོགས་པ།",
    "title-g_bo_900": "2023ལོའི་ཉི་མའི་འགུལ་སྐྱོད་དྲག་པའི་སྐབས་སུ་བྱང་སྣེའི་སྣེ་འོད་མཐོང་ཐུབ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་གསར་འགོད་པའི་ཚོགས་འདུ་གཙོ་སྐྱོང་གནང་བ།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གི་མི་བཟོས་དུ་ཞག་དབྱུག་ནས་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ལ་འགེབས་སྲུང་བྱེད་པ་མ་ཟད། སྐམ་མཚོ་མཁའ་གསུམ་གྱི་མཐུན་སྦྱོར་གཡུལ་འགྱེད་ལ་བརྟེན་ནས་ཀ་ཧྲ་རྒྱུད་ཀྱི་ཕ་ལེ་",
    "title-g_bo_578": "2023ལོའི་ཚེས་22ཉིན་དབྱི་སི་རལ་དམག་ཀ་ཧྲ་ས་ཁུལ་ལ་ཕར་རྒོལ་བྱས་པ།",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་འབྲེལ་བ་འཕེལ་རྒྱས་བྱེད་པའི་བཟོ་སྤྱོད་བྱུང་བ།",
    "title-g_bo_235": "2024ལོར་ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ལ་ཧྲང་ཧའེ་ཅིན་ཧྲན་ནས་ཡོང་བའི་རང་བདག་རྩེར་སོན་སྒྱུ་རྩལ་གྱི་ཁུ་ལུའི་སྤུས་རྟགས་ཧྲ་ཅོན་ཐོག་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023 ལོའི་བོད་རང་སྐྱོང་ལྗོངས་བྱིས་པའི་ལྷན་སྐྱེས་སྙིང་ནད་སྐྱོབ་བཅོས་ཀྱི་གཙོ་གནད་ཆེད་ཚན་འཛུགས་བརྟག་དཔྱད་བྱེད་རྒྱུ་རེད།",
