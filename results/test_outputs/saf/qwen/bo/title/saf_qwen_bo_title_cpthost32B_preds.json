    "title-g_bo_769": "2023 ལོའི་སྤྱི་ཚེས་27ཉིན་ཕ་ལེ་སི་ཐན་དབྱི་སི་རལ་བར་ཁུངས་གཞི་བརྒྱུད་བྱས་པའི་གནས་ཚུལ།",
    "title-g_bo_582": "21 ཚོད་བྱེད་ཀྱི་སྐུད་མེད་དྲ་བ་དང་བདེ་འཇགས་ཀྱི་ཉེན་ཁ་གཉིས་ཀྱི་གཟིགས་རོགས།",
    "title-g_bo_635": "2023ལོའི་ཟླ་4ཚེས་ལྷ་ས་གྲོང་མི་ལི་ཆེ་གེ་མོ་དང་ལིའུ་ཆེ་གེ་མོ་ལ་ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ཐེབས་པ།",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་བས་བུ་མོ་ཞིག་བསད་པ་དང་བྱ་སྤྱོད་འདི་རིགས་ལག་ལེན་བསྟར་བྱས་པ།",
    "title-g_bo_167": "2023ལོའི་བརྟག་དཔྱད་གནང་དུས་གཟུགས་པོའི་བདེ་ཐང་གནས་ཚུལ་དངོས་པ།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེ་སྐུ་སྲུང་རུ་ཁག་དང་གང་དེའི་རྒྱབ་སྐྱོར་རྩ་འཛུགས་ཀྱི་སི་རི་ཡའི་ཤར་རྒྱུད་ལ་ཡ་ལན་སློག་པ་བྱས་པ།",
    "title-g_bo_872": "2023ལོའི་འབའ་ཐང་རྫོང་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ཆེན་མོ་ཉེ་ཆར་ཐུགས་གྲ་ལེགས་མཇུག་འགྲིལ་བ།",
    "title-g_bo_247": "2023ལོའི་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་ལ་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་།",
    "title-g_bo_575": "2020 ལོའི་ཟླ་10པ་ནས་2021 ལོའི་ཟླ་11པའི་བར་དུ་ཡར་ཀླུང་གཙང་པོའི་སྐྱེ་དངོས་སྣ་མང་རང་བཞིན་གྱི་བརྟག་དཔྱད་བྱས་མཐར་གྲུབ་འབྲས་རགས་ཙམ་ཐོབ་པ།",
    "title-g_bo_417": "2055 མི་བཟུང་འཕྲོད་བསྟེན་ཚན་པ་ལ་5087 རྐྱེན་ལམ་དུ་ཤོར་བ་དེ་བས་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་དམངས་ཀྱི་གཙོ་གནད་འཕྲོད་བསྟེན་ཚན་པའི་གྲངས་གཞི་གསར་ཤོས་ལུང་དུ་དྲངས།",
    "title-g_bo_484": "2024ལོའི་སྤྱིར་བཏང་མཐོ་སློབ་དང་སློབ་བསྡུའི་འོས་སྐྱེལ་ཆ་རྐྱེན་གསར་པ།",
    "title-g_bo_249": "2024ལོ་ནི་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་50འཁོར་བའི་ལོ།",
    "title-g_bo_380": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གདོང་ཐུག་བྱུང་ནས་ཉིན་གྲངས་མང་པོ་ཕྱིན་ཡོད། ཨ་རིའི་དམག་དཔུང་གི་རྟེན་གཞིར་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "2023ལོའི་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཚོགས་གཏོགས་བཟོ་བྱས་པ།",
    "title-g_bo_959": "2013ལོའི་ཁོང་ཀོ་པུའུ་ལ་གནས་པའི་ཀྲུང་གོའི་སྨན་པ།",
