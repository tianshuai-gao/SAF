    "title-g_bo_495": "《སེ་མ་བྲོ》གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་བྱ་དགའ་སྤྲོད་པའི་མཛད་སྒོ་འཚོགས་པ།",
    "title-g_bo_372": "2023ལོའི་ཡུག་རེན་གྱི་ཙུང་ཐུང་ལྷག་པ་དུས་ནས་ཨ་རི་དང་ཨ་རིའི་མནའ་གྲོགས་ཀྱིས་ཡུག་རེན་ལ་མུ་མཐུད་རྒྱབ་སྐྱོར་བྱ་རྒྱུ་ཡོད་པ་རེད།",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་སྨན་ཁང་གི་གསར་རྟོགས་བྱུང་བ་ལྟར་བྱས་པ།》",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་སྤྱི་ལོ་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2023ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023 ཚེས་16 ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་གི་མུ་མཐུད་དེ་ཀ་ཧྲ་ས་ཁུལ་གྱི་ལྷོ་རྒྱུད་ཧན་ཡུའི་ཉི་སི་ས་ཁུལ་དུ་བྱ་སྤྱོད་སྤེལ།",
    "title-g_bo_222": "2023ལོའི་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱེད་པ། ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་གཅེས་བཏུས་མཚོ་སྔོན་ཞིང་ཆེན་གནའ་དཔེ་མྱུར་སྐྱོབ་རིགས་ཀྱི་དཔེ་ས�",
