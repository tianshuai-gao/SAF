    "title-g_bo_56": "2023 ལོའི་ཟླ་བ་10 ཚེས་15 ལ་ནད་པ་འདི་རིཊ་བྱུང་བར་ཆེད་མཁས་པས་དྲན་སྐུལ་བྱས་པ།",
    "title-g_bo_973": "དབང་ཆེན་གྱི་སྐྱིད་སྡུག་དང་གཞུང་གི་ལས་གནས་ནས་ཕྱིར་འབུད་བཏང་འདུག",
    "title-g_bo_294": "2023 ལོའི་དངོས་པོའི་བྱང་བུ་ཞེས་བྲིས་པའི་སྐད་འཕྲིན་དང་བྱང་བུའི་རྒྱབ་ངོས་སུ་བཀོལ་སྤྱོད་བྱེད་པའི་གནད་འགག་ཆེ།",
    "title-g_bo_689": "《སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་དོ་སྣང་བྱེད་དགོས་པ་དང་ཆ་འཕྲིན་གང་དག་ཕྱིར་གྱར་མི་རུང་བའི་དྲན་སྐུལ་བྱེད་རྒྱུ་ཡིན》",
    "title-g_bo_551": "2023ལོའི་ཟླ་5ཚེས་23ཉིན་ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་65འཁོར་བ་དང་ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་གྱི་མཛའ་གྲོགས་ལོ་ཡིན།",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན》ལོ་རྒྱུས་རང་བཞིན་གྱི་གྲུབ་འབྲས་ཐོབ་པ།",
