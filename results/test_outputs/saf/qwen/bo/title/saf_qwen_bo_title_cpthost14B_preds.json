    "title-g_bo_351": "2023ལོའི་དཔལ་འབྱོར་འཕར་སྣོན་དང་ལེགས་སུ་འགྲོ་བའི་འཕེལ་ཕྱོགས་མུ་མཐུད་བརྟན་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_182": "5.12 ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོའི་གཟི་བརྗིད་མཚན་སྙན་སྤྲད་པ།",
    "title-g_bo_980": "《ལྗར་པན་གྱི་ཆུ་ཐོན་དངོས་རྫས་ཕྱོགས་ཡོངས་ནས་ནང་འདྲེན་བྱེད་མཚམས་འཇོག་རྒྱུའི་སྐོར་གྱི་སྤྱི་བསྒྲགས》2023ལོའི་ཨང་103པ།",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་གངས་རིན་པོ་ཆེ་དང་མ་ཕམ་གཡུ་མཚོའི་མཛེས་ལྗོངས་ཁུལ་དུ་དགུན་དུས་ལས་མཚམས་འཇོག་རྒྱུའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_225": "2023ལོའི་བོད་ལྗོངས་འབྲོང་པ་རྫོང་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་མཚོན་གྱི་ཡོད།",
