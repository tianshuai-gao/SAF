    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་གནས་རི་གནས་མཚོ་དང་ཐུན་མིན་གྱི་ཡུལ་གོམས་གཤིས་ལུགས་མྱོང་རོལ་དང་། འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེར་ཆགས་པའི་གནས་མཆོག་འདིས་སྦྱིན་པའི་ཐུན་མོང་མ་ཡིན་པའི་ཚོར་སྣང་ཉམས་སུ་མྱོང་བར་འགྲོ་",
    "title-g_bo_276": "2024ལོ་ལོ་རེའི་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་བསྟུད་མར་འཁུར་བ་དང་འགན་ཡུན་བསྟུད་འཛིན་སྐབས་གཅིག་མ་གཏོགས་བྱེད་ཆོག",
    "title-g_bo_954": "2023ལོའི་ཟླ་11ཚེས་4ཉིན་ནེ་པ་ལ་ས་ཡོམ་དྲག་པོ་བརྒྱབ་པའི་ཐད་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་ལ་འཚམས་འདྲིའི་གློག་འཕྲིན་བཏང་གནང་བ།",
