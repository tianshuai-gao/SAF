    "title-g_bo_2": "2023ལོའི་སྤྱི་ཚེས་15ཉིན་ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ཉེན་ཁ་ཆེ་རུ་ཕྱིན་པ།",
    "title-g_bo_16": "2023ལོའི་ལོ་གསར་དར་ཤིང་དུ་གཅོད་པའི་སྤྱི་ཚོགས་ལྷག་བསམ་དང་ཁོར་ཡུག་སྲུང་སྐྱོང་གི་ལྷག་བསམ།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་བོད་ལྗོངས་གཞིས་རྩེ་བཞད་མཐོང་སྨོན་རྫོང་མི་དམངས་ཁྲིམས་ཁང་གིས་རིན་ཆེ་གེ་མོ་ཆག་སྒོ་བསླངས་པར་ཆད་པ་བཅད་འདུག",
    "title-g_bo_12": "སློབ་མ་ཚོས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ།",
    "title-g_bo_577": "2022ལོའི་ལོ་གཉིས་ནང་ཨ་རིའི་དཔལ་འབྱོར་ལ་ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ལས་ཁེ་ཕན་ཆེན་པོ་ཐོབ་པའི་དོན་དངོས་ཐེར་འདོན་བྱས་པ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་ནས་རྒྱལ་ཁབ་འཕེལ་སྒྱུར་ཨུ་ལྷན་ནས་གནས་འཕེལ་བ་དང་རེས་སྐོར་གསར་པའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་འགོ་འཛུགས་རྒྱུ་ཡིན།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཤིག་གིས་དམག་མི་ལྔ་ངོ་ལོག་ཟིང་འཁྲུག་པ་དང་འཐབ་འཁྲུག་བྱས་པ།",
    "title-g_bo_831": "ཡེ་མན་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་མེ་རི་ཁའི་དམག་གི་བར་དུ་ཡང་གྲི་འཕྱར་ཞིང་གཞུ་འཐེན་པ་ལྟ་བུའི་འགྲན་རྒོལ་བྱས་པ།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་བརྟག་དཔྱད་བྱས་པའི་མའོ་ཆེ་གེ་མོའི་སྐད་ཆ་དང་འབྲེལ་ཡོད་འགན་འཁུར།",
    "title-g_bo_696": "2022ལོའི་ཕྱོགས་ཀྱི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་དུ་ཕྱུར་ཁྲི་31ཟིན་པ་དང་། གྲངས་འཛིན་དཔལ་འབྱོར་གྱིས་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་བསྡུར་གྲངས་ཀྱི་58%བཟུང་ནས་གཞི་ཁྱོན་རྒྱུན་",
    "title-g_bo_675": "སློབ་གསོ་པུའི་སློབ་ཕྱིའི་ལུས་སྦྱོང་དུ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་པ།",
    "title-g_bo_65": "2023ལོའི་ཟླ་14ཚེས་ཀྲུང་གོ་དང་ཏེན་མག་གི་འབྲེལ་བ་འཕེལ་རྒྱས་མྱུར་པོ་ཕྱིན་པ། ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་དང་མཉམ་དུ་འབད་བརྩོན་བྱས་པ།",
    "title-g_bo_214": "2023 སྤྱི་ཟླ་བ་དང་པོའི་ཨ་རིས་གྲོས་ཆོད་འཆར་ཟིན་ནང་དབྱི་སི་རལ་ལ་ཕྱོགས་ཞེན་བྱེད་པའི་གནས་བབ་ཇེ་སྡུག་ཏུ་གྱུར་བ།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་དཔལ་འབྱོར་འཕེལ་རྒྱས་ཤུགས་ཆེན་གཏོང་བ།",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་སྤེལ་བའི་བྱེད་ཐབས་དང་ཡོ་རོབ་མནའ་འབྲེལ་ཨུ་ཡོན་ལྷན་ཁང་དང་ཁོངས་གཏོགས་རྒྱལ་ཁབ་གཞན་དག་གི་གནོན་ཤུགས་ཀྱིས་ཡུག་རེན་དང་ཁྱིམ་མཚེས་རྒྱལ་ཁབ་དབར་གྱི་རྒྱུན་ལྡན་ཚོང་དོན་སླར་གསོ་འབྱུང་བར",
    "title-g_bo_632": "200ཙམ་དམག་དོན་དམིགས་འབེན་ཀ་ཧྲ་བྱང་རྒྱུད་དུ་ཕ་ལི་སི་ཐན་དབྱི་སི་རལ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དམག་དོན་དམིགས་འབེན་བྱས་པ།",
    "title-g_bo_318": "2023ལོའི་ཟླ་5ཚེས་25: ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་སྤྲད་པ་བྱུང་བ།",
    "title-g_bo_856": "ཨ་རིའི་ཉེ་འགྲམ་ནས་ཁ་བའི་སྡིག་སྲིན་ཕྱུར་བཅུ་ཕྲག་ཁ་ཤས་མེད་པར་གྱུར་ཅིང་།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་23ཉིན་ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་གསར་འགོད་པའི་རྒྱུན་ལྡན་གྱི་ཚོགས་འདུ་གཙོ་སྐྱོང་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་གདོང་ཐུག་ཐེངས་གཉིས་པ་དམག་བརྒྱབ་པ།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་མི་རེ་རེས་འཕྲིན་ཡིག་རེ་བྲིས་པ།",
    "title-g_bo_638": "2023ལོའི་ཟླ་དང་པོ་ནས་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་དབྱར་རྩྭ་དགུན་འབུ་ཕྱིར་གཏོང་བྱེད་ཚད་དུས་མཚུངས་ལས་12.1%འཕར་ཞིང་།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་: ཡུག་རེན་དམག་གིས་ཕར་རྒོལ་ཟླ་ཤས་བྱས་པ་ནས་བཟུང་དོན་སྙིང་ལྡན་པའི་འཕེལ་རིམ་ཐོག་མ་དེ་ཡིན།",
    "title-g_bo_319": "2023ལོའི་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས་ལ་གཞིགས་ན། མིག་སྔར་རྒྱལ་ཡོངས་ཀྱི་འབྲུ་རིགས་མཛོད་ཉར་འདང་ངེས་ཡོད་པ་དང་། རང་རྒྱལ་གྱིས་ལོ་ཧྲིལ་པོར་འབྲུ་རིགས་ར�",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད་དམ།",
    "title-g_bo_511": "དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་པུའི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས། ༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
    "title-g_bo_185": "2023ལོའི་ཟླ་7པའི་སྤྱི་ཟླ་སྨད་དུ་མཚོ་སྔོན་གཙང་གསུམ་ཆུ་མགོའི་གཙོད་ཕྲུག་བཙས་རྗེས་སླར་ལོག་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_884": "2023ལོའི་ཟླ་8ཚེས་18ཉིན་པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བར་རིམ་པ་སྤོར་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ།",
    "title-g_bo_165": "2023ལོའི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས་ནས་ལོ་30འཁོར་བའི་ལོ་དུས་རབས་འདིའི་དུས་དཀྱིལ་དུ་འཁྲིད་དག",
    "title-g_bo_275": "2017ལོ་ནས་ཕེ་རུ་ནས་རྙེད་པའི་ཕུང་རུས་གཉིས་ཀྱི་ཞིབ་འཇུག་དཔང་ཉན་ཚོགས་འདུ་ཐེངས་དང་པོ་འཚོགས་པ།",
    "title-g_bo_900": "2023ལོའི་ཚེས་24ཉིན་ནས་ལྟ་ན་སྡུག་པའི་སྣེ་འོད་མཐོང་ཐུབ་པ།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་གསར་འགོད་པའི་ཚོགས་འདུ་གཙོ་སྐྱོང་གནང་བ།",
