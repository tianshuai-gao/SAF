    "title-g_bo_739": "2023ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གི་དགོང་མོ་གསལ་བསྒྲགས་སྤེལ་བ།",
    "title-g_bo_190": "2020ལོའི་བོད་ལྗོངས་ཡོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་521.99ཟིན་ཡོད།",
    "title-g_bo_553": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ།",
    "title-g_bo_519": "ཁ་རླངས་མི་འཁོར་བའི་ལམ་དོན་དང་ཁ་རས་རྒྱག་གི་བྱ་རྒྱུ་དཔེ་བོད་ཡིག",
    "title-g_bo_141": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཀྲུང་ཧྭ་མི་རིགས་གཅིག་མཐུན་མ་ལག་གི་འདུ་ཤེས་འཛུགས་སྐྱོང་བྱེད་པ།",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཧ་མ་སིའི་ཅ་ཧྲ་ས་ཁུལ་དུ་ཡོད་པའི་འགོ་ཁྲིད་ཤིན་ཝར་སྡོད་སའི་ཅ་ཧྲ་ས་ཁུལ་གྱི་ཁང་པ་ཞིག་མཐའ་སྐོར་བྱུང་འདུག",
    "title-g_bo_688": "2024ལོའི་ཟླ་11ཚེས་20: ཀྲུང་ཧྥ་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་60འཁོར་བར་བསུ་བ་ཞུ་རྒྱུ།",
    "title-g_bo_586": "《དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་གྲོང་ཁྱེར་དང་དེའི་ཉེ་འགྲམ་ས་ཁུལ་དུ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་ཤུགས་ཆེན་བྱས་པ་དང་ས་ངོས་ནས་མེ་སྒྱོགས་འབོར་ཆེན་འཕེན་པ་བྱུང་བ》",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི། རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི། ཀྲུང་དབྱང་དམག་ཨུད་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲ",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "2023 མཚོ་སྔོན་ཞིང་ཆེན་དུ་རྒྱལ་ཁབA5 རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་། 《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་",
    "title-g_bo_60": "2023ལོའི་ཟླ་བ་དང་པོའི་བརྗོད་པ། སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཕེབས་པའི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ས་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ།",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
    "title-g_bo_96": "2023ལོའི་ཟླ་10པ་ནས་ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་མདོར་བསྡུས།",
    "title-g_bo_312": "དབྱི་རག་གིས་སྒྲོམ་གཞི་བཟོས་པའི་དུས་ཚོད་ཟླ་1ཚེས་10ཉིན། སུའུ་ཏ་ཉི་ཡིས་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_176": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ཁྲོད་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་1800ལྷག་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་བྱུང་འདུག",
    "title-g_bo_500": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་ནས་ཁ་ཚ་དགོས་གཏུགས་ཀྱི་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "2023 ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན།",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་མཉམ་དུའི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་དོན་དངོས་ཀྱི་ཀ་ཧྲ་ས་རྒྱུད་དུ་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་བརྙན་ལམ་ལས་མངོན་པ་ལྟར་དྲ་དཔོན་ཞིག་གིས་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་པ་དང་། མེ་ཏོག་དཀར་པོ་གཉིས་བཟུང་ནས་འདི་ནི་ཐེན་ཧྲན་རི་བོའི་གངས་ལྷ་མེ་ཏོག་རེད། མེ་ཏོག་དེ་མཐོ་ཚད་སྨི",
    "title-g_bo_481": "2022ལོ་ལྟར་བོད་ལྗོངས་ཀྱི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བོད་ལྗོངས་ཀྱི་གླུ་གར་སི་རི་ལན་ཁའི་གར་སྟེགས་སུ་འཁྲུག་ཆ་དོད》",
    "title-g_bo_818": "2022ལོའི་ཟླ་12ཚེས་13ཉིན་ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གཉིས་པོའི་འབྲེལ་བ་གོང་འཕེལ་གཏོང་བའི་དུས་མཚམས་གསར་པ་བཏོད་པ།",
    "title-g_bo_650": "2023ལོའི་ཚེས་16ཉིན་གྱི་ཧུའུ་སའེ་དྲག་ཤོག་གི་དམག་དོན་མགྲིན་ཚབ་གསལ་བསྒྲགས།",
    "title-g_bo_829": "ཕ་ཁི་སི་ཐན་དང་རྒྱ་གར་གྱི་གདོང་ཐུག་ཐེངས་གཉིས་པ་དམག་བརྒྱབ་པ།",
    "title-g_bo_330": "《ཁྲག་རྡོ་བྱུང་ན་ལུས་ཕུང་ལ་གནོད་པ་གང་དག་ཡོད་པ།》",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པའི་མི་ཁག་གཅིག་མྱུལ་ཞིབ་བྱེད་འགོ་ཚུགས།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཕྱི་དྲོའི་ཕྱིར་ལོག་གནང་བ། ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་ནས་ཕེབས་སྐྱེལ་ཞུས་པ།",
    "title-g_bo_737": "2023ལོའི་བཟོ་སྐྲུན་ཆེ་མོ་བའི་དཔུང་ཁག་འཛུགས་སྐྱོང་ལ་སྐུལ་འདེད་གཏོང་དགོས་པ།",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་ཞི་ཅིན་ཕིང་གི་སྐབས་དང་པོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024 ལོའི་ཕོ་བྲུག་ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོའི་བརྙན་ཕབ་བྱེད་པ།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་པ། ཕོ་ལན་གྱིས་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་གྱར་བའི་སྐོར་གྱི་ཡོ་རོབ་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་སྲིད་ཇུས་ལ་ངོ་རྒ",
    "title-g_bo_520": "《关于惩治武装叛乱、武装暴乱犯罪活动的决定》颁布实施",
    "title-g_bo_476": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་བྱང་སྣེའི་འོད་ཟེར་མཐོང་ཐུབ་པ།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱིས་ཀྲ་ཁཱ་ལི་ཡ་དང་ཁོ་པའི་ནང་མི་གདོང་ཐུག་ཁྲོད་རིམ་བཞིན་ཕྱིར་འཐེན་བྱས་པ།",
    "title-g_bo_749": "2023ལོའི་ཟླ་7ཚེས་18: ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་ནི་ཀྲུང་གོས་རང་བརྟེན་ངང་ཞིབ་བཟོ་བྱས་པའི་ཐོན་གསར་པའི་མི་མེད་མྱུལ་ཞིབ་གནམ་གྲུ་ཞིག་ཡིན།",
    "title-g_bo_168": "2023 ལོའི་གཟུགས་པོ་བརྟག་དཔྱད་གནང་དགོས་པའི་དུས་ཚོད་དེ་གཉིས་པ་ནི་གཟུགས་པོའི་བདེ་ཐང་གི་གནས་ཚུལ་དངོས་ཤེས་རྟོགས་ཐུབ་པའི་ཆེད་དུ་རེད།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་ཀྲུང་གོ་དང་ལྗར་པན་གྱི་འབྲེལ་བའི་ངེས་གནས་བསྐྱར་དུ་གཏན་འཁེལ་བྱས་པ།",
    "title-g_bo_522": "2021ལོའི་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་བྱེད་པའི་ལོ་རྒྱུས་བརྒྱུད་རིམ་ལ་ཞིབ་འཇུག་བྱེད་པ།",
    "title-g_bo_787": "2023ལོའི་སྤྱི་ཚེས་8ཉིན་སུའུ་ཏན་གྱི་ཁྱིམ་མི་ཁྲི་400ལྷག་ཙམ་དུས་ལོག་བྱུང་།",
    "title-g_bo_36": "2023ལོའི་ཟླ་བ་དང་པོའི་ཚེས་10ཉིན་ནས་བཟུང་། ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》: གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་དང་འཁྲབ་སྟོན་བྱ་དགའི་མཛད་སྒོ་ཧྥུའུ་ཅན་ཤ་མོན་དུ་འཚོགས་པ།",
    "title-g_bo_372": "2023 ཡུག་རེན་དང་ཧི་པུ་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་གཉིས་པོས་གྲོས་བསྡུར་བྱས་པ།",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་གྱི་ཁྲག་རྩའི་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་སྨན་ཁང་དུ་སྤྱིའི་མཁྲིས་རྒྱུ་གཤེར་རྩིའི་གར་ཚད་དམའ་བ་བྱུང་བ་དང་།》",
    "title-g_bo_538": "2024 ལོའི་བོད་ལྗོངས་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
