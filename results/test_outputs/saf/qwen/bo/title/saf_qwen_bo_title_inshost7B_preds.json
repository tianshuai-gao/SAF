    "title-g_bo_973": "དབང་ཆེན་གྱི་ཕུགས་བསམ་དད་སེམས་ཤོར་བ།",
    "title-g_bo_294": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད།",
    "title-g_bo_689": "《སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས་པ་དང་ཆ་འཕྲིན་གང་དག་ཕྱིར་གྱར་མི་རུང་བའི་དྲན་སྐུལ་བྱེད་རྒྱུ་ཡིན།》",
    "title-g_bo_551": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་གྱི་སྔ་དྲོ་ཧང་ཀྲོའུ་ཤིས་ཧུའུ་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉ",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》དེ་ཉེ་ཆར་མི་དམངས་དཔེ་སྐྲུན་ཁང་གིས་དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་མོ་ཞི་ཁོའི་ཙུང་ཐུང་ལུའོ་ཕེ་སི་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_351": "2023ལོའི་དཔལ་འབྱོར་འཕར་སྣོན་དང་ལེགས་སུ་འགྲོ་བའི་འཕེལ་ཕྱོགས་མུ་མཐུད་བརྟན་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་བཟའ་བཅའི་བདེ་འཇགས་བཅའ་ཁྲིམས་》དང་དེ་བཞིན་དེའི་ལག་བསྟར་སྲོལ་ཡིག《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཕྱིར་གཏོང་ནང་འདྲེན་བཟའ་བཅའི་བདེ་འཇགས་དོ་དམ་",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ལ་སླེབས་ཡོད།",
    "title-g_bo_225": "2019ལོའི་ལེགས་རྩེ་འགག་སྒོ་དེ་རྒྱལ་ཁབ་འགག་སྒོའི་སྒོ་དབྱེའི་འཆར་འགོད་ནང་བཅུག་པ་དང་། སྤྱི་ལོ་2019ལོར་རྒྱལ་སྲིད་སྤྱི་ཁྱབ་ཁང་གིས་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་དབྱེ་རྒྱུའི་མཆོག་མཆན་ཐོབ་ཡོད།",
    "title-g_bo_131": "2023ལོའི་ཟླ་བ་བཅུ་གཉིས་པའི་ཚེས་བཅུ་གཉིས་ཉིན་གྱི་དུས་ཚོད་བཅུ་གཉིས་ནས་བཅུ་གསུམ་བར་དུ་ཞིང་ལས་ཐོན་སྐྱེད་བྱེད་པའི་བྱ་སྤྱོད་སྤེལ་བ་དང་། དེ་ནི་ཞིང་ལས་ཐོན་སྐྱེད་བྱེད་པའི་དུས་ཚོད་ཡིན་པ་རེད།",
    "title-g_bo_739": "2023ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གིས་ཉིན་དེར་ཀ་ཧྲ་ས་ཁུལ་གྱི་ལྷོ་རྒྱུད་གྲོང་ཁྱེར་ལ་ཧྥར་མཁའ་ཐོག་འཇབ་རྒོལ་ཐེངས་མང་བྱས་པ་དང་། ཐོག་ཁང་མང་པོ་ཞིག་གཏོར་བཤིག་བཏང་བ། ཉུང་མཐར་ཡང་མི་12",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་ནས་ཀྱི་ཐོན་འབབ་ཏུན་ཁྲི་83བྱུང་ཡོད།",
    "title-g_bo_553": "2023ལོའི་ཁྲུང་ཆིང་གློག་ཤུགས་ཉོ་ཚོང་ལྟེ་གནས་ཚད་ཡོད་ཀུང་སི་ནས་ཤེས་རྟོགས་བྱས་པར་གཞིགས་ན། བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དེ་རྒྱལ་ཁབ་གློག་དྲ་ཁྲུང་ཆིང་གྲོང་ཁྱེར་གློ",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་མི་འཁོར་བའི་ཐབས་ཤེས་ཡག་པོ་ཞིག་བསླབས་འདུག",
    "title-g_bo_141": "2023ལོའི་ཟླ་བ་བཅུ་པའི་ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་ཉེས་གསོག་དོན་དངོས་གཞན་དག་ཤེས་རྟོགས་བྱུང་འདུག",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ་དང་།",
    "title-g_bo_688": "2024ལོའི་ཟླ་4པའི་ནང་ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་འབྲེལ་བ་སྐས་རིམ་གསར་པ་ཞིག་ཏུ་སླེབས་རྒྱུར་སྐུལ་འདེད་གཏོང་དགོས།",
    "title-g_bo_586": "《ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་མི་ཆོས་རིང་ལུགས་ཀྱི་དམག་མཚམས་འཇོག་རྒྱུའི་རེ་བ་བཏོན་པ》གྲོས་ཆོད་འཆར་ཟིན་ནང་གཏའ་མར་བཞག་པའི་མི་སྣ་གློད་དཀྲོལ་གཏོང་དགོས་པ་དང་། ལྷོ་ཨ་ཧྥི་རི་ཁ་ཡིས་རྒྱལ་སྤྱིའི་ཁྲིམས་ཁང་ནང",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་དུ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་ཚབ་ཞུས་ནས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་། འཐབ་ཕྱོགས་གཅིག་གྱུར་གྱི་རྒྱ་ཆེའི",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ་དང་།",
    "title-g_bo_45": "2023ལོའི་མཚོ་སྔོན་ཞིང་ཆེན་མཚོ་བྱང་བོད་རིགས་རང་སྐྱོང་ཁུལ་གྱི་གནས་སྐོར་མཛེས་ལྗོངས་ཁུལ་དུ་གཏན་ཁེལ་བྱས་པའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་།《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་ག",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་པེ་ཅིང་དང་ཧོ་པེ་ཡི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་། གན�",
    "title-g_bo_223": "《རུས་ཚིགས་མི་བདེ་ན་མྱུར་དུ་མཚམས་འཇོག་དགོས།》",
    "title-g_bo_96": "2005ལོའི་ཟླ་4པ་ནས་2010ལོའི་ཟླ་4པའི་བར་ལིའོ་རྨིན་གྱི་ལོ་རྒྱུས་མདོར་བསྡུས།",
    "title-g_bo_312": "དབྱི་རག་གི་ཙུང་ལི་སུའུ་ཏ་ཉི་ཡིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད་པ་དང་། དབྱི་རག་གི་ས་ཁོངས་ནང་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་བཅའ་སྡོད་དཔུང་སྡེའི་རྟེན་གཞིར",
    "title-g_bo_176": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་གྱི་ཕྱི་དྲོའི་དུས་ཚོད་བརྒྱད་ནས་དགུ་བར་དབྱི་སི་རལ་དམག་དཔུང་གི་མི་སྣ་དང་མི་ཆིག་ཁྲི་ལྔ་སྟོང་ལྷག་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་ཆིག་ཁྲི་ལྔ་སྟོང་ལྷག་ལ་རྨས་སྐྱོན་ཕོག",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་ལ་ཞིང་ཆེན་རིམ་པའི་མཛེས་རྩལ་ཁང་མེད་པའི་སྟོང་ཆ་བསྐངས་ཡོད་པ་དང་།",
    "title-g_bo_500": "2023ལོའི་ཟླ་10ཚེས་7ཉིན་ནས་བཟུང་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་དོན་རྐྱེན་ནང་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་སེར་སོགས་ལ་སྐར་མ་གཅིག་གི་རིང་ལ་ངག་བསྡམས་མྱ་ངན་ཞུས་པ་རེད།",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་དུ་མཛོད་དགེ་རྒྱ་མཚོའི་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་བ།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་ནན་ཧའེ་རུ་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན། འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱིས་2018ལོར་ཐེངས་དང་པོར་འཛམ་ག",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་འཇབ་རྒོལ་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་གྱི་དྲ་དཔོན་དེའི་མི་སྒེར་གྱི་རྩིས་ཐོ་དེ་གསང་བའི་རྩིས་ཐོར་གྱུར་ཡོད་པ་མ་ཟད། འབྲེལ་ཡོད་གཏན་འབེབས་ལས་འགལ་བས་བརྩམས་ཆོས་འགྲེམས་སྤེལ་བྱེད་མི་ཆོག་པ་བཟོས་ཡོད།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བཀྲ་ཤིས་སྨོན་འདུན》ནས་འགོ་ཚུགས་ཏེ་བོད་ལྗོངས་ཀྱི་གླུ་གར་ཚོགས་པ་ཞིག་གིས་སི་རི་ལན་ཁའི་མང་ཚོགས་ལ་བོད་ལྗོངས་ཀྱི་ཁྱད་འཕགས་གླུ་གར་སྐྱེས་སུ་ཕུལ་བ་དང་ཆབས་ཅིག སི་རི་ལན་ཁའི་དམངས་གཞས་བཟོ་བཅོས་བརྒྱབ་ནས་",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཧ་ནོ་དབྱིའི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་དང་མཇལ་མོལ་གནང་བ།",
    "title-g_bo_650": "2023ལོའི་ཟླ་12ཚེས་16ཉིན་གྱི་ཆུ་ཚོད་15དང་སྐར་མ་15ཡི་ཐོག་སྤེལ་བའི་འཇབ་རྒོལ་བྱེད་ཁུལ་དུ་རྒྱ་མཚོ་དམར་པོའི་མཚོ་ཁོངས་སུ་མར་ཐའི་རྒྱལ་དར་བཀལ་བའི་དངོས་ཟོག་སིལ་མ་སྐྱེལ་འདྲེན་བྱེད་མཁན་གྲུ་གཟིངས་",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱིས་ཁེ་ཧྲི་སྨིའར་ས་ཁུལ་དུ་དམག་འཐབ་བྱས་པ།",
    "title-g_bo_330": "《ཁྲག་རྡོ་》དེ་དག་སྨན་བཅོས་ཡོ་བྱད་སྤྱོད་པའི་བཀག་རྡོ་ལྟ་བུར་གྱུར་ནས་ཁྲག་རྩའི་འདེགས་སྒྲོམ་སྤྱོད་མི་ཐུབ་པར་བྱུང་བ།",
    "title-g_bo_244": "གཞིས་རྩེ་གྲོང་ཁྱེར་རྒྱལ་རྩེ་རྫོང་སྤྱི་བདེ་ཅུས་ཉེས་དོན་མྱུལ་ཞིབ་རུ་ཆེན་ལ་མི་ཁག་གཅིག་གིས་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པའི་ཁུངས་སྣེ་ཞིག་རྙེད་ཡོད།",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་དུ་ཕེབས་སྐྱེལ་ཞུས་པ།",
    "title-g_bo_737": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོར་ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་ནང་། སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་གཏོང་སྤེལ་བ�",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་སྐབས་དང་པོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་ཞུགས་རྒྱལ་ཁབ་དང་ཡུལ་འཁྱར་བ་འབོར་ཆེན་བསྡུ་ལེན་བྱས་པའི་རྒྱལ་ཁབ་དཔེར་ན།",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》ཞེས་འཁོད་པ་དེ་སྤེལ་ཡོད་པ་རེད།",
    "title-g_bo_476": "2023ལོའི་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་སྐབས་རེར་མཐོང་ཐུབ་ཀྱི་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་བདེ་ཐང་ལ་གནོད་པ་ཐེབས་པའི་དོན་དངོས་གཞན་དག་ཤེས་རྟོགས་བྱུང་འདུག",
    "title-g_bo_749": "2023ལོའི་ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུའི་འགྲེམས་སྟོན་ཐོག་ཀྲུང་གོའི་ཐོན་གསར་པའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུར་ཀུན་གྱིས་དོ་ཁུར་ཆེན་པོ་བྱས་པ་དང་། �",
    "title-g_bo_168": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་པའི་གནས་ཚུལ་ལ་གཞིགས་ན། གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་པ་དེ་ནི་གཟུགས་པོའི་བདེ་ཐང་གི་གནས་ཚུལ་དངོས་ཤེས་རྟོགས་ཐུབ་པའི་ཆེད་དུ་རེད།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_522": "2021ལོའི་སི་ཁྲོན་ཞིང་ཆེན་དཀར་མཛེས་བོད་རིགས་རང་སྐྱོང་ཁུལ་འདབ་པ་རྫོང་ཕན་རོགས་གནའ་ཤུལ་གྱི་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་བྱེད་པའི་ལོ་རྒྱུས་བརྒྱུད་རིམ་ལ་ཞིབ་འཇུག་བྱེད་པའི་བྱེད་སྒོ་སྤེལ་བ་ར",
    "title-g_bo_787": "2023ལོའི་ཟླ་8པའི་ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད་པ་རེད།",
    "title-g_bo_36": "2023ལོའི་ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ་དེ་ནི་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོར་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་མྱུར་བགྲོད་ལྕགས་ལམ་ཐོག་མ་དེ་ཡིན།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ནི་གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་ཡིན་ཞིང་།",
    "title-g_bo_372": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་ཙེ་ལན་སི་ཅིས་ཡུག་རེན་གྱི་རྒྱལ་སྲུང་པུའུ་ཀྲང་ཨའོ་སི་ཐིང་དང་ཐུག་འཕྲད་བྱས་ཏེ། ཕྱོགས་གཉིས་པོས་ཡུག་རེན་གྱི་གནས་བབ་དང་། དམག་དོན་རོགས་སྐྱོར། ཧེ་ཧ",
    "title-g_bo_672": "《དབང་རྩའི་རིག་པ་》ཞེས་པའི་དུས་དེབ་སྟེང་དུ་ཁྲག་རིགས་Aཅན་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་། ཁྲག་རིགས་Aཅན་ལ་ནད་འབྱུང་བའི་ཉེན་ཁ་ཆེ་བ་ཡིན།",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023ལོའི་ཟླ་12ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ལྷོ་རྒྱུད་ཧན་ཡུའི་ཉི་སི་ས་ཁུལ་དུ་བྱ་སྤྱོད་སྤེལ་ནས། ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ལྷོ་ཧན་ཡ�",
    "title-g_bo_222": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས།",
    "title-g_bo_611": "1953ལོར་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་ལ་སླེབས་པ་ཡིན་པའི་ཡོན་ཧྲི་ཁོང་གིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་གི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}