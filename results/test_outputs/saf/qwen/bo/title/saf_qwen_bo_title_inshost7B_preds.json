    "title-g_bo_327": "2023ལོའི་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་པ་རེད།",
    "title-g_bo_323": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་ཨུ་རུ་སུའི་མྱུལ་ཞིབ་ཨུ་ལྷན་གྱིས་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་ཞིག་ཚེས་24ཉིན་ཨུ་རུ་སུའི་པེའར་ཀེ་ལུའོ་ཏེ་མངའ་སྡེར་ལྷུང་བས། གནམ་གྲུའི་ཐོག་གི་མི་ཚང",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་ས་འཛིན་ཕྲེང་བ་རིམ་པར་འདས་པའི་སར་ཆགས་པའི་སྟོད་མངའ་རིས་ཞེས་བྱ་བའི་ཡུལ་དེ་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་སྙན་པའི་གྲགས་པ",
    "title-g_bo_276": "2024ལོའི་ཀྲུང་གོའི་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་ཡུན་ལོ་2026ལོའི་བར་ཡིན་པ་རེད།",
    "title-g_bo_954": "2023ལོའི་ཟླ་11ཚེས་4ཉིན་ཞི་ཅིན་ཕིང་གིས་ནེ་པ་ལར་ས་ཡོམ་དྲག་པོ་བརྒྱབ་པའི་ཐད་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་ལ་འཚམས་འདྲིའི་གློག་འཕྲིན་བཏང་གནང་བ་རེད།",
    "title-g_bo_962": "12306ཐོག་ཏུ་སྐར་ཆ་གཅིག་གི་ནང་པ་སེ་འཚོང་བའི་དུས་ཚོད་བརྗེད་འགྲོ་སྲིད།",
    "title-g_bo_200": "《མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ་ཅི་ཡིན་ནམ།》",
