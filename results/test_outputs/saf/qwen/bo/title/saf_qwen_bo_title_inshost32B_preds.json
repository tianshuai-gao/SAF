    "title-g_bo_578": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་ས་སྲིབ་མཚམས་སུ་དབྱི་སི་རལ་དམག་ཕྱོགས་ཀྱིས་ཀ་ཧྲ་ས་ཁུལ་ལྷོ་རྒྱུད་ཀྱི་ཧན་ཡིའུ་ཉི་སིར་གཞི་ཁྱོན་ཆེ་བའི་ཕར་རྒོལ་བྱས་པ།",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཨན་ཏེ་ལི་·ཉི་ལི་ནཱ་·ལ་ཆའོ་ལི་ནཱ་ལ་གློག་འཕྲིན་བཏང་གནང་ནས་ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་འབྲེལ་བ་འཕེལ་རྒྱས་མགྱོགས་པོ་བྱུང་བ་དང་། ཁྱབ་ཁོངས་ཁག་གི་སྤེལ་རེས་མཉམ་ལས་ལ་གཡུར་ཟའི་ག�",
    "title-g_bo_235": "2024ལོར་ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ཇུས་འགོད་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023ལོའི་བོད་རང་སྐྱོང་ལྗོངས་བུད་མེད་དང་བྱིས་པའི་སྨན་ཁང་གི་སྒྲ་རླབས་གསོ་རིག་ཚན་ཁག་གི་བྱེད་སྒོ་སྤེལ་ཡུལ་ལྷ་ས་གྲོང་ཁྱེར་སྣེའུ་ཁུལ་གསར་ཚ་རྒུར་ལམ་ཆེན་སྒོ་རྟགས་ 10 པའི་སྒྲ་རླབས་གསོ་རིག་ཚ",
    "title-g_bo_918": "《ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་ཞུ་བའི་འཕྲིན་ཡིག》སྤྲིངས་ནས་ཀྲུང་གོ་རིག་པའི་ཞིབ་འཇུག་གི་དོན་སྙིང་གལ་ཆེན་རྒྱས་བཤད་གཏིང་ཟབ་གནང་བ།",
    "title-g_bo_451": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་10པར་ཞིང་ཆེན་ནན་ཁྲང་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་སྒོར་ཁྲི་1169ཏག་ཅོག་ཙེའི་སྟེང་དུ་སྤུངས་ཡོད།",
    "title-g_bo_997": "2023ལོའི་ཟླ་10ཚེས་8ཉིན་གྱི་ཆུ་ཚོད་12པའི་ཐོག་ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་གནས་སྐབས་སྲིད་གཞུང་གི་རང་བྱུང་གནོད་འཚེ་དོ་དམ་པུའི་མགྲིན་ཚབ་པ་ཅ་ནན·སའེ་དབྱི་ཁེས་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་གནོད་",
    "title-g_bo_544": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ་དང་། སྐབས་འདིའི་བརྗེ་རེས་ཚོགས་འདུའི་ཐོག་རྒྱལ་ནང་ནས་ཐོན་སྐྱེད་བྱས་པའི་འཛམ་ག�",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་སྦྱོང་བརྡར་བྱེད་དགོས་སམ།",
    "title-g_bo_847": "2023ལོའི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བཞིན་པའི་ཚུལ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ངང་གསན་གཟིགས་གནང་བ།",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "2023ལོའི་ཟླ་11པའི་ཚེས་5ཉིན་གྱི་ཕྱི་དྲོའི་བར་དབྱི་སི་རལ་དང་དབྱི་སི་རལ་གྱི་དམག་ཕྱོགས་ཀྱི་མི་ཆོས་རྩ་བ་ནས་མེད་པར་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_830": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་2དང་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་2ཀྲུང་གོའི་ནན་ཧྲ་གླིང་ཕྲན་གྱི་རེན་ཨའེ་ཅའོ་ཉེ་འགྲམ་མཚོ་ཁོངས་སུ་འཛུལ་འདུག་ཟེར།",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་ཆེད་མཁས་ལས་དོན་གྲོས་ཚོགས་དེ་དྲ་ཐོག་དང་དྲ་ཕྱི་ཟུང་འབྲེལ་གྱི་རྣམ་པས་འཚོགས་ཤིང་།",
    "title-g_bo_826": "2023ལོའི་ཟླ་6ཚེས་6ཉིན་གྱི་ཕ་དབྱི་གདོང་ཐུག་དེ་ཚེས་7ཉིན་ཏག་ཏག་དུས་ཡུན་ཟླ་བ་གཅིག་ཟིན་པ་དང་། ཚེས་6ཉིན་བར། གདོང་ཐུག་དབང་གིས་ཕྱོགས་གཉིས་པོའི་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་11500ལས་བརྒལ་བ་དང་། དེའི་",
    "title-g_bo_17": "2023ལོའི་རྒྱལ་ཡོངས་ཀྱི་བཟོ་ལས་དང་ཆ་འཕྲིན་ཅན་གྱི་རྩལ་ནུས་འགྲན་བསྡུར་ཆེ་མོ་སྐབས་གཉིས་པ་ལས་ཐོན་ལས་ཀྱི་དགོས་མཁོ་དང་ལས་རིགས་གསར་པར་ཁ་གཏད་དེ་དེར་མཚུངས་ཀྱི་འགྲན་བསྡུར་རྣམ་གྲངས་བཀོད་སྒྲིག་བྱས་ནས།",
    "title-g_bo_285": "《མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་ཆབས་ཅིག ལག་པས་འོག་ནས་སྒང་ལ་འཕུར་འཕུར་བཏང་ན་ན་ཟུག་ཆེ་རུ་ཕྱིན་ཚེ། སྤྱིར་ན་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཡོད》",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ནས་ཚེས་24ཉིན་བར་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ་གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཨ་རི་གཉིས་ཀྱི་འཁྲུག་རྐྱེན་སློང་བའི་བྱ་སྤྱོད་སྤེལ་བའི་དོན་རྐྱེན་དེ་ནི་ཨ་རི་དང་ཧྥི་ལི་ཕིན་གྱི་འཁྲུག་རྐྱེན་སློང་བའི་བྱ་སྤྱོད་སྤེལ་བའི་དོན་རྐྱེན་དེ་ཡིན།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན།",
    "title-g_bo_563": "3Dམིག་ཤེལ་མི་དགོས་པའི་གཟིགས་མོ་བར་ཐུན་མིན་གྱི་མཐོང་རྒྱ་ཞིག་བཟོས་པ།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་འཚོགས་པ།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་ཀྱི་ཡིག་རྒྱུགས་སྤྱི་ཟླ་11པའི་ཚེས་25དང་26ཉིན་གཏོང་རྒྱུ་རེད།",
    "title-g_bo_932": "ཧུའུ་སའེ་དྲག་ཆས་ཀྱིས་ཚོད་འཛིན་བྱས་པའི་རྒྱ་མཚོ་དམར་པོའི་གྲོང་ཁྱེར་ཧོ་ཐའེ་ཏ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
    "title-g_bo_110": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའ",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "2023ལོའི་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོར་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་པ།",
    "title-g_bo_529": "གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ཧན་ཡིའུ་ཉི་སིའི་ནུབ་རྒྱུད་དུ་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་ན",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་11ཉིན་བསྟན་པར། ཉིན་དེའི་སྔ་དྲོའི་ཆུ་ཚོད་7པར་ཟོག་འདྲེན་མེ་འཁོར་ཞིག་ལིའང་ཙན་མངའ་སྡེ་བརྒྱུད་འགྲོ་སྐབས་ཆག་སྒོ་བྱུང",
    "title-g_bo_287": "ཨ་རི་དང་ཡུག་རེན་གྱི་གདོང་གཏུག་བྱུང་ཚུལ་བརྗོད་པ།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བར།",
    "title-g_bo_901": "2023ལོའི་ཟླ་2ཚེས་20ཉིན་གྱི་སྔ་དྲོ་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་ཕྱི་འབྲེལ་འབྲེལ་བ་སླར་གསོ་བྱ་རྒྱུའི་ཆབ་སྲིད་ཀྱི་ཇུས་ཐག་བཅད་ཡོད།",
    "title-g_bo_342": "2023ལོའི་ཟླ་9ཚེས་5ཉིན་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་མཐོང་དཀོན་པའི་གསལ་བསྒྲགས་ཤིག་སྤེལ་ཡོད།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་དེ་བས་མངོན་འགྱུར་བྱེད་རྒྱུ་རེད།",
    "title-g_bo_259": "2023ལོའི་ཀྲུང་གོའི་བྱིས་པའི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་བརྩམས་ཆོས་ལ་བྱ་དགའ་སྤྲོད་པའི་བཞུགས་མོལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_685": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པའི་དྲུང་ཆེ་མ་ལེ་ཨེར་ཏེ་ལེ་སིའི་སྐད་ཆ་ལུང་དུ་དྲངས་ནས་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་བ་དང་། སྤྱི་ཚེས་14ཉིན་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའ",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས་པ།",
    "title-g_bo_50": "2023ལོའི་ཟླ་12པའི་ཚེས་3ཉིན་གྱི་ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_769": "2023ལོའི་ཟླ་11ཚེས་27ཉིན་གྱི་ཆུ་ཚོད་7པར་དབྱི་སི་རལ་བ་10དང་ཕ་ལེ་སི་ཐན་བ་30བརྗེ་པོ་རྒྱག་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན་ཞེས་བཤད་ཡོད།",
    "title-g_bo_582": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་བཅུ་པའི་སྐུད་མེད་དྲ་བ་བཙལ་ནས་སྦྲེལ་མཐུད་བྱེད་པ།",
    "title-g_bo_635": "2023ལོའི་ཟླ་4ཚེས་2ཉིན་ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོར་ཅིང་ཏུང་ཆད་འཛིན་གྱི་ཁ་བསླུས་ལ་དོགས་ཟོན་གྱིས་མི་མང་པོར་ཁ་བསླུས་ཐེབས་འདུག",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་སྟབས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་པའི་དོན་ཚན་དང་པོ།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་ཨ་རིའི་དམག་ལ་ཉེ་ཆར་འཇབ་རྒོལ་རབ་དང་རིམ་པ་ཕོག་པར་ཡ་ལན་སློག་པ་ཡིན་ཞེས་བརྗོད་འདུག",
    "title-g_bo_872": "2023ལོའི་ཟླ་4པར་འབའ་ཐང་རྫོང་གི་གསར་གཏོད་གསུམ་གྱི་འགྲན་བསྡུར་ཆེན་མོ་ཉེ་ཆར་ཐུགས་གྲ་ལེགས་མཇུག་འགྲིལ་བ་དང་། བྱ་དགའ་ཐོབ་མཁན་གྱི་འགྲན་ཞུགས་པ་རྣམས་ལ་གཟེངས་བསྟོད་སྤྲོད་པའི་མཛད་སྒོ་ཡང་ས་གནས་དེ་གའི",
    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་གྱི་རྟེན་འབྲེལ་མཛད་སྒོ་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་བ།",
    "title-g_bo_575": "2020ལོའི་ཟླ་10པ་ནས་2021ལོའི་ཟླ་11པའི་བར་རྒྱལ་ཁབ་ནགས་ཚལ་དང་རྩྭ་ཐང་ཅུས་ཀྱི་ཡར་ཀླུང་གཙང་པོའི་སྐྱེ་དངོས་སྣ་མང་རང་བཞིན་གྱི་བརྟག་དཔྱད་རྣམ་གྲངས་ཏེ། ལོ་དང་པོ་བརྟག་དཔྱད་བྱས་མཐར་གྲུབ་འབྲས་རགས་ཙམ",
    "title-g_bo_417": "2023ལོའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་5087རྐྱེན་ལམ་དུ་ཤོར་བ།",
    "title-g_bo_484": "2024ལོའི་སྤྱིར་བཏང་མཐོ་སློབ་ཀྱི་དམིགས་བསལ་རིགས་ཁག་ཅིག་གི་སློབ་བསྡུའི་ལས་དོན་ཡག་པོ་བསྒྲུབ་རྒྱུའི་ཐད་བཀོད་སྒྲིག་བྱས་པ།",
    "title-g_bo_249": "2024ལོ་ནི་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ནས་ལོ་ངོ་50འཁོར་བའི་ལོ།",
    "title-g_bo_380": "2023ལོའི་ཟླ་10པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོའི་དུས་ཚོད་བར་དབྱི་རག་ཏུ་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "2023ལོའི་ཟླ་9ཚེས་6ཉིན་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཨ་པུ་བཀྲ་པེར་འཚམས་འདྲིར་སླེབས་པའི་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་དང་གྲོས་མོལ་བྱས་པ།",
    "title-g_bo_959": "2013ལོའི་ཟླ་3པའི་ཚེས་30ཉིན། ཀྲུང་གོ་དང་ཁོང་ཀོ་པུའི་མཛའ་གྲོགས་སྨན་ཁང་དུ་ཁོང་གིས་ཕྱི་རྒྱལ་ལ་རོགས་སྐྱོར་ལས་འགན་སྒྲུབ་བཞིན་པའི་ཀྲུང་གོའི་སྨན་བཅོས་རུ་ཁག་ལ་ཆེད་མངགས་གཟིགས་པ།",
    "title-g_bo_976": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་གྱི་ཆུ་ཚོད་12པའི་ཐོག་སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར་ཡོད།",
    "title-g_bo_97": "2040ལོར་ལྗར་ཕན་དུ་རྒན་རྒོན་ཁྲི་3928བར་མང་དུ་འགྲོ་རྒྱུ་དང་། སྐབས་དེ་དུས་རྒན་རྒོན་ཅན་གྱིས་རྒྱལ་ཁབ་དེའི་མི་འབོར་གྱིས་34.8%ཟིན་རྒྱུ་ཡིན་པ་རེད།",
    "title-g_bo_309": "2023ལོའི་ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན་གྱི་གྲོང་མི་ཀྲང་ཆེ་གེ་མོ།",
    "title-g_bo_56": "2023ལོའི་ཞིང་ཆེན་ཁ་ཤས་ལ་ནད་པ་འདི་རིཊ་བྱུང་བར་ཆེད་མཁས་པས་དྲན་སྐུལ་བྱས་པ།",
    "title-g_bo_973": "དབང་ཆེན་ཏང་གི་སྐྱིད་སྡུག་དང་གཞུང་གི་ལས་གནས་ནས་ཕྱིར་འབུད་བཏང་འདུག",
    "title-g_bo_294": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད།",
    "title-g_bo_689": "《སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས་པ་དང་ཆ་འཕྲིན་གང་དག་ཕྱིར་གྱར་མི་རུང་བའི་དྲན་སྐུལ་བྱེད་རྒྱུ་ཡིན།》",
    "title-g_bo_551": "2023ལོའི་ཟླ་11ཚེས་23ཉིན་གྱི་སྔ་དྲོ་ཧང་ཀྲོའུ་ཤིས་ཧུའུ་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉ",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》དེ་ཉེ་ཆར་མི་དམངས་དཔེ་སྐྲུན་ཁང་གིས་དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་མོ་ཞི་ཁོ་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་ལ་ལོ་ཟླའི་ཚོད་བགམ་ཐེག་པ་དང་ལོ་རྒྱུས་ཡུན་རིང་ལྡན་ཡོད།",
    "title-g_bo_351": "2023ལོའི་ཟླ་བ་དང་པོ་ནས་བཅུ་པའི་བར་དུ་དཔལ་འབྱོར་འཕར་སྣོན་ལ་སྐུལ་ཁྲིད་ཐུབ་ཚད་བརྒྱ་ཆའི་གནས་1.6ཟིན་ཡོད།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་བཟའ་བཅའི་བདེ་འཇགས་བཅའ་ཁྲིམས》དང་དེ་བཞིན་དེའི་ལག་བསྟར་སྲོལ་ཡིག《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཕྱིར་གཏོང་ནང་འདྲེན་བཟའ་བཅའི་བདེ་འཇགས་དོ་དམ་བ",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་གྱི་གངས་རིན་པོ་ཆེ་དང་མ་ཕམ་གཡུ་མཚོའི་མཛེས་ལྗོངས་ཁུལ་དུ་དགུན་དུས་ལས་མཚམས་འཇོག་རྒྱུའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_225": "2023ལོའི་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་མཚོན་གྱི་ཡོད།",
    "title-g_bo_131": "2023ལོའི་ཟླ་བ་བཅུ་གཉིས་པའི་ཚེས་བཅུ་བཞི་ཉིན་གྱི་དུས་ཚོད་བཅུ་གཉིས་ནང་། རང་རྒྱལ་གྱི་སྟོན་འབྲུར་འབབ་འཕར་ཡོང་རྒྱུ་ངེས་གཏན་ཡིན་ཞིང་། ལོ་ཧྲིལ་པོའི་འབྲུ་རིགས་ཐོན་འབོར་གྱིས་སླར་ཡང་ལོ་རྒྱུ",
    "title-g_bo_739": "2023ལོའི་ཟླ་10ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་10པའི་སྟེང་ཀ་ཧྲ་རྒྱུད་དུ་རྐྱེན་ལམ་དུ་ཤོར་བའི་མི་གྲངས་ཁྲི་2ཟིན་ཡོད།",
    "title-g_bo_190": "2020ལོར་བོད་ལྗོངས་ཀྱི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་103ཟིན་ཡོད།",
    "title-g_bo_553": "2023ལོའི་ཁྲུང་ཆིང་གློག་ཤུགས་ཉོ་ཚོང་ལྟེ་གནས་ཚད་ཡོད་ཀུང་སི་ནས་བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་མང་པོ་འཁོར་བའི་ཐབས་ཤེས་ཡག་པོ་ཞིག་བསླབས་འདུག",
    "title-g_bo_141": "2023ལོའི་ཟླ་བ་བཅུ་གཉིས་པའི་ཚེས་བཅུ་བཞི་ཉིན་གྱི་དུས་ཚོད་བཅུ་གཉིས་ནང་། བོད་ལྗོངས་ཀྱི་མི་རིགས་མཐུན་སྒྲིལ་ཡར་ཐོན་གྱི་དཔེ་སྟོན་ཁུལ་གཙོ་གནད་དུ་འཛུགས་སྐྱོང་བྱས་པ་དང་། རྒྱལ་ཡོངས་མི་རིགས་མཐ�",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་གྱི་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ་དང་། ཧ་མ་སིའི་ཅ་ཧྲ་ས་ཁུལ་དུ་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ།",
    "title-g_bo_688": "2024ལོར་ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་འབྲེལ་བ་སྐས་རིམ་གསར་པ་ཞིག་ཏུ་སླེབས་རྒྱུར་སྐུལ་འདེད་གཏོང་དགོས།",
    "title-g_bo_586": "《ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་མི་ཆོས་རིང་ལུགས་ཀྱི་དམག་མཚམས་འཇོག་རྒྱུའི་རེ་བ་བཏོན་པ》གྲོས་ཆོད་འཆར་ཟིན་ནང་གཏའ་མར་བཞག་པའི་མི་སྣ་གློད་དཀྲོལ་གཏོང་དགོས་པ་དང་། ལྷོ་ཨ་ཧྥི་རི་ཁ་ཡིས་རྒྱལ་སྤྱིའི་ཁྲིམས་ཁང་ནང",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་དུ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་ཚབ་ཞུས་ནས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་། འཐབ་ཕྱོགས་གཅིག་གྱུར་གྱི་རྒྱ་ཆེའི",
    "title-g_bo_838": "2023ལོར་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "2023ལོའི་མཚོ་སྔོན་ཞིང་ཆེན་དུ་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་།《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་ག",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་པེ་ཅིང་དང་ཧོ་པེ་ཡི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་།",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
    "title-g_bo_96": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_312": "དབྱི་རག་གི་ས་ཁོངས་ནང་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_176": "2023ལོའི་ཟླ་11ཚེས་23ཉིན་གྱི་ཕྱི་དྲོའི་བར་དུ་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་དབར་གྱི་རེས་སྐོར་གསར་པའི་གདོང་ཐུག་ཛ་དྲག་ཏུ་ཕྱིན་པ་དང་བསྟུན་ནས་མིག་སྔའི་བར་ཕྱོགས་གཉིས་པོའི་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤ",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་ལྟེ་གནས་སྒོ་ཕྱེ་བ་མཚོན་གྱི་ཡོད།",
    "title-g_bo_500": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་ནས་བཟུང་ཀྲུང་གོའི་གཙོ་སྐྱོང་འོག་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་འཐུས་མི་ཚོགས་པའི་བླང་བྱ་ལྟར་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བདེ་འཇགས་ལས་འཛིན་ལྷན་ཚོགས་ཀྱིས་ཨ་རབ་མཉམ་འབྲ",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་དང་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི། ཀྲུང་དབྱང་དམག་ཨུད་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཚེས་23ཉིན་གྱི་ཕྱི་ད�",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན། འཛམ་གླིང་ཡོངས་སུ་སྔར་བཞིན་མི་གྲངས་དུང་ཕྱུར་50ལ་སྔར་བཞིན་ས�",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་འཇབ་རྒོལ་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་གྱི་དྲ་དཔོན་དེའི་མི་སྒེར་གྱི་རྩིས་ཐོ་དེ་གསང་བའི་རྩིས་ཐོར་གྱུར་ཡོད།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བཀྲ་ཤིས་སྨོན་འདུན》ནས་འགོ་ཚུགས་ཏེ་བོད་ལྗོངས་ཀྱི་གླུ་གར་ཚོགས་པ་ཞིག་གིས་སི་རི་ལན་ཁའི་མང་ཚོགས་ལ་བོད་ལྗོངས་ཀྱི་ཁྱད་འཕགས་གླུ་གར་སྐྱེས་སུ་ཕུལ་བ།",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཧ་ནོ་དབྱིའི་ཀྲུའུ་ཞིའི་ལས་ཤག་ཏུ་ཝེ་ཐེ་ནམ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུའུ་ཝུན་ཧྲང་དང་མཇལ་མོལ་གནང་བ་རེད།",
    "title-g_bo_650": "2023ལོའི་ཟླ་12ཚེས་16ཉིན་གྱི་ཆུ་ཚོད་12དང་སྐར་མ་15ཡི་ཐོག་ས་ནཱ་ཡི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་16ཉིན་གྱི་སྔ་དྲོའི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་ཨ་རིའི་དམག་གིས་ཡེ་མོན་ཧུའུ་སའེ་དྲག་ཤོག་གིས་ཚོད་འཛིན་བྱེ",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་མི་ཞིག་གདོང་ཐུག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_330": "《ཁྲག་རྡོ་བྱུང་ན་ཁྲག་རྩལ་རྡོལ་ནས་ཁྲག་རེང་ནད་དུ་འགྱུར་སླ》དང་། 《ཁྲག་རྡོ་བྱུང་ན་ཁྲག་རྩལ་རྡོལ་ནས་ཁྲག་རེང་ནད་དུ་འགྱུར་སླ》གཉིས་ཀྱི་གནོད་འཚེ་གཉིས་པ་དང་གསུམ་པ་དེ་དག་གི་སྐོར་ལ་བོད་ལྗོངས་ཉིན་ར",
    "title-g_bo_244": "བོད་ལྗོངས་སུ་ཁ་བསླུས་རྒྱག་མཁན་ལ་རོཊ་བྱེད་མཁན་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཟླ་11ཚེས་18ཉིན་གྱི་དགོང་མོ་ཆེད་གཏོང་གནམ་གྲུར་བཞུགས་ནས་པེ་ཅིང་དུ་ཕྱིར་ལོག་གནང་བ།",
    "title-g_bo_737": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆེས་མཐོའི་མི་དམངས་ཁྲིམས་ཁང་གི་མྱུར་དཔྱད་ནང་། ཀྲུང་དབྱང་བརྙན་འཕྲིན་ལས་ཁུངས་ཀྱི་མྱུར་དཔྱད་གཏོང་སྤེལ་བྱས་པའི་སྐབས་སུ་མཛུབ་སྟོན་གལ་ཆེན་གནང་བ།",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་སྐབས་དང་པོའི་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན་ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ཕོ་ལན་གྱིས་ཡོ་རོབ་ལ་འཕྲད་པའི་གནས་སྤོས་ཡུལ་མིའི་གནོན་ཤུགས་ཀྱི་འབྱུང་རྩའི་གནད་དོན་ཐག་གཅོད་མི་ཐུབ་པ་མཚོན་པ།",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》ཞེས་པའི་རྩོམ་ཡིག་འགྲེམས་སྤེལ་བྱས་པ།",
    "title-g_bo_476": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་སྐབས་རེར་མཐོང་ཐུབ་པའི་བྱང་སྣེའི་འོད་ཟེར་དེ་དག་མངོན་གྱི་ཡོད།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་བདེ་ཐང་གནས་ཚུལ་ཉིན་བཞིན་སྡུག་ཏུ་འགྲོ་གི་འདུག",
    "title-g_bo_749": "2023ལོའི་ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་མེ་ཤུགས་འཕུར་མདའི་མེ་སྒྱོགས་ལ་རམས་འདེགས་བྱེད་པར་བྱས་པ།",
    "title-g_bo_168": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་པའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_522": "2021ལོའི་སི་ཁྲོན་ཞིང་ཆེན་རིག་དངོས་གནའ་རྫས་རྟོག་ཞིབ་ཞིབ་འཇུག་ཁང་གི་སྔོག་འདོན་བྱེད་རིང་སྟ་རེ་སོགས་ཨང་སྒྲིག་དངོས་དཔེ་3000ལྷག་ཙམ་གསར་རྙེད་ཐུབ་པ་མ་ཟད། ད་དུང་ཕན་རོགས་གནའ་ཤུལ་གྱི་མཐའ་འཁོར་དུ་རྡ�",
    "title-g_bo_787": "2023ལོའི་ཟླ་8ཚེས་8ཉིན་སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད།",
    "title-g_bo_36": "2023ལོའི་ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ནི་གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་ཡིན་ཞིང་།",
    "title-g_bo_372": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་ཙེ་ལན་སི་ཅིས་ཡུག་རེན་གྱི་རྒྱལ་ས་ཅི་ཧྥུ་རུ་ཨ་རིའི་རྒྱལ་སྲུང་པུའུ་ཀྲང་ཨའོ་སི་ཐིང་དང་ཐུག་འཕྲད་བྱས་ཏེ། ཕྱོགས་གཉིས་པོས་ཡུག་རེན་གྱི་གནས་བབ་དང་",
    "title-g_bo_672": "《དབང་རྩའི་རིག་པ་》ཞེས་པའི་དུས་དེབ་སྟེང་དུ་བཀོད་པའི་ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་། ཁྲག་རིགས་གཞན་པ་དང་བསྡུར་ན། ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་16%ཡིས་མཐོ་བ་དང་། Oཅ",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023ལོའི་ཟླ་12ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་དུ་བྱ་སྤྱོད་སྤེལ་ནས་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ལྷོ་ཧན་ཡིའུ་ཉི་སིའི་དམག་སྒར་གྱི་མཐོ་རིམ་བཀོད་འད",
    "title-g_bo_222": "2023ལོའི་བོད་ཀྱི་གསོ་རིག་སྨྲ་བ་ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས།",
    "title-g_bo_611": "1953ལོར་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་ལ་སླེབས་པའི་ཡོན་ཧྲི་ཁོང་གིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་གི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
