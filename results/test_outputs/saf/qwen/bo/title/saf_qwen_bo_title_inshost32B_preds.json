{
    "title-g_bo_923": "2021ལོའི་ཡུལ་སྐོར་བ་མི་142འབྱོར་བའི་དུས་ཆེན་གྱི་གཟབ་མཆོར་ལེགས་པར་སྤྲས་པ།",
    "title-g_bo_752": "ཀ་ཧྲ་རྒྱུད་ཀྱི་ཡུལ་གྱར་བའི་བསྒར་སར་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ་དང་། མི་ཆོས་རིང་ལུགས་ཀྱི་ཉམས་ཉེན་ཐོན་རྒྱུ་རེད།",
    "title-g_bo_589": "2023ལོའི་ཟླ་10ཚེས་9ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་གཉིས་པོ་གང་འདྲ་བྱས་ཏེ་མཉམ་གནས་བྱ་རྒྱུ་དེས་མིའི་རིགས་ཀྱི་མདུན་ལམ་དང་ལས་དབང་གཏན་ཁེལ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_267": "2022ལོའི་རྟ་མགྲིན་གྱི་གླུ་གཞས་ལེན་བཞིན་པ།",
    "title-g_bo_139": "2023ལོར་ཀོང་ཏུང་གི་ས་ཁུལ་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13.57ཟིན་ནས་རྒྱལ་ཡོངས་ཀྱི་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་ག�",
    "title-g_bo_809": "ནོ་རོ་ནད་དུག་གི་ནད་རྟགས་མི་མངོན་པའི་དུས་ཡུན་ཆུ་ཚོད་12ནས་ཆུ་ཚོད་72བར་ཡིན་ཞིང་། སྤྱིར་བཏང་ཆུ་ཚོད་24ནས་48བར་ཡིན་པ་རེད།",
    "title-g_bo_355": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་སློབ་གསོ་པུའུ་སློབ་ཕྱིའི་སློབ་གསོ་གསོ་སྦྱོང་ལྟ་སྐུལ་དོ་དམ་སི་དང་སྤྱི་བདེ་པུའུ་ཡི་ཉེས་དོན་མྱུལ་ཞིབ་ཅུའུ་ཡིས་མཉམ་འབྲེལ་ཐོག་སློབ་གྲྭའི་ཕྱི་རོལ་གྱ",
    "title-g_bo_154": "2023ལོའི་ཟླ་9ཚེས་12ཉིན་མཇུག་འགྲིལ་བའི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས་འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "ཀྲུང་གོའི་ཕྱོགས་ཀྱིས་ལྗར་ཕན་གྱི་སྤྱི་དམངས་ལ་གསང་མྱུལ་བྱ་སྤྱོད་སྤེལ་བའི་དོགས་གཞི་ཡོད་པའི་ལྗར་ཕན་གྱི་སྤྱི་དམངས་ཤིག་དངོས་སུ་འཛིན་བཟུང་བྱ་རྒྱུའི་ཐག་བཅད་ཡོད་མེད་སྐོར་ལ་ཀྲུང་གོའི",
    "title-g_bo_327": "2023ལོའི་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་པ་དང་། དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་ག",
    "title-g_bo_323": "2023ལོའི་ཟླ་11ཚེས་25ཉིན་ཨུ་རུ་སུའི་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་ཐོག་མའི་ཞིབ་བཤེར་བྱས་འབྲས་ལ་གཞིགས་ན། དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུར་ཡུག་རེན་མངའ་ཁོངས་ཀྱི་མཁའ་�",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་གནས་མཆོག་འདི་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་སྙན་པའི་གྲགས་པ་ཕྱོགས་བཞིར་གྲགས།",
    "title-g_bo_276": "2024ལོའི་ཀྲུང་གོ་དང་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་ཡུན་སྤྱི་ལོ་2024ལོ་ནས་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ་དང་འགན་ཡུན་བསྟུད་འཛིན་སྐབས་གཅིག་མ་གཏོགས་བྱེད་ཆོག་གི་མ�",
    "title-g_bo_954": "2023ལོའི་ཟླ་11ཚེས་4ཉིན་གྱི་ཕྱི་དྲོ། ཞི་ཅིན་ཕིང་གིས་ནེ་པ་ལར་ས་ཡོམ་དྲག་པོ་བརྒྱབ་པའི་ཐད་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་ལ་འཚམས་འདྲིའི་གློག་འཕྲིན་བཏང་གནང་བ་རེད།",
    "title-g_bo_962": "12306ཐོག་ཏུ་སྔོན་འཚོང་དུས་ཚོད་ཕུད་པའི་དུས་ཚོད་གཞན་དག་སྟེང་དུ་དྲན་སྐུལ་ཞེས་པའི་ཡིག་འབྲུ་གཉིས་ཀྱི་རྟགས་བརྒྱབ་ཡོད་པས། དྲན་སྐུལ་ཞེས་པར་མནན་ན་སྐབས་དེ་དུས་ཅོང་བརྡ་དང་འདྲ་བར་ཁྱེད་ལ་པ་སེ་ཉོ་རན་",
    "title-g_bo_200": "《མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ“ཞི་བ”དང་“དྲག་པོ”གཉིས་ཡོད་པ་ཅི་ཡིན་ནམ།》",
    "title-g_bo_210": "2019ལོའི་ཟླ་12ཚེས་1ཉིན་གྱི་ཕྱི་དྲོར་འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ་ནི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་འཐབ་ཇུས་གལ་ཆེན་ཞིག་ཡིན།",
    "title-g_bo_299": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཧྥེ་ཁྲེང་མཉམ་སྒྲོག་རོལ་དབྱངས་ཚོགས་པའི་སྤྱི་འདོམས་པ་དང་དབུ་བཞུགས་ལག་བསྟར་དཔོན་གཅིག་ལྕོགས་མཱ་སི་དབྱི་ལ་འཕྲིན་ལན་སྤྲིངས་གནང་ནས། ཀྲུང་གོ་",
    "title-g_bo_527": "2023ལོའི་ཟླ་11ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐུ་གཤེགས་པ་དང་། སྐུ་གཤེགས་དུས་དགུང་ལོ་85ཡིན་པ་རེད།",
    "title-g_bo_726": "2023ལོའི་ཟླ་10པའི་བརྟག་དཔྱད་སྙན་ཞུ་ལས་མངོན་པ་ལྟར་ན། ཨ་རིའི་འཛད་སྤྱོད་པའི་དངུལ་ལོར་འགྲེམས་ཐལ་ཤོར་ཚུལ་གྱི་སྔོན་དཔག་སྤྱིའི་ཆ་ནས་ཆག་པ་དང་། དེའི་ཁྲོད་ཨ་རིར་ལོ་གཅིག་གི་རྗེས་དངུལ་ལོར་འགྲེམས་�",
    "title-g_bo_188": "ཕ་ལི་སི་ཐན་གྱི་དབྱི་སི་རལ་གྱི་འཇབ་རྒོལ་ཕོག་པའི་མི་གྲངས་ལ་གཞུང་ཕྱོགས་ཀྱི་ཆ་འཕྲིན་གསལ་པོ་ཞིག་མེད་པ་དང་། མི་10000ལྷག་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་། མི་2000ཙམ་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_706": "གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ།",
    "title-g_bo_681": "2020ལོའི་བོད་ལྗོངས་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "2023ལོའི་ཟླ་11ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་14དང་སྐར་མ་30ཙམ་ལ་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་ཞིག་ཐོན་པ།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱིས་ཕྱི་ཚུལ་རིང་ལུགས་དང་དཔོན་ཉམས་རིང་ལུགས་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "2023ལོའི་ཟླ་11ཚེས་15ཉིན་ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ས་ཡོམ་བརྒྱབ་པ་དང་མེ་རི་འཕྱུར་བའི་ཉེན་ཁ་ཆེ་རུ་ཕྱིན་པ།",
    "title-g_bo_16": "2023ལོའི་ལོ་གསར་གྱི་སྐབས་འདིར་དར་ཤིང་ལས་འཕྲོས་པའི་འབྱུང་ཁམས་སྲུང་སྐྱོང་གི་ཕུགས་འདུན།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་འདྲི་གཅོད་བྱས་པ་བརྒྱུད་ཁྲིམས་ལྟར་ཞུ་སྦྱོར་ཕྱི་མ་རིན་ཆེ་གེ་མོས་འགྲིམ་འགྲུལ་ཆག་སྒོ་བསླངས་པའི་གྱོད་དོན་ལ་ཡོངས་བསྒྲགས་ཐོག་འདྲི་གཅ",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ།",
    "title-g_bo_577": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་དང་། རེས་སྐོར་གསར་པའི་བཅོས་སྣུམ་གྱི་རིན་གོང་ལེགས་སྒྲིག་བྱེད་རིམ་དེ་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ་",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཤིག་གིས་རྒྱ་གར་གྱི་དམག་མི་ལྔས་ངོ་ལོག་ཟིང་འཁྲུག་པ་དང་འཐབ་འཁྲུག་བྱས་ཏེ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་དམག་གི་གནམ་ཐང་གྲུ་གཟིངས་ཨ་མ་ཉིས་ལྡན་དམག་འཐབ་རུ་ཁག་གིས་དབྱི་སི་རལ་ལ་འཕུར་མདེལ་འཕེན་རྒྱུ་ཡིན་ཞེས་བརྗོད་པ།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་ཉིང་ཁྲི་གྲོང་ཁྱེར་བྲག་ཡིབ་ཆུས་སྤྱི་བདེ་ཅུས་ཁ་བསླུས་འགོག་རྒོལ་ལྟེ་གནས་ལ་དངུལ་ཁང་གཱ་བསྡམས་བཅད་བྱས་པའི་སྐོར་གྱི་མང་ཚོགས་མའོ་ཆེ་གེ་མོའི་བློ་འདྲིའི་ཁ་པར་འབྱོར་བ་དང",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོ་དེ་ཨ་རི་དང་ཀྲུང་གོ འཇར་མན། ལྗར་པན། ལྷོ་ཁོ་རེ་ཡ་བཅས་རྒྱལ་ཁབ་ལྔའི་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་ཨ་སྒོར་དུང་ཕྱུ",
    "title-g_bo_675": "སློབ་གསོ་པུས་སློབ་ཕྱིའི་ལུས་སྦྱོང་ཐད་བྱ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོའི་མི་ཉུང་མཐར་ཡང་15546རྐྱེན་ལམ་དུ་ཤོར་བ་དང་། མི་བཅུ་ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_65": "2023ལོའི་ཟླ་14ཚེས་14ཉིན་ཞི་ཅིན་ཕིང་གིས་ཏེན་མག་གི་གསར་དུ་བསྐོ་གཞག་བྱས་པའི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པར་རྟེན་འབྲེལ་ཞུ་བའི་གློག་འཕྲིན་བཏང་སྟེ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོ",
    "title-g_bo_214": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ།",
    "title-g_bo_761": "ཡུག་རེན་གྱི་ཙུང་ལི་གཞོན་པ་དང་པོ་དང་དཔལ་འབྱོར་པུའུ་ཀྲང་ཡིའུ་ལི་ཡ་སི་ཝུའེ་ལི་ཏེང་ཁོ་ཡིས་ཡུག་རེན་གྱི་འབྲུ་རིགས་ནང་འདྲེན་བྱེད་མི་ཆོག་པའི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་པ་དང་། ཡུག་རེན་གྱིས་སྤ�",
    "title-g_bo_632": "2023ལོའི་ཟླ་12ཚེས་27ཉིན་དབྱི་སི་རལ་དམག་གི་དྲག་ཇུས་དམག་དཔོན་གྱིས་ཀ་ཧྲ་ལ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་མོས་མཐུན་ཡོད་པའི་འདེམས་ཤོག་ཡོངས་ཀྱི་ཐོག་ནས་ཁྲིམས་གཞི་ཞིག་ལ་གྲོས་འཆམ་བྱུང་བ་དང་། ཉིང་རྡུལ་མཚོན་ཆའི་ཚོད་ལྟ་ཡོངས་སུ་གཏན་འགོག་བྱེད་པའི་ཆིང་ཡིག་མེད་པར་བཟོ་རྒྱུར་ཆོག་མཆན་",
    "title-g_bo_856": "ཨ་རིའི་རྒྱ་མཚོ་དང་རླུང་ཁམས་ཆེན་མོའི་དོ་དམ་ཅུས་ཀྱི་ཞིབ་འཇུག་ལས་ཤེས་རྟོགས་བྱུང་བར་གཞིགས་ན། ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེས་ཆེ།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཝང་ཝུན་པིན་གྱིས་གསར་འགོད་པའི་རྒྱུན་ལྡན་གྱི་ཚོགས་འདུ་གཙོ་སྐྱོང་བྱས་པ་དང་། ཨ་རིས་ཀྲུང་གོའི་དཔོན་རིགས་ཁག་གཅི",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན་ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་མི་ཞིག་གདོང་ཐུག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ཡིས་མི་རེ་རེས་འཕྲིན་ཡིག་རེ་བྲིས་པ་དང་། ཧ་ལམ་གཟའ་འཁོར་གཅིག་ཙམ་སོང་རྗེས། འཕྲིན་ཡིག་དག་སྤྱི་ལེ་1400ཡི་བར་ཐག་ཆོད་པའི་བོད་རང་སྐྱོང་ལྗོངས་ཆབ",
    "title-g_bo_638": "2023ལོའི་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་བ།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གྱོད་གཞི་དང་པོ་དེ་ཨུ་རུ་སུའི་མཁའ་དམག་གི་མི་མེད་གནམ་གྲུ་གཏོར་ལྷུངས་བཏང་ཡོད།",
    "title-g_bo_319": "2023ལོར་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱིས་ལོ་ཧྲིལ་པོར་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་པ།",
