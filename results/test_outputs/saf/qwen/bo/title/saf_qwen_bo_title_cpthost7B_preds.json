    "title-g_bo_578": "2023ལོའི་ཚེས་22ཉིན་གནས་ཚུལ་ལ་ཕ་ལེ་སི་ཐན་གྱི་དམག་མི་3དམག་དོན་བྱ་སྤྱོད་ནང་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་50རྐྱེན་ལམ་དུ་ཤོར་ཡོད་པ་རེད།",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཨན་ཏེ་ལི་·ཉི་ལི་ནཱ་·ལ་ཆའོ་ལི་ནཱ་ལ་གློག་འཕྲིན་བཏང་གནང་ནས་ཁོང་མ་ཏ་ཀ་སི་ཁར་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་ལ་སླར་ཡང་བདམས་ཐོན་བྱུང་ནས་འགན་གནས་བསྟུད་འཛིན་གནང་བར་བཀྲ་ཤིས་བདེ་ལ�",
    "title-g_bo_235": "2024ལོ་ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ཇུས་འགོད་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ་རེད།",
    "title-g_bo_277": "2023ལོའི་ལྷན་སྐྱེས་སྙིང་ནད་ལ་བརྟག་དཔྱད་བྱེད་རྒྱུ་བོད་རང་སྐྱོང་ལྗོངས་ཀྱི་སྨན་ཁང་གི་སྒྲ་རླབས་གསོ་རིག་ཚན་ཁག",
    "title-g_bo_918": "《འཛམ་གླིང་ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་སྤྲིངས་གནང་བའི་རྟེན་འབྲེལ་འཕྲིན་ཡིག་དེར་ལན་ཆ་བཟང་པོ་བྱུང་བ།》",
    "title-g_bo_451": "2023ལོའི་ལོ་མཇུག་བྱ་དགའི་དངུལ་སྒོར་ཁྲི་བསྟུད་མར་ལོ་14ལ་ལོ་མཇུག་གི་བྱ་དགའ་སྤྲད་ཅིང་།",
    "title-g_bo_997": "2023ལོའི་ཟླ་བ་དང་པོ་ཨ་ཧྥུ་ཀ་ནི་སི་ཐན་གྱི་གནས་སྐབས་སྲིད་གཞུང་གི་རང་བྱུང་གནོད་འཚེ་དོ་དམ་པུའི་མགྲིན་ཚབ་པ་ཅ་ནན·སའེ་དབྱི་ཁེས་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག",
    "title-g_bo_544": "2023ལོའི་ཟླ་11པའི་ཚེས་19ཉིན་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ།",
