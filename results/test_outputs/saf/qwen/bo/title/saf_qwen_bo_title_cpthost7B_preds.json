    "title-g_bo_404": "21ཉིན་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན།",
    "title-g_bo_65": "2023ལོའི་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བདེ་ལེགས་ཞུས་པ་དང་ཕྱོགས་ཡོངས་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བ་བཅུ་པར་བསྐྲུན་འདོད།",
    "title-g_bo_214": "2023ལོའི་ཨ་རིས་ཕ་དབྱི་གདོང་ཐུག་ཁྲོད་བྱུང་བའི་ཕ་དབྱི་གདོང་ཐུག་གི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་འཕེལ་བ་བཅས་བྱ་ཆེད།",
    "title-g_bo_761": "ཡུག་རེན་གྱི་ཕྱོགས་ཀྱི་སྤྱི་ཚེས་18ཉིན་ཡུལ་བརྡ་ཁྱབ་སྤེལ་ནས་བྱེད་ཐབས་དང་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་གནད་དོན་ལ་དམིགས་ནས་ཞུ་གཏུག་བྱས་ཡོད།",
    "title-g_bo_632": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་ཀ་ཧྲ་ལ་མཁའ་ཐོག་ནས་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "2023ལོའི་ཨུ་རུ་སུའི་གྲོས་ཚོགས་སྟོད་པས་ཚེས་25ཉིན་མོས་མཐུན་ཡོད་པའི་འདེམས་ཤོག་ཡོངས་ཀྱི་ཐོག་ནས་ཁྲིམས་གཞི་ཞིག་ལ་གྲོས་འཆམ་བྱུང་བ།",
