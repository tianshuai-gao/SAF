    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་སྟེ། ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་�",
    "title-g_bo_575": "2021ལོའི་ཡར་ཀླུང་གཙང་པོའི་སྲུང་སྐྱོང་ལྟེ་གནས་དང་ཤིས་ཙེ་གཙང་པོའི་སྣོད་བཅུད་སྐྱེ་དངོས་སྣ་མང་རང་བཞིན་གྱི་བརྟག་དཔྱད་རྣམ་གྲངས།",
    "title-g_bo_417": "2023ལོའི་ལོ་རྒྱུས་ཐོག་ཆེས་ཡ་ང་ཤོས་ཀྱི་དུས་མཚམས་ཤིག་བརྒྱུད་བ",
    "title-g_bo_484": "2024ལོའི་སློབ་ཆེན་ལ་རྒྱུཊ་སྤྲོད་མི་དགོས་པར་འོས་སྐྱེལ་བྱེད་པའི་ཆ་རྐྱེན་གསར་པ།",
