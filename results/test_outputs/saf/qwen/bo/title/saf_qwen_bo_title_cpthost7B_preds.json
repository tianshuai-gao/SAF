    "title-g_bo_529": "སྨན་ཁང་ནང་གློ་བ་བཀྲུ་བའི་བྱིས་པ་འཚང་ཁ་ཤིག་ཤིག",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་ལ་ཁྲིད་མེ་ཤུགས་འཕུར་མདེལ་བཟོ་བའི་འཁོར་སྟེགས་དང་། རྒྱང་ཁྲིད་མེ་ཤུགས་འཕུར་མདེལ། ཐན་རྒོལ་འཕུར་མདེལ། ས་འོག་འབར་མདེལ། དེ་བཞིན་འབར་གས་སྒྲིག་ཆས་ཁག་གཅིག་བཅས་རྩ་མེད་བཟོས་ཡོད་པ",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱི་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་11ཉིན་བསྟན་པར།",
