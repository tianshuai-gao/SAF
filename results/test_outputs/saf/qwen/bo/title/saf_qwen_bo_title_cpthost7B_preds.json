    "title-g_bo_838": "2023ལོ་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ་དང་།",
    "title-g_bo_45": "21རྒྱལ་ཁབA5རིམ་པའི་མཚོ་སྔོན་ཞིང་ཆེན་མཚོ་བྱང་བོད་རིགས་རང་སྐྱོང་ཁུལ་དུ་གཏན་ཁེལ་བྱས་པའི་སྤྱི་བསྒྲགས།",
    "title-g_bo_491": "《ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་རྒྱུན་ལས་ཨུ་ཡོན་ལྷན་ཁང་གིས་རྒྱལ་ཡོངས་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ཡོན་ལྷན་ཁང་དང་། རྒྱལ་སྲིད་སྤྱི་ཁྱབ་ཁང་། རྒྱལ་ཡོངས་སྲིད་གྲོས། ཆེས་མཐོའི་མི་དམངས་ཁྲིམས་",
    "title-g_bo_60": "2023ལོའི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཕིང་པེ་ཅིང་དང་ཧོ་པེ་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་།",
    "title-g_bo_223": "《རུས་ཚིགས་མི་བདེ་བར་བཟོད་བསྲན་བྱས་ཏེ་འགུལ་སྟངས་འགའ་རེ་རྒྱུན་འཁྱོངས་བྱེད་པའི་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས།》",
    "title-g_bo_96": "2005ལོའི་ཟླ་4པ་ནས་སི་ཁྲོན་ཞིང་ཆེན་ཀྲུང་གོ་གུང་ཁྲན་ཏང་ནང་ཞུགས།",
    "title-g_bo_312": "ས་གནས་དེ་གའི་དུས་ཚོད་ཟླ་1ཚེས་10ཉིན་ལ་སྨྱན་སྦྱོར་གྱི་བཅར་འདྲི་དང་ལེན་བྱེད་སྐབས།",
    "title-g_bo_176": "2023ལོའི་དབྱི་སི་རལ་དབར་གྱི་ཕྱི་མ་བ་ཡུལ་བར་ཕྱོགས་གཉིས་པོའི་མི་6500ལྷག་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_145": "2023ལོའི་ཟླ་བ་11པའི་ཚེས་15ཉིན་ལོ་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་དེ་ལྷ་སར་གཉེར་བ་རེད།",
    "title-g_bo_500": "2023ལོའི་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་འཐུས་མི་ཚོགས་པའི་བླང་བྱ་ལྟར།",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་གྲོང་ཁྱེར་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་བཀལ།",
    "title-g_bo_101": "2023ལོའི་ཞི་ཅིན་ཕིང་གིས་ཀྲུང་ཧྭ་རྒྱལ་ཡོངས་སྤྱི་ཁྱབ་བཟོ་ཚོགས་ཀྱི་སྐབས་གསར་པའི་འགོ་ཁྲིད་ཚན་ཁག་གི་ཁོངས་མི་དང་མཉམ་སྡེབ་གླེང་མོལ་གནང་བ།",
    "title-g_bo_607": "2023ལོའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་ཚིལ་ཞག་ལྡོག་མ་ཞེས་པ།",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་དབར་ཕྱི་འབྲེལ་བཙུགས་ལ་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་ཀ་ཧྲ་ས་རྒྱུད་ཀྱི་འཇབ་རྒོལ་བྱས་པ་དེས་མི་200རྐྱེན་ལམ་དུ་བཏང་ཡོད།",
    "title-g_bo_708": "2023ལོའི་ཞིབ་དཔྱད་བྱས་པ་ལས་བརྙན་ལམ་དེར་དྲ་དཔོན་དེས་འཐུས་པ་དང་མི་ལ་ལས་དྲ་དཔོན་དེས་འཐུས་པ་གངས་ལྷ་མེ་ཏོག་ལ་བརྙན་དུ་བླངས་ཡོད་ཟེར་བར།",
    "title-g_bo_481": "2022ལོའི་མཚོ་བོད་ས་མཐོར་གནས་པའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བཀྲ་ཤིས་སྨོན་འདུན》ལ་བོད་ལྗོངས་ཀྱི་གླུ་གར་ཚོགས་པ་ཞིག་བཤམས་བྱུང་འདུག",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་ཁྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཁྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "2023ལོའི་ཨ་རི་ཀྲུང་དབྱང་དམག་སྤྱི་པུས་ཚེས་16ཉིན་གསལ་བསྒྲགས་སྤེལ་ནས་ཧུའུ་སའེ་དྲག་ཤོག་གི་འཇབ་རྒོལ་བྱས་པའི་དམག་དོན་མགྲིན་ཚབ་པས།",
    "title-g_bo_829": "ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་9ཉིན་ལ་ཕ་ཁི་སི་ཐན་གྱི་དམག་མི་ཞིག་གདོང་ཐུག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་ཡོད་པ་རེད།",
    "title-g_bo_330": "《ཁྲག་རྡོ་ལྡེམ་གཤིས་ཞན་འགྱུར་བྱུང་ཚེ་ཁྲག་རྒྱུན་གྱི་བཞུར་ཤུགས་ཇེ་ཞན་དུ་གྱུར་ནས་ཁྲག་ཤེད་མཐོ་བ་དང་འཕར་རྩའི་རྩ་ལམ་དོག་པ།》",
    "title-g_bo_244": "མང་ཚོགས་ལ་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱས་པའི་ལག་ཐོག་ཁ་པར་གྱི་མཐུད་སྣེའི་ལས་སྒོ",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཞི་ཅིན་ཕིང་ཅིའུ་ཅིན་ཧྲན་དུ་ཕྱི་དྲོ་བཞུགས་ནས་ཕྱིར་ལོག་གནང་བ།",
    "title-g_bo_737": "2023ལོའི་ཚན་རྩལ་ལ་བརྟེན་ནས་རྒྱལ་ཁབ་ཀྱི་དྲིན་ལན་འཇལ་བ་དང་མི་དམངས་ལ་བདེ་སྐྱིད་བསྐྲུན་པའི་ཕུགས་བསམ་བརྟན་དུ་གཏོང་དགོས།",
    "title-g_bo_564": "2023ལོའི་ཞི་ཅིན་ཕིང་གི་“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོ་གསར་རིག་རྩལ་དགོང་ཚོགས་ཆེན་མོ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན་ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ས་གནས་དེ་གའི་དུས་ཚོད་ཟླ་10ཚེས་5ཉིན་ཕོ་ལན་གྱི་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བའི་སྐོར་གྱི་ཡོ་རོབ་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་སྲིད་ཇུས་ལ་ངོ་རྒོལ་མཐའ་གཅིག་ཏུ་བྱ་རྒྱུ་མ་ཟད།",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས་》",
    "title-g_bo_476": "2023ལོའི་ཚེས་བཅུ་དྲུག་ཉིན་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "སྤྱི་ཟླ་2ཚེས་26ཉིན་ལྟ་ན་སྡུག་པའི་མཁའ་དབྱིངས་ཀྱི་བྱང་སྣེའི་འོད་ཟེར་མཐོང་དཀོན་པ་ཞིག་མངོན་ཡོད་པ་དང་།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ཐོན་པ་ནས་བཟུང་བྱུང་བ།",
    "title-g_bo_749": "2023ལོའི་ཚོགས་ལ་མི་མེད་གནམ་གྲུའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུའི་ཐོན་གསར་པའི་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུའི་དོ་ཁུར་ཆེན་པོ་བྱས་པ།",
    "title-g_bo_168": "2023ལོའི་མི་མང་པོས་གཟུགས་པོར་བརྟག་དཔྱད་གནང་བའི་དུས་ཚོད་ཚོད་ལྟ་བྱེད་པའི་བརྟག་དཔྱད་གནང་བ།",
    "title-g_bo_74": "2023ལོའི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་ཡོད།",
    "title-g_bo_522": "2021ལོའི་ཕན་རོཊ་གནའ་ཤུལ་ལ་ལོ་13000ཡན་གྱི་ལོ་རྒྱུས་ལྡན་པ་ར་འཕྲོད་བྱུང་།",
    "title-g_bo_787": "2023ལོའི་ཨུ་རུ་སུའི་མི་ཁྲི་བར་དུ་སུའུ་ཏན་གྱི་ཁྲོད་བྱུང་བའི་མི་ཁྲི་བར་དུ་སུའུ་ཏན་གྱི་ཁྲོད་བྱུང་བའི་མི་ཁྲི་བར་དུ་སུའུ་ཏན་གྱི་ཁྲོད་བྱུང་བའི་མི་ཁྲི་བར་དུ་སུའུ་ཏན་གྱི་ཁྲོད་བྱུང་བའི",
    "title-g_bo_36": "2023ལོའི་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོའི་གྲོང་ཁྱེར་དང་པོ་སྟེ་ཟི་ལིང་དུ་བསྐྱོད་བྱུང་བ།",
    "title-g_bo_495": "《སེ་མ་བྲོ》བོད་ཡིག་ལོ་གཞི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་བྱུང་བ།",
    "title-g_bo_372": "20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། ཙེ་ལན་སི་ཅིས་ཐུག་འཕྲད་བྱེད་སྐབས།",
    "title-g_bo_672": "《དབང་རྩའི་རིག་པ་》ཞེས་པའི་དུས་དེབ་ཀླད་པ་ཁྲག་རྩའི་ནད་དང་སྐྲན་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ།",
    "title-g_bo_538": "2023ལོའི་སྤྱི་ལོ་བོད་ལྗོངས་ཀྱི་སྤྱི་པའི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023ལོའི་དབྱི་སི་རལ་དམག་གི་ཚེས་16ཉིན་གནས་ཚུལ་སྤེལ་ནས་ཧ་མ་སིའི་དམག་མི་སྐྱེལ་འདྲེན་བྱེད་མཁན་རླངས་འཇབ་རྒོལ་བྱས་པ་དང་། ཡུལ་ཁང་ལ་དམག་མི་སྐྱེལ་འདྲེན་བྱེད་མཁན་རླངས་འཇབ་རྒོལ་བྱས་པ་བྱུང་འདུག",
    "title-g_bo_222": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་ལ་ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གསོ་རིག་གསུང་རྩོམ་འགྲེམ་སྤེལ་བྱས།",
    "title-g_bo_611": "1953ལོ་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་གྱི་ཡོན་ཧྲི་ཧྲེན་ཧྲི་ཀྲའོ་ཡིས་གསུངས་དང་ལོ་90ལ་ཕེབས་པའི་ཡོན་ཧྲི་ཁོང་གིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན་",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་དང་རྒྱལ་སྤྱིའི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}