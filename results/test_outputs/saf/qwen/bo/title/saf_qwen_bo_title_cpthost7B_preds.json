    "title-g_bo_638": "2023ལོའི་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་བསྒྲགས་བྱས་པའི་གྲངས་གཞི།",
    "title-g_bo_626": "2023ལོའི་ཨུ་རུ་སུའི་ཡུག་རེན་དམག་ཕྱོགས་ཀྱི་སྤྱི་ཚེས་19ཉིན་ལ་འཇབ་རྒོལ་བྱེད་རྩིས་བྱེད་ཀ་མེད་བཟོས་ཡོད།",
    "title-g_bo_319": "2023ལོ་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྲོམ་ར་ཅན་གྱི་ཉོ་སྒྲུབ་དང་སྲིད་ཇུས་རང་བཞིན་གྱི་ཉོ་སྒྲུབ་ལ་གཅིག་གྱུར་འཆར་འགོད་ངང་དམ་འཛིན་ཡག་པོ་བྱས་ཏེ།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་འགོས་ན་ནད་རོ་འཇོག་སྲིད་དམ།",
    "title-g_bo_511": "བོ་ལི་ཝེ་ཡའི་ཕྱི་འབྲེལ་པུའི་ཕྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས། འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།",
    "title-g_bo_185": "2023ལོའི་ལོ་རེའི་སྤྱི་ཟླ5པ་ནས་མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན།",
    "title-g_bo_884": "2023ལོའི་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་18ཉིན་པ་ལེ་པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་བར་ཕྱི་འབྲེལ་བཙུགས་པ།",
    "title-g_bo_165": "2023ལོའི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས་ནས་ལོ་30འཁོར་བའི་ལོ་ཡིན།",
    "title-g_bo_275": "2017ལོའི་ཕུང་རུས་དེ་གཉིས་ཀྱི་དཔང་ཉན་ཚོགས་འདུ་ཐེངས་དང་པོ་འཚོགས་པ།",
    "title-g_bo_900": "24ཉིན་ཚན་རིག་ཁྱབ་སྤེལ་བྱེད་མཁན་དྲ་གྲོགས་@Jeffཡི་སྐར་ཚོགས་བཀྲ་བའི་གནམ་མཁའི་འགྲུལ་བཞུད་ཅེས་པས་ཤིན་ཅང་ནས་ལྟ་ན་སྡུག་པའི་གླིང་སྣེའི་འོད་ཟེར་བརྙན་དུ་བླངས་ཡོད་པ་རེད།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་ཚོགས་འདུ་གཙོ་སྐྱོང་གནང་བ།",
