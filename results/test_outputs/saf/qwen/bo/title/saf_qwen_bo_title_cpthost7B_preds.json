    "title-g_bo_847": "2022ལོའི་ཟླ་9ཚེས་7ཉིན་ལ་ཨུ་རུ་སུའི་ཙུང་ཐུང་ཕུའུ་ཅིང་གི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐོག་གསུང་བཤད་གནང་བཞིན་པའི་ཚུལ།",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ལ་བཅིངས་འགྲོལ་དམག་དང་དྲག་ཆས་ཉེན་རྟོག་དཔུང་སྡེའི་ཁྲོད་ལན་ཆ་ཡག་པོ་བྱུང་ཡོད།",
    "title-g_bo_1": "2ཉིན་ཚོང་དོན་པུའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "2023ལོའི་ཟླ་སྤྱི་ཟླ་11པའི་ཚེས་5ཉིན་གནས་ཚུལ་སྤེལ་བར་དབྱི་སི་རལ་བར་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གྱི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_830": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་ཧྥི་ལི་ཕིན་གྱི་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་ལ་འཛུལ་འདུག",
    "title-g_bo_90": "2023ལོ་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གསར་པ་ཚོགས་དེ་དྲ་ཐོག་དང་དྲ་ཕྱི་ཟུང་འབྲེལ་གྱི་རྣམ་པས་འཚོགས་ཤིང་།",
    "title-g_bo_826": "2023ལོའི་ཚེས་6ཉིན་དབྱི་སི་རལ་དམག་གིས་ཕ་དབྱི་གདོང་ཐུག་དེ་ཚེས་7ཉིན་ཏག་ཏག་དུས་ཡུན་ཟླ་བ་གཅིག་ཟིན་པ་དང་། སྒྲིག་འཛུགས་དེས་ཉིན་དེར་ལི་པ་ནོན་གྱི་ལྷོ་རྒྱུད་ནས་དབྱི་སི་རལ་བྱང་ཕྱོགས་ལ་མེ་ཤུགས་འཕུར",
    "title-g_bo_17": "2023ལོའི་5G རྟོག་བཟོའི་དངོས་ཡོད་སོགས་ཀྱི་ཐོན་ལས་མགྱོགས་མྱུར་ངང་འཕེལ་རྒྱས་བྱུང་བ།",
    "title-g_bo_285": "《མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་ཆབས་ཅིག ལག་པས་འོག་ནས་ན་ཟུག་གཏོང་བའི་ནད་ཕོག་ཚེ་ལ་འགྱུར་གྱི་ཡོད།》",
    "title-g_bo_827": "སྤྲི་དཀར་མང་པོ་འདུས་པའི་ཟས་རིགས་དཔེར་ན་ཉ་དང་། བྱ་དེ། མཚོ་ཟས། སྲན་མ་སོགས་ལ་ལོ་ཨན་སོན་མང་པོ་ལྡན་ཡོད་པས་རིག་པ་དྭངས་བ་དང་སྦི་ལ་སིལ་དུ་འགྲོ་བར་ཕན་ཐོགས་ཡོད།",
    "title-g_bo_337": "2023ལོའི་ཕྱོགས་གཉིས་པོའི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ་རེད།",
    "title-g_bo_405": "2023ལོའི་ཨུད་དྲིལ་བསྒྲགས་པུའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཨ་རི་དང་ཧྥི་ལི་ཕིན་ཕྱོགས་ཀྱི་ཐུན་མོང་འགོག་སྲུང་ཆིངས་ཡིག",
    "title-g_bo_248": "གལ་ཏུ་བཀག་དགོས་པ་ནི་སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན།",
    "title-g_bo_563": "3D མིག་ཤེལ་མི་དགོས་པའི་བརྙན་ལམ་དེ་སི་ཁྲོན་ཁྲེང་ཏུའུ་ཐའེ་ཀུའུ་ལིར་བསྟན་པ།",
    "title-g_bo_759": "2023ལོའི་ཟླ་12ཚེས་25ཉིན་ལོ་སེ། འབར་མ། ཐེ་ལན་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་དེ་བརྙན་ལམ་ཐོག་ནས་འཚོགས་ཤིང་།",
    "title-g_bo_432": "2024ལོའི་ཡིག་རྒྱུགས་གཏོང་རྒྱུ་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིད་གཟབ་བྱ་དགོས།",
