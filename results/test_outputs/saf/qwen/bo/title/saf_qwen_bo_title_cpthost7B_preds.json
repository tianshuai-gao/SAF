    "title-g_bo_909": "2023ལོའི་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་གསར་འགྱུར་ཁང་གིས་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན།",
    "title-g_bo_959": "2013ལོའི་ཁོང་ཀོ་པུའུ་ལ་འཚམས་འདྲི་གནང་སྐབས། ཀྲུང་གོ་དང་ཁོང་ཀོ་པུའི་མཛའ་གྲོགས་སྨན་ཁང་དུ་ཁོང་གིས་ཕྱི་རྒྱལ་ལ་རོགས་སྐྱོར་ལས་འགན་སྒྲུབ་བཞིན་པའི་ཀྲུང་གོའི་སྨན་བཅོས་རུ་ཁག་ལ་ཆེད་མངགས་གཟིགས་པ།",
    "title-g_bo_976": "2023ལོའི་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་10ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་བསྟན་དོན།",
