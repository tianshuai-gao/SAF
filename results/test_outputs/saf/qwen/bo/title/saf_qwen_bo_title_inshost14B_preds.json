    "title-g_bo_589": "2023ལོའི་ཟླ་10ཚེས་9ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་གཉིས་པོ་གང་འདྲ་བྱས་ཏེ་མཉམ་གནས་བྱ་རྒྱུ་དེས་མིའི་རིགས་ཀྱི་མདུན་ལམ་དང་ལས་དབང་གཏན་ཁེལ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_267": "2022ལོའི་རྟ་མགྲིན་གྱིས་རང་གི་ཨ་མ་ལགས་ཀྱི་གླུ་གཞས་ལེན་བཞིན་པ།",
    "title-g_bo_139": "2023ལོའི་ཀོང་ཏུང་གི་ས་ཁུལ་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13.57ཟིན་ནས་རྒྱལ་ཡོངས་ཀྱི་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་སྒོར་དུང་ཕྱུར་ཁྲི་13ལས་བརྒལ་བའི་ཞིང་ཆེན་དང་པོར་",
    "title-g_bo_809": "ནོ་རོ་ནད་དུག་གི་ནད་རྟགས་མི་མངོན་པའི་དུས་ཡུན་ཆུ་ཚོད་12ནས་48བར་ཡིན་ཞིང་། སྤྱིར་བཏང་ཆུ་ཚོད་24ནས་48བར་ཡིན་པ་རེད།",
    "title-g_bo_355": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་ཉེས་གསོག་དོན་དངོས་གཞན་དག་ཤེས་རྟོགས་བྱུང་འདུག",
    "title-g_bo_154": "2023ལོའི་ཟླ་9ཚེས་12ཉིན་མཇུག་འགྲིལ་བའི་གནམ་གཤིས་འགྱུར་ལྡོག་སྒྲོམ་གཞིའི་སྤྱི་ཆིངས་འཇོག་མཁན་ཕྱོགས་ཀྱི་ཚོགས་ཆེན་ཐེངས་28པ་ས་གནས་དེ་གའི་དུས་ཚོད་ཚེས་12ཉིན་མཇུག་འགྲིལ་རྒྱུ་རེད།",
    "title-g_bo_221": "ཀྲུང་གོ་ཕྱོགས་ཀྱིས་ལྗར་ཕན་གྱི་སྤྱི་དམངས་དེ་དོགས་གཞི་ཡོད་པའི་ལྗར་ཕན་གྱི་སྤྱི་དམངས་ཤིག་དངོས་སུ་འཛིན་བཟུང་བྱ་རྒྱུའི་ཐག་བཅད་ཡོད་མེད་སྐོར་ལ་ཀྲུང་གོའི་ཕྱོགས་ཀྱིས་ར་སྤྲོད་བྱེད་ཐ�",
    "title-g_bo_327": "2023ལོའི་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་མཐོ་རིམ་དམག་དཔོན་སུའུ་ལའེ་མན་ཉི་ཨ་རིས་ལྐོག་གསོད་བཏང་ནས་ལོ་བཞི་འཁོར་བའི་ཉིན་མོ་ཡིན་པ་དང་དབྱི་རན་གྱི་དབྱི་སི་ལམ་གསར་བརྗེའི་སྲུང་དམག་གི་",
    "title-g_bo_323": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་ཨུ་རུ་སུའི་དབྱིར་76རྟགས་ཅན་གྱི་སྐྱེལ་འདྲེན་གནམ་གྲུ་ཞིག་ཚེས་24ཉིན་ཨུ་རུ་སུའི་པེའར་ཀེ་ལུའོ་ཏེ་མངའ་སྡེར་ལྷུང་བས། གནམ་གྲུའི་ཐོག་གི་མི་ཚང་མ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད་པ",
    "title-g_bo_213": "སྟོད་མངའ་རིས་ཀྱི་གནས་མཆོག་འདི་ནི་བོད་ལྗོངས་ཀྱི་ཡུལ་གྲུ་གཞན་ལས་ཆེས་མཐོ་སར་གནས་པས་འཛམ་གླིང་གི་ཡང་རྩེའི་ཡང་རྩེ་ཞེས་པའི་སྙན་པའི་གྲགས་པ་ཕྱོགས་བཞིར་གྲགས།",
    "title-g_bo_276": "2024ལོའི་ཀྲུང་གོ་དང་འགྲོ་བ་མིའི་ཐོབ་ཐང་ལས་འཛིན་ལྷན་ཚོགས་ཀྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་ཀྱི་འགན་ཡུན་སྤྱི་ལོ་2024ལོ་ནས་སྤྱི་ལོ་2026ལོའི་བར་ཡིན་པ་དང་འགན་ཡུན་བསྟུད་མར་འཛིན་རྒྱུ་རེད།",
    "title-g_bo_954": "2023ལོའི་ཟླ་11ཚེས་4ཉིན་ཞི་ཅིན་ཕིང་གིས་ནེ་པ་ལར་ས་ཡོམ་དྲག་པོ་བརྒྱབ་པའི་ཐད་ནེ་པ་ལའི་ཙུང་ཐུང་པའོ་ཏེའར་ལ་འཚམས་འདྲིའི་གློག་འཕྲིན་བཏང་གནང་བ་རེད།",
    "title-g_bo_962": "12306ཐོག་ཏུ་པ་སེ་ཉོ་སྐབས་ཉིན་16གི་སྔ་བསྣུར་དུ་ཉོ་དགོས།",
    "title-g_bo_200": "《མཚོ་སྔོན་པོའི་མཚོ་དར་ཞུ་བ་ལ་ཚང་མས་དོ་ཁུར་ཆེན་པོ་བྱེད་བཞིན་ཡོད》",
    "title-g_bo_210": "2019ལོའི་ཟླ་12ཚེས་1ཉིན་གྱི་ཕྱི་དྲོའི་ཆུ་ཚོད་10པར་འབྲི་ཆུའི་ཟུར་གསུམ་གླིང་གི་གཞི་གཅིག་ཅན་གོང་འཕེལ་ལ་སྐུལ་འདེད་གཏོང་བ་ནི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གིས་འཆར་གཞི་མཉམ་འགོད་དང་ལག་ལེན་མཉམ་བ",
    "title-g_bo_299": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཧྥེ་ཁྲེང་མཉམ་སྒྲོག་རོལ་དབྱངས་ཚོགས་པའི་སྤྱི་འདོམས་པ་དང་དབུ་བཞུགས་ལག་བསྟར་དཔོན་གཅིག་ལྕོགས་མཱ་སི་དབྱི་ལ་འཕྲིན་ལན་སྤྲིངས་གནང་བ་དེར་རྒྱལ་ཁ",
    "title-g_bo_527": "2023ལོའི་ཟླ་11ཚེས་9ཉིན་པེ་ཅིང་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོར་ཞུགས་འབུལ་ཞུས་པ།",
    "title-g_bo_726": "2023ལོའི་ཟླ་10པའི་བརྟག་དཔྱད་སྙན་ཞུ་ལས་མངོན་པ་ལྟར་ན། ཨ་རིའི་ཉིའུ་ཡོག་རྒྱལ་ཕྲན་མཉམ་འབྲེལ་གསོག་འཇོག་དངུལ་ཁང་གིས་རེས་གཟའ་ཟླ་བའི་ཉིན་ཁྱབ་བསྒྲགས་བྱས་པའི་བརྟག་དཔྱད་སྙན་ཞུ་ལས་མངོན་པ་ལྟར་ན། ས�",
    "title-g_bo_188": "དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ཁྲོད་མི་1538རྐྱེན་ལམ་དུ་ཤོར་བ་བརྗོད་ཡོད།",
    "title-g_bo_706": "གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ། གཟུགས་པོར་ལྕགས་རྒྱུ་མི་འདང་བ།",
    "title-g_bo_681": "2020ལོའི་བོད་ལྗོངས་ཀྱི་འབྱུང་ཁམས་ཁོར་ཡུག་ལས་གོ་ལ་ཧྲིལ་པོར་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་སམ།",
    "title-g_bo_960": "2023ལོའི་ཟླ་12ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་14དང་སྐར་མ་30ཙམ་ལ་མེ་འཁོར་འཁོར་ལམ་ལས་བྲལ་བའི་དོན་རྐྱེན་ཐོན་པ།",
    "title-g_bo_371": "བོད་ལྗོངས་ཀྱིས་ཕྱི་ཚུལ་རིང་ལུགས་དང་དཔོན་ཉམས་རིང་ལུགས་ལ་རྡུང་རྡེག་ནན་པོ་བཏང་།",
    "title-g_bo_2": "2023ལོའི་ཀེ་ལིན་ཏ་ཝུའེ་ཁེ་གྲོང་རྡལ་གྱི་ས་ཡོམ་འགོག་བཅོས་བྱེད་པའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_16": "2023ལོའི་ལོ་གསར་དར་ཤིང་ལས་འཕྲོས་པའི་འབྱུང་ཁམས་སྲུང་སྐྱོང་གི་ཕུགས་འདུན།",
    "title-g_bo_844": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་བོད་ལྗོངས་གཞིས་རྩེ་བཞད་མཐོང་སྨོན་རྫོང་མི་དམངས་ཁྲིམས་ཁང་གིས་འདྲི་གཅོད་བྱས་པ་བརྒྱུད་ཁྲིམས་ལྟར་ཞུ་སྦྱོར་ཕྱི་མ་རིན་ཆེ་གེ་མོས་འགྲིམ་འགྲུལ་ཆག་སྒོ་བསླངས་པའི་ག�",
    "title-g_bo_12": "སློབ་མས་སྨན་ཆུ་བླུགས་ཞོར་སྦྱོང་ཚན་འབྲི་བཞིན་པ།",
    "title-g_bo_577": "2022ལོའི་ཨ་རིའི་རྒྱལ་སྲུང་དང་མཁའ་སྐྱོད་ཁྱབ་ཁོངས་ཀྱི་བཟོ་ལས་ཐོན་རྫས་རིན་ཐང་དེ་ཨུ་རུ་སུ་དང་ཡུག་རེན་གྱི་གདོང་ཐུག་ཐོན་པ་ནས་བཟུང་17.5%འཕར་ཡོད།",
    "title-g_bo_474": "2023ལོའི་ཟླ་11ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་24ཐོག་འགོ་འཛུགས་རྒྱུ་ཡིན་པ།",
    "title-g_bo_140": "རྒྱ་གར་དམག་ཕྱོགས་ཀྱི་དཔོན་རིགས་ཤིག་གིས་རྒྱ་གར་དམག་མི་ལྔས་ངོ་ལོག་ཟིང་འཁྲུག་པ་དང་འཐབ་འཁྲུག་བྱས་ཏེ་རྐྱེན་ལམ་དུ་ཤོར་བ་དང་ཉུང་མཐར་ཡང་དམག་མི་གཉིས་ལ་རྨས་སྐྱོན་ཕོག་པ་དང་དེ་རྗེས་ནགས་ཚལ་སྟུག་པ�",
    "title-g_bo_831": "ཡེ་མན་གྱི་ཧུའུ་སའེ་དྲག་ཆས་དང་ཨ་དམག་གཉིས་ཀྱི་བར་དུ་ཡང་གྲི་འཕྱར་ཞིང་གཞུ་འཐེན་པ་ལྟ་བུའི་འགྲན་རྒོལ་རྣམ་པར་གནས་ཡོད།",
    "title-g_bo_933": "2023ལོའི་ཟླ་4ཚེས་10ཉིན་བརྟག་དཔྱད་བྱས་པའི་མའོ་ཆེ་གེ་མོའི་བློ་འདྲིའི་ཁ་པར་འབྱོར་བ།",
    "title-g_bo_696": "2022ལོའི་རྒྱལ་ཁབ་གྲངས་འཛིན་དཔལ་འབྱོར་བསྡོམས་འབོར་ཨ་སྒོར་དུང་ཕྱུར་ཁྲི་31ཟིན་པ་དང་། གྲངས་འཛིན་དཔལ་འབྱོར་གྱིས་རྒྱལ་ནང་ཐོན་སྐྱེད་སྤྱིའི་རིན་ཐང་བསྡུར་གྲངས་ཀྱི་58%བཟུང་ནས་གཞི་ཁྱོན་ར�",
    "title-g_bo_675": "སློབ་གསོ་པུས་སློབ་ཕྱིའི་ལུས་སྦྱོང་ཐད་བྱ་མི་རུང་བ་ལྔ་བཏོན་འདུག",
    "title-g_bo_404": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕྱོགས་གཉིས་པོས་ཁྱབ་བསྒྲགས་བྱས་པའི་གྲངས་གཞི་གསར་ཤོས་ལས་མངོན་པར་གཞིགས་ན། མིག་སྔའི་བར་རེས་སྐོར་དེའི་གདོང་ཐུག་ཁྲོད་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་ཕ�",
    "title-g_bo_65": "2023ལོའི་ཟླ་10ཚེས་14ཉིན་ཏེན་མག་གི་གསར་དུ་བསྐོ་གཞག་བྱས་པའི་རྒྱལ་པོ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པར་རྟེན་འབྲེལ་ཞུ་བའི་གློག་འཕྲིན་བཏང་སྟེ་ཧྥེ་ཐེ་ལེ་སྐུ་ཐོག་བཅུ་པ་ཁྲི་ལ་འཁོད་པར་བཀྲ་ཤིས་བད�",
    "title-g_bo_214": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་གྲོས་ཆོད་འཆར་ཟིན་ལ་ཨ་རིས་བསྟུད་མར་མོས་མཐུན་མེད་པའི་འདེམས་ཤོག་འཕངས་ཡོད།",
    "title-g_bo_79": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་མི་དམངས་སྲིད་གཞུང་གི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ཚོང་ཁང་དང་པོའི་དཔལ་འབྱོར་ལ་རོགས་སྐྱོར་བྱ་ཐབས་ཀྱི་ཚོད་ལྟའི་ལག་བསྟར་བརྡ་ཐོ་༼ལྷ་ས་གྲོང་ཁྱེར་སྲིད་གཞུང་གི་ཡིག་ཆ་〔2023〕�",
    "title-g_bo_761": "ཡུག་རེན་གྱིས་ཡོ་རོབ་མནའ་འབྲེལ་གྱི་ཁོངས་གཏོགས་རྒྱལ་ཁབ་གསུམ་གྱི་བྱ་སྤྱོད་དེ་རྒྱལ་སྤྱིའི་འོས་འགན་ལས་འགལ་ཡོད་པར་ངོས་འཛིན་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_632": "2023ལོའི་ཟླ་12པའི་ཚེས་27ཉིན་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་དུ་འཇབ་རྒོལ་བྱས་པ་གནད་ལ་འཕིགས་པ་དང་དམིགས་ཡུལ་ཡོད་པ་ཞིག་ཡིན་ཞེས་བཤད་པ།",
    "title-g_bo_318": "2023ལོའི་ཟླ་9ཚེས་25ཉིན་མོས་མཐུན་ཡོད་པའི་འདེམས་ཤོག་ཡོངས་ཀྱི་ཐོག་ནས་ཁྲིམས་གཞི་ཞིག་ལ་གྲོས་འཆམ་བྱུང་བ།",
    "title-g_bo_856": "ཨ་རིའི་རྒྱ་མཚོའི་ཤར་རྒྱུད་ཀྱི་རྒྱ་མཚོའི་ཚ་རླབས་ཀྱི་རྐྱེན་ལས་ཁ་བའི་སྡིག་སྲིན་གྱི་གྲངས་འབོར་ཆེས་ཆེ།",
    "title-g_bo_292": "2023ལོའི་ཟླ་8ཚེས་23ཉིན་གྱི་གསར་འགོད་པའི་རྒྱུན་ལྡན་གྱི་ཚོགས་འདུ་གཙོ་སྐྱོང་བྱས་པ།",
    "title-g_bo_0": "《དེ་རིང་གི་རྒྱ་གར》ཞེས་པའི་ཐོག་གནས་ཚུལ་སྤེལ་བར་གཞིགས་ན། རྒྱ་གར་དང་ཁ་ན་ཏའི་བར་གྱི་ཕྱི་འབྲེལ་ཉེན་ཁ་ཇེ་ཆེ་རུ་འགྱུར་བཞིན་ཡོད།",
    "title-g_bo_802": "ཨ་རི་དང་ལྗར་པན། ལྷོ་ཁོ་རེ་ཡ་བཅས་ཀྱིས་ཁོ་རེ་ཡ་ཕྱེད་གླིང་ནས་མཁའ་ཐོག་ནང་སྦྱོང་ཐོག་མ་བྱ་རྒྱུ།",
    "title-g_bo_713": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཧ་ནོ་དབྱིར་ཕེབས་ཏེ་ཝེ་ཐེ་ནམ་དུ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་སྐབས།",
    "title-g_bo_865": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་མི་ཞིག་གདོང་ཐུག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_180": "2023ལོའི་ལོ་མཇུག་ཏུ་ཁྲུང་ཆིང་སློབ་ཆེན་གྱི་སློབ་མ་1100ལྷག་ཙམ་དང་ལོ་རིམ་དང་པོའི་སློབ་མ་200ལྷག་ཙམ་གྱི་ལག་ཏུ་འབྱོར་ནས་དྲོ་སྐྱིད་ལྡན་པའི་འགོ་ཚུགས་པ།",
    "title-g_bo_638": "2023ལོའི་ཟླ་དང་པོ་ནས་ཟླ་བཅུ་པའི་བར་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་ཕྱིར་གཏོང་ནང་འདྲེན་གྱི་སྤྱིའི་རིན་ཐང་དུས་མཚུངས་ལས་12.1%འཕར་ཡོད།",
    "title-g_bo_626": "2023ལོའི་ཟླ་11ཚེས་19ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གིས་ཨུ་རུ་སུའི་མཁའ་དམག་གིས་ཉིན་དེར་མོ་སེ་ཁོར་འཇབ་རྒོལ་བྱེད་རྩིས་ཡོད་པའི་ཡུག་རེན་གྱི་མི་མེད་གནམ་གྲུ་གཅིག་གཏོར་ལྷུངས་བཏང་ཡོད་པའི་སྐོར་གྱི་གས",
    "title-g_bo_319": "2023ལོའི་རྒྱལ་ཁབ་འབྲུ་རིགས་དང་དངོས་ཟོག་གྲབས་གསོག་ཅུས་ཀྱི་ཁྱབ་བསྒྲགས་གསར་ཤོས་ལ་གཞིགས་ན། རང་རྒྱལ་གྱིས་འབྲུ་རིགས་རྒྱ་མ་དུང་ཕྱུར་8000ལྷག་ཉོ་སྒྲུབ་བྱས་ཡོད།",
    "title-g_bo_566": "གློ་ཚད་ཕྲ་གྱེས་གདོད་གཟུགས་ལ་ཁྱད་ཆོས་གཉིས་ཡོད་པ་དང་། གཉིས་ནི་ད་ལོ་འགོས་ནད་ཕོག་མང་བ་དང་། གཅིག་ནི་འགོས་ནད་ཕོག་པའི་མི་ཚོགས་ཀྱི་ལོ་ན་ཆུང་བའི་ཁྱད་ཆོས་མངོན་ཡོད།",
    "title-g_bo_511": "དབྱི་སི་རལ་དང་ཕྱི་འབྲེལ་གྱི་འབྲེལ་བ་རྦད་དེ་གཅོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_656": "༢༠༢༤ལོའི་ཀན་ལྷོ་ཁུལ་མཉམ་འདྲེས་སྨྱན་སྦྱོར་ལྟེ་གནས་ཀྱི་རྒྱང་སྒྲོག་ལོ་སར་སྤྲོ་ཚོགས།༼འབྲུག་གཡང་ནོར་བུའི་མཆོད་བསྟོད།༽",
    "title-g_bo_185": "2023ལོའི་ཟླ5པ་ནས7པའི་བར་མཚོ་སྔོན་གྱི་གཙང་གསུམ་ཆུ་མགོ་དང་ཤིན་ཅང་ཨའར་ཅིན་ཧྲན། བོད་བྱང་ཐང་བཅས་ཀྱི་གཙོད་མོ་ཨ་ཆེན་གངས་རྒྱབ་ཀྱི་གཙོད་གནས་མཚེའུ་ཉེ་འགྲམ་དུ་གནས་སྤོ་བྱེད་ཅིང་། གཙོད་ཕྲུག་བཙས་རྗེས་",
    "title-g_bo_884": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་པའེ་ཏེང་དབྱི་སི་རལ་དུ་འབྱོར་བ་དང་གདོང་ཐུག་ཁྲོད་གྲོངས་པའི་མི་གྲངས་ 5200 ཟིན་པ།",
    "title-g_bo_82": "2023ལོའི་ལོ་འཁོར་གྱི་ཕྱི་རྒྱལ་དུ་བཅའ་སྡོད་གཞུང་ཚབ་པའི་ལས་དོན་གྲོས་ཚོགས་ལ་ཞུགས་མཁན་གཞུང་ཚབ་པར་མཇལ་འཕྲད་གནང་བ།",
    "title-g_bo_199": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཁོ་ལོམ་པི་ཡའི་འབྲེལ་བ་དེ་འཐབ་ཇུས་རོགས་ཟླའི་འབྲེལ་བར་རིམ་པ་སྤོར་རྒྱུའི་ཁྱབ་བསྒྲགས་གནང་བ།",
    "title-g_bo_165": "2023ལོའི་ཨ་ཤེ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེན་མོའི་དཔལ་འབྱོར་མཉམ་ལས་སྒྲིག་འཛུགས་ཀྱི་འགོ་ཁྲིད་པའི་དངོས་གཞི་མིན་པའི་གྲོས་ཚོགས་ཐེངས་དང་པོ་འཚོགས་ནས་ལོ་30འཁོར་བའི་ལོ་ཡིན།",
    "title-g_bo_275": "2017ལོའི་མོ་ཞི་ཁོའི་གྲོས་ཚོགས་ཀྱི་དཔང་ཉན་ཚོགས་འདུའི་ཐོག་གོ་ལ་གཞན་གྱི་སྐྱེ་དངོས་འདྲ་པོ་ཡོད་པའི་ཕུང་རུས་གཉིས་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_900": "2023ལོའི་ཟླ་2ཚེས་24ཉིན་གྱི་ཐོ་རེངས་ཆུ་ཚོད་2པར། ཉི་མའི་འགུལ་སྐྱོད་དྲག་པའི་སྐབས་སུ་འཕྲེད་ཐིག་ཚད་ཆེ་འབྲིང་ས་ཁུལ་དུ་སྣེ་འོད་མཐོང་ཐུབ་པར་གྱུར་བ་རེད།",
    "title-g_bo_550": "2024ལོའི་ཀྲུང་གོའི་བདེ་འཇགས་འཐབ་ཇུས་སྙན་ཞུ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_388": "དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་རྒྱུད་དུ་འབྱོར་བའི་དོན་དག་གཞིར་བཟུང་ནས་དམག་དོན་རྡུང་རྡེག་གཏོང་བཞིན་ཡོད།",
    "title-g_bo_578": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་དབྱི་སི་རལ་དམག་ཕྱོགས་ཀྱིས་ཀ་ཧྲ་ས་ཁུལ་ལྷོ་རྒྱུད་ཀྱི་ཧན་ཡིའུ་ཉི་སིར་གཞི་ཁྱོན་ཆེ་བའི་ཕར་རྒོལ་བྱས་པ།",
    "title-g_bo_722": "2023ལོའི་ཟླ་12ཚེས་5ཉིན་ཨན་ཏེ་ལི་·ཉི་ལི་ནཱ་·ལ་ཆའོ་ལི་ནཱ་ལ་གློག་འཕྲིན་བཏང་གནང་ནས། ཀྲུང་གོ་དང་མ་ཏ་ཀ་སི་ཁར་གྱི་འབྲེལ་བ་འཕེལ་རྒྱས་མགྱོགས་པོ་བྱུང་བ་དང་། ཁྱབ་ཁོངས་ཁག་གི་སྤེལ་རེས་མཉམ་ལས་ལ་གཡུར་ཟའི་",
    "title-g_bo_235": "2024ལོའི་ཧྥ་རན་སེའི་ཕ་རི་སིའི་དར་སྲོལ་ཁྱིམ་ཆས་ཇུས་འགོད་འགྲེམས་སྟོན་ཐོག་དངོས་སུ་འགྲེམས་སྟོན་བྱས་པ།",
    "title-g_bo_277": "2023ལོའི་བོད་ལྗོངས་སྨན་ཁང་གཉིས་པའི་བོད་རང་སྐྱོང་ལྗོངས་མ་བུ་བདེ་སྲུང་སྨན་ཁང་གི་སྒྲ་རླབས་གསོ་རིག་ཚན་ཁག་གི་བྱིས་པའི་ལྷན་སྐྱེས་སྙིང་ནད་ལ་བརྟག་དཔྱད་བྱེད་རྒྱུ་རེད།",
    "title-g_bo_918": "《ཀྲུང་གོ་རིག་པའི་ཚོགས་ཆེན་ཧྲང་ཧའེ་གླེང་སྟེགས་ལ་རྟེན་འབྲེལ་ཞུ་བའི་འཕྲིན་ཡིག》སྤྲིངས་ནས་ཀྲུང་གོ་རིག་པའི་ཞིབ་འཇུག་གི་དོན་སྙིང་གལ་ཆེན་རྒྱས་བཤད་གཏིང་ཟབ་གནང་བ།",
    "title-g_bo_451": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆུ་ཚོད་10པར་ཞིང་ཆེན་ནན་ཁྲང་ཨན་དབྱི་རྫོང་ཏིན་ཧུའུ་གྲོང་རྡལ་དུ་སྒོར་ཁྲི་1169ཏག་ཅོག་ཙེའི་སྟེང་དུ་སྤུངས་ཡོད་པ།",
    "title-g_bo_997": "2023ལོའི་ཟླ་10ཚེས་8ཉིན་གྱི་ཆུ་ཚོད་10པར་ཧོ་ལ་ཐེ་མངའ་སྡེའི་ས་ཡོམ་ནང་མི་2053རྐྱེན་ལམ་དུ་ཤོར་བ་དང་མི་9000ལྷག་ཙམ་ལ་རྨས་སྐྱོན་ཕོག་ཡོད།",
    "title-g_bo_544": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་གསར་མཐོའི་ལག་རྩལ་གྲུབ་འབྲས་བརྗེ་རེས་ཚོགས་འདུ་སྐབས་ཉེར་ལྔ་བ་མཇུག་བསྒྲིལ་བ་དང་།",
    "title-g_bo_99": "རྐེད་པའི་ཤ་གནད་ལ་གནོད་འཚེ་བཟོ་གི་ཡོད།",
    "title-g_bo_847": "2023ལོའི་ཤར་ཕྱོགས་དཔལ་འབྱོར་གླེང་སྟེགས་ཀྱི་ཚང་འཛོམས་གྲོས་ཚོགས་ལ་ཞུགས་རྒྱུ་ཡིན་ལུགས་བརྗོད་འདུག",
    "title-g_bo_92": "2024ལོའི་ལོ་གསར་ཤིས་ཚིག་ནན་ཏན་ངང་གསན་གཟིགས་གནང་བ།",
    "title-g_bo_1": "2023ལོའི་ཀྲུང་གོ་རྒྱལ་སྤྱིའི་ནང་འདྲེན་དངོས་མང་འགྲེམས་ཚོགས་འགོ་ཚུགས་གྲབས་ཡོད།",
    "title-g_bo_936": "2023ལོའི་ཟླ་11པའི་ཚེས་5ཉིན་གྱི་ཕྱི་དྲོའི་ཆུ་ཚོད་10པར་རེས་སྐོར་གསར་པའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་བར་གྱི་གདོང་ཐུག་ཁྲོད་ཕྱོགས་གཉིས་པོའི་མི་11000ལྷག་ཙམ་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_830": "2023ལོའི་ཟླ་8ཚེས་22ཉིན་ཧྥི་ལི་ཕིན་གྱི་སྐྱེལ་འདྲེན་ཁ་གསབ་གྲུ་གཟིངས་2དང་མཚོ་ཐོག་ཉེན་རྟོག་གྲུ་གཟིངས་2ཀྲུང་གོའི་ནན་ཧྲ་གླིང་ཕྲན་གྱི་རེན་ཨའེ་ཅའོ་ཉེ་འགྲམ་མཚོ་ཁོངས་སུ་འཛུལ་འདུག",
    "title-g_bo_90": "2023ལོའི་ཀྲུང་གོའི་མི་རིགས་ཡིག་སྒྱུར་ཅུས་ཀྱི་བོད་སྐད་ཡིག་བརྡ་ཆད་གཅིག་གྱུར་གཏན་འབེབས་བྱས་པ།",
    "title-g_bo_826": "2023ལོའི་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱེད་བཞིན་ཡོད།",
    "title-g_bo_17": "2023ལོའི་རྒྱལ་ཡོངས་ཀྱི་བཟོ་ལས་དང་ཆ་འཕྲིན་ཅན་གྱི་རྩལ་ནུས་འགྲན་བསྡུར་ཆེ་མོའི་རྣམ་གྲངས་བཀོད་སྒྲིག་བྱས་ནས་རྩལ་ནུས་ཆེ་བའི་ཤེས་ལྡན་པ་གདམ་གསེས་བྱས་ཡོད།",
    "title-g_bo_285": "《མཇིང་པར་ན་ཟུག་གཏོང་བ་དང་། ལག་པས་འོག་ནས་སྒང་ལ་འཕུར་འཕུར་བཏང་ན་ན་ཟུག་ཆུང་དུ་འགྲོ་བ་དང་ཤུགས་ཀྱིས་མནན་ན་ན་ཟུག་ཆེ་རུ་ཕྱིན་ཚེ། སྤྱིར་ན་མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཡོད།》",
    "title-g_bo_827": "དབྱར་ཁ་དང་སྟོན་ཁའི་དུས་ཚིགས་ནི་མི་རྣམས་སྒྱིད་ལུག་དང་ཉོབ་སྟངས་སླེབས་པའི་ནམ་དུས་ཤིག་རེད།",
    "title-g_bo_337": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ནས་ཚེས་24ཉིན་བར་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་མཐའ་མཚམས་གྲོས་མོལ་ཐེངས་ཉེར་ལྔ་པ་པེ་ཅིང་དུ་འཚོགས་པ།",
    "title-g_bo_405": "2023ལོའི་བོད་སྐད་སྒྱུར་བཟོའི་གློག་བརྙན་གྱི་ཞིབ་བསྡུར་ཚོགས་འདུ་དང་གློག་བརྙན་དཔྱད་འདེམས་ལས་སྒོའི་གསོ་སྦྱོང་བྱེད་སྒོ་ལྷ་ས་གྲོང་ཁྱེར་དུ་གཉེར་བ།",
    "title-g_bo_858": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་གྱི་ལམ་དུམ་ཁག་གཅིག་ཏུ“འགྲུལ་བཞུད་མཁན་སྔོན་ལ་མ་བཏང་ཚེ”གློག་མིག་ནས་པར་རྒྱག་པའི་མ་ལག་སྤྱོད་འགོ་ཚུགས་པའི་སྐོར་གྱི་སྤྱི་བསྒྲགས།",
    "title-g_bo_982": "ཧྥི་ལི་ཕིན་དང་ཀྲུང་གོའི་མཉམ་འབྲེལ་ཁྲིམས་མཐུན་གྱིས་ཁྲིམས་མཐུན་ཁེ་དབང་བྱ་སྤྱོད་ལ་སྐྱོན་འཛུགས་བྱས་པ།",
    "title-g_bo_248": "སྐད་འཕྲིན་གྱི་དངུལ་རྩའི་རྒྱུ་ནོར་བདག་གཉེར་ཐོན་རྫས་ཞབས་ཞུ་ཡིན་པ་དང་། དེ་ལས་ལྡོག་སྟེ་དེས་བཀོལ་སྤྱོད་ནོར་འཁྲུལ་ཐོན་སླ་བའམ་གཡོ་འོག་ཏུ་ཚུད་བྱེད་ཙམ་ལས་གཞན་ཕན་པ་གཏན་ནས་མེད།",
    "title-g_bo_563": "3Dམིག་ཤེལ་མི་དགོས་པའི་གཡོ་འགུལ་རྣམ་པ་ཉམས་སུ་མྱོང་བ་དང་།",
    "title-g_bo_759": "2023ལོའི་རྫ་ཆུ་དང་མའེ་ཀུང་གཙང་པོའི་མཉམ་ལས་ཀྱི་འགོ་ཁྲིད་པའི་ཚོགས་འདུ་ཐེངས་བཞི་པ་བརྙན་ལམ་ཐོག་ནས་འཚོགས་པ།",
    "title-g_bo_432": "2024ལོའི་རྒྱལ་ཁབ་ལས་ཁུངས་ཀྱི་གཞུང་ཞབས་པ་བསྡུ་བའི་ཡིག་རྒྱུགས་སྤྱི་ཟླ་11པའི་ཚེས་25དང་26ཉིན་གཏོང་རྒྱུ་རེད།",
    "title-g_bo_932": "ཧོ་ཐའེ་ཏ་གྲོང་ཁྱེར་གྱི་མཁའ་དབྱིངས་སུ་ལྡིང་སྐོར་བརྒྱབ་པ།",
    "title-g_bo_110": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐབས་བཅུ་དགུ་པའི་ཀྲུང་དབྱང་ཨུ་ཡོན་ལྷན་ཁང་གི་ཚོགས་འདུ་ཐེངས་བཅུ་པའི་ཐོག་ཨེ་ཤ་ཡ་དང་ཞི་བདེ་རྒྱ་མཚོ་ཆེ་མོ་ཁུལ་གྱི་མཉམ་ལས་ཀྱི་ཐོག་མའི་བསམ་འདུན་མཐ",
    "title-g_bo_707": "ཨུ་རུ་སུ་དང་བྱང་ཁོ་རེ་ཡ་བར་གྱི་འབྲེལ་བ་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་ཡོད་ལུགས་བརྗོད་འདུག",
    "title-g_bo_822": "2023ལོའི་ཀྲུང་གོ་བཟོ་སྐྲུན་ཁང་གི་ཡོན་ཧྲིའི་མིང་ཐོ་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_604": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་པེ་ཅིང་དུ་རྒྱལ་ཡོངས་དྲིལ་བསྒྲགས་པུའུ་ཀྲང་གི་གྲོས་ཚོགས་ཚེས་3ཉིན་པེ་ཅིང་དུ་སྐོང་འཚོགས་བྱས་པ།",
    "title-g_bo_529": "བུ་ཆང་ཆང་ལ་ཚ་བ་རྒྱས་པའི་གློ་ལུ་རྒྱག་དགོས་སམ།",
    "title-g_bo_38": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ཧན་ཡིའུ་ཉི་སིའི་ནུབ་རྒྱུད་དུ་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་གོ་མཚོན་བཟོ་གྲྭ་ཞིག་ལ་འཇབ་རྒོལ་བྱས་ན",
    "title-g_bo_341": "ཨུ་རུ་སུའི་མོ་སི་ཁོའི་ལྕགས་ལམ་ཅུས་ཀྱིས་ས་གནས་དེ་གའི་དུས་ཚོད་སྤྱི་ཚེས་11ཉིན་བསྟན་པར། ཉིན་དེའི་སྔ་དྲོའི་ཆུ་ཚོད་7པར་ཟོག་འདྲེན་མེ་འཁོར་ཞིག་ལིའང་ཙན་མངའ་སྡེ་བརྒྱུད་འགྲོ་སྐབས་ཆག་སྒོ་བྱུང",
    "title-g_bo_287": "ཨ་རི་དང་ཡུག་རེན་གྱི་གདོང་གཏུག་བྱུང་ཚུན་ཨུ་རུ་སུ་ཕྱོགས་ཀྱིས་མེ་ཐོག་སྣུམ་བླུགས་པ་དང་། དེའི་དམིགས་ཡུལ་ནི་ཡུག་རེན་བེད་སྤྱད་དེ་མེ་ཐོག་སྣུམ་བླུགས་པ་རེད།",
    "title-g_bo_394": "2023ལོའི་ལོ་འཁོར་གྱི་ལྗོངས་ཡོངས་ཀྱི་དཔལ་འབྱོར་འཁོར་རྒྱུག་གནས་ཚུལ་གྱི་གསར་འགྱུར་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ནས་ཤེས་རྟོགས་བྱུང་བ།",
    "title-g_bo_901": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་ནི་ཁ་ར་ཀྭའི་ཕྱི་འབྲེལ་འབྲེལ་བ་སླར་གསོ་བྱ་རྒྱུའི་ཆབ་སྲིད་ཀྱི་ཇུས་ཐག་བཅད་ཡོད།",
    "title-g_bo_342": "2023ལོའི་ཟླ་9ཚེས་5ཉིན་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་མཐོང་དཀོན་པའི་གསལ་བསྒྲགས་ཤིག་སྤེལ་ཡོད།",
    "title-g_bo_629": "2025ལོར་རང་རྒྱལ་གྱི་མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་འཕེལ་རྒྱས་ཀྱི་མཛུབ་ཁྲིད་བསམ་འཆར་ཁྱབ་བསྒྲགས་བྱས་ནས། མིའི་དབྱིབས་ཀྱི་འཕྲུལ་མི་གསར་གཏོད་མ་ལག་ཐོག་མར་བཙུགས་ཏེ། “ཀླད་ཆེན་དང་། ཀླད་ཆུང་།ར",
    "title-g_bo_259": "2023ལོའི་ཀྲུང་གོའི་ལོ་ཆུང་བྱིས་པའི་དཔྱིད་འགོའི་མེ་ཏོག་ཆུང་ངུའི་བརྩམས་ཆོས་ལ་བྱ་དགའ་སྤྲོད་པའི་བཞུགས་མོལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_685": "ཨ་རིའི་མཉམ་འབྲེལ་གསར་འགྱུར་ཁང་གིས་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའེ་ཚོགས་པའི་དྲུང་ཆེ་མ་ལེ་ཨེར་ཏེ་ལེ་སིའི་སྐད་ཆ་ལུང་དུ་དྲངས་ནས་ཆུ་ལོག་གནོད་འཚེ་ཚབས་ཆེན་བྱུང་བ་དང་། སྤྱི་ཚེས་14ཉིན་ལི་པི་ཡའི་ཧུང་ཤིན་ཡུའ",
    "title-g_bo_978": "2023ལོའི་ཟླ་10ཚེས་23ཉིན་ཀྲུང་གོ་དང་འབྲུག་ཡུལ་གྱི་ཕྱི་འབྲེལ་བློན་ཆེན་བསྟན་ཏིག་རྡོ་རྗེ་ལ་ཐུག་འཕྲད་བྱས།",
    "title-g_bo_50": "2023ལོའི་ཟླ་12པའི་ཚེས་3ཉིན་གྱི་ཞི་ཅིན་ཕིང་གིས་སྐབས་དང་པོའི“ལིའང་ཀྲུའུ་གླེང་སྟེགས”ལ་རྟེན་འབྲེལ་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_769": "2023ལོའི་ཟླ་11ཚེས་27ཉིན་གྱི་ཆུ་ཚོད་7པར་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་བ་10དང་ཕ་ལེ་སི་ཐན་བ་30བརྗེ་པོ་རྒྱག་རྒྱུ་དང་། དམག་མཚམས་འཇོག་པའི་ཆ་རྐྱེན་ཡང་དེའི་གོང་དང་གཅིག་མཚུངས་ཡིན་ཞེས་བཤད་ཡོད།",
    "title-g_bo_582": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་སྐུད་མེད་དྲ་བ་སྦྲེལ་མཐུད་བྱེད་པའི་གྱོད་དཔེ་གཉིས་ལ་གཟིགས་རོགས།",
    "title-g_bo_635": "2023ལོའི་ཟླ་4ཚེས་2ཉིན་ལྷ་སའི་གྲོང་མི་ལི་ཆེ་གེ་མོར་ཅིང་ཏུང་དངུལ་རྩའི་འཛད་སྤྱོད་ཞབས་ཞུ་བ་ཡིན་ཟེར་མཁན་ཞིག་གི་ཁ་པར་འབྱོར་བ་དང་། མི་དེས་ཅིང་ཏུང་ཆད་འཛིན་གྱི་རྩིས་ཐོ་སུབ་རོགས་བྱས་ཆོག་ཅེས་པར་ཁ་གཡར",
    "title-g_bo_444": "རླངས་འཁོར་གློ་བུར་དུ་སྒོ་ཕྱེ་སྟབས་བུ་མོ་ཞིག་བསད་འདུག",
    "title-g_bo_167": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གཟུགས་པོར་བརྟག་དཔྱད་གནང་དགོས་པའི་དོན་ཚན་གཞན་དག་ལ་དོ་སྣང་གནང་དགོས།",
    "title-g_bo_283": "ལྷ་སར་མཐའ་མཚམས་འགྲོ་འོང་ལག་ཁྱེར་གྱི་འགྲོ་ལུགས་གཉེར་སྟབས་བདེ་རུ་བཏང་བ།",
    "title-g_bo_263": "ཨ་རིའི་དམག་ཕྱོགས་ཀྱིས་དབྱི་རག་དང་སི་རི་ཡར་ཡོད་པའི་ཨ་རིའི་དམག་ལ་ཉེ་ཆར་འཇབ་རྒོལ་རབ་དང་རིམ་པ་ཕོག་པར་ཡ་ལན་སློག་པ་ཡིན།",
    "title-g_bo_872": "2023ལོའི་ཟླ་4པའི་ཚེས་18ཉིན་འབའ་ཐང་རྫོང་སྤྱི་ཚོགས་སྟོབས་ཤུགས་འཕེལ་རྒྱས་ལྟེ་གནས་སུ་འགྲན་བསྡུར་ཆེན་མོ་འཚོགས་པ།",
    "title-g_bo_247": "2023ལོའི་ཟླ་12ཚེས་15ཉིན་ཨ་རི་དང་ཀྲུང་གོའི་ཉོ་ཚོང་རྒྱལ་ཡོངས་ཨུ་ཡོན་ལྷན་ཁང་དབུ་བརྙེས་ནས་ལོ་50འཁོར་བའི་རྟེན་འབྲེལ་མཛད་སྒོར་ཤིས་འཕྲིན་སྤྲིངས་གནང་སྟེ། ཨུ་ཡོན་ལྷན་ཁང་དང་དེའི་ཁོངས་མི་ཡོངས་ལ་",
    "title-g_bo_575": "2020ལོའི་ཡར་ཀླུང་གཙང་པོའི་རི་རྩེ་གནམ་ལྕགས་འབར་བའི་སྣོད་བཅུད་རིན་ཐང་ལྡན་པའི་ས་ཁུལ་གྱི་གྲོང་རོང་ཞིག་རེད།",
    "title-g_bo_417": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་གཏུག་ཁྲོད་ཀ་ཧྲ་ས་ཁུལ་གྱི་མི་5087རྐྱེན་ལམ་དུ་ཤོར་བ་དང་། དེའི་ཁྲོད་དུ་བྱིས་པ་2055ཡོད་པ།",
    "title-g_bo_484": "2024ལོའི་སྤྱིར་བཏང་མཐོ་སློབ་ཀྱི་འོས་སྐྱེལ་ཆ་རྐྱེན་ལྡན་པའི་སློབ་མའི་འོས་སྐྱེལ་ཆ་རྐྱེན་དང་སློབ་བསྡུའི་ཆེད་ལས་སོགས་ཀྱི་ཐད་ལ་གཏན་འབེབས་བྱས་ཡོད།",
    "title-g_bo_249": "2023ལོའི་ཟླ་1ཚེས་31ཉིན་ཀྲུང་གོ་དང་མ་ལེ་ཞི་ཡའི་མཉམ་ལས་གྲོས་མཐུན་བཀོད་པ།",
    "title-g_bo_380": "2023ལོའི་ཟླ་10པའི་ཚེས་20ཉིན་གྱི་ཕྱི་དྲོའི་དུས་ཚོད་དང་ཟླ་11པའི་ཚེས་18ཉིན་གྱི་དགོང་མོ་འཇབ་རྒོལ་ཕོག་པ།",
    "title-g_bo_909": "2023ལོའི་ཟླ་9ཚེས་6ཉིན་ཨ་རབ་མཉམ་འབྲེལ་ཚོ་དཔོན་རྒྱལ་ཁབ་ཀྱི་ཙུང་ཐུང་མོ་ཧན་མོ་ཏེས་ཨ་པུ་བཀྲ་པེར་འཚམས་འདྲི་བྱེད་པའི་གནས་ཚུལ།",
    "title-g_bo_959": "2013ལོའི་ཟླ་3པའི་ཚེས་30ཉིན། ཀྲུང་གོ་དང་ཁོང་ཀོ་པུའི་མཛའ་གྲོགས་སྨན་ཁང་དུ་ཁོང་གིས་ཕྱི་རྒྱལ་ལ་རོགས་སྐྱོར་ལས་འགན་སྒྲུབ་བཞིན་པའི་ཀྲུང་གོའི་སྨན་བཅོས་རུ་ཁག་ལ་ཆེད་མངགས་གཟིགས་པ།",
    "title-g_bo_976": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་བྱིས་པའི་ཐེབས་རྩ་ཚོགས་པས་སུའུ་ཏན་གྱི་བྱིས་པ་ཁྲི་350ཡུལ་གྱར་བར་གྱུར་ཡོད།",
    "title-g_bo_97": "2023ལོའི་ལྗར་ཕན་དུ་ལོ་65ཡན་གྱི་རྒན་རྒོན་ཁྲི་3623ཡོད་པ་དེ་ན་ནིང་གི་དུས་མཚུངས་ལས་མི་ཁྲི་1ཉུང་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_309": "2023ལོའི་ནེ་པ་ལའི་ས་ཡོམ་ཁྲོད་མི་སྣ་ཤི་རྨས་སྐོར་གྱི་གནས་ཚུལ་གསར་ཤོས།",
    "title-g_bo_792": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
    "title-g_bo_102": "ཁ་བསླུས་རྒྱག་མཁན་གྱི་གྲོང་མི་ཀྲང་ཆེ་གེ་མོ་དང་པའེ་དབན་སྨན་བཅོས་འགན་བཅོལ་གྱི་ལས་གཉེར་བ་ཡིན་ནམ།",
    "title-g_bo_56": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེད་མཁས་པས་ཏེང་གེ་ཚ་ནད་ཕོག་པའི་ནད་པ་མང་དུ་ཕྱིན་པ།",
    "title-g_bo_973": "དབང་ཆེན་གྱི་ཕུགས་བསམ་དད་སེམས་ཤོར་བ།",
    "title-g_bo_294": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེད་མངགས་བྱང་བུ་འདི་འདྲ་ཞིག་རྙེད་ཀྱི་ཡོད།",
    "title-g_bo_689": "《སློབ་མ་ཚོར་དོན་དག་གང་དག་ལ་ངེས་པར་དུ་དོ་སྣང་བྱེད་དགོས་པ་དང་ཆ་འཕྲིན་གང་དག་ཕྱིར་གྱར་མི་རུང་བའི་དྲན་སྐུལ་བྱེད་རྒྱུ་ཡིན།》",
    "title-g_bo_551": "2023ལོའི་ཟླ་12ཚེས་23ཉིན་གྱི་སྔ་དྲོ་ཧང་ཀྲོའུ་ཤིས་ཧུའུ་རྒྱལ་མགྲོན་ཁང་དུ་སྐབས་19པའི་ཨ་ཤེ་ཡའི་ལུས་རྩལ་འགྲན་ཚོགས་ཀྱི་འགོ་ཚུགས་མཛད་སྒོར་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་རྒྱལ་པོ་ཞི་ཧ་མུའུ་ཉ",
    "title-g_bo_857": "《བཟོ་སྐྲུན་རྒྱལ་ཁབ་སྟོབས་ཆེན་སྐོར་གྱི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་གི་རྣམ་བཤད་གལ་ཆེན་གྱི་སློབ་སྦྱོང་ཀློག་དེབ》དེ་ཉེ་ཆར་མི་དམངས་དཔེ་སྐྲུན་ཁང་གིས་དཔེ་སྐྲུན་བྱས་ནས་རྒྱལ་ཡོངས",
    "title-g_bo_146": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་སྔ་དྲོ་ཀྲུང་གོ་དང་མོ་ཞི་ཁོ་རྒྱལ་ཁབ་གཉིས་པོའི་མཛའ་གྲོགས་ལ་ལོ་ཟླའི་ཚོད་བགམ་ཐེག་པ་དང་ལོ་རྒྱུས་ཡུན་རིང་ལྡན་ཡོད།",
    "title-g_bo_351": "2023ལོའི་དཔལ་འབྱོར་འཕར་སྣོན་དང་ལེགས་སུ་འགྲོ་བའི་འཕེལ་ཕྱོགས་མུ་མཐུད་བརྟན་དུ་ཕྱིན་ཡོད།",
    "title-g_bo_182": "5.12ཝུན་ཁྲོན་ས་ཡོམ་ཆེན་པོའི་ན་ཆུང་དཔའ་བོ་ལིན་ཧའོ་ཡིས་གཉེན་སྒྲིག་དཔང་ཡིག་བླངས་པ།",
    "title-g_bo_980": "《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་བཟའ་བཅའི་བདེ་འཇགས་བཅའ་ཁྲིམས་》དང་དེ་བཞིན་དེའི་ལག་བསྟར་སྲོལ་ཡིག《ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཕྱིར་གཏོང་ནང་འདྲེན་བཟའ་བཅའི་བདེ་འཇགས་དོ་དམ་",
    "title-g_bo_771": "2023ལོའི་ཟླ་10ཚེས་31ཉིན་ནས་བཟུང་དགུན་དུས་ཀྱི་ཡུལ་སྐོར་བ་ཉུང་བའི་དུས་ཚིགས་ཀྱི་ལས་རེས་ལྟ་སྲུང་དང་སྒོ་རྒྱག་ངལ་གསོའི་དུས་སྐབས་ཀྱི་གཉེར་སྐྱོང་བྱ་རྒྱུ་ཡིན།",
    "title-g_bo_225": "2023ལོའི་ལེགས་རྩེ་འགག་སྒོ་དེ་བོད་ལྗོངས་གཞིས་རྩེ་གྲོང་ཁྱེར་གྱི་ཕྱི་ཕྱོགས་སུ་སྒོ་མོ་འབྱེད་པའི་ལས་དོན་ཆུ་ཚད་གསར་པ་ཞིག་ཏུ་སླེབས་པ་མཚོན་གྱི་ཡོད།",
    "title-g_bo_131": "2023ལོའི་ཟླ་བ་དང་པོའི་ཚེས་18ཉིན་གྱི་ཆུ་ཚོད་10པར་ཀྲུང་གོའི་སྟོན་འབྲུར་འབབ་འཕར་ཡོང་རྒྱུ་ངེས་གཏན་ཡིན།",
    "title-g_bo_739": "2023ལོའི་ཀ་ཧྲ་རྒྱུད་ཀྱི་འཕྲོད་བསྟེན་སྡེ་ཁག་གིས་ཉུང་མཐར་ཡང་མི་30རྐྱེན་ལམ་དུ་བཏང་བ།",
    "title-g_bo_190": "2020ལོའི་ལོ་ལྔ་ཚན་བཅུ་གསུམ་པའི་འབྲུ་རིགས་ཐོན་འབབ་ཏུན་ཁྲི་521.99ཟིན་ཡོད།",
    "title-g_bo_553": "2023ལོའི་ཁྲུང་ཆིང་གློག་ཤུགས་ཉོ་ཚོང་ལྟེ་གནས་ཚད་ཡོད་ཀུང་སི་ནས་ཤེས་རྟོགས་བྱུང་བར་གཞིགས་ན། བོད་ལྗོངས་ཀྱི་ལྗང་གློག་ཁྲུང་ཆིང་དུ་ཤར་གཏོང་ཐུབ་པ་དེ་རྒྱལ་ཁབ་གློག་དྲ་ཁྲུང་ཆིང་གྲོང་ཁྱེར་གླ",
    "title-g_bo_519": "མིག་ཤེལ་ལ་ཁ་རླངས་མི་འཁོར་བའི་ཐབས་ཤེས་ཡག་པོ་ཞིག་བསླབས་འདུག",
    "title-g_bo_141": "2023ལོའི་ཟླ་བ་བཅུ་པའི་ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་བྱིས་པ་བསླུ་འཚོང་བྱས་པའི་གྱོད་གཞི་དེ་བསྐྱར་ཞིབ་བྱ་རྒྱུར་ཕྱིར་སློག་བྱས་པ།",
    "title-g_bo_886": "2023ལོའི་དབྱི་སི་རལ་དམག་དཔུང་གིས་ཧན་ཡིའུ་ཉི་སི་བསྐོར་བ་དང་འབྲེལ་ས་ཁུལ་དེའི་ལྟེ་བའི་ཁུལ་དུ་དམག་དོན་བྱ་སྤྱོད་ཐེངས་དང་པོ་སྤེལ་བ།",
    "title-g_bo_688": "2024ལོའི་ཟླ་4པའི་ནང་ཀྲུང་གོ་དང་ཧྥ་རན་སེའི་འབྲེལ་བ་སྐས་རིམ་གསར་པ་ཞིག་ཏུ་སླེབས་རྒྱུར་སྐུལ་འདེད་གཏོང་དགོས།",
    "title-g_bo_586": "《ཀ་ཧྲ་ཡི་དུས་བབ་ཀྱི་གྲོས་ཆོད་གསར་པའི་འཆར་ཟིན་སྐོར་ལ་བརྡས་ཐག་གཅོད་སྐབས་རྒྱུན་ལས་ལས་འཛིན་རྒྱལ་ཁབ་སྟེ་ཨ་རིའི་མོས་མཐུན་ཐོབ་མེད་པ་རེད》",
    "title-g_bo_990": "2023ལོའི་དཔྱིད་གསར་དུས་ཆེན་དུ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་ཚབ་ཞུས་ནས་དམངས་གཙོ་ཏང་ཤོག་ཁག་དང་། བཟོ་ཚོང་མཉམ་འབྲེལ་ལྷན་ཚོགས། ཏང་ཤོག་གང་ལ་ཡང་མི་གཏོགས་པའི་མི་སྣ་བཅས་དང་། འཐབ་ཕྱོགས་གཅིག་གྱུར་གྱི་རྒྱ་ཆེའི",
    "title-g_bo_838": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཡུལ་སྐོར་དཔལ་འབྱོར་སྟོབས་ཆེར་བཏང་བ།",
    "title-g_bo_45": "2023ལོའི་མཚོ་སྔོན་ཞིང་ཆེན་གྱི་རྒྱལ་ཁབA5རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་གསར་སྣོན་བྱས།",
    "title-g_bo_491": "《ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐོར་གཟིགས་ལས་དོན་སྲོལ་ཡིག》དང་། 《ཞི་ཅིན་ཕིང་གི་དུས་རབས་གསར་པའི་ཀྲུང་གོའི་ཁྱད་ཆོས་ལྡན་པའི་སྤྱི་ཚོགས་རིང་ལུགས་ཀྱི་དགོངས་པ་སློབ་སྦྱོང་དང་ལག་བསྟར་བྱེད་པའི་བརྗོད་དོན་",
    "title-g_bo_60": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོ། སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་ཞི་ཅིན་ཕིང་པེ་ཅིང་དང་ཧོ་པེ་ཡི་གནོད་འཚེ་ཕོག་ཚབས་ཅུང་ཆེ་བའི་ཁུལ་དུ་ཕེབས་ནས་གནོད་འཚེ་ཕོག་པའི་མང་ཚོགས་ལ་གཟིགས་ཞིབ་དང་འཚམས་འདྲི་གནང་བ་དང་། ག",
    "title-g_bo_223": "《རུས་ཚིགས་སྲུང་སྐྱོབ་བྱ་བར་གནད་འདི་གཉིས་ལ་དོ་སྣང་བྱ་དགོས》",
    "title-g_bo_96": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་སི་ཁྲོན་ཞིང་ཆེན་རྔ་བ་ཁུལ་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཨུ་ལྷན་གྱི་ཏང་ཙུའུ་ཡི་ཁོངས་མི། དྲུང་ཆེ། ལས་ཁུངས་ཏང་ཙུའུ་ཡི་ཧྲུའུ་ཅི་ལིའོ་རྨིན་གྱིས་སྒྲིག་འགལ་ཁྲིམས་འགལ་ཚབ",
    "title-g_bo_312": "དབྱི་རག་གི་ཙུང་ལི་སུའུ་ཏ་ཉི་ཡིས་རྒྱལ་སྤྱིའི་མནའ་འབྲེལ་ཕྱིར་འཐེན་བྱ་རྒྱུའི་རེ་བ་བྱེད་ཀྱི་ཡོད།",
    "title-g_bo_176": "2023ལོའི་ཟླ་12ཚེས་23ཉིན་གྱི་ཕྱི་དྲོའི་བར་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་གྱི་མི་མེད་གནམ་གྲུའི་རྒོལ་རྡུང་གཞི་ཁྱོན་ཆེན་པོ་བྱ་རྒྱུའི་འཆར་གཞི་ཡོད།",
    "title-g_bo_145": "2023ལོའི་བོད་ལྗོངས་མཛེས་རྩལ་ཁང་གི་འགྲེམས་སྟོན་ལ་ཞིང་ཆེན་རིམ་པའི་མཛེས་རྩལ་ཁང་མེད་པའི་སྟོང་ཆ་བསྐངས་ཡོད།",
    "title-g_bo_500": "2023ལོའི་ཟླ་11ཚེས་10ཉིན་ནས་བཟུང་ཀྲུང་གོའི་གཙོ་སྐྱོང་འོག ཅ་ཧྲ་ས་ཁུལ་གྱི་མི་ཆོས་རིང་ལུགས་ཀྱི་དུས་བབ་སྐོར་ལ་ཚོགས་འདུ་འཚོགས་པ།",
    "title-g_bo_414": "2023ལོའི་པེ་ཅིང་དུ་བོད་ལུགས་གསོ་རིག་མངོན་མིན་རིག་གནས་ཤུལ་བཞག་རྒྱུད་སྦྱོང་རྟེན་གནས་ཀྱི་སྒོ་བྱང་འགེལ་བའི་མཛད་སྒོ་གཉེར་ཡོད།",
    "title-g_bo_101": "2023ལོའི་ཟླ་9ཚེས་23ཉིན་གྱི་ཕྱི་དྲོ་ཀྲུང་གུང་ཀྲུང་དབྱང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི། རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི། ཀྲུང་དབྱང་དམག་ཨུད་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཚེས་23ཉིན་གྱི་ཕྱི་དྲ",
    "title-g_bo_607": "2023ལོའི་ཟླ་བ་དང་པའི་ཚེས་ཉེར་གསུམ་ཉིན་འཛམ་གླིང་འཕྲོད་བསྟེན་རྩ་འཛུགས་ཀྱི་གཞུང་ཕྱོགས་དྲ་ཚིགས་ཐོག་གནས་ཚུལ་ཁྱབ་བསྒྲགས་བྱས་དོན། འཛམ་གླིང་ཡོངས་སུ་སྔར་བཞིན་མི་གྲངས་དུང་ཕྱུར་50ལ་སྔར་བཞིན་ས�",
    "title-g_bo_174": "2023ལོའི་ཟླ་10ཚེས་19ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཁམ་ཕུ་ཁྲེའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པའི་ཁམ་ཕུ་ཁྲེའི་དབུ་བཞུགས་བློན་ཆེན་ཧུང་མ་ནའེ་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_619": "《ལིའུ་ཡེ་ཏའོ།·སྤྱི་པའི་བདེ་ཐང་》ཞེས་པའི་ཐོག་ཀྲུང་གོའི་ཚོགས་པའི་ཞིབ་འཇུག་གི་གྲུབ་འབྲས་ཆེན་པོ་ཞིག་སྤེལ་ཡོད།",
    "title-g_bo_668": "2023ལོའི་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་རྒྱུད་དུ་མེ་ཤུགས་འཕུར་མདེལ་དང་འབར་རྗས་བཞི་ཁྲི་ལྔ་སྟོང་ལྷག་འཕེན་ཡོད།",
    "title-g_bo_708": "2023ལོའི་ཟླ་11ཚེས་2ཉིན་གྱི་དྲ་དཔོན་དེའི་མི་སྒེར་གྱི་རྩིས་ཐོ་དེ་གསང་བའི་རྩིས་ཐོར་གྱུར་ཡོད།",
    "title-g_bo_481": "2022ལོའི་འགྲམ་བ་གླང་དང་ང་ཕོད་རྒྱ་ཚའི་བ་གླང་གི་ལུས་པོའི་ཕྲ་ཕུང་གི་རྒྱུད་བཤུས་ལག་རྩལ་བརྒྱུད།",
    "title-g_bo_218": "《བོད་ལྗོངས་ཀྱི་གླུ་གར་སྐྱེས་སུ་ཕུལ་བ》ཞེས་པའི་གླུ་གར་ཚོགས་པ་དེ་སི་རི་ལན་ཁའི་མང་ཚོགས་ལ་བོད་ལྗོངས་ཀྱི་ཁྱད་འཕགས་གླུ་གར་སྐྱེས་སུ་ཕུལ་བ་དང་ཆབས་ཅིག སི་རི་ལན་ཁའི་དམངས་གཞས་བཟོ་བཅོས་བརྒྱབ་ནས་གླུ་ག",
    "title-g_bo_818": "2023ལོའི་ཟླ་12ཚེས་13ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་འཐབ་ཇུས་ཀྱི་དོན་སྙིང་ལྡན་པའི་ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གྱི་ལས་དབང་གཅིག་མཐུན་མ་ལག་གཏོད་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
    "title-g_bo_650": "2023ལོའི་ཟླ་9ཚེས་16ཉིན་གྱི་ཆུ་ཚོད་4དང་སྐར་མ་15ཡི་ཐོག་སྤེལ་བའི་གནས་ཚུལ།",
    "title-g_bo_829": "རྒྱ་གར་དང་ཕ་ཁི་སི་ཐན་གྱི་དམག་མི་ཞིག་གདོང་ཐུག་ཁྲོད་རྐྱེན་ལམ་དུ་ཤོར་ཡོད།",
    "title-g_bo_330": "《ཁྲག་རྡོ་བྱུང་ན་ཁྲག་རྩལ་རྡོལ་ནས་ཁྲག་རེང་ནད་དུ་འགྱུར་སླ》དང་། 《ཁྲག་རྡོ་བྱུང་ན་ཁྲག་རྩལ་རྡོལ་ནས་ཁྲག་རེང་ནད་དུ་འགྱུར་སླ》གཉིས་ཀྱི་ནང་དོན་གསལ་བཤད་བྱས་པ།",
    "title-g_bo_244": "གཞིས་རྩེ་གྲོང་ཁྱེར་རྒྱལ་རྩེ་རྫོང་སྤྱི་བདེ་ཅུས་ཉེས་དོན་མྱུལ་ཞིབ་རུ་ཆེན་ལ་ཁ་བསླུས་རྒྱག་མཁན་ལ་འཕྲིན་གཏོང་ལས་སྒོ་སྒྲུབ་རོགས་བྱེད་མཁན་ཝང་ཆེ་གེ་མོ་ཞིག་འཇུས་འདུག",
    "title-g_bo_821": "ཉི་ཤར་རྫ་ནག་གི་རྒྱུན་འཛིན་དང་གསར་གཏོད།",
    "title-g_bo_560": "2023ལོའི་ཟླ་11ཚེས་18ཉིན་གྱི་ཆེད་གཏོང་གནམ་གྲུར་བཞུགས་ནས་པེ་ཅིང་དུ་ཕྱིར་ལོག་གནང་བ།",
    "title-g_bo_737": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆེས་མཐོའི་མི་དམངས་ཁྲིམས་ཁང་གི་མྱུར་དཔྱད་བྱེད་སྒོ་སྤེལ་བ།",
    "title-g_bo_564": "2023ལོའི་ཟླ་11པའི་ཚེས་6ཉིན་གྱི་སྐབས་དང་པོའི“རྒྱུད་གཅིག་ལམ་གཅིག”ཚན་རྩལ་སྤེལ་རེས་ཚོགས་ཆེན་ལ་བཀྲ་ཤིས་བདེ་ལེགས་ཞུ་བའི་འཕྲིན་ཡིག་སྤྲིངས་གནང་བ།",
    "title-g_bo_746": "2024ལོའི་ཨ་མདོ་བརྙན་འཕྲིན་གྱི་བོད་རབ་རྒྱན་ཤིང་ཕོ་འབྲུག་ལོའི་དགོང་ཚོགས་ཆེན་མོ༼ གཡུ་འབྲུག་དགྱེས་པའི་མཆོད་སྤྲིན༽ཞེས་པ་བརྙན་ཕབ་ལེགས་གྲུབ་བྱུང་།",
    "title-g_bo_297": "ཕོ་ལན་གྱི་ཙུང་ཐུང་ཏུའུ་ཏཱ་ཡིས་ཕོ་ལན་གྱི་ཙུང་ལི་མོ་ལཱ་ཝེ་ཚི་དང་མཉམ་འབྲེལ་ཡོངས་བསྒྲགས་ཚོགས་འདུའི་ཐོག་ཕོ་ལན་གྱིས་ཁྲིམས་འགལ་གྱི་གནས་སྤོས་ཡུལ་མི་དང་ཡུལ་འཁྱར་བའི་སྐོར་གྱི་ཡོ་རོབ་ལས་འཛིན་ལྷ",
    "title-g_bo_520": "《ཀྲུང་གོའི་རྣམ་པའི་དེང་རབས་ཅན་ལ་སྐུལ་འདེད་གཏོང་བར་འབྲེལ་བ་གལ་ཆེན་ཁག་གཅིག་ཐག་གཅོད་ཡག་པོ་བྱ་དགོས》ཞེས་པའི་རྩོམ་ཡིག་འགྲེམས་སྤེལ་བྱས་པ།",
    "title-g_bo_476": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ས་ཁུལ་གང་སར་དཔྱིད་འདེབས་ཀྱི་འགོ་འཛུགས་མཛད་སྒོ་གཟབ་རྒྱས་གཉེར་ཡོད།",
    "title-g_bo_699": "དབྱིན་ཇིའི་མཚན་མོའི་མཁའ་དབྱིངས་སུ་སྐབས་རེར་མཐོང་ཐུབ་པའི་བྱང་སྣེའི་འོད་ཟེར་དེ་དག་གི་སྣང་ཚུལ་དེ་དབྱིན་ཇི་ནས་མཐོང་ཐུབ་པ་ཡིན།",
    "title-g_bo_479": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱིས་བྱིས་པ་རྣམས་ལྟོགས་ནས་ནད་ཀྱང་ཕོག་གི་འདུག་ཅེས་བཤད་འདུག",
    "title-g_bo_749": "2023ལོའི་ཀྲུང་གོའི་རྒྱང་མེ་ཞེས་པའི་མྱུར་བགྲོད་མི་མེད་གནམ་གྲུ་དེ་མེ་ཤུགས་འཕུར་མདའི་མེ་སྒྱོགས་ལ་རམས་འདེགས་བྱས་པ།",
    "title-g_bo_168": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་གཟུགས་པོར་བརྟག་དཔྱད་བྱེད་པའི་གནས་ཚུལ་སྤེལ་བ།",
    "title-g_bo_74": "2023ལོའི་ཟླ་11ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཅིའུ་ཅིན་ཧྲན་དུ་ལྗར་པན་གྱི་དབུ་བཞུགས་བློན་ཆེན་ཨན་ཐེན་ཝུན་ཞུང་དང་མཇལ་འཛོམས་གནང་བ།",
    "title-g_bo_522": "2021ལོའི་ཟླ་4པར་གནའ་རྫས་རྟོག་ཞིབ་སྔོག་འདོན་ལས་དོན་སྤེལ་འགོ་ཚུགས་པ།",
    "title-g_bo_787": "2023ལོའི་ཟླ་8ཚེས་8ཉིན་མཉམ་འབྲེལ་རྒྱལ་ཚོགས་ཉམ་ཐག་མི་སེར་ལས་ཁུངས་ཀྱིས་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། སུའུ་ཏན་གྱི་གདོང་ཐུག་ནང་མི་ཁྲི་400ལྷག་ཙམ་ཁྱིམ་གཞིས་མེད་པར་གྱུར་ཡོད་པ་རེད།",
    "title-g_bo_36": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་ནས་བཟུང་། ཝུའུ་ཧན་ནས་ཟི་ལིང་བར་ཐད་གཏོང་མྱུར་བགྲོད་ལྕགས་ལམ་ཤར་གཏོང་ཐུབ་པ་དེ་ནི་ཝུའུ་ཧན་ནས་མཚོ་བོད་ས་མཐོར་ཐད་ཀར་ཤར་གཏོང་ཐུབ་པའི་མྱུར་བགྲོད་ལྕགས་ལམ་ཐོག་མ་དེ་ཡིན།",
    "title-g_bo_495": "《སེ་མ་བྲོ》ནི་གཞིས་རྩེའི་དམངས་ཁྲོད་ཀྱི་སྐེད་རྔའི་བྲོ་ཞིག་ཡིན་ཞིང་།",
    "title-g_bo_372": "2023ལོའི་ཟླ་9ཚེས་20ཉིན་ཡུག་རེན་གྱི་ཙུང་ཐུང་ཙེ་ལན་སི་ཅིས་ཡུག་རེན་གྱི་རྒྱལ་སྲུང་པུའུ་ཀྲང་ཨའོ་སི་ཐིང་དང་ཐུག་འཕྲད་བྱས་པ་དང་། ཕྱོགས་གཉིས་པོས་ཡུག་རེན་གྱི་གནས་བབ་དང་། དམག་དོན་རོགས་སྐྱོར། ཧེ",
    "title-g_bo_672": "《ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་དང་། ཁྲག་རིགས་གཞན་པ་དང་བསྡུར་ན། ཁྲག་རིགས་Aཅན་གྱི་མི་ལ་གྲིབ་ནད་ཕོག་པའི་ཉེན་ཁ་ཆེ་བ་ཡིན།》ཞེས་པའི་དུས་དེབ་སྟེང་དུ་བཀོད་པའི་ཞིབ་འཇུག་ཅིག་ལས་མངོན་པ་ལ�",
    "title-g_bo_538": "2024ལོའི་བོད་ལྗོངས་ཀྱི་སྔོན་རྩིས་ལག་བསྟར་བྱས་ཚུལ་དང་སྤྱི་ལོ་2024ལོའི་སྔོན་རྩིས་འཆར་ཟིན་སྙན་ཞུ།",
    "title-g_bo_192": "2023ལོའི་ཟླ་9ཚེས་16ཉིན་གྱི་ཕྱི་དྲོ་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་དུ་བྱ་སྤྱོད་སྤེལ་ནས་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་ལྷོ་ཧན་ཡིའུ་ཉི་སིའི་དམག་སྒར་གྱི་མཐོ་རིམ་བཀོད་འད�",
    "title-g_bo_222": "2023ལོའི་བོད་ཀྱི་གསོ་རིག་སྨྲ་བ་ངང་རུང་མཁན་ཆེན་འཇམ་དབྱངས་མཁྱེན་རབ་རྒྱ་མཚོ་མཆོག་གི་རྣམ་ཐར་དང་གསོ་རིག་གསུང་རྩོམ་གཅེས་བཏུས་མཚོ་སྔོན་ཞིང་ཆེན་གནའ་དཔེ་མྱུར་སྐྱོབ་རིགས་ཀྱི་དཔེ་སྐྲུན་ལས་གཞིའི་ཁ",
    "title-g_bo_611": "1953ལོར་ཧའར་པིན་བཟོ་ལས་སློབ་ཆེན་ལ་སླེབས་པའི་ཡོན་ཧྲི་ཁོང་གིས་སྒོར་ས་ཡ་3ཞལ་འདེབས་བསྐྱོན།",
    "title-g_bo_565": "2023ལོའི་རྒྱལ་ནང་གི་གསར་འགྱུར་ཆེན་པོ་བཅུ།"
}