{
 "predictions": {
  "trans-d_bo_236": "ཁོང་ཚོ་དག་པོ་མེད་པ་དང་པོ་ཟ་མ་ཟས་བྱེད་པ་ཡིན་པ་དག་གི་ཕྱིར་དུ་གཞན་པ་དག་ལ་བཀོད་པ་དང་། ཁོང་ཚོ་དག་པོ་དག་ལ་བཀོད་པ་ནི། ཁོང་ཚོ་དག་",
  "trans-d_bo_52": "ཁྱེད་དུས་གསུམ་དུ་འགྲོ་དགོས་པ་ཡིན་པ་དོན་དག་པ་ནི་པོད་ཀྱིས་བཤད་དགོས། ཁྱེད་དུས་གསུམ་དུ་དམག་པར་འགྲོ་དགོས་པ་ནི་གཞན་དག་ལ་དག",
  "trans-d_bo_454": "ལོ་གསར་ལ་བྱུང་བ་དགོས་པ་དེ་དག་ལ་བྱུང་བ་དགོས་པ་དེ་དག་ལ་བྱུང་བ་དགོས་པ་དེ་དག་ལ་བྱུང་བ་དགོས་པ་དེ་དག་ལ་བྱུང་བ་དགོས་པ་དེ་དག་ལ་བ�",
  "trans-d_bo_571": "རེད།་ཁྱོད་གཅིག་པའི་ཇིུ་ཛིན་ཞིམ་བྱས་ན་གཉིས་པ་བཏང་ནས་བྱོན་ཏེ།་གསུམ་པའི་ཁྱད་ཆོས་ཀྱི་ཁྱེད་ཀྱི་བརྩེ་སྐྱོང་དང་དུ",
  "trans-d_bo_555": "དེ་ནི་ཉིན་ཐོག་ལ་བཀོད་པ་དགོས་པ་བཀོད་པ་རེད། དེ་ནི་ང་ཚོས་ཁྱོད་ལ་བརྗེད་དགོས་པ་ཡིན་པ་དེ་དག་ལ་དེ་བཞིན་བརྗེད་དགོས་པ་རེད། ད�",
  "trans-d_bo_604": "ཁྱེད་ཀྱིས་གཤི་ལྕགས་ཟས་ཟེར་བྱས་ན་ཁྱེད་ཀྱི་བདུན་བདུན་བརྒྱུད་དོན་ལ་བྱུང་།",
  "trans-d_bo_151": "ཅི་ཕྱིར་ཁྱོད་དེ་དག་གང་དག་པར་བྱེད་ཀྱི་ཡིན་པ་དག་གི་ཡིད་ལ་བཟུང་། ཁྱོད་དེ་དག་མི་འཆི་དགོས་པ་དག་ལ་མི་འཆི་བ་དགོས་པ་ཡིན་པ་དག་",
  "trans-d_bo_296": "འ་ནི་མེད་པ་ཡིན་རེད།་དེ་དག་གི་དགོས་མཁན་དང་པོ་དག་དེ་དག་གི་མཐུན་ཚོགས་ལ་དེ་དག་གི་དགོས་མཁན་དང་པོ་དག་དེ་དག་གི་མཐུན་ཚོགས་ལ་དེ་དག་གི",
  "trans-d_bo_530": "དེ་འདྲ་བརྡ་སྟོན་གང་དུ་ཡིད་ལ་བཟུང་བ་དང་བསྟུན་པ་དང་པོ་གཉིས་ཀྱི་ཆེད་དུས་ཡོད་པ་དང་བསྟུན་པ་དང་པོ་གཉིས་ཀྱི་ཆེད་དུས་ཡོད",
  "trans-d_bo_316": "ཁྱེད་ཀྱིས་བོད་སྐད་དཔེ་མཛོད་ཁང་དུ་བོད་རིག་གཟུགས་བྱེད་པའི་བྱིན་ཇི་ལྡན་ཞིག་ལ་འགོ་ཁྲིད་བྱེད་པ་དང་བོད་སྐད་དཔེ་མཛོ",
  "trans-d_bo_762": "ཁྱེད་ཀྱི་ཞིང་ཁང་དེ་དག་གསར་བྱུང་བ་དགོས་པ་ནི་བརྗོད་དགོས། ཁྱེད་ལ་ཞིང་ཁང་དེ་དག་ལ་འཇུག་པར་བྱེད་ཀྱི་ཡོད།",
  "trans-d_bo_200": "སྐྱོན་ཆེ། ཁྱེད་ཀྱིས་དེ་དག་གི་གྲུ་གཟུགས་ལ་གཞི་བོད་མེད། ཁྱེད་ཀྱིས་དེ་དག་ལ་གཞི་བོད་བྱུང་པ་ལ་གོང་དུ་གཞི་བོད་མ",
  "trans-d_bo_469": "སྐབས་ཤེས།་ངས་སྒོར་མོ་ལ་སྒོར་བྱུང་བ་དང་བཅས་པ་ཡིན་པ་དོན་དམ་པར་བྱུང་དགོས་པ་ཡིན་པ་དོན་དམ་པར་བྱོད་དགོས་པ་ཡིན།",
  "trans-d_bo_661": "རེད། སྐོར་བ་ཡོད།",
  "trans-d_bo_147": "སྟེང་ན་ཁྱོད་དག་དགོས་པའི་དུས་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡིན་པ་དག་ཡ",
  "trans-d_bo_56": "༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡༡",
  "trans-d_bo_543": "སྐོར་བ་བཟང་།་ང་ལ་ཁྱོད་ལ་ཨུ་དི་བོད་སྐབས་བྱོད་པ་ཞིག་ཡོད་པ་ཞིག་བྱུང་བ་ཞིང་བྱོད་དོ།། གང་པོ་ཞིག་ཡིན་པ་དོགས་པ་དག་ཡོད།",
  "trans-d_bo_57": "ཁྱེད་ཀྱིས་དེ་ལས་ཀྱི་ཉིད་དུ་བྱེད་པ་དང་དེ་དག་པོ་ཆེའི་ཉིད་དུ་བྱེད་པ་ཡིན་པ་མིན་པར་བྱུང་ཡིན་པར་བྱོད་དགོས་པར་བྱོད་ད",
  "trans-d_bo_401": "སྐབས་དོན་པོ་ཆེ་ང་ཚོས་དགོས་པ་བཟང་བ་བྱུང་བ་དོན་ལེན་བྱེད་དགོས།",
  "trans-d_bo_471": "བོད་སྐད་དུ་\"ང་དུས་འཁོར་བྱས་པ་དང་ལོ་རྒྱུས་བོད་སྐད་\"ཨིནི་བོད་སྐད་དུ་\"ང་དུས་འཁོར་བྱས་པ་དང་ལོ་རྒྱུས་བོད་སྐད་\"ཨིན།",
  "trans-d_bo_309": "མེད་དོ། ། འདི་ཕྱིར་ཞེས་པ་དག་ལ་བོད་པ་ལ་ཕྱི་རིང་དུ་ཞུགས་པ་ལ་བོད་པ་བཞག་པ་དང་། བོད་པ་ལ་མི་འཇུག་པ་ཡིན། །",
  "trans-d_bo_728": "བོད་དཔེ་ཁང་དེ་དུས་དེ་ནས་བོད་དཔེ་ཁང་གི་གཙུག་ལག་ལ་འདུག་པའི་མིག་མདོག་ལ་འདུག།",
  "trans-d_bo_34": "༡༠༠ མོང་གི་བོད་སྐད་ཆེན་མོ་དེ་བོད་ཡིག་ལ་བྱས་ན་དེ་དག་པར་བྱེད་ཀྱི་བར་ན་ལེགས་འདོད་པ་དང་། དེ་དག་ལ་བྱེད་པའི་བར་ན་ལེགས་འདོད་",
  "trans-d_bo_509": "སྦྱོར་བ་དངོས་གྲུབ་མེད་པས་ལྷག་པར་བསྐྱོད་པ་བཀོད་འདོད།",
  "trans-d_bo_686": "ཁྱེད་ཀྱི་གྲོགས་པའི་མཆན་ཡིག་གོ་དུས་གསུང་བ་དོན་ལ་བྱུང་དུས་གསུང་བ་དོན་ལ་བྱུང་དོན་ལ་བྱུང་དོན་ལ་བྱུང་དོན་ལ་བྱུང་དོན་",
  "trans-d_bo_326": "ང་སྐོར་གྱི་ཁང་ཁང་ལ་གྱུར་ནས་གཟུགས་བཅུད་དང་ལྡེངས་པ་བྱོས་པ་དང་པོ་བཞིན་ཡོད། ཁྱོད་གྱིས་འགྲོ་དགོས་པ་རེད།",
  "trans-d_bo_596": "ང་སུམ་ཤོས་བྱུང་། མེད་པར་བྱུང་།",
  "trans-d_bo_217": "སྤྱི་དོན་དང་པོ་ཆེ་བའི་གདེང་དབྱིབས་ཀྱི་གཞི་བཟུང་བ་བཞིན་པ་ལ་བརྗོད་དགོས།",
  "trans-d_bo_322": "༢༠༢༠ བོད་སྐད་དུ་བྱས་པ་ལ་བརྟེན་ན། ། རྒྱལ་ཁབ་གཙུག་ལག་ཏི་ན་མིན་དུས་ལ་གྲངས་སུ་གྱུར་ན་ག་རིམ་གྱི་གྲངས་སུ་གྱུར་དགོས་",
  "trans-d_bo_384": "སཱ་ཌཱི་གཟའ་སྤེན་དགོས་པ་མེད་པ་ཡིན་པ་དགོས་པ་རེད།་དེ་དག་ལ་ངེས་དགོས་པར་གྲ་སྒྲིག་ལོ་རྒྱུས་ལ་འགོད་དགོས།",
  "trans-d_bo_251": "ཁྱེད་ཀྱིས་བོད་ཀྱི་ཆུ་མོ་བདེམས་པ་བྱས་པ་ཡིན་པ་དག་པ་དག་གི་ངེས་པ་ནི་ང་ཚོས་དགེ་བ་དང་། ཁྱེད་ཀྱིས་བོད་ཀྱི་ཆུ་མོ་བདེམས་པ་",
  "trans-d_bo_306": "ཀྲུང་གོ་ནི་ཀྲི་ཌི་མ་གསོལ་བ་བྱེད་པའི་བྲོ་བ་མི་འདུག་པ་དང་གཞོག་པ་མི་ཡོད་པ་དེ་དག་ལ་བརྡ་བོད་ཡོད།",
  "trans-d_bo_551": "ཉིན་དུས་ཀྱི་བུ་དབང་དུག་པོ་ང་ལ་དགའ་བོ་མེད། དེ་སྔ་ཕྲུག་གི་བུ་དབང་དུག་པོ་ལ་ང་དག་པ་དེ་དག་ལ་བྱ་དགོས་པ་ཅི་ཡིན་པ་དག་གི་ལས་དེ་ད",
  "trans-d_bo_618": "ཁྱེད་ཀྱི་སློབ་གྲྭ་དུས་མི་འདུག་པས། ཁྱེད་ཀྱི་དགོང་འདུག་དུས་དགེ་འདུག་གི་ཕྱིར་གཏན་འཁེལ་བྱེད་པ་དགོས་པ་རེད།",
  "trans-d_bo_230": "བོད་པ་ཁྱོད་ལ་ཉིན་མོ་དྲི་མེད་ལ་གཡང་དཀར་ཁང་ལ་འགྲོ་གིས་བོད་པ་དཀར་ལ་བལྟས་ན་རེད།",
  "trans-d_bo_652": "ཁྱེད་ཀྱི་དོན་ཁོངས་ནི་དེ་ཡིན། བྱུང་ཁང་གི་དོན་ཁོངས་ནི་བོད་དུམ་གཏོང་ཡོད། བརྟེན་འདོctrine་ཁང་ནི་དབུ་དུམ་གཏོང་ཡོད།",
  "trans-d_bo_701": "ང་ཡང་དག་པར་བརྩེགས་པ་ལ་བལྟས་བཟོས། ཁྱེད་ཀྱིས་ལོ་རྒྱུས་ཀྱི་དོན་ལྡན་གྱི་བརྩེགས་པ་གང་དག་ཡིན་པ་དོས་གསལ་བྱེད་དགོས་པ་ར�",
  "trans-d_bo_304": "ཁྱེད་ཀྱིས་ངོ་མོའི་བརྗོད་བཀོད་འདོན་པ་དུས་ལ་བསྒྱུར་བ་དགེ་ནས་ང་ཚོས་ཅི་ལྟར་བཤད་པ་བྱས་པ་ཡིན་པ་དེ་དག་པོ་གང་ཡིན་པ་དེ་དག་པ�",
  "trans-d_bo_755": "ཁྱེད་ཀྱི་གཏན་འབེབས་བཟང་པོ་ཉུང་ཟད་ཡིན།",
  "trans-d_bo_35": "དེ་དུས་ནི་ཁྱེད་སེང་གེ་ཁང་ལ་བྱོན་ནས་དགོས་པ་དག་ལ་བོད་ཡིག་གི་ལེགས་ལུགས་དང་བོད་ཡིག་མ་ལི་ཡི་ལི་ལ་བྱུང་དུས་ལ་བྱོན་ནས་དགོས་པ་",
  "trans-d_bo_753": "ལིའུ་བོ་།་ཁྱོད་དགའ་བོ་བྱུང་བ་མཐོང་།་དེ་དག་ལ་བཟང་པོ་བྱུང་བ་ཡིན་པ་དགོས་པར་དབང་དོན་གྱི་ཡིད་ལ་བཟུང་།",
  "trans-d_bo_92": "ཁྱེད་ཀྱི་འཁྲུལ་པ་འདོད་པའི་ཕྱིར་འདི་འདྲ་འཁྲུལ་པ་འདོད་པ་ཡིན་པ་དོན་གྱི་ཡིན་པ་དོན་གྱི་འདི་འདྲ་འཁྲུལ་པ་འདོད་པ་ཡིན་",
  "trans-d_bo_54": "ཁྱེད་ལ་བསྒོམ་པ་ཁྱེད་ཀྱིས་དུས་དུས་བོད་ཡིག་ལས་འདོད་པ་དག་གི་ཕྱིར་ཅི་ཡིན། ཁྱེད་ཀྱིས་དོན་དག་གི་རྒྱུན་དུ་གྲགས་པ་ཡ�",
  "trans-d_bo_361": "འབྲེལ་བ་མེད་པར་བོད་རྒྱུ་ཡི་གེ་བོད་རྒྱུ་བསྒྱུར་མ་བྱ། །",
  "trans-d_bo_89": "དེ་དག་གང་ཡང་བོད་རྒྱུ་ཡིན་ནོ། འགྲོ་བ་ལ་བྱུང་ལུས་མེད་པ་དང་ལུས་དེ་ལ་མི་འགོ་བཙུགས་པ་དང་། འབྲུག་གི་གནས་གཞི་མེད་པ་དང་། འད�",
  "trans-d_bo_303": "༡༢ཟླ་བ་དགོས་པའི་བརྒྱད་པ་དུས་ལ་ང་ཚོས་ཞེས་པ་ལ་བྱུང་བ་མི་ཐུབ། དེ་ལ་ལོ་གསར་དུས་ལ་གཞིས་བྱེད་པ་ལ་བྱུང་བ་ཡིན།",
  "trans-d_bo_733": "རེད།་སློབ་མ་དང་སློབ་པ་ཤིང་གི་རིང་ལ་འགྲོ་བོད་དཔྱད་དེ་དགོས།",
  "trans-d_bo_514": "སྲོག་གི་བོད་ཡིག་ལ་བཤད་པ་ནི་ལེགས་འབྲེལ་བ་མིན་པས་བོད་ཡིག་ལ་བཤད་པ་ནི་ལེགས་འབྲེལ་བ་མིན་པས་བོད་ཡིག་ལ་བཤད་པ་ནི་ལེགས་འབྲེལ་བ་",
  "trans-d_bo_219": "སྐབས་ཤེས་ཀྱང་དུས་མི་བཟོ་བ་མིན། སྔོན་པོའི་བཟོ་བ་སྣོན་པ་ལས་དཀྱིལ་ལྕིའི་བཟོ་བ་ལ་བཟོ་བ་མེད། སྔོན་པོའི་བཟོ་བ་ལ་",
  "trans-d_bo_205": "ལོ་རྒྱུས་ཆུ་ཆུང་ཆུང་ཞིབ་ཏུ་བོད་དང་ཐུགས་རྗེ་ཆུང་ཆུང་ཞིབ་ཏུ་བོད།",
  "trans-d_bo_641": "ལུང་འདོད་དང་འབྲེལ་བ་བཞིན་བརྗོད་པ་དང་། སྒྲུང་གོ་དང་། བོད་ཀྱི་ལུང་འདོད་ཡིན།",
  "trans-d_bo_2": "ཁྱེད་དང་དུས་དེའི་དུས་ལ་བཟོད་པར་བཤད་པ་མེད་པ་དང་། ཁྱེད་ཀྱི་དཔེ་བོད་དཔེ་དཔེ་དང་། ཁྱེད་ཀྱི་ཕྲེང་བ་དང་། ཁྱེད་ཀྱི་ད",
  "trans-d_bo_744": "སྐྱོར་ཁང་ལ་འོང་བ་དུས་ལྟར་བོད་ལ་འགྲུབ་དང་། བྱོན་ཚོད་ལ་འགྲུབ་ནས་དབུ་ལྟར་འགྲུབ།",
  "trans-d_bo_233": "ཁོང་ཚོ་ལ་བོད་སྐད་དུ་བཅད་མཁས་པ་མིན། ཁོང་ཚོ་ལ་བོད་སྐད་དུ་བཅད་མཁས་པ་མིན། ཁོང་ཚོ་ལ་བོད་སྐད་དུ་བཅད་མཁས་པ་མིན། སྔོན་པོ་ཞེས་པ",
  "trans-d_bo_96": "ཡོང་དབང་དུས་དོན་ལ་ཕྱིར་འགྲོ་མ་བོད་པ་བོད་པ་བོད་པ་དོན་ལ་ཕྱིར་འགྲོ་མ་བོད་པ་བོད་པ་བོད་པ་དོན་ལ་ཕྱིར་འགྲོ་མ་བོད་པ་བོད་པ་བོ"
 },
