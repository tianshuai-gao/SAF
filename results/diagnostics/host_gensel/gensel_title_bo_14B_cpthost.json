  "title-g_bo_34": "2023ལོའི་བོད་ལྗོངས་ཀྱི་ཚད་གཞི་མཐོ་བའི་ས་ཞིང་མུའུ་ཁྲི་430བསྐྲུན་པ།",
  "title-g_bo_54": "2024ལོའི་ཟླ་1པོའི་ཚེས་5ཉིན་ཀྲུང་གུང་ཧོ་པེ་ཞིང་ཆེན་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ལས་ཀྲུའུ་རེན་གཞོན་པ་ཞེ་ཅི་ལའེ་ལ་ལྐོག་རྔན་བླངས་པའི་གྱོད་གཞིའི་འདྲི་གཅོད་དང་པོའི་བཅད་ཁྲ་ཁྱབ་བསྒྲགས་བྱས་པ།",
  "title-g_bo_399": "2023ལོའི་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་བྱང་རྒྱུད་དུ་ས་འོག་དོང་ལམ་དྲ་བ་ཞིག་དང་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་བསྟན་སྲུང་སྒྲིག་འཛུགས་ཅེ་ཧ་ཏེའི་མཐོ་རིམ་ཁོངས་མིའི་སྡོད་གནས་ཤིག་རྩ་གཏོར་བཏང་ཡོད།",
  "title-g_bo_559": "བོད་རིགས་ཀྱི་རྒྱན་ཆར་གྱུར་གྱི་ལྟ་བ་དང་སྒྱུ་རྩལ།",
  "title-g_bo_521": "2022ལོའི་ཟླ་12ཚེས་18ཉིན་བརྒྱད་པའི་ས་ཡོམ་དཀྲོག་གཏམ་སྤེལ་བྱས་པ།",
  "title-g_bo_874": "2023ལོའི་ཐོག་དཔེ་མཚོན་གྱོད་གཞི་7བརྡ་ཁྱབ་བཏང་འདུག: 'སྤྱོད་ཚུལ་བཞིའི'གནད་དོན་ལ་ལྟ་སྐུལ་ཐེར་འདོན་དང་དམར་འདོན་བྱེད་ས",
  "title-g_bo_875": "2024ལོའི་རྒྱལ་ཡོངས་སྨན་བཅོས་འགན་བཅོལ་ལས་དོན་ཐད་ཞིབ་འཇུག་དང་བཀོད་སྒྲིག་བྱས་པ།",
  "title-g_bo_591": "2022ལོའི་ཨ་རབ་དང་དབྱི་སི་ལན་ཕྱི་འབྲེལ་བློན་ཆེན་གྱི་བཀག་ཉར་དང་གནད་དོན་སྐུལ་འདེད་གཏོང་བ།",
  "title-g_bo_137": "ས་ཡོམ་ཆེ་གྲས་གཉིས་པའི་གཏོར་སྐྱོན་ཕོག་པ་དང་མི་2562ལ་རྨས་སྐྱོན་ཕོག་པ།",
