  "title-g_bo_124": "དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་ས་ཁུལ་ལ་མཁའ་ཐོག་འཇབ་རྒོལ་བྱས་པ།",
  "title-g_bo_290": "2023ལོའི་ཟླ་10ཚེས་18ཉིན་ཕྱི་འབྲེལ་པུའུ་ཡི་མགྲིན་ཚབ་པས་ཧྲུའུ་མོ་ཀྲུང་གོར་འཚམས་འདྲིར་ཡོང་བའི་ཐད་གསར་འགོད་པའི་དྲི་བར་ལན་བཏབ།",
  "title-g_bo_975": "2023ལོའི་དབྱི་སི་རལ་དམག་གིས་ཀ་ཧྲ་རྒྱུད་ལ་ཚོད་འཛིན་བྱེད་དགོས་པའི་གནས་ཚུལ།",
  "title-g_bo_392": "2023ལོའི་ཕྱི་འབྲེལ་པུའི་མགྲིན་ཚབ་པ་ཧྭ་ཁྲུན་ཡིང་གིས་“རྒྱུད་གཅིག་ལམ་གཅིག”མཉམ་སྐྲུན་བྱེད་པའི་གླེང་སྟེགས་དེ་ཟླ་10ཚེས་17ཉིན་ནས་ཚེས་18ཉིན་བར་པེ་ཅིང་དུ་སྐོང་ཚོགས་བྱ་རྒྱུ་ཡིན།",
  "title-g_bo_231": "2023ལོའི་ཟླ་11ཚེས་6ཉིན་ཀྲུང་གོ་དང་ཁུ་པའི་མི་དམངས་ཚོགས་ཁང་ཆེན་མོར་ཁུ་པའི་ཙུང་ལི་མ་ལེ་ལུའོ་དང་མཇལ་འཛོམས་གནང་བ།",
  "title-g_bo_969": "2023ལོའི་ཟླ་11ཚེས་1ལ་བོད་ལྗོངས་ཀྱི་ཀ་པ་རིམ་པའི་ལྗོངས་ཁུལ་དུ་རིན་མེད་ངང་ཕེབས་ཆོག",
  "title-g_bo_354": "2023ལོའི་ཟླ་12ཚེས་7ཉིན་བློ་མཐུན་སང་གོ་ཝུའེ་སྐུ་གཤེགས་པ་དང་སྐུ་གཤེགས་སྐབས་དགུང་ལོ་82ལ་ཕེབས་པ།",
  "title-g_bo_657": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་ཀྲུང་གོ་དང་ཕ་ཕུ་ཡ་ཀུའི་ནེ་ཡ་གསར་པའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པ།",
  "title-g_bo_914": "2024ལོའི་དཔྱིད་གསར་སྐྱེལ་འདྲེན་ལྷ་ས་མེ་འཁོར་འབབ་ཚུགས་ཀྱི་འགྲུལ་སྐྱེལ་འཁོར་སྐྱོད་འཁོར་ཁང་གི་གནས་ཚུལ་དང་འགྲུལ་པ་ཚོའི་བཞིན་ལས་དགའ་བའི་འཛུམ་མདངས་འཕྱུར་བཞིན་རང་སོའི་གཏམ་རྒྱུད་མི་འདྲ་བ་རེ་རུམ་",
  "title-g_bo_719": "《བོད་གནའ་རབས་ཀྱི་ཤིང་རྐོས་སྐོར་མདོ་ཙམ་བརྗོད་པ།》",
  "title-g_bo_302": "2023ལོའི་ཟླ་4ཚེས་15ཉིན་སུའུ་ཏན་གྱི་དྲག་ཆས་དཔུང་སྡེ་དང་འཕྲལ་སྒྲུབ་རོགས་སྐྱོར་དཔུང་སྡེའི་བར་རྒྱལ་ས་ཁ་ཧྲེ་མུར་དྲག་པོའི་གདོང་ཐུག་ཐོན་པ་དང་འབྲེལ་ད་བར་རྒྱུན་མཐུད་བྱས་པ།",
  "title-g_bo_109": "2023ལོ་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་གཞི་ཁྱོན་ཕྱི་རྒྱལ་གྱི་མ་འཇོག་མཁན་ལ་ཨ་སྒོར་དུང་ཕྱུར་ཆག་པ་དང་ཕྱིན་པ།",
  "title-g_bo_508": "2023ལོའི་ཝེ་ཐེ་ནམ་དང་ཀྲུང་གོ་གཉིས་པོའི་འབྲེལ་བ་འཕེལ་རྒྱས་འགྲོ་བ།",
  "title-g_bo_754": "ཨ་ལ་པི་ཡ་བརྙན་འཕྲིན་ཁང་གི་ལི་པི་ཡ་ཤར་རྒྱུད་གནོད་འཚེ་ཆེན་པོ་བཏང་བ།",
