  "title-g_bo_6": "2023ལོའི་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དབར་བཀག་ཉར་བྱས་པའི་མི་སྣ་བརྗེ་པོ་རྒྱག་པ།",
  "title-g_bo_832": "ཆུ་མགྱོགས་པོ་འཐུང་མི་རུང་། མཇིང་ཚིགས་ཀྱི་ནད་ཕོག་ཉེན་ཆེན་པོ་ཡོད།",
  "title-g_bo_243": "2022ལོའི་ཟླ་10ཚེས་25ཉིན་ཀྲུང་གོ་དང་ཨ་རིའི་མི་དམངས་ཚོགས་ཁང་ཆེན་མོར་ཨ་རིའི་ཀ་ལི་ཧྥུ་ཉི་ཡ་མངའ་སྡེའི་འགོ་འཛིན་ཉིའུ་སེན་དང་མཇལ་འཛོམས་གནང་བ།",
  "title-g_bo_359": "མི་བཟའ་བའི་དུས་ཚུལ་དང་གནོད་འཚེ་ཚབས་ཆེན་པོ་བཟོས་པ།",
