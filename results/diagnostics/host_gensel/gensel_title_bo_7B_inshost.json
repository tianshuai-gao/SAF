  "title-g_bo_237": "《སྐྲན་ནད་གྲལ་བཤེར་དང་ཚད་མཐུན་གྱི་སྐྲན་འགོག་བརྟག་དཔྱད་ཀྱི་སྐུལ་སློང་བྱེད་ཐབས》ལ་གྲོས་འཆམ་བྱུང་བ།",
  "title-g_bo_389": "2023ལོའི་ཟླ་12ཚེས་19ཉིན་གྱི་ཆུ་ཚོད་16བར་མཚོ་སྔོན་ཞིང་ཆེན་ཆུ་བེད་ཐིང་ནས་ཤེས་རྟོགས་བྱས་པར་གཞིགས་ན། ཟླ་12ཚེས་19ཉིན་གྱི་ཆུ་ཚོད་16བར་མཚོ་སྔོན་ཞིང་ཆེན་ཆུ་བེད་ཐིང་ནས་ཤེས་རྟོགས་བྱས་པར་གཞིགས་ན། �",
  "title-g_bo_658": "ས་བབས་མཐོ་ཚད་སྨི་5150ཟིན་པའི་རྔེའུ་ལའི་ཉག་གར་མི་སྣ་དང་རླངས་འཁོར་ལ་ཉེན་ཁ་འཕྲད་བྱུང་།",
  "title-g_bo_507": "2023ལོའི་ཉ་འཛིན་གྲུ་གཟིངས་ཤིག་ཧྲན་ཏུང་ཞིང་ཆེན་ཆིན་ཏའོ་གྲོང་ཁྱེར་ཧོང་ཏའོ་ཁུལ་ལིན་ཧྲན་གླིང་ཕྲན་ནུབ་ཕྱོགས་ཀྱི་ཆུ་ཁོངས་སུ་ཉེན་ཁ་དང་འཕྲད་པས། གནས་ཚུལ་ཧ་ཅང་ཛ་དྲག་ཆེ།",
  "title-g_bo_124": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་རེས་སྐོར་གསར་པའི་གདོང་ཐུག་རྒྱུན་མཐུད་ཐོན་བཞིན་ཡོད།",
  "title-g_bo_290": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་ཀྲུང་གོ་ཕྱོགས་ཀྱི་འགོ་ཁྲིད་པའི་དྲི་བར་ལན་བཏབ།",
  "title-g_bo_975": "2023ལོའི་ཟླ་9ཚེས་13ཉིན་གྱི་དགོང་མོ་ཐེ་ལ་ཝེ་ཕུའུ་ཚུད་པའི་དབྱི་སི་རལ་དབུས་རྒྱུད་ས་ཁུལ་དུ་མེ་ཤུགས་འཕུར་མདེལ་འཕེན་གཏོང་བྱས་པ།",
  "title-g_bo_392": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་ནས་ཚེས་18ཉིན་བར་པེ་ཅིང་དུ་སྐོང་ཚོགས་བྱ་རྒྱུ་ཡིན་པ་དང་། བརྗོད་དོན་གཙོ་བོ་ནི“སྤུས་ཚད་མཐོ་པོས‘རྒྱུད་གཅིག་ལམ་གཅིག’མཉམ་སྐྲུན་བྱེད། ལག་གདང་སྦྲེལ་ནས་ཐུན་མོང་གོང་འཕེལ་",
  "title-g_bo_231": "2023ལོའི་ཟླ་11ཚེས་6ཉིན་གྱི་ཕྱི་དྲོ། ཞི་ཅིན་ཕིང་གིས་མི་དམངས་ཚོགས་ཁང་ཆེན་མོར་ཁུ་པའི་ཙུང་ལི་མ་ལེ་ལུའོ་དང་མཇལ་འཛོམས་གནང་བ་རེད།",
  "title-g_bo_969": "2023ལོའི་དགུན་དུས་བོད་ལྗོངས་མྱུལ་ཞེས་པའི་ཁྲོམ་རའི་སྐུལ་སྤེལ་བྱེད་སྒོ་སྤེལ་བའི་གནས་ཚུལ།",
  "title-g_bo_354": "2023ལོའི་ཟླ་12ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་17དང་སྐར་མ་10ཡི་ཐོག་པེ་ཅིང་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོ་ཁང་དུ་ཞུགས་འབུལ་ཞུས་པའི་བློ་མཐུན་སང་གོ་ཝུའེ་ཡི་སྐུ་གཤེགས་པ་དང་། སྐུ་གཤེགས་སྐབས་དགུང་ལོ་",
  "title-g_bo_657": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོར་སྐབས་གསུམ་པའི“རྒྱུད་གཅིག་ལམ་གཅིག”རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པ།",
  "title-g_bo_914": "2024ལོའི་དཔྱིད་གསར་སྐྱེལ་འདྲེན་དེ་སྤྱི་ཟླ་1ཚེས་26ཉིན་ནས་སྤྱི་ཟླ་3ཚེས་5ཉིན་བར་ཏེ་དུས་ཡུན་ཉིན་40ཡིན་ཞིང་།",
  "title-g_bo_719": "《བོད་གནའ་རབས་ཀྱི་ཤིང་རྐོས་སྐོར་མདོ་ཙམ་བརྗོད་པ》",
  "title-g_bo_302": "2023ལོའི་ཟླ་4ཚེས་15ཉིན་སུའུ་ཏན་གྱི་དྲག་ཆས་དཔུང་སྡེ་དང་འཕྲལ་སྒྲུབ་རོགས་སྐྱོར་དཔུང་སྡེའི་བར་རྒྱལ་ས་ཁ་ཧྲེ་མུར་དྲག་པོའི་གདོང་ཐུག་ཐོན་པ་དང་། དེ་རྗེས་གདོང་ཐུག་ས་ཁུལ་གཞན་དག་ཏུ་ཁྱབ་པ་དང་འབྲ",
  "title-g_bo_109": "2023ལོའི་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་གཞི་ཁྱོན་ཆེ་རུ་ཕྱིན་པ་དང་ཨ་རིའི་དངུལ་རྩ་བརྟན་ལྷིང་ངང་རྒྱུན་འཁྱོངས་བྱེད་པའི་དཀའ་ཚེགས་ཆེ་རུ་ཕྱིན་པ།",
  "title-g_bo_508": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཝེ་ཐེ་ནམ་ལ་རྒྱལ་དོན་འཚམས་འདྲི་གནང་རྒྱུ་རེད།",
  "title-g_bo_754": "ལི་པི་ཡ་རྒྱལ་དམངས་འཐུས་མི་ཚོགས་ཆེན་གྱིས་ལི་པི་ཡ་ཤར་རྒྱུད་ཀྱི་ཆུ་ལོག་གནོད་འཚེའི་ཁྲོད་མི6000ལྷག་ཚེ་ལས་འདས་ཡོད་ཅེས་བརྗོད་འདུག",
  "title-g_bo_576": "2023ལོའི་ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་རྒྱལ་རྟགས་ནི་རླབས་ཆེན་མེས་རྒྱལ་གྱི་མཚོན་རྟགས་ཤིག་དང་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་མཚོན་རྟགས་ཤིག་རེད།",
  "title-g_bo_6": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་10པ་ནས་བཟུང་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དབར་བཀག་ཉར་བྱས་པའི་མི་སྣ་བརྗེ་པོ་རྒྱག་རྒྱུ་དང་ཀ་ཧྲ་རྒྱུད་དུ་ཉིན་4ཡི་རིང་གནས་",
  "title-g_bo_832": "ཆུ་མགྱོགས་པོ་འཐུང་མི་རུང་།",
  "title-g_bo_243": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་འཕེལ་རྒྱས་བྱུང་ནས་ད་ལྟའི་གྲུབ་འབྲས་ཐོབ་པ་ནི་ལས་སླ་པོར་ཐོབ་པ་ཞིག་མིན་པས། དེར་གཅེས་འཛིན་ལྡབ་འགྱུར་བྱེད་རིན་ཡོད།",
  "title-g_bo_359": "སྒྲོག་ཙེར་སྤུས་ཚད་ཡག་པོ་མེད་པའི་རས་འདིང་བ།",
  "title-g_bo_710": "《ཉིང་རྡུལ་ཚོད་ལྟ་ཕྱོགས་ཡོངས་ནས་གཏན་འགོག་བྱེད་པའི་ཆིངས་ཡིག》ལ་མཆོག་མཆན་བཀོད་པ་ཕྱིར་འཐེན་བྱས་པ་དེས། ཨུ་རུ་སུའི་རྒྱལ་ཕྲན་མཉམ་འབྲེལ་མཉམ་མཐུད་ཀྱི་མི་མེད་གནམ་གྲུའི་བྱ་སྤྱོད་ཀྱི་འགན་འཁུར་བཞ�",
  "title-g_bo_34": "2022ལོའི་བོད་ལྗོངས་ཀྱི་ཚད་གཞི་མཐོ་བའི་ས་ཞིང་མུའུ་ཁྲི་430བསྐྲུན་པ།",
  "title-g_bo_54": "2024ལོའི་ཟླ་1པོའི་ཚེས་5ཉིན་ཞུ་སྦྱོར་ཕྱི་མ་ཞེ་ཅི་ལའེ་ལ་ལྐོག་རྔན་བླངས་པའི་གྱོད་གཞིའི་འདྲི་གཅོད་དང་པོའི་བཅད་ཁྲ་ཁྱབ་བསྒྲགས་བྱས་པ་དང་།",
  "title-g_bo_399": "2023ལོའི་ཟླ་7ཚེས་6ཉིན་གྱི་ཕྱི་དྲོ་གནས་ཚུལ་སྤེལ་བའི་གནས་སྟངས་དང་འབྲེལ་བའི་གནས་ཚུལ།",
  "title-g_bo_559": "བོད་ཀྱི་སྲོལ་རྒྱུན་རྒྱན་ཆའི་རིགས་སྣེ་མང་ཕུན་ཚོགས་ཤིང་།",
  "title-g_bo_521": "2023ལོའི་ཟླ་12ཚེས་18ཉིན་མཚོ་སྔོན་སྤྱི་བདེ་དང་དྲ་བའི་བདེ་འཇགས་སྡེ་ཁག་གིས་ཁྱོན་དྲ་རྒྱའི་དཀྲོག་གཏམ་སྐོར་གྱི་ཁུངས་སྣེ་40ལྷག་ཙམ་རྩད་རྙེད་བྱུང་བ་དང་། ཁྲིམས་ལྟར་མི་3ལ་སྲིད་འཛིན་ཆད་པ་བཅད་པ",
  "title-g_bo_874": "2023ལོའི་ལོ་གསར་དང་དཔྱིད་གསར་དུས་ཆེན་རིང་གི་སྤྱོད་ཚུལ་བཞིའི་གནད་དོན་ལ་ལྟ་སྐུལ་ཐེར་འདོན་དང་དམར་འདོན་བྱེད་ས་7བརྡ་ཁྱབ་བཏང་འདུག",
  "title-g_bo_875": "2024ལོའི་སྨན་བཅོས་འགན་བཅོལ་ལས་དོན་ཚོགས་འདུ་པེ་ཅིང་དུ་སྐོང་ཚོགས་བྱས་པ་དང་།",
  "title-g_bo_591": "2023ལོའི་ཟླ་11ཚེས་20ཉིན་པེ་ཅིང་དུ་སོ་ཏི་ཨ་རབ་ཀྱི་ཕྱི་འབྲེལ་བློན་ཆེན་ཧྥེ་སར་དང་། ཇོ་ཏན་གྱི་དབུ་བཞུགས་བློན་ཆེན་གཅིག་ལྕོགས་ས་ཧྥ་ཏི། ཨེ་ཅིབ་ཀྱི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་ཧྲུའུ་ཁེ་ལི། ཧིན་ར",
  "title-g_bo_137": "ས་ཡོམ་གྱིས་མོ་རོ་ཁོའི་མི་གསུམ་འབུམ་ལྷག་ལ་ཤུགས་རྐྱེན་ཐེབས་ཡོད།",
  "title-g_bo_793": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་ཁྲེང་ཀོན་ཆུས་དྲིལ་བསྒྲགས་པུས་གཙོ་གཉེར་བྱས་པའི་བོད་ཀྱི་ལོ་གསར་ལ་བསུ་བ་ཞུ་བའི་བྱེད་སྒོ་སྐབས་གཉིས་པ་ལྷ་སའི་གནའ་རབས་བཟོ་སྐྲུན་སྒོ་ར་ཆེན་མོར་གཉེར་ཡོད།",
  "title-g_bo_349": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་དང་ཐོག་ཡུང་ཏིང་ཆུ་བོའི་སན་ཅ་ཏེན་གྱི་ཆུ་འདྲེན་ལྟེ་གནས་སུ་ཕེབས་ཏེ་པེ་ཅིང་གྲོང་ཁྱེར་གྱི་ཆུ་རྒྱུད་དང་། ཡུང་ཏིང་ཆུ་བོའི་ཉམས་གསོ་བཅོས་སྐྱ�",
  "title-g_bo_782": "ང་ཚོས་ཟ་མ་ཟ་སྐབས་དོ་སྣང་མ་བྱུང་བར་ཟ་ཡས་མང་དྲག་པའི་རྒྱུ་མཚན་སྐོར་དང་ནམ་རྒྱུན་བཟའ་རྒྱུ་མང་དྲག་ན་ལུས་གཟུགས་ལ་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་པའི་ཐད་གླེང་མོལ་བྱེད་རྒྱུ་ཡིན།",
  "title-g_bo_951": "2023ལོའི་ལོ་གསར་མཁོ་ཆས་བར་སྐོར་ཚོང་གྲོང་དུ་ཡོད་པ་དང་ལྷ་སའི་གྲོང་མིས་བར་སྐོར་ཚོང་གྲོང་ནས་དཔྱིད་གསར་ཆ་ཡིག་ཉོ་བཞིན་པ།",
  "title-g_bo_989": "《ཆོས་ལུགས་ལས་དོན་དོ་དམ་སྲོལ་ཡིག》དང་། 《ནང་བསྟན་ཆོས་ལུགས་དང་ཏའོ་ཅའོ་ཆོས་ལུགས་ཀྱི་ཚོང་ལས་ཅན་སྔར་བས་བཅོས་སྐྱོང་བྱ་རྒྱུའི་སྐོར་གྱི་བསམ་འཆར་འགའ་ཞིག》 《དྲ་སྦྲེལ་ཆོས་ལུགས་ཆ་འཕྲིན་ཞབས་ཞུ་དོ་དམ་བྱ་ཐ",
  "title-g_bo_128": "2023ལོའི་ཟླ་11ཚེས་15ཉིན་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཨ་རིའི་ཅིའུ་ཅིན་ཧྲན་ཕེ་ལོ་ལི་གཞིས་ཀར་ཨ་རིའི་ཙུང་ཐུང་པའེ་ཏེང་དང་མཇལ་འཕྲད་གནང་བ་རེད།",
  "title-g_bo_230": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》སྟེང་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ཕ་ལི་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིར་གཞི་ཁྱོན་ཆེ་བའི་དམག་དོན་ལས་འགུལ་སྤེལ་འཆར་ཡོད་ཅེས་བསྟན་",
  "title-g_bo_636": "2023ལོའི་ཞི་ཅིན་ཕིང་གིས་བསམ་བློ་རིག་གནས་དྲིལ་བསྒྲགས་ཀྱི་ལས་དོན་ལ་མཛུབ་སྟོན་གལ་ཆེན་གནང་།",
  "title-g_bo_894": "2023ལོའི་ཟླ་1ཚེས་12ཉིན་ཀྲུང་ལའེ་དབར་གྱི་འབྲེལ་བ་སླར་གསོ་བྱུང་ནས་ལོ་30འཁོར་བར་རྟེན་འབྲེལ་ཞུས་གནང་བ།",
  "title-g_bo_606": "2013ལོའི་ཟླ་9ཚེས་7ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་འགོ་ཁྲིད་ཚོགས་འདུ་འཚོགས་ནས་ཀྲུང་གོའི་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཞི་ཅིན་ཕིང་གིས་ཧ་སག་སི་ཐན་ལ་བདེ་སྐྱིད་སྐྲུན་པའི་བྱ་གཞག་ཆེན་པོ་ཞིག་རེད།",
  "title-g_bo_910": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་གླིང་ཆེན་ཨ་མེ་རི་ཁ་དབུས་མའི་གྲོས་ཚོགས་ཀྱི་གྲོས་དཔོན་སའེ་ལུའུ་ཏེ་ཡིས་ཀྲུང་གོའི་རྒྱལ་ཡོངས་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་སྡོད་ལྟ་ཞིབ་པར་བརྩི་རྒྱུའི་གྲོས་ཆོད་ཁག་གཉ�",
  "title-g_bo_588": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་བདེ་ཐང་ལ་གནོད་པ་ཐེབས་པའི་དོན་དངོས་གཞན་དག་ཤེས་རྟོགས་བྱུང་འདུག",
  "title-g_bo_908": "2023ལོའི་ཟླ་2ཚེས་1ཉིན་གྱི་འགྲེམས་སྟོན་ཁྲེང་ཏུའུ་ཅིན་ཧྲ་གནའ་ཤུལ་རྟེན་རྫས་བཤམས་མཛོད་ཁང་དུ་འགྲེམས་སྟོན་བྱེད་འགོ་བརྩམས།",
  "title-g_bo_979": "ཨ་རིའི་རྒྱལ་དོན་ཁང་གིས་ཨ་རིས་སྐམ་ས་ཆེན་པོའི་སྒྲོམ་གྱི་དབྱེ་མཚམས་གྱི་ས་ཁམས་གནས་ཚད་རྒྱ་ཆེ་རུ་གཏོང་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
  "title-g_bo_786": "2024ལོའི་ཟླ་1ཚེས་8ཉིན་ནས་ཚེས་10ཉིན་བར་པེ་ཅིང་དུ་ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐབས་ཉི་ཤུ་པའི་ཀྲུང་དབྱང་སྒྲིག་ཁྲིམས་ཞིབ་བཤེར་ཨུ་ཡོན་ལྷན་ཁང་གི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐེངས་གསུམ་པ་འཚོགས་པ་རེད།",
  "title-g_bo_269": "2023ལོའི་རང་རྒྱལ་གྱི་ནུས་ཆེའི་བར་རྡུལ་དཔྱད་ཆས་ཐོག་མ་བསྐྲུན་ཟིན་པ།",
  "title-g_bo_499": "2023ལོའི་འཆར་ཅན་རྟ་རྒྱུག་དུས་ཆེན་གྱི་འགོ་ཚུགས་མཛད་སྒོ་དེ་བོད་ལྗོངས་ནག་ཆུ་གྲོང་ཁྱེར་གེ་སར་རྟ་རྒྱུག་ཐང་ཆེན་དུ་ཚུགས་ཤིང་།",
  "title-g_bo_543": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་བོད་ལྗོངས་སུ་སློབ་སྦྱོང་བརྟག་ཞིབ་དང་ཆོས་ལུགས་མཛད་སྒོ་སྤེལ་གནང་བ།",
