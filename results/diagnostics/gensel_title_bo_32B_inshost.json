  "title-g_bo_237": "《སྐྲན་ནད་གྲལ་བཤེར་དང་ཚད་མཐུན་གྱི་སྐྲན་འགོག་བརྟག་དཔྱད་ཀྱི་བྱ་ཐབས》ལ་གྲོས་འཆམ་བྱུང་བ།",
  "title-g_bo_389": "2023ལོའི་ཟླ་12ཚེས་19ཉིན་གྱི་ཆུ་ཚོད་16བར་མཚོ་སྔོན་ཞིང་ཆེན་ཆུ་བེད་ཐིང་ནས་ཤེས་རྟོགས་བྱས་པར་གཞིགས་ན། ཟླ་12ཚེས་19ཉིན་གྱི་ཆུ་ཚོད་16བར། མཚོ་སྔོན་ཞིང་ཆེན་ཆུ་བེད་ཁོངས་གཏོགས་ཀྱིས་ཆེད་ལས་ལས་བྱེད་པ་7",
  "title-g_bo_658": "ས་བབས་མཐོ་ཚད་སྨི་5150ཟིན་པའི་རྔེའུ་ལའི་ཉག་གར་མི་སྣ་དང་རླངས་འཁོར་ལ་ཉེན་ཁ་འཕྲད་བྱུང་།",
  "title-g_bo_507": "2023ལོའི་ཉེ་ཆར་ཉ་འཛིན་གྲུ་གཟིངས་ཤིག་ཧྲན་ཏུང་ཞིང་ཆེན་ཆིན་ཏའོ་གྲོང་ཁྱེར་ཧོང་ཏའོ་ཁུལ་ལིན་ཧྲན་གླིང་ཕྲན་ནུབ་ཕྱོགས་ཀྱི་ཆུ་ཁོངས་སུ་ཉེན་ཁ་དང་འཕྲད་པ།",
  "title-g_bo_124": "ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་རེས་སྐོར་གསར་པའི་གཞི་ཁྱོན་ཆེ་བའི་གདོང་ཐུག་རྒྱུན་མཐུད་ཐོན་བཞིན་ཡོད།",
  "title-g_bo_290": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཕྱི་དྲོར་ཨ་རིའི་རྒྱལ་ཚོགས་ཀྱི་གྲོས་ཁང་གོང་མའི་ཏང་ཕལ་མོ་ཆེའི་གཙོ་འཛིན་ཧྲུའུ་མོ་ཡིས་ཀྲུང་གོར་འཚམས་འདྲིར་ཡོང་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས།",
  "title-g_bo_975": "2023ལོའི་ཟླ་10ཚེས་13ཉིན་གྱི་དགོང་མོ་ཐེ་ལ་ཝེ་ཕུའུ་ཚུད་པའི་དབྱི་སི་རལ་དབུས་རྒྱུད་ས་ཁུལ་དུ་མེ་ཤུགས་འཕུར་མདེལ་འཕེན་གཏོང་བྱས་པ།",
  "title-g_bo_392": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་ནས་ཚེས་18ཉིན་བར་པེ་ཅིང་དུ་སྐོང་ཚོགས་བྱ་རྒྱུ་ཡིན་པ་དང་། བརྗོད་དོན་གཙོ་བོ་ནི“སྤུས་ཚད་མཐོ་པོས‘རྒྱུད་གཅིག་ལམ་གཅིག’མཉམ་སྐྲུན་བྱེད། ལག་གདང་སྦྲེལ་ནས་ཐུན་མོང་གོང་འཕེལ་",
  "title-g_bo_231": "2023ལོའི་ཟླ་11ཚེས་6ཉིན་གྱི་ཕྱི་དྲོ། ཞི་ཅིན་ཕིང་གིས་མི་དམངས་ཚོགས་ཁང་ཆེན་མོར་ཁུ་པའི་ཙུང་ལི་མ་ལེ་ལུའོ་དང་མཇལ་འཛོམས་གནང་བ།",
  "title-g_bo_969": "2023ལོའི་དགུན་དུས་བོད་ལྗོངས་མྱུལ་ཞེས་པའི་ཁྲོམ་རའི་སྐུལ་སྤེལ་བྱེད་སྒོ་སྤེལ་བ་དང་།",
  "title-g_bo_354": "2023ལོའི་ཟླ་12ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་17དང་སྐར་མ་10ཡི་ཐོག་པེ་ཅིང་དུ་སྐུ་གཤེགས་པ་དང་། སྐུ་གཤེགས་སྐབས་དགུང་ལོ་82ལ་ཕེབས་ཡོད།",
  "title-g_bo_657": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་གྱི་སྔ་དྲོ། ཀྲུང་གོ་དང་ཕ་ཕུ་ཡ་ཀུའི་ནེ་ཡ་གསར་པའི་ཙུང་ལི་མཱ་ལ་ཕེ་དང་མཇལ་འཛོམས་གནང་བ།",
  "title-g_bo_914": "2024ལོའི་དཔྱིད་གསར་སྐྱེལ་འདྲེན་དེ་སྤྱི་ཟླ་1ཚེས་26ཉིན་ནས་སྤྱི་ཟླ་3ཚེས་5ཉིན་བར་ཏེ་དུས་ཡུན་ཉིན་40ཡིན།",
  "title-g_bo_719": "《བོད་ཀྱི་ཤིང་རྐོས་སྐོར་མདོ་ཙམ་བརྗོད་པ》",
  "title-g_bo_302": "2023ལོའི་ཟླ་4ཚེས་15ཉིན་སུའུ་ཏན་གྱི་དྲག་ཆས་དཔུང་སྡེ་དང་འཕྲལ་སྒྲུབ་རོགས་སྐྱོར་དཔུང་སྡེའི་བར་རྒྱལ་ས་ཁ་ཧྲེ་མུར་དྲག་པོའི་གདོང་ཐུག་ཐོན་པ་དང་། དེ་རྗེས་གདོང་ཐུག་ས་ཁུལ་གཞན་དག་ཏུ་ཁྱབ་པ་དང་འབྲ",
  "title-g_bo_109": "2023ལོར་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་གཞི་ཁྱོན་ཆེ་རུ་ཕྱིན་པ་དང་ཨ་རིའི་དངུལ་རྩ་བརྟན་ལྷིང་ངང་རྒྱུན་འཁྱོངས་བྱེད་པའི་དཀའ་ཚེགས་ཆེ་རུ་ཕྱིན་པ།",
  "title-g_bo_508": "2023ལོའི་ཝེ་ཐེ་ནམ་གུང་ཁྲན་ཏང་ཀྲུང་དབྱང་ཨུ་ཡོན་ལྷན་ཁང་གི་སྤྱི་ཁྱབ་ཧྲུའུ་ཅི་རོན་ཧྥུ་ཀྲུང་དང་ཝེ་ཐེ་ནམ་སྤྱི་ཚོགས་རིང་ལུགས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་ཀྲུའུ་ཞི་ཝུ་ཝུན་ཧྲང་གིས་གདན་འད�",
  "title-g_bo_754": "ཨ་ལ་པི་ཡ་བརྙན་འཕྲིན་ཁང་གིས་ལི་པི་ཡ་ཤར་རྒྱུད་ཀྱི་ཆུ་ལོག་གནོད་འཚེའི་ཁྲོད་མི6000ལྷག་ཚེ་ལས་འདས་པ་བྱུང་།",
  "title-g_bo_576": "2023ལོའི་ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་རྒྱལ་རྟགས་ནི་རླབས་ཆེན་མེས་རྒྱལ་གྱི་མཚོན་རྟགས་ཤིག་དང་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་མཚོན་རྟགས་ཤིག་རེད།",
  "title-g_bo_6": "2023ལོའི་ཟླ་10ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་10པ་ནས་བཟུང་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དབར་བཀག་ཉར་བྱས་པའི་མི་སྣ་བརྗེ་པོ་རྒྱག་རྒྱུ་དང་ཀ་ཧྲ་རྒྱུད་དུ་ཉིན་4ཡི་རིང་གནས",
  "title-g_bo_832": "ཆུ་མགྱོགས་པོ་འཐུང་མི་རུང་།",
  "title-g_bo_243": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཨ་རི་རྒྱལ་ཁབ་གཉིས་པོ་ནི་གོ་ལ་ཧྲིལ་པོའི་དཔལ་འབྱོར་མ་ལག་ཆེན་པོ་གཉིས་ཡིན་ཏེ། དཔལ་འབྱོར་བསྡོམས་འབོར་གྱིས་འཛམ་གླིང་གི་གསུམ་ཆ་གཅིག་ལྷག་ཟིན་པ",
  "title-g_bo_359": "སྤུས་ཚད་ཡག་པོ་མེད་པའི་རས་གཙང་སྦྲ་བྱེད་དཀའ་ལ། ཁ་ཤས་ལ་དུག་ཤེད་ལྡན་པས། འདི་རིགས་ཡུན་རིང་བེད་སྤྱོད་བཏང་ཚེ་རྒྱུན་མཐོང་རང་བཞིན་གྱི་དུག་ཕོག་པའི་ཉེན་ཁ་ཤིན་ཏུ་ཆེ།",
  "title-g_bo_710": "《ཉིང་རྡུལ་ཚོད་ལྟ་ཕྱོགས་ཡོངས་ནས་གཏན་འགོག་བྱེད་པའི་ཆིངས་ཡིག》ལ་མིང་རྟགས་བཀོད་པ་ཕྱིར་འཐེན་བྱས་པ་དེ་ནི་ཨུ་རུ་སུའི་ཕྱོགས་ཀྱིས་ཉིང་རྡུལ་ཚོད་ལྟ་བྱ་རྒྱུ་ཡིན་པ་མཚོན་པ་རེད།",
  "title-g_bo_34": "2022ལོར་བོད་ལྗོངས་ཀྱི་ཚད་གཞི་མཐོ་བའི་ས་ཞིང་མུའུ་ཁྲི་430བསྐྲུན་པ།",
  "title-g_bo_54": "2024ལོའི་ཟླ་1པོའི་ཚེས་5ཉིན་ཐེན་ཅིན་གྲོང་ཁྱེར་འབྲིང་རིམ་མི་དམངས་ཁྲིམས་ཁང་དང་པོས་ཡོངས་བསྒྲགས་ངང་ཧོ་པེ་ཞིང་ཆེན་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ཨུད་ཀྱི་དེ་སྔའི་ཀྲུའུ་རེན་གཞོན་པ་ཞེ་ཅི་ལའེ་ཡིས་ལ�",
  "title-g_bo_399": "2023ལོའི་ཟླ་7ཚེས་6ཉིན་གྱི་དགོང་མོ་ནས་བཟུང་། ཀ་ཧྲ་ས་ཁུལ་ལྷོ་རྒྱུད་ཧན་ཡིའུ་ཉི་སི་ས་ཁུལ་ལ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་དང་མེ་སྒྱོགས་བརྒྱབ་པས་མི་71རྐྱེན་ལམ་དུ་བཏང་ཡོད།",
  "title-g_bo_559": "བོད་ཀྱི་སྲོལ་རྒྱུན་རྒྱན་ཆའི་རིགས་སྣེ་མང་ཕུན་ཚོགས་ཤིང་། མགོ་རྒྱན་དང་། རྣ་རྒྱན། མགུལ་རྒྱན། མཛུབ་རྒྱན་སོགས་ཡོད་པ་དེ་དག་ཁྱད་ཆོས་མངོན་པར་དོད་ཅིང་། རིག་གནས་ཀྱི་མཚོན་དོན་ཕུན་སུམ་ཚོགས་པ་�",
  "title-g_bo_521": "2023ལོའི་ཟླ་12ཚེས་18ཉིན་མཚོ་སྔོན་སྤྱི་བདེ་དང་དྲ་བའི་བདེ་འཇགས་སྡེ་ཁག་གིས་ས་ཡོམ་རིམ་པ་6.2བརྒྱབ་རྗེས་ཁྲིམས་ལྟར་མི་3ལ་སྲིད་འཛིན་ཆད་པ་བཅད་པ།",
  "title-g_bo_874": "2023ལོའི་ལོ་གསར་དང་དཔྱིད་གསར་དུས་ཆེན་རིང་གི་སྤྱོད་ཚུལ་བཞིའི་གནད་དོན་ལ་ལྟ་སྐུལ་ཐེར་འདོན་དང་དམར་འདོན་བྱེད་ས་བརྡ་ཁྱབ་བཏང་བའི་དཔེ་མཚོན་གྱོད་གཞི་7བརྡ་ཁྱབ་བཏང་འདུག",
  "title-g_bo_875": "2024ལོའི་སྨན་བཅོས་འགན་བཅོལ་ལས་དོན་ཐད་ཞིབ་འཇུག་བྱས་པ།",
  "title-g_bo_591": "2023ལོའི་ཟླ་11ཚེས་20ཉིན་པེ་ཅིང་དུ་སོ་ཏི་ཨ་རབ་དང་དབྱི་སི་ལན་རྒྱལ་ཁབ་ཀྱི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་ཝང་དབྱི་ཡིས་པེ་ཅིང་དུ་སོ་ཏི་ཨ་རབ་དང་དབྱི་སི་ལན་རྒྱལ་ཁབ་ཀྱི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་ཧྥེ་སར་དང་། �",
  "title-g_bo_137": "ས་ཡོམ་རིམ་པ་6.8བརྒྱབ་པའི་ས་ཡོམ་གྱི་གཏོར་སྐྱོན་ཕོག་པའི་མི་གྲངས་དང་མི་གྲངས་ཀྱི་གཏོར་སྐྱོན་ཕོག་པའི་མི་གྲངས་གཞི་རྩའི་ཆ་ནས་མཐོ་རུ་ཕྱིན་ཡོད།",
  "title-g_bo_793": "2023ལོའི་ལོ་ཟོག་ཉོ་བའི་བྱེད་སྒོ་སྤེལ་ཡུལ་དངོས་སུ་རིག་རྩལ་འཁྲབ་སྟོན་དང་ཚོང་ཟོག་སྣ་ཁ་མང་བས་ཉེ་འཁོར་གྱི་གྲོང་མི་དང་ཡུལ་སྐོར་བ་མང་པོའི་ཡིད་ཀྱི་དབང་པོ་ཅིག་ཅར་འཕྲོག་སྟེ་མ་གྲོས་གཅིག་མཐུན་ག�",
  "title-g_bo_349": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་པེ་ཅིང་མོན་ཐོའུ་ཀའུ་དང་ཧོ་པེ་པའོ་ཏིང་དུ་ཕེབས་ནས་ད་ལོ་རྒྱལ་ནང་དུ་རྟོག་ཞིབ་གནང་བ་དང་། ས་ཆ་དེ་དག་ཏུ་གནོད་འཚེའི་རྗེས་ཀྱི་སླར་གསོ་བསྐྱར་འཛུ",
  "title-g_bo_782": "ང་ཚོས་ཟ་མ་ཟ་སྐབས་དོ་སྣང་མ་བྱུང་བར་ཟ་ཡས་མང་དྲག་པའི་གནས་ཚུལ་ཐོན་སྲིད་པ་དང་། དེ་རིང་ང་ཚོས་དོ་སྣང་མ་བྱུང་བར་ཟ་ཡས་མང་དྲག་པའི་རྒྱུ་མཚན་སྐོར་དང་ནམ་རྒྱུན་བཟའ་རྒྱུ་མང་དྲག་ན་ལུས་གཟུགས་ལ་ཤུགས་རྐ�",
  "title-g_bo_951": "2023ལོའི་ལོ་གསར་མཁོ་ཆས་བར་སྐོར་ཚོང་གྲོང་དུ་ཡོད་པ་དང་ལྷ་སའི་གྲོང་མིས་བར་སྐོར་ཚོང་གྲོང་ནས་དཔྱིད་གསར་ཆ་ཡིག་ཉོ་བཞིན་པ།",
  "title-g_bo_989": "《ཆོས་ལུགས་ལས་དོན་དོ་དམ་སྲོལ་ཡིག》དང་། 《ནང་བསྟན་ཆོས་ལུགས་དང་ཏའོ་ཅའོ་ཆོས་ལུགས་ཀྱི་ཚོང་ལས་ཅན་སྔར་བས་བཅོས་སྐྱོང་བྱ་རྒྱུའི་སྐོར་གྱི་བསམ་འཆར་འགའ་ཞིག》 《དྲ་སྦྲེལ་ཆོས་ལུགས་ཆ་འཕྲིན་ཞབས་ཞུ་དོ་དམ་བྱ་ཐ",
  "title-g_bo_128": "2023ལོའི་ཟླ་11ཚེས་15ཉིན་ཨ་རིའི་ཅིའུ་ཅིན་ཧྲན་ཕེ་ལོ་ལི་གཞིས་ཀར་ཨ་རིའི་ཙུང་ཐུང་པའེ་ཏེང་དང་མཇལ་འཕྲད་གནང་བ།",
  "title-g_bo_230": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》སྟེང་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ཕ་ལི་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིར་གཞི་ཁྱོན་ཆེ་བའི་དམག་དོན་ལས་འགུལ་སྤེལ་འཆར་ཡོད་ཅེས་བསྟན་",
  "title-g_bo_636": "2023ལོའི་ཟླ་10ཚེས་1ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་བསམ་བློ་རིག་གནས་དྲིལ་བསྒྲགས་ལས་དོན་ལ་མཛུབ་སྟོན་གལ་ཆེན་གནང་།",
  "title-g_bo_894": "2023ལོའི་ཟླ་1ཚེས་12ཉིན་ཀྲུང་ལའེ་དབར་གྱི་འབྲེལ་བ་སླར་གསོ་བྱུང་ནས་ལོ་30འཁོར་བར་རྟེན་འབྲེལ་ཞུས་གནང་བ།",
  "title-g_bo_606": "2013ལོའི་ཟླ་9ཚེས་7ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གཏམ་བཤད་གལ་ཆེན་གནང་བ།",
  "title-g_bo_910": "2023ལོའི་ཟླ་2ཚེས་21ཉིན་གླིང་ཆེན་ཨ་མེ་རི་ཁ་དབུས་མའི་གྲོས་ཚོགས་ཀྱི་གྲོས་དཔོན་སའེ་ལུའུ་ཏེ་ཡིས་ཀྲུང་གོ་གཅིག་ལས་མེད་པའི་རྩ་དོན་གྱི་དོན་དངོས་མཚོན་ཡོད།",
  "title-g_bo_588": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱི་བདེ་ཐང་གནས་ཚུལ་ཉིན་བཞིན་སྡུག་ཏུ་འགྲོ་གི་འདུག",
  "title-g_bo_908": "2023ལོའི་ཟླ་2ཚེས་1ཉིན་གྱི་འགྲེམས་སྟོན་ཁྲེང་ཏུའུ་ཅིན་ཧྲ་གནའ་ཤུལ་རྟེན་རྫས་བཤམས་མཛོད་ཁང་དུ་འགྲེམས་སྟོན་བྱེད་འགོ་བརྩམས།",
  "title-g_bo_979": "ཨ་རི་ཕྱོགས་ཀྱིས་བྱང་སྣེའི་ས་ཁུལ་གྱི་ས་མཚམས་འགྲན་རྩོད་སྔར་བས་ཛ་དྲག་ཏུ་འགྲོ་རྒྱུ་རེད།",
  "title-g_bo_786": "2024ལོའི་ཟླ་1ཚེས་8ཉིན་ནས་ཚེས་10ཉིན་བར་པེ་ཅིང་དུ་གྲོལ་བའི་ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐབས་ཉི་ཤུ་པའི་ཀྲུང་དབྱང་སྒྲིག་ཁྲིམས་ཞིབ་བཤེར་ཨུ་ཡོན་ལྷན་ཁང་གི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐེངས་གསུམ་པ།",
