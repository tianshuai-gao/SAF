  "title-g_bo_290": "2023ལོའི་ཟླ་9ཚེས་18ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གོང་མའི་ཏང་ཕལ་མོ་ཆེའི་གཙོ་འཛིན་ཧྲུའུ་མོ་ཡིས་ཀྲུང་གོར་འཚམས་འདྲིར་ཡོང་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
  "title-g_bo_975": "2023ལོའི་ཟླ་10ཚེས་13ཉིན་གྱི་དགོང་མོ་ཐེ་ལ་ཝེ་ཕུའུ་ཚུད་པའི་དབྱི་སི་རལ་དབུས་རྒྱུད་ས་ཁུལ་དུ་མེ་ཤུགས་འཕུར་མདེལ་འཕེན་གཏོང་བྱས་པ།",
  "title-g_bo_392": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་ནས་ཚེས་18ཉིན་བར་པེ་ཅིང་དུ་སྐོང་ཚོགས་བྱ་རྒྱུ་ཡིན་པ་དང་། བརྗོད་དོན་གཙོ་བོ་ནི“སྤུས་ཚད་མཐོ་པོས‘རྒྱུད་གཅིག་ལམ་གཅིག’མཉམ་སྐྲུན་བྱེད། ལག་གདང་སྦྲེལ་ནས་ཐུན་མོང་གོང་འཕེལ་",
  "title-g_bo_231": "2023ལོའི་ཟླ་11ཚེས་6ཉིན་གྱི་ཕྱི་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོ་དང་ཁུ་པའི་འགོ་ཁྲིད་པའི་སྣེ་ཁྲིད་དང་སྐྱེད་སྲིང་འོག་མི་དམངས་ཚོགས་ཁང་ཆེན་མོར་ཁུ་པའི་ཙུང་ལི་མ་ལེ་ལུའོ་དང་མཇལ་འཛོམས་གནང་བ།",
  "title-g_bo_969": "2023ལོའི་དགུན་དུས་བོད་ལྗོངས་མྱུལ་ཞེས་པའི་ཁྲོམ་རའི་སྐུལ་སྤེལ་བྱེད་སྒོ་སྤེལ་རྒྱུ་དང་།",
  "title-g_bo_354": "2023ལོའི་ཟླ་12ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་17དང་སྐར་མ་10ཡི་ཐོག་པེ་ཅིང་པ་པའོ་ཧྲན་གསར་བརྗེའི་སྤྱི་པའི་བང་སོ་ཁང་དུ་ཞུགས་འབུལ་ཞུས་པའི་བློ་མཐུན་སང་གོ་ཝུའེ་ཡི་སྐུ་གཤེགས་པ་དང་། སྐུ་གཤེགས་སྐབས་དགུང་ལོ་",
  "title-g_bo_657": "2023ལོའི་ཟླ་10ཚེས་17ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་གིས་ཀྲུང་གོར་སྐབས་གསུམ་པའི“རྒྱུད་གཅིག་ལམ་གཅིག”རྒྱལ་སྤྱིའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཞུགས་པར་ཕེབས་པ་མ་ཟད་དངོས་གཞིའི་འཚམས་འདྲི་གནང་བར་ཕ�",
  "title-g_bo_914": "2024ལོའི་དཔྱིད་གསར་སྐྱེལ་འདྲེན་དེ་སྤྱི་ཟླ་1ཚེས་26ཉིན་ནས་སྤྱི་ཟླ་3ཚེས་5ཉིན་བར་ཏེ་དུས་ཡུན་ཉིན་40ཡིན་པ་དང་། དམིགས་བསལ་གྱི་དུས་སྐབས་འདིར་ལྷ་ས་མེ་འཁོར་འབབ་ཚུགས་ཀྱིས་སྔོན་དཔག་བྱས་ན་འགྲུལ་པ་",
  "title-g_bo_719": "《བོད་གནའ་རབས་ཀྱི་ཤིང་རྐོས་སྐོར་མདོ་ཙམ་བརྗོད་པ》",
  "title-g_bo_302": "2023ལོའི་ཟླ་4ཚེས་15ཉིན་སུའུ་ཏན་གྱི་དྲག་ཆས་དཔུང་སྡེ་དང་འཕྲལ་སྒྲུབ་རོགས་སྐྱོར་དཔུང་སྡེའི་བར་རྒྱལ་ས་ཁ་ཧྲེ་མུར་དྲག་པོའི་གདོང་ཐུག་ཐོན་པ་དང་། དེ་རྗེས་གདོང་ཐུག་ས་ཁུལ་གཞན་དག་ཏུ་ཁྱབ་པ་དང་འབྲ",
  "title-g_bo_109": "2023ལོའི་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་གཞི་ཁྱོན་ཆེ་རུ་ཕྱིན་པ་དང་ཕྱི་རྒྱལ་གྱི་མ་འཇོག་མཁན་ལ་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་རྣམ་པར་འགྱུར་ལྡོག་ཕྱིན་མེད།",
  "title-g_bo_508": "2023ལོའི་ཟླ་12ཚེས་12ཉིན་ཝེ་ཐེ་ནམ་དང་ཀྲུང་གོ་གཉིས་པོའི་འབྲེལ་བ་འཕེལ་རྒྱས་འགྲོ་རྒྱུར་མདུན་ལྗོངས་གསར་པ་གཏོད་ངེས་ཡིན་པ།",
  "title-g_bo_754": "ཨ་ལ་པི་ཡ་རྒྱལ་དམངས་འཐུས་མི་ཚོགས་ཆེན་གྱིས་ལི་པི་ཡ་ཤར་རྒྱུད་ཀྱི་ཆུ་ལོག་གནོད་འཚེའི་ཁྲོད་མི6000ལྷག་ཚེ་ལས་འདས་ཡོད།",
  "title-g_bo_576": "2023ལོའི་ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་རྒྱལ་རྟགས་ནི་རླབས་ཆེན་མེས་རྒྱལ་གྱི་མཚོན་རྟགས་ཤིག་དང་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་མཚོན་རྟགས་ཤིག་རེད།",
  "title-g_bo_6": "2023ལོའི་ཟླ་9ཚེས་22ཉིན་གྱི་ཆུ་ཚོད་10པ་ནས་བཟུང་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིའི་དབར་བཀག་ཉར་བྱས་པའི་མི་སྣ་བརྗེ་པོ་རྒྱག་རྒྱུ་དང་ཀ་ཧྲ་རྒྱུད་དུ་ཉིན་4ཡི་རིང་གནས་",
  "title-g_bo_832": "ཆུ་མགྱོགས་པོ་འཐུང་མི་རུང་།",
  "title-g_bo_243": "2023ལོའི་ཟླ་10ཚེས་25ཉིན་གྱི་ཕྱི་དྲོ། ཀྲུང་གོ་དང་ཨ་རིའི་འབྲེལ་བ་འཕེལ་རྒྱས་བྱུང་ནས་ད་ལྟའི་གྲུབ་འབྲས་ཐོབ་པ་ནི་ལས་སླ་པོར་ཐོབ་པ་ཞིག་མིན་པས། དེར་གཅེས་འཛིན་ལྡབ་འགྱུར་བྱེད་རིན་ཡོད།",
  "title-g_bo_359": "སྒྲོག་ཙེར་སྤུས་ཚད་ཡག་པོ་མེད་པའི་རས་འདིང་བ།",
  "title-g_bo_710": "《ཉིང་རྡུལ་ཚོད་ལྟ་ཕྱོགས་ཡོངས་ནས་གཏན་འགོག་བྱེད་པའི་ཆིངས་ཡིག》ལ་མིང་རྟགས་བཀོད་པ་ཕྱིར་འཐེན་བྱས་པ་དེ་ནི་ཨུ་རུ་སུའི་ཙུང་ཐུང་གིས་ཉིང་རྡུལ་ཚོད་ལྟ་བྱ་རྒྱུ་ཡིན་པ་མཚོན་པ་དང་། ཨུ་རུ་སུའི་ཙུང་ཐུང་ག�",
  "title-g_bo_34": "2022ལོའི་བོད་ལྗོངས་ཀྱི་ཚད་གཞི་མཐོ་བའི་ས་ཞིང་མུའུ་ཁྲི་430བསྐྲུན་པ།",
  "title-g_bo_54": "2024ལོའི་ཟླ་1པོའི་ཚེས་5ཉིན་ཐེན་ཅིན་གྲོང་ཁྱེར་འབྲིང་རིམ་མི་དམངས་ཁྲིམས་ཁང་དང་པོས་ཡོངས་བསྒྲགས་ངང་ཧོ་པེ་ཞིང་ཆེན་མི་དམངས་འཐུས་ཚོགས་རྒྱུན་ཨུད་ཀྱི་དེ་སྔའི་ཀྲུའུ་རེན་གཞོན་པ་ཞེ་ཅི་ལའེ་ཡིས་ལ�",
  "title-g_bo_399": "2023ལོའི་ཟླ་7ཚེས་7ཉིན་གྱི་ཕྱི་དྲོ་ཀ་ཧྲ་ས་ཁུལ་བྱང་རྒྱུད་དུ་མུ་མཐུད་དེ་མཁའ་ཐོག་འཇབ་རྒོལ་དང་མེ་སྒྱོགས་བརྒྱབ་པས་མི་71རྐྱེན་ལམ་དུ་བཏང་ཡོད།",
  "title-g_bo_559": "བོད་ཀྱི་རྒྱན་ཆའི་རིགས་སྣེ་མང་ཕུན་ཚོགས་ཤིང་། མགོ་རྒྱན་དང་། རྣ་རྒྱན། མགུལ་རྒྱན། མཛུབ་རྒྱན་སོགས་ཡོད་པ་དེ་དག་ཁྱད་ཆོས་མངོན་པར་དོད་ཅིང་། རིག་གནས་ཀྱི་མཚོན་དོན་ཕུན་སུམ་ཚོགས་པ་ཞིག་ཡོད།",
  "title-g_bo_521": "2022ལོའི་ཟླ་12ཚེས་18ཉིན་མཚོ་སྔོན་སྤྱི་བདེ་ལས་ཁུངས་ཀྱིས་ས་ཡོམ་རིམ་པ་6.2བརྒྱབ་རྗེས་དྲ་རྒྱའི་དཀྲོག་གཏམ་སྤེལ་བའི་དཔེ་མཚོན་གྱོད་དཔེ་ཁྱབ་བསྒྲགས་བྱས་པ།",
  "title-g_bo_874": "2023ལོའི་ལོ་གསར་དང་དཔྱིད་གསར་དུས་ཆེན་རིང་གི་སྤྱོད་ཚུལ་བཞིའི་གནད་དོན་ལ་ལྟ་སྐུལ་ཐེར་འདོན་དང་དམར་འདོན་བྱེད་ས་7བརྡ་ཁྱབ་བཏང་འདུག",
  "title-g_bo_875": "2024ལོའི་སྨན་བཅོས་འགན་བཅོལ་ལས་དོན་ཐད་ཞིབ་འཇུག་དང་བཀོད་སྒྲིག་བྱས་པ།",
  "title-g_bo_591": "2023ལོའི་ཟླ་11ཚེས་20ཉིན་པེ་ཅིང་དུ་སོ་ཏི་ཨ་རབ་དང་དབྱི་སི་ལན་རྒྱལ་ཁབ་ཀྱི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་མཉམ་འབྲེལ་འཐུས་ཚབ་ཚོགས་པ་དང་གྲོས་མོལ་བྱས་པ།",
  "title-g_bo_137": "ས་ཡོམ་རིམ་པ་6.8བརྒྱབ་པའི་ས་ཡོམ་གྱི་གཏོར་སྐྱོན་ཕོག་པའི་མི་གྲངས་དང་མི་གྲངས་ཀྱི་གྲངས་གཞི་ལྟར་ན། ས་ཡོམ་རིམ་པ་7.8རྗེས་ཀྱི་ས་ཡོམ་ཆེ་གྲས་གཉིས་པར་གྱུར་ཡོད།",
  "title-g_bo_793": "2023ལོའི་ལྷ་ས་གྲོང་ཁྱེར་ཁྲེང་ཀོན་ཆུས་དྲིལ་བསྒྲགས་པུས་གཙོ་གཉེར་བྱས་པའི་བོད་ཀྱི་ལོ་གསར་ལ་བསུ་བ་ཞུ་བའི་བྱེད་སྒོ་སྐབས་གཉིས་པ་ལྷ་སའི་གནའ་རབས་བཟོ་སྐྲུན་སྒོ་ར་ཆེན་མོར་གཉེར་ཡོད།",
  "title-g_bo_349": "2023ལོའི་ཟླ་10ཚེས་10ཉིན་གྱི་སྔ་དྲོ། ཞི་ཅིན་ཕིང་དང་ཐོག་ཡུང་ཏིང་ཆུ་བོའི་སན་ཅ་ཏེན་གྱི་ཆུ་འདྲེན་ལྟེ་གནས་སུ་ཕེབས་ཏེ་པེ་ཅིང་གྲོང་ཁྱེར་གྱི་ཆུ་རྒྱུད་དང་། ཡུང་ཏིང་ཆུ་བོའི་ཉམས་གསོ་བཅོས་སྐྱ�",
  "title-g_bo_782": "ང་ཚོས་དོ་སྣང་མ་བྱུང་བར་ཟ་ཡས་མང་དྲག་པའི་རྒྱུ་མཚན་སྐོར་དང་ནམ་རྒྱུན་བཟའ་རྒྱུ་མང་དྲག་ན་ལུས་གཟུགས་ལ་ཤུགས་རྐྱེན་གང་འདྲ་ཐེབས་པའི་ཐད་གླེང་མོལ་བྱེད་རྒྱུ་ཡིན།",
  "title-g_bo_951": "2023ལོའི་ལོ་གསར་མཁོ་ཆས་བར་སྐོར་ཚོང་གྲོང་དུ་ཡོད་པ་དང་ལྷ་སའི་གྲོང་མིས་བར་སྐོར་ཚོང་གྲོང་ནས་དཔྱིད་གསར་ཆ་ཡིག་ཉོ་བཞིན་པ།",
  "title-g_bo_989": "《ཆོས་ལུགས་ལས་དོན་དོ་དམ་སྲོལ་ཡིག》དང་། 《ནང་བསྟན་ཆོས་ལུགས་དང་ཏའོ་ཅའོ་ཆོས་ལུགས་ཀྱི་ཚོང་ལས་ཅན་སྔར་བས་བཅོས་སྐྱོང་བྱ་རྒྱུའི་སྐོར་གྱི་བསམ་འཆར་འགའ་ཞིག》 《དྲ་སྦྲེལ་ཆོས་ལུགས་ཆ་འཕྲིན་ཞབས་ཞུ་དོ་དམ་བྱ་ཐ",
  "title-g_bo_128": "2023ལོའི་ཟླ་11ཚེས་15ཉིན་ཀྲུང་གུང་ཀྲུང་དབྱང་ཆབ་སྲིད་ཅུས་ཀྱི་ཨུ་ཡོན་དང་ཕྱི་འབྲེལ་པུའི་པུའུ་ཀྲང་ཝང་དབྱི་ཡིས་ཨ་རིའི་ཅིའུ་ཅིན་ཧྲན་ཕེ་ལོ་ལི་གཞིས་ཀར་ཨ་རིའི་ཙུང་ཐུང་པའེ་ཏེང་དང་མཇལ་འཕྲད་གནང་བ་",
  "title-g_bo_230": "《དབྱི་སི་རལ་སྐབས་དོན་ཚགས་པར》སྟེང་སྤེལ་བའི་གནས་ཚུལ་ལྟར་ན། དབྱི་སི་རལ་གྱིས་ཀ་ཧྲ་ས་ཁུལ་གྱི་ཕ་ལི་སི་ཐན་དབྱི་སི་ལམ་འགོག་རྒོལ་ལས་འགུལ་ཧ་མ་སིར་གཞི་ཁྱོན་ཆེ་བའི་དམག་དོན་ལས་འགུལ་སྤེལ་འཆར་ཡོད་ཅེས་བསྟན་",
  "title-g_bo_636": "2022ལོའི་ཞི་ཅིན་ཕིང་གིས་བསམ་བློ་རིག་གནས་དྲིལ་བསྒྲགས་ལས་དོན་ལ་མཛུབ་སྟོན་གལ་ཆེན་གནང་།",
  "title-g_bo_894": "2023ལོའི་ཟླ་1ཚེས་12ཉིན་ཀྲུང་ལའེ་དབར་གྱི་འབྲེལ་བ་སླར་གསོ་བྱུང་ནས་ལོ་30འཁོར་བར་རྟེན་འབྲེལ་ཞུ་བ།",
  "title-g_bo_606": "2013ལོའི་ཟླ་9ཚེས་7ཉིན་གྱི་ཆེས་མཐོའི་ཁྲིམས་ཁང་གི་གཏམ་བཤད་གལ་ཆེན་གནང་བ།",
  "title-g_bo_910": "2023ལོའི་ཟླ་9ཚེས་21ཉིན་གླིང་ཆེན་ཨ་མེ་རི་ཁ་དབུས་མའི་གྲོས་ཚོགས་ཀྱིས་ནི་ཁ་ར་ཀྭ་ཡི་རྒྱལ་ས་མ་ན་ཀྭ་རུ་ཚང་འཛོམས་གྲོས་ཚོགས་འཚོགས་པ།",
  "title-g_bo_588": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་ཀྱིས་བྱིས་པ་རྣམས་ལྟོགས་ནས་ནད་ཀྱང་ཕོག་གི་འདུག་ཅེས་བཤད་འདུག",
  "title-g_bo_908": "2023ལོའི་ཟླ་2ཚེས་1ཉིན་ཅིན་ཧྲ་གནའ་ཤུལ་རྟེན་རྫས་བཤམས་མཛོད་ཁང་དུ་འགྲེམས་སྟོན་བྱེད་འགོ་བརྩམས།",
  "title-g_bo_979": "ཨ་རིའི་རྒྱལ་དོན་ཁང་གིས་ཨ་རིས་སྐམ་ས་ཆེན་པོའི་སྒྲོམ་གྱི་དབྱེ་མཚམས་གྱི་ས་ཁམས་གནས་ཚད་རྒྱ་ཆེ་རུ་གཏོང་རྒྱུའི་ཁྱབ་བསྒྲགས་བྱས་པ།",
  "title-g_bo_786": "2024ལོའི་ཟླ་1ཚེས་8ཉིན་ནས་ཚེས་10ཉིན་བར་པེ་ཅིང་དུ་ཀྲུང་གོ་གུང་ཁྲན་ཏང་གི་སྐབས་ཉི་ཤུ་པའི་ཀྲུང་དབྱང་སྒྲིག་ཁྲིམས་ཞིབ་བཤེར་ཨུ་ཡོན་ལྷན་ཁང་གི་ཚང་འཛོམས་གྲོས་ཚོགས་ཐེངས་གསུམ་པ་འཚོགས་པ་རེད།",
  "title-g_bo_269": "2023ལོའི་རང་རྒྱལ་གྱི་ནུས་ཆེའི་བར་རྡུལ་དཔྱད་ཆས་ཐོག་མ་བསྐྲུན་ཟིན་པ།",
