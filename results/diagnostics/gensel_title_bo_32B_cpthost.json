{
 "predictions": {
  "title-g_bo_549": "2023ལོའི་ཉིན་རེའི་སྦྲག་སྲིད་ཚགས་པར་ནས་བདེ་ཐང་གཞི་གྲངས་ཕྱོགས་གཅིག་ཏུ་བསྡུས་པ།",
  "title-g_bo_237": "《སྐྲན་ནད་གྱི་སྔོན་འགོག་དང་ཚོད་འཛིན་བྱེད་པའི་བྱ་སྤྱོད་བཟོ་བཞི》",
  "title-g_bo_389": "2023ལོའི་ཟླ་12ཚེས་19ཉིན་གྱི་མཚོ་སྔོན་ཞིང་ཆེན་ཆུ་བེད་ཐིང་ནས་ཤེས་རྟོགས་བྱས་པ། ཞིང་ཆུ་འདྲེན་ཁུལ་དང་འཐུང་ཆུའི་བདེ་འཇགས་ལས་གྲྭ་མང་ཆེ་བ་རྒྱུན་ལྡན་ངང་འཁོར་སྐྱོད་ཐུབ་པ།",
  "title-g_bo_658": "ཉེན་བརྡ་འབྱོར་བའི་མི་དམངས་ཉེན་རྟོག་པ་དང་མང་ཚོགས་ཀྱི་རོགས་སྐྱོབ་ལས་དོན་ལ་དཀའ་ངལ་འཕྲད་བྱུང་།",
  "title-g_bo_507": "2023ལོའི་ཉ་འཛིན་གྲུ་གཟིངས་ཉེན་ཁ་དང་འཕྲད་པ་བྱུང་། འཇིགས་སུ་རུང་བའི་རྦ་རླབས་ཁྲོད་ཀྱི་ཚེ་སྲོག་སྐྱོབ་རོགས་ལེགས་འགྲུབ་བྱུང་།",
  "title-g_bo_124": "ཀ་ཧྲ་ས་ཁུལ་གྱི་དབྱི་སི་རལ་དང་ཕ་ལེ་སི་ཐན་གི་མཐུད་ཐོན་བཟོ་བྱུང་།",
  "title-g_bo_290": "2023ལོའི་ཕྱི་འབྲེལ་པུའུ་ཡི་མགྲིན་ཚབ་ནས་ཀྲུང་གོ་དང་ཨ་རིའི་བར་གྱི་འབྲེལ་བ་གོང་དུ་སྤེལ་བར་དགེ་མཚན་ལྡན་པའི་རྒྱུ་རྐྱེན་སྣོན་རྒྱུའི་རེ་བ་ཡོད།",
  "title-g_bo_975": "2023ལོའི་ཐེ་ལ་ཝེ་ཕུའུ་ཚུད་པའི་དབྱི་སི་རལ་དབུས་རྒྱུད་ས་ཁུལ་དུ་མེ་ཤུགས་འཕུར་མདེལ་འཕེན་གཏོང་བྱས་པ།",
  "title-g_bo_392": "2023ལོའི་ཕྱི་འབྲེལ་མགྲིན་ཚབ་ནས་“རྒྱུད་གཅིག་ལམ་གཅིག”གི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་བྱ་རྒྱུ་བྱས།",
  "title-g_bo_231": "2023ལོའི་ཕྱི་དྲོ་བཞིན་ཀྲུང་གོ་དང་ཁུ་པ་གཉིས་པོ་བརྟན་པའི་ཁ་དན་ཚིག་གནས་ཀྱི་འབྲེལ་བ་བཙུགས་པ།",
  "title-g_bo_969": "2023-2024 དགུན་དུས་བོད་ལྗོངས་མྱུལ་ཞེས་པའི་ཁྲོམ་རའི་སྐུལ་སྤེལ་བྱེད་སྒོ་དེ་བོད་རང་སྐྱོང་ལྗོངས་ཀྱི་ཀ་པ་རིམ་པའི་མཛེས་ལྗོངས་ཁུལ་ཚང་མར་རིན་མེད་ངང་མྱོང་རོལ་བྱེད་ཆོག་གི་ཡོད།",
  "title-g_bo_354": "2023ལོའི་ཟླ་12ཚེས་7ཉིན་གྱི་ཆུ་ཚོད་17དང་སྐར་མ་10ཡི་ཐོག་པེ་ཅིང་དུ་སྐུ་གཤེགས་པ་དང་། བློ་མཐུན་སང་གོ་ཝུའེ་ལ་སྙུན་གཞི་ལྕི་པོ་ཕོག་རིང་དང་སྐུ་གཤེགས་རྗེས། ཞི་ཅིན་ཕིང་དང་། ལི་ཆང་། ཀྲའོ་ལེ་ཅི། �",
  "title-g_bo_657": "2023ལོའི་མཉམ་ལས་མཐོ་རིམ་གླེང་སྟེགས་ལ་ཕ་ཕུ་ཡ་ཀུའི་ནེ་ཡ་གསར་པ་དང་ཀྲུང་གོ་གཉིས་ཀྱི་འབྲེལ་བ་བརྟན་པོར་འགྱུར་བ།",
  "title-g_bo_914": "2024 དཔྱིད་གསར་སྐྱེལ་འདྲེན་ལྷ་ས་མེ་འཁོར་འབབ་ཚུགས་ཀྱི་འགྲུལ་བཞུད་བརྒྱུད་ཕ་ཡུལ་དུ་ནང་མི།",
  "title-g_bo_719": "《བོད་ཀྱི་ཤིང་རྐོས་སྐོར་བརྗོད་པ།》",
  "title-g_bo_302": "2023ལོའི་ཟླ་1ཚེས་4ཉིན་སུའུ་ཏན་དུ་དྲག་པོའི་གདོང་ཐུག་ཐོན་པ་ནས་བཟུང་རྒྱལ་ཁབ་དེའི་མི་ཁྲི་730ལས་བརྒལ་བ་ཡུལ་གྱར་དུ་གྱུར་བ།",
  "title-g_bo_109": "2023ལོར་ཨ་རིའི་བུ་ལོན་འཛིན་པའི་གཞི་ཁྱོན་འཕར་ཆག་ཁྲོད་ཅུང་འཕར་བའི་རྣམ་པ་ཐོན་ཡོད།",
  "title-g_bo_508": "2023ལོའི་ཝེ་ཐེ་ནམ་ལྷན་ཁང་གི་འཚམས་འདྲི་བྱེད་དགོས། ཀྲུང་གོ་དང་ཝེ་ཐེ་ནམ་གཉིས་ཀྱི་འབྲེལ་བ་འཕེལ་རྒྱས་འགྲོ་རྒྱུར་མདུན་ལྗོངས་གསར་པ་གཏོད།",
  "title-g_bo_754": "ཨ་ལ་པི་ཡ་བརྙན་འཕྲིན་ཁང་གི་གནོད་འཚེ་ཆེན་པོ་བཏང་བ་དང་གནོད་འཚེའི་གནས་ཚུལ་ཆེས་ཚབས་ཆེ་བའི་བཞི་ཆ་གཅིག་གི་ས་ཆ་ཆུས་བསྣུབས་པ།",
  "title-g_bo_576": "2023ལོའི་ཀྲུང་ཧྭ་མི་དམངས་སྤྱི་མཐུན་རྒྱལ་ཁབ་ཀྱི་རྒྱལ་རྟགས་བཀལ་བའི་བརྒྱུད་བཞིན།",
  "title-g_bo_6": "2023ལོའི་གནས་ཚུལ་སྤེལ་བ་དང་གནས་སྐབས་དམག་མཚམས་འཇོག་རྒྱུའི་གྲོས་ཆོད་ལ་མོས་མཐུན་བྱུང་བ།",
  "title-g_bo_832": "ཆུ་མགྱོགས་པོ་འཐུང་དང་མཇིང་ཚིགས་མི་འཁྱག་པའི་དུས་ཚིགས་བཟོ་བ།",
  "title-g_bo_243": "2023ལོའི་ཨ་རི་དང་ཀྲུང་གོའི་འབྲེལ་བ་འཕེལ་རྒྱས་བྱེད་པའི་མཇལ་འཛོམས།",
  "title-g_bo_359": "ཞོགས་ཟས་མི་བཟའ་བའི་བྱུང་བ་དང་བྱུང་བ་ལ་བྱུང་བ་དང་པོ་བྱུང་བའི་ཕྱིར་བྱུང་བ།",
  "title-g_bo_710": "《ཉིང་རྡུལ་ཚོད་ལྟ་ཕྱོགས་ཡོངས་ནས་གཏན་འགོག་བྱེད་པའི་ཆིངས་ཡིག》ལ་མིང་རྟགས་བཀོད་པ་ཕྱིར་འཐེན་བྱས་པ།",
  "title-g_bo_34": "2022ལོར་བོད་ལྗོངས་ཀྱི་ཚད་གཞི་མཐོ་བའི་ས་ཞིང་མུའུ་ཁྲི་430བསྐྲུན་པ།",
  "title-g_bo_54": "2024ལོའི་ཟླ་1པོའི་ཚེས་5ཉིན་གྱི་འདྲི་གཅོད་དང་པོའི་བཅད་ཁྲ་ཁྱབ་བསྒྲགས་བྱས་པ། ཞེ་ཅི་ལའེ་ལ་ལྐོག་རྔན་བླངས་པའི་ཉེས་མིང་ཐོག་ནས་ལྷག་པ་བྱས་པ།",
  "title-g_bo_399": "2023ལོའི་ཕ་ལེ་སི་ཐན་དབྱི་སི་ལན་འགོག་རྒོལ་ལས་ཀ་ཧྲ་ས་ཁུལ་བྱང་རྒྱུད་དུ་མི་71རྐྱེན་ལམ་དུ་བཏང་བ་དང་། རེས་སྐོར་འདིའི་ཕ་ལེ་སི་ཐན་དང་དབྱི་སི་རལ་གྱི་གདོང་ཐུག་ཐོན་ཚུན།",
  "title-g_bo_559": "བོད་རིགས་ཀྱི་མཛེས་ཆོས་ལྟ་བ་དང་སྲོལ་རྒྱུན་གྱི་རྒྱན་ཆར་གྱི་མེ་ཏོག།",
  "title-g_bo_521": "2023ལོའི་ཟླ་12ཚེས་18ཉིན་གྲོང་ཁྱེར་སྤྱི་བདེ་དང་དྲ་བའི་བདེ་འཇགས་སྡེ་ཁག་གི་ས་ཡོམ་རིམ་པ་6.2བརྒྱབ་བྱས་པ།",
  "title-g_bo_874": "2023ལོའི་སྤྱི་ལོའི་ལོ་གསར་དང་དཔྱིད་གསར་དུས་ཆེན་རིང་གི་གནད་དོན་ལ་ལྟ་སྐུལ་ཐེར་འདོན་དང་དམར་འདོན་བྱེད་པའི་བཞུགས་སྤྱོད་བརྡ་ཁྱབ་བཏང་བ།",
  "title-g_bo_875": "2024ལོའི་རྒྱལ་ཡོངས་སྨན་བཅོས་འགན་བཅོལ་ལས་དོན་ཐད་ཞིབ་འཇུག་བྱས་པ།",
  "title-g_bo_591": "2023ལོའི་ཕྱི་འབྲེལ་ཚོགས་འདུར་བཞུགས་པ། ཨ་རབ་དང་དབྱི་སི་ལན་རྒྱལ་ཁབ་ཀྱི་ཕྱི་འབྲེལ་པུའུ་ཀྲང་གི་མཉམ་འབྲེལ་འཐུས་ཚབ་ཚོགས་པ།",
  "title-g_bo_137": "མོ་རོ་ཁོའི་མི་གསུམ་འབུམ་ལྷག་ལ་ཤུགས་རྐྱེན་བྱུང་བའི་ས་ཡོམ་6.8བརྒྱབ་བྱུང་།",
  "title-g_bo_793": "2023ལོའི་བོད་ལྗོངས་འགྲོ་ཕན་གླིང་རིག་གནས་ཚད་ཡོད་ཀུང་སིས་འགན་གཉེར་བྱས་པའི་བོད་ཀྱི་ལོ་གསར་ལ་བསུ་བ་ཞུ་ཞེས་པའི་ལོ་ཟོག་ཉོ་བའི་བྱེད་སྒོ་སྤྱི་ཚེས་27ཉིན་ལྷ་ས་གྲོང་ཁྱེར་དུ་བསྟེན་པ།",
