  "title-g_bo_894": "2023ལོའི་ཟླ་1ཚེས་12ཉིན་གྲུབ་པའི་ཀྲུང་ལའེ་དབར་གྱི་འབྲེལ་བ་སླར་གསོ་བྱུང་ནས་ལོ་30འཁོར་བར་ཕན་ཚུན་རྟེན་འབྲེལ་གློག་འཕྲིན་བཏང་གནང་བ།",
  "title-g_bo_606": "2013ལོའི་ཟླ་9ཚེས་7ཉིན་གྱི་ཧ་སག་སི་ཐན་ལ་“རྒྱ་མཚོའི་གྲུ་ཁ་དབང་བར་གྱུར”བྱ་བ་བྱེད་པ།",
  "title-g_bo_910": "21ཚེས་གླིང་ཆེན་ཨ་མེ་རི་ཁ་དབུས་མའི་གྲོས་ཚོགས་ཀྱི་གྲོས་ཆོད་བྱུང་བ། ཀྲུང་གོ་འདི་ཉིད་གླིང་ཆེན་ཨ་མེ་རི་ཁ་དབུས་མའི་གྲོས་ཚོགས་ཀྱི་རྒྱུན་སྡོད་ལྟ་ཞིབ་པར་གྱུར་པ་ནི་ལོ་རྒྱུས་ཀྱི་འཕེལ་ཕྱ",
  "title-g_bo_588": "ཀ་ཧྲ་རྒྱུད་ཀྱི་མང་ཚོགས་འབོར་ཆེན་བཀྲེས་ལྟོགས་ཀྱིས་མནར་ཡོད། མི་ཆོས་རིང་ལུགས་ཀྱི་རོགས་སྐྱོབ་དངོས་རྫས་ཀ་ཧྲ་རྒྱུད་དུ་སྐྱེལ་བར་འགོག་རྐྱེན་ཐེབས་པ།",
