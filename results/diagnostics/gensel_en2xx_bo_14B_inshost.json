{
 "predictions": {
  "trans-d_bo_236": "དེ་ལྟར་ང་ཚོ་དུས་རྒྱུན་དུ་བྱུང་བ་ཡིན་ནམ།",
  "trans-d_bo_52": "ད་དུང་ང་ཚོ་དང་མཉམ་དུ་འགྲོ་འདོད།",
  "trans-d_bo_454": "འདི་ནི་བྱེད་པ་མི་འདུག་ལ་དེ་ནི་བྱེད་པ་མི་འདུག་ཟེར།",
  "trans-d_bo_571": "རེད།་ང་ཚོས་ཟ་མ་ཟས་ཡོད་དམ།་ཟ་མ་ཟས་ཡོད་དམ།་ཟ་མ་ཟས་ཡོད་དམ།",
  "trans-d_bo_555": "དེ་ལྟར་བསྒྱུར་བ་དེ་ཡིན་ན་ང་ཚོས་ཁྱོད་ལ་བསྒྱུར་བ་དེ་བཟོ་བ་དང་།་ཁྱོད་ལ་བསྒྱུར་བ་དེ་བཟོ་བ་དེ་ཡིན་ན་ང་ཚོས་ཁྱོད་ལ་བ",
  "trans-d_bo_604": "སྤུ་རྒྱལ་གྱི་ཤ་དང་བོད་ཀྱི་ཤ་སོགས་ལ་ཤུགས་རྐྱེན་བཟོ་བ་དང་།་ཤ་སྐྱོན་བྱུང་ན་ཤ་སྐྱོན་བྱུང་བ་དང་།་ཤ་སྐྱོ",
  "trans-d_bo_151": "དེ་ལྟར་ང་ཚོས་ད་དུང་དུས་ཚོད་དམ་འཛིན་བྱེད་དགོས་པ་ཡིན་ནམ།",
  "trans-d_bo_296": "འོ་ན་དེ་ལྟར་བྱུང་བ་ཡིན་ནམ།་དེ་ལྟར་བྱུང་བ་ཡིན་ནམ།",
  "trans-d_bo_530": "དེ་ལྟར་དོན་དུ་བྱེད་པའི་དོན་དེ་དོན་དུ་བྱེད་པ་དང་།་དེ་ལྟར་དོན་དུ་བྱེད་པའི་དོན་དེ་དོན་དུ་བྱེད་པ་དང་།",
  "trans-d_bo_316": "དེ་ལྟར་སློབ་གསོ་མ་བྱས་ན་ད་དུང་ཁྱོད་ཀྱིས་ང་ཚོའི་དཔེ་ཁང་དུ་བསྐྱོད་དགོས་པ་དང་།",
  "trans-d_bo_762": "སྤྱི་བདེ་ལས་ཁུངས་ཀྱི་དྲ་ཐོག་ནས་ང་ཚོ་དང་མཉམ་དུ་སྤྱི་བདེ་ལས་ཁུངས་ཀྱི་དྲ་ཐོག་ནས་ང་ཚོ་དང་མཉམ་དུ་སྤྱི་བདེ་ལས་ཁུང",
  "trans-d_bo_200": "སྐྱོན་མེད་པ་ཞིག་ཡིན་པས་ང་ཚོ་དེ་རིང་གི་དུས་ཚོད་དེ་ལྟར་བཟོ་བཞིན་ཡོད།",
  "trans-d_bo_469": "འདི་ནི་ང་ཚོ་དང་མཉམ་དུ་འགྲོ་བ་ཡིན།་དེ་ནི་ང་ཚོ་དང་མཉམ་དུ་འགྲོ་བ་ཡིན།",
  "trans-d_bo_661": "རེད།་ང་ཚོས་ད་དུང་གྲོས་བསྡུར་བྱེད་བཞིན་ཡོད།",
  "trans-d_bo_147": "དེ་ནས་ང་ཚོ་ད་དུང་གཞན་རེད་དམ།",
  "trans-d_bo_56": "༡༩༩༩ ལོའི་ཟླ་བ་དང་པོ་ནས་བོད་ལ་ཕུལ་བ་དང་།་ཟླ་བ་གཉིས་པ་ནས་བོད་ལ་ཕུལ་བ་དང་།་ཟླ་བ་གསུམ་པ་ནས་བོད་ལ་ཕུལ་བ་དང་།་ཟླ་བ་བཞི་པ་ནས་",
  "trans-d_bo_543": "ལྷག་པར་དུ་ང་ལ་ཐོག་མར་བོད་ཀྱི་ཐོག་མའི་དུས་སྐབས་ཀྱི་དཔལ་འབྱོར་གྱི་གནས་ཚུལ་དང་། དེ་བཞིན་དུ་ང་ལ་ཐོག་མར་བོད་ཀྱི་ཐོག",
  "trans-d_bo_57": "ང་ཚོ་དེ་དག་ལ་བྱིན་པ་དེ་དག་གི་དོན་དུ་བྱེད་པ་དེ་དག་ལ་བྱིན་པ་དེ་དག་གི་དོན་དུ་བྱེད་པ་དེ་དག་ལ་བྱིན་པ་དེ་དག་གི་དོན་དུ་བྱ�",
  "trans-d_bo_401": "འདི་ནི་ང་ཚོ་དང་མཉམ་དུ་བྱེད་པ་ཡིན།་དེ་ནི་ང་ཚོ་དང་མཉམ་དུ་བྱེད་པ་ཡིན།",
  "trans-d_bo_471": "འདི་ནི་ང་ལ་བསྟོད་པ་ཡིན།",
  "trans-d_bo_309": "མིན་ན་ད་དུང་ང་ཚོ་དེ་ལྟར་ལྷ་ས་ལ་འགྲོ་བ་མིན་པས་ང་ཚོ་དེ་ལྟར་ལྷ་ས་ལ་འགྲོ་བ་ཡིན།",
  "trans-d_bo_728": "སློབ་གྲྭ་དེ་དུས་རབས་བཅུ་གཉིས་པའི་ནང་དུ་བསྐྱོད་པ་དང་། སློབ་གྲྭ་དེ་དུས་རབས་བཅུ་གཉིས་པའི་ནང་དུ་བསྐྱོད་པ་དང་། ས�",
  "trans-d_bo_34": "༡༠༠ ལྷག་གི་དུས་ཚོད་ལ་ཐོན་པ་ཡིན་ན།་ད་དུང་དུས་ཚོད་དེ་ལ་ཐོན་པ་ཡིན་ན།",
  "trans-d_bo_509": "སྐྱེ་དངོས་ཀྱི་རྒྱུ་སྤུས་དེ་དག་ལ་དོ་སྣང་བྱེད་དགོས་པ་དེ་དག་ལ་དོ་སྣང་བྱེད་དགོས་པ་དེ་དག་ལ་དོ་སྣང་བྱེད་དགོས་པ་ད�",
  "trans-d_bo_686": "དེ་བཞིན་དུ་ཁྱོད་ཀྱི་སྐད་ཆ་བཤད་ན་ཡང་།་ཁྱོད་ཀྱི་སྐད་ཆ་དེ་དག་ལ་བཤད་ན་ཡང་།",
  "trans-d_bo_326": "ང་སྤྱི་ཚོགས་ཀྱི་སྒོ་ཁར་བོད་སྐྱོར་བྱེད་པའི་སྐབས་སུ་སྤྱི་ཚོགས་ཀྱི་སྒོ་ཁར་བོད་སྐྱོར་བྱེད་པའི་སྐབས་སུ་",
  "trans-d_bo_596": "དེ་ལྟར་ང་ཚོས་བསྒྱུར་བ་ཡིན།",
  "trans-d_bo_217": "སྐྱེ་དངོས་ཀྱི་དབྱིབས་དང་དེ་བཞིན་དུ་སྐྱེ་དངོས་ཀྱི་དབྱིབས་དང་དེ་བཞིན་དུ་སྐྱེ་དངོས་ཀྱི་དབྱིབས་དང་དེ་བཞིན",
  "trans-d_bo_322": "༢༠༠༠ ལྷག་གི་རྒྱུ་ཆ་དེ་དག་ལ་བསྟན་ནས་བཤད་ན།་དེ་ནི་དུས་ཚོད་དང་མི་འདྲ་བ་ཞིག་ཡིན།",
  "trans-d_bo_384": "སྤྱི་ཟླ་བདུན་པའི་ཚེས་བཅུ་བདུན་ཉིན་གྱི་དུས་ཚོད་དང་སྐར་མ་བཅུ་གཉིས་སོང་བ་དང་།་དུས་ཚོད་དེ་དག་ལ་སྤྱི་ལེ་བཅུ་བདུན་ཡོ",
  "trans-d_bo_251": "དེ་ལྟར་བྱས་པ་ཡིན་ན་ང་ཚོས་བཤད་པ་ཡིན།་ང་ཚོས་དེ་ལྟར་བྱས་པ་ཡིན་ན་ང་ཚོས་བཤད་པ་ཡིན།",
  "trans-d_bo_306": "རྒྱ་ནག་གི་སྐད་ཆ་དེ་དག་ནི་དུས་ཚོད་དང་མི་འདྲ་བ་ཞིག་ཡིན་པ་དང་།་དུས་ཚོད་དེ་དག་ནི་དུས་ཚོད་དང་མི་འདྲ་བ་ཞིག་ཡིན་པ་དང་།་དུས་ཚ�",
  "trans-d_bo_551": "དེ་ལྟར་ང་ཚོ་དང་མཉམ་དུ་བྱེད་པའི་སྐབས་དེ་དུས་ང་ཚོ་དང་མཉམ་དུ་བྱེད་པའི་སྐབས་དེ་དུས་ང་ཚོ་དང་མཉམ་དུ་བྱེད་པའི་སྐབས་དེ་ད�",
  "trans-d_bo_618": "དེ་ལྟར་སློབ་གྲྭ་ནས་མི་འགོར་བ་དང་།་སློབ་གྲྭ་ནས་མི་འགོར་བ་དེ་ལྟར་སློབ་གྲྭ་ནས་མི་འགོར་བ་དང་།",
  "trans-d_bo_230": "ད་དུང་དགུན་དུས་ཨོ་རྩལ་འགྲན་ཚོགས་ལ་ཞུགས་པ་དང་།་དགུན་དུས་ཨོ་རྩལ་འགྲན་ཚོགས་ལ་ཞུགས་པ་དང་།་དགུན་དུས་ཨོ་རྩལ་འགྲན་ཚོགས་ལ་ཞ�",
  "trans-d_bo_652": "སྐྱོང་ཁང་དེ་ང་ལ་ཡོད་པ་དང་།་སྤྱི་ཁྱབ་ཁང་གི་སྐྱོང་ཁང་དེ་ང་ལ་ཡོད་པ་དང་།་སྤྱི་ཁྱབ་ཁང་གི་སྐྱོང་ཁང་དེ་ང་ལ་ཡོད་པ་དང་།",
  "trans-d_bo_701": "དེ་ཡང་ང་ཚོ་དངོས་གནས་སློབ་གསོ་བྱེད་པ་དང་།་དེ་ལྟར་བྱེད་པ་དེ་ཡང་ང་ཚོ་དངོས་གནས་སློབ་གསོ་བྱེད་པ་དང་།་དེ་ལྟར་བྱེད་པ་དེ་ཡང་",
  "trans-d_bo_304": "ང་ཚོས་ད་དུང་ཁྱོད་ཀྱིས་ང་ཚོ་ལ་བྱེད་པའི་བྱ་བ་དེ་དག་ལ་བསྟུན་ནས་དེ་ལྟར་བྱེད་དགོས་པ་དེ་བཤད་པ་ཡིན།",
  "trans-d_bo_755": "དེ་ལྟར་ང་ཚོ་དང་མཉམ་དུ་འབྲེལ་བ་བྱེད་བཞིན་ཡོད།",
  "trans-d_bo_35": "སྐར་མ་བཞི་བཅུ་ལྷག་ཙམ་ལ་སླེབས་པ་དང་།་ང་ཚོ་ད་དུང་དུས་ཚོད་བཞི་བཅུ་ལྷག་ཙམ་ལ་སླེབས་ཡོད།",
