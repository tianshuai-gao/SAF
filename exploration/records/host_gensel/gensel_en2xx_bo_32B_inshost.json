  "trans-d_bo_753": "ལོ་མ་བཞིན་དུ་འདི་འདྲ་བཟང་བ་མཐོང་ན།་ང་ཚོས་ད་དུང་གྲོས་བསྡུར་བྱེད་བཞིན་ཡོད།",
  "trans-d_bo_92": "དེ་ལྟར་རྒྱུན་དུ་རྒྱ་གར་གྱི་སྐད་དུ་བསྒྱུར་བ་ཡིན་ན་དེ་ལྟར་རྒྱུན་དུ་རྒྱ་གར་གྱི་སྐད་དུ་བསྒྱུར་བ་ཡིན་ན་",
  "trans-d_bo_54": "ད་ལྟ་ང་ལ་བོད་ལ་སློབ་གྲྭ་འགྲིམ་བཞིན་ཡོད་པ་དང་།་ང་ལ་སློབ་གྲྭ་འགྲིམ་བཞིན་ཡོད་པ་དེ་དག་གི་སློབ་གྲྭ་འགྲིམ་བཞིན་",
