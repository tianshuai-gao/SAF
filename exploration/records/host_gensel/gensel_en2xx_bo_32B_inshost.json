{
 "predictions": {
  "trans-d_bo_236": "དེ་ལྟར་ང་ཚོས་དུས་ཚོད་དང་མི་འདྲ་བ་ཞིག་བཟུང་ནས་བཟོ་བཞིན་ཡོད།",
  "trans-d_bo_52": "དེ་ལྟར་ཡིན་ན་ད་ལྟ་ང་ཚོ་དང་མཉམ་དུ་འགྲོ་བ་ཡིན་ནམ།",
  "trans-d_bo_454": "འདི་ནི་བསྒྱུར་བ་མེད་པ་དང་།་དེ་ནི་སྒོར་མོ་མེད་པ་དང་།་དེ་ནི་སྒོར་མོ་མེད་པ་དང་།་དེ་ནི་སྒོར་མོ་མེད་པ་དང་།་དེ་ནི་སྒོར་མ",
  "trans-d_bo_571": "རེད།་ང་ཚོ་ཐོག་མར་ཉིན་གཉིས་པ་དང་གསུམ་པ་བཟོ་བཅོས་བྱེད་དགོས་པ་དང་།་ཉིན་གཉིས་པ་དང་གསུམ་པ་བཟོ་བཅོས་བྱེད་དགོས་པ་དང་།་ཉིན་གཉ",
  "trans-d_bo_555": "དེ་ཡི་ཕྱིར་བསྡུས་པའི་གོ་སྐབས་དེ་ཡིན་ནམ།་དེ་ཡི་ཕྱིར་བསྡུས་པའི་གོ་སྐབས་དེ་ཡིན་ནམ།",
  "trans-d_bo_604": "སྒོ་ཕྱུགས་ལ་ཟས་སྐྱེ་བ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང་།་ཟ་མ་ཟས་པ་དང",
  "trans-d_bo_151": "དེ་ལ་དེ་འདྲ་བཟང་བ་མཐོང་ན།་ང་ཚོ་ད་དུང་སྒོར་མོ་གསོག་པ་དང་ལེན་པ་མིན།",
  "trans-d_bo_296": "འོ་ན་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།",
  "trans-d_bo_530": "སྐབས་དེ་དུས་ང་ཚོས་དེ་ལྟར་བྱེད་དགོས་པ་དང་།་དེ་ལྟར་བྱེད་དགོས་པ་དེ་དག་ལ་བརྟེན་ནས་བྱེད་དགོས་པ་དེ་དག་ལ་བརྟེན་ནས་བྱེད་དག",
  "trans-d_bo_316": "དེ་ལྟར་སློབ་གསོ་མི་བྱེད་པ་དང་།་ང་ཚོ་སློབ་གྲྭ་ཆེན་མོ་དེ་དག་ལ་འགྲོ་བ་མི་བྱེད་པ་དང་།་ང་ཚོ་སློབ་གྲྭ་ཆེན་མོ་དེ་དག",
  "trans-d_bo_762": "དེ་བཞིན་དུ་ང་ལ་དངོས་སྤྱོད་བྱེད་བཞིན་ཡོད་དམ།",
  "trans-d_bo_200": "སྐྱེས་པ་དེ་དག་གི་སྐྱེས་མ་དེ་དག་གི་སྐྱེས་མ་དེ་དག་གི་སྐྱེས་མ་དེ་དག་གི་སྐྱེས་མ་དེ་དག་གི་སྐྱེས་མ་དེ་དག་གི་སྐ",
  "trans-d_bo_469": "འདི་ནི་ང་ཚོ་དང་མཉམ་དུ་བྱེད་དགོས་པ་ཡིན་ནམ།",
  "trans-d_bo_661": "རེད།་ཡོད་པ་རེད།",
  "trans-d_bo_147": "དེ་ལྟར་བྱུང་ན་ད་དུང་དེ་ལྟར་བྱུང་ན་དེ་ལྟར་བྱུང་ན་དེ་ལྟར་བྱུང་ན་དེ་ལྟར་བྱུང་ན་དེ་ལྟར་བྱུང་ན་དེ་ལྟར་བྱུང་ན་ད",
  "trans-d_bo_56": "༡༢ ལོ་ནས་བཟུང་ང་ལ་སློབ་གྲྭ་འདི་དང་པོ་བྱུང་བ་ཡིན་ནམ།",
  "trans-d_bo_543": "དེ་བཞིན་ང་ཚོ་དང་མཉམ་དུ་བོད་ཀྱི་སྐད་ཡིག་སློབ་ཁྲིད་བྱེད་པའི་སློབ་མ་ཞིག་ཡིན་པས་ང་ཚོ་དང་མཉམ་དུ་བོད་ཀྱི་སྐད་ཡིག་ས�",
  "trans-d_bo_57": "ང་དེ་ལྟར་བྱེད་པ་དང་དེ་ལྟར་བྱེད་པ་མིན་ནམ།",
  "trans-d_bo_401": "འདི་ནི་ང་ལ་བྱེད་ཐབས་བཟང་པོ་ཞིག་ཡིན་པས་ང་ལ་བྱེད་ཐབས་བཟང་པོ་ཞིག་བྱེད་དགོས་པ་ཡིན།",
  "trans-d_bo_471": "དེ་བས་ང་ཚོ་སླར་ཡང་སློབ་གྲྭ་ནས་བསྡད་པ་ཡིན།",
  "trans-d_bo_309": "མིན་ན་དེ་ལྟར་བྱེད་དགོས་པ་མེད།་དེ་ལྟར་བྱེད་དགོས་པ་མེད།",
  "trans-d_bo_728": "སློབ་ཁང་དུ་འདུག་པ་དེ་དགོན་པའི་གྲྭ་བ་དག་གི་སློབ་ཁང་དུ་འདུག་པ་དེ་དགོན་པའི་གྲྭ་བ་དག་གི་སློབ་ཁང་དུ་འདུག་པ་དེ་དགོན་པའི་",
  "trans-d_bo_34": "༡༢༠ ལོ་ནས་བཟུང་ང་ཚོ་དང་མཉམ་དུ་རྒྱལ་ཁབ་ཀྱི་སྐྱེ་ཁམས་དཔལ་ཡོན་འཛུགས་སྐྲུན་ལ་ཞུགས་པ་དང་། དེ་ནས་བཟུང་ང་ཚོ་དང་མཉམ་དུ་ར",
  "trans-d_bo_509": "སྐྱེ་བ་སྔོན་མ་དེ་འདྲ་བཟང་བ་མཐོང་ན།་ང་ཚོ་སྐྱེ་བ་སྔོན་མ་དེ་འདྲ་བཟང་བ་མཐོང་ན།་ང་ཚོ་སྐྱེ་བ་སྔོན་མ་དེ་འདྲ་བཟང་བ",
  "trans-d_bo_686": "དེ་བཞིན་དུ་བོད་ཡིག་གི་དུས་དེབ་དང་དུས་ཚིགས་ཀྱི་དུས་དེབ་བཅས་ལ་བརྡ་བརྒྱབ་ནས་བོད་ཡིག་གི་དུས་དེབ་དང་དུས་ཚིགས་ཀྱི་དུས་དེ",
  "trans-d_bo_326": "ང་ལ་སྒོ་ཁྱིམ་དུ་བསྡད་དེ་སྒོ་ཁྱིམ་དུ་འགྲོ་བ་ཡིན།་ང་ཚོ་སྒོ་ཁྱིམ་དུ་འགྲོ་བ་ཡིན་པས།་ང་ཚོ་སྒོ་ཁྱིམ་དུ་འགྲོ་བ་",
  "trans-d_bo_596": "འདི་ལ་བརྟེན་ནས་མི་འདུག་གོ།",
  "trans-d_bo_217": "སྐྱེ་བོ་དག་ལ་དུས་ཚོད་དང་མཐུན་པའི་སྐྱེ་བོ་དག་གི་སྐྱེ་བོ་དག་ལ་དུས་ཚོད་དང་མཐུན་པའི་སྐྱེ་བོ་དག་གི་སྐྱེ་བོ་དག་ལ",
  "trans-d_bo_322": "༡༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠༠",
  "trans-d_bo_384": "སྤྱི་ཟླ་དང་པོའི་ཚེས་བཅུ་བཞི་ཉིན་གྱི་དུས་ཚོད་དང་སྐར་མ་བཅོ་བརྒྱད་པ་དང་། སྐར་མ་བཅོ་བརྒྱད་པ་དང་སྐར་མ་བཅོ་བརྒྱ",
  "trans-d_bo_251": "དེ་ལྟར་བྱུང་བ་ཡིན་ན་ང་ཚོ་བཟོ་བཀོད་བྱེད་པ་དང་།་ང་ཚོ་བཟོ་བཀོད་བྱེད་པ་དེ་ལྟར་བྱུང་བ་ཡིན་ན་ང་ཚོ་བཟོ་བཀོད་བྱེད་པ་དང་།",
  "trans-d_bo_306": "ཀྲུང་གོ་ནི་དུས་རབས་བཅུ་བཞི་བའི་དུས་དཀྱིལ་དུ་བོད་ཀྱི་སྐད་ཡིག་སློབ་སྦྱོང་བྱེད་པའི་དུས་རབས་ཤིག་ཡིན་པ་དང་། དུས་ར",
  "trans-d_bo_551": "དེ་ལྟར་ང་ཚོས་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།",
  "trans-d_bo_618": "དེ་ལྟར་སློབ་ཁང་ནང་མི་འགྲོ་བ་ཡིན་ན་དེ་ལྟར་སློབ་ཁང་ནང་མི་འགྲོ་བ་ཡིན་ན་དེ་ལྟར་སློབ་ཁང་ནང་མི་འགྲོ་བ་ཡིན་ན་དེ་ལྟར་ས�",
  "trans-d_bo_230": "ད་དུང་ཕྱི་ལོ་ཟླ་བ་གསུམ་པ་ལ་སློབ་གྲྭ་འདི་ལ་བསྐྱོད་དེ་ལྷ་ས་ནས་ཟ་མ་ཟས་པ་དང་།",
  "trans-d_bo_652": "དེ་ནས་བཟུང་ང་ཚོ་དེ་རུ་འགྲོ་བ་ཡིན།་དེ་ནས་བཟུང་ང་ཚོ་དེ་རུ་འགྲོ་བ་ཡིན།",
  "trans-d_bo_701": "དེ་ལྟར་ཡིན།་ང་ཚོ་དེ་ལྟར་བྱེད་པ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་ཡིན།",
  "trans-d_bo_304": "ང་ཚོ་ད་དུང་ཁྱོད་ཀྱི་བྱ་བ་བཟང་བོ་བསྒྲུབ་པའི་དོན་དག་གི་སྐོར་ལ་བཤད་དུས་ཁྱོད་ཀྱི་བྱ་བ་བཟང་བོ་བསྒྲུབ་པའི་དོན་དག",
  "trans-d_bo_755": "དེ་ལྟར་བྱེད་པ་དེ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་དེ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་དེ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་དེ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་དེ་",
