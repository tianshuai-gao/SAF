{
 "predictions": {
  "trans-d_bo_236": "བྱས་པ་དག་མི་བྱས་པ་ཡིན་པ་ཟས་པ་ལེགས་མི་ཟས་པ་ཡོད་པར་ཤེས་པ་ཡང་དག་མི་ཡང་དག་པ་ཞེས་བསྒྱུར་ན་དེ་ལྟར་བསྒྱུར་བ་དག་མི་དག་བྱེད་",
  "trans-d_bo_52": "བཞིན་ཏུ་འགྲོ་བ་རེད་པ་མི་རེད།",
  "trans-d_bo_454": "གསལ་བྱེད་ཀྱི་དུས་མ་རེད། ནང་དུའང་དུས་ཀྱི་ཕུག་ལས་བྱེད་པ་ལ་བཟོ་བ་ཡོད་པས་བྲི་བར་དམག་གི་བྲི་བར་ཡིན་པ་དང་པོ་ཡོད།",
  "trans-d_bo_571": "རེད།་ཇིུ་ཐེན་ཟི་ཆུ་གཅིག་བསྒྱུར་བྱས་པས་གཉིས་ཀ་ལ་བཏུབ་པ་དང་གཤམ་གྱི་བར་ཁོ་བཞི་བུ་མཉེ་ཉི་ལྷག་པའི་ཕྱོགས་བརྗེ་བ་བར",
  "trans-d_bo_555": "ཁོ་བཟུང་བཤད་ཀྱི་ཆ་རྩེ་དེ་མིན་དགོས་པ་ཡིན། ཁོ་བཟུང་བཤད་ཁོ་ལ་བརྗེད་དགོས་པ་ཡིན་པས། ཁོ་ལ་བརྒྱུད་བཟུང་བཤད་བརྡ་དགོས་པ",
  "trans-d_bo_604": "སྦྱི་བོ་ཞུ་རྒྱུ་ཞུགས་པ་ལ་བྱེད་པ་ནི་བདེ་བ་ལྡན་པ་བྱེད་པ་རེད།",
  "trans-d_bo_151": "དེ་བཞིན་དམིགས་རིམ་དུ་གསུམ་པ་ཕུད་པ་ལ་ཕུད་གཟིག་བྱེད་པ་མི་ཤེས་པ་ཡིན་པས་ཕུད་གཟིག་བྱེད་པ་མི་ཤེས་པ་ཡིན།",
  "trans-d_bo_296": "སྣོད་དུ་ཞེས་པ་དང་། སྒོ་མཚམས་གཉིས་པ་ལ་བྱུང་བ་ཡོད་པ་དང་། སྒྲིབ་པ་ཊི་བཞི་བཅུ་བྱས་བྱེད།",
  "trans-d_bo_530": "དེ་པའི་བློ་གྲོས་ད་དུང་བཟོ་བཅས་བཟོ་བཞིན་ཡོད་དགོས་པ་དང་། དེ་ལ་ཕྱིར་བློ་གྲོས་བརྟག་ཏུ་བྱེད་པ་ལྟ་བུ་བྱེད་དགོས།",
  "trans-d_bo_316": "ཁྱོད་མི་བརྡ་སྡེ་དངོས་པ་མེད་པ་དང་། ལྡེའུ་བུས་ཀྱི་བཟོ་བརྡ་སྡེ་བྱེད་པ་ལ་འཇུག་བྱེད་དགོས་པ་ཡིན།",
  "trans-d_bo_762": "རང་སྐོར་བཤད་ཀྱི་ཐབས་ཀྱི་དཔེ་གཞི་བཤེས་བྱེད་དགོས་པ་ལ་ང་ནི་བཤེས་བྱེད་བྱེད་པ་ཡིན།",
  "trans-d_bo_200": "ཀྱེད་དགོས་པ་ཞེས་བྱ་བ་དགོས་པོ་ནས་དེ་བཞིན་དུ་བཞིན་གཞི་དེ་ལ་གཞི་བཟོ་བྱེད་མི་ཤེས།",
  "trans-d_bo_469": "སློབ་ལྡན་ཡིན་པ་དེ་ནི་ང་ལ་བཀག་དགོས་པའི་སྒོར་མོ་བཟུང་བཞིན་བསྡུས་པ་དེ་ལ་གསོག་བྱེད་བྱེད་དགོས་པ་ཡིན་པ་མ་ཡིན་པ།",
  "trans-d_bo_661": "རེད། ཡོད།",
  "trans-d_bo_147": "སྒོ་བཞིན་གཤམ་གསལ་པ་ཡིན་པ་མ་རེད།",
  "trans-d_bo_56": "༨ ཁེ་ཟེར་བ་དེ་དྲུག་དུ་ཁམས་ལ་བྱེད་པ་སྔོན་དུ་བཞིན་ཡོད་པ་སང་ཞེས་བཤད་དོ།",
  "trans-d_bo_543": "དགའ་བདེ་བ་ཞུ།་བཤད་པ་བྱས་པས་ཝཱ་དི་འགྲེལ་བཞིན་ཡོད་དོ།་རང་གི་འབྲུ་གཞི་གཞན་ཡིན་པ་རགས་གཞན་ཡིན་དམ།",
  "trans-d_bo_57": "ལས་ཀྱི་དོན་ལ་བཟོ་བ་མི་ཟེར་བ་མིན། དེ་དུས་བཟོ་བ་མི་ཟེར་བ་མིན།",
  "trans-d_bo_401": "སློབ་ལྡན་གྱིས་བྱེད་དགོས།་བོས་ང་ལ་བཟོ་བཟང་པོ་བྱེད་དགོས།་ང་ནི་དེ་བཞིན་གཞི་རེད།",
  "trans-d_bo_471": "སློབ་ལྡན་འདི་ལ་མི་རེད། གཤམ་གྱི་བཞིན་བྱེད་དུ་མོ་རེད།",
  "trans-d_bo_309": "མི་ཐུབ།་ཉིན་མོར་བློ་བསྟན་གྱི་བཞིན་ཁོ་བོ་འཁྲུལ་བསྟེན་ལ་འགྲོ་བ་ཡོད་པས་ང་ནི་ཐོག་ཡིན་མེད།",
  "trans-d_bo_728": "བུས་ཀྱི་ཁང་གི་དགོས་པ་ལ་ཐེངས་མཁན་ཁང་གི་འདྲ་བ་ཡོད།",
  "trans-d_bo_34": "༨ཊང་ཤ་དུ་བཟོ་བ་རེད་པའི་ཉིན་ཐོ་བརྡ་རེད།",
  "trans-d_bo_509": "ཀྱི་ལུས་སྐྱེད་མེད་པ་དང་། སྤྱི་བཙུན་ལྟ་བུ་བཟོ་བསྒྱུར་བ་ཡིན།",
  "trans-d_bo_686": "ཁེང་བཤད་བྱེད་དགོས་པ་ནི་བཤད་རིགས་གཞི་གཞི་བཤད་བྱེད་ཡོད་པ་རེད།",
  "trans-d_bo_326": "ཁྱེད་ཀྱི་བྲག་ལ་བུམ་པ་དང་བུམ་བཅུད་བཟོ་བྱེད་པ་ཡིན། ཁྱེད་ལ་དོག་མ་རེད།",
  "trans-d_bo_596": "ཁོང་ལྷོ་བཏོན་བྱས་པས་དེ་དག་ཡོད་མི་བཟོད།",
  "trans-d_bo_217": "མཐུན་པ་བཟང་པའི་བཟང་པོ་བཞིན་རྒྱག་དགོས།",
  "trans-d_bo_322": "༨། དེ་ན་མིན་དོན་ཁང་དུ་འགྲོ་བའི་བསྒྱུར་བ་སྤྱི་བཞིན་ཡོད་པ་སколь ཡོད།",
  "trans-d_bo_384": "སྤེན་པ་བཞིན་ཞེས་པའི་ཉིན་དེ་ཁོ་ལ་དུས་མེད་པ་ཡིན་པས་མི་དམིགས་པར་ལིས་བསྒྲིག་དགོས་པ་ཤེས་པ་ཡིན།",
  "trans-d_bo_251": "སྐུལ་པ་ལ་བརྟེན་པ་ཡིན་པ་མ་ཡུས་པ་བཟོད་པ་ཡིན་། ཁོང་ལ་བསྒྱུར་བ་ལ་བརྟེན་པ་བཟོད་པ་ཡིན། སྐྱེད་ཀྱི་བརྗེད་དཀའ་བ་མ་ཡུས་པ་",
  "trans-d_bo_306": "ཀྲི་བུ་དུས་ཆེན་ལ་བོད་ཀྱི་མི་རིགས་ཀྱི་བློ་གྲོས་མེད་དུ་ཡོད་དང་ཉེས་ལིང་མེད་པ་དེ་ལ་བཟོ་བཞིན་ཡོད།",
  "trans-d_bo_551": "མཉམ་དགའ་མེད་པའི་བཟོ་བོ་ཉིད་ཀྱིས་བྱུང་བ་མེད་པ་རེད། ཁེ་ཕྱེད་བྱ་བ་གང་ཤིག་གི་རྟགས་གཞི་ག་དུ་ཡོད་པ་རེད། ཁེ་ཕྱེད་བྱ",
  "trans-d_bo_618": "མིང་དུང་བརྡ་ཚང་མ་ཡོད་མིན་ན་གསུམ་བུ་བརྗོད་པ་ཕུད་གཞན་གྱུར་པ་ཕུད་གཞན་གྱུར་པ་ཕུད་གཞན་ཡིན་པ་ག་དུ་གསུམ་བུ་བརྗོད་པ་གྱུར་པ་",
  "trans-d_bo_230": "བོད་པ་ཁྱོད་ལ་ཞུ་ཁང་ལ་འགྲོ་བྱུང་བ་དང་བཟོ་མཐོང་བ་ཡིན་ནོ།།",
  "trans-d_bo_652": "དེ་པའི་ཁང་པ་དེ་ཁོ་བོ་ཡིན།་བཟོ་བྱེད་ཁང་པ་ལ་བཞིན་གཞིས་ཡོང་བ་དང་།་འཚོ་བའི་ཁང་པ་ལ་བཞིན་གཟུགས་ཡོང་བ།",
  "trans-d_bo_701": "ང་དེ་ལྟར་བརྡ་སྦྱོར་བ་བསྟན་པ་ལ་དགའ་བསུ་ཡོད། ཁེང་དུས་མཚོན་པ་གང་ཡིན་པས།",
  "trans-d_bo_304": "ཁེམས་པ་ལ་ང་ཚོའི་བཀྲ་བ་བཤད་ནས་མ་སྐྱེད་གྱུར་བ་སོ་སོ་བསྒྱུར་བཞིན་ཡོད།",
  "trans-d_bo_755": "ཁྱོད་ཀྱི་བརྡ་སྤྲོད་བཞིན་ནུས་པ་བཟང་པོ་ཡོད།",
  "trans-d_bo_35": "དེ་འགོ་ཁམས་བཞིན་འདི་འདྲ་བརྗོད་བྱེད་ཀྱི་ཡོད། དེ་འགོ་བརྒྱུད་བཞིན་འདི་འདྲ་བྱུང་བ་དུས་རྒྱུན་བྱེད་ཀྱི་ཡོད།",
  "trans-d_bo_753": "རེའུ་ཧྲུའུ། ཁྱོད་བདེ་བར་བྱེད་པ་བཟང་བ་མཐོང་ན། ཡིན་གཤམ་བཞིན་ཡོད།",
  "trans-d_bo_92": "རེད་གྷོང་གི་འགྲེལ་པོ་བཞིན་ནི་བཟོས་པ་ཡོད་པ་མ་རེད།",
  "trans-d_bo_54": "ཁེབས་བསྒྱུར་བ་འདི་ཕྱིར་གཞི་བཟོ་བཞིན་ཁྱོད་དམིགས་ཡོད་པ་རེད་པ་རགས་བཤད་དུ་སྐྱོན་ན་ཁྱོད་ཕྱིར་བ་སྐྱེད་བཞིན་ཡོད།",
  "trans-d_bo_361": "སྤྱིད་དུ་བརྩོད་པ་མི་བྱེད་དོ་ཞེས་བསྒྱུར་ན་གཤམ་གསལ་བྱུང་བ་ཞིག་བྱུང་བ་འགྲོ་བྱེད་དོ།",
  "trans-d_bo_89": "སྤུས་པ་བཞིན་དགོས་པ་དགོས་པ་ལ་བྱེད་པ་དགོས་པ་ལ་བྱེད་པ་དགོས་པ་ལ་བྱེད་པ་དགོས་པ་ལ་བྱེད་པ་དགོས་པ་ལ་བྱེད་པ་དགོས་པ་ལ་བྱེད་པ་དག�",
  "trans-d_bo_303": "༡༢ གཟའ་བཟང་བོད་ལ་འགྲོ་བ་དང་། རྒྱུན་དུ་ཉིན་ཟླ་བཟང་བོད་ལ་འགྲོ་བ་མི་ཐུབ། རྒྱུན་དུ་ཆོས་གྲུབ་ལ་འགྲོ་བ་དགོས་པ་དང",
  "trans-d_bo_733": "རེད།་བོན་བཟང་པོ་བཟང་མོ་ཐམས་ཅད་བར་ཁོང་ལ་འགྲོ་འདོད་པ་ཡོད།",
  "trans-d_bo_514": "སྐྱེ་དྲུག་པ་ནི་དགོས་བཅུ་གཉིས་ཀྱི་བཅུ་བཞི་ཡིན་པ་ཡིན་པས།",
  "trans-d_bo_219": "གཤམ་གསལ་བྱུང་བ་དེ་དག་ལ་མཐུན་པ་ཡིན་པ་དང་། ལྡན་སྐབས་བཟུང་བཞིན་ཆུས་པ་བཟུང་བཞིན་ཡོད།",
  "trans-d_bo_205": "སློབ་ལྡན་གྱིས་ཆ་བཟུང་།་ཆ་ཐོ་བཟུང་དང་བསྡུས་པ་བཟུང་།",
  "trans-d_bo_641": "ལྷོང་དང་འཆམ་པ་ཡིན་དག་ནི་ཡོད་དགོས། སྤྱི་མཐུན་ཐེ་མེད་ཡིན་དག་ནི་ཡོད། བོད་ལུགས་ཀྱི་ཐེ་མེད་ཡིན་དག་ནི་ཡོད།",
  "trans-d_bo_2": "འདི་བཞིན་ན་དེ་དག་ལ་བརྒྱུད་བྱེད་པ་མེད་པ་ལྟ་བུ་ཡོད། དེ་དག་ནི་བཟོ་བཟང་པོ་ཡོད།",
  "trans-d_bo_744": "སྒོ་བརྒྱུད་བྱ་ནས་བཞིགས་ལྡོག་གི་འགྲོ་སྤོད་དང་པོ་ལ་བཞིགས་ལྡོག་བྱ་དགོས་པ་ལ་བཞིགས་ལྡོག་བྱ།།",
  "trans-d_bo_233": "ཁྱེད་ཟང་དོང་།་དེ་དག་དུ་སྒྲིག་བྱེད་དགོས་པ་ཡིན་པས་མི་རེད།་ང་ལ་ཁྱེད་དང་བསྒྲིག་བྱེད་འདོད་པ་ཡིན།",
  "trans-d_bo_96": "ཁྱོད་ཝ་ང་དབྱངས་དེ་དག་བརྗོད་མེད་པ་ལོ་རྒྱུས་མེད་པ་ཡིན་ནོ། ཁྱོད་ལ་རྒྱུ་ཆེས་པ་ཡོད་པ་ཡིན་ནོ།"
