{
 "predictions": {
  "trans-d_bo_236": "དེ་ལ་དོན་དག་མེད་པ་དང་།་དེ་ལ་དོན་དག་མེད་པ་དང་།",
  "trans-d_bo_52": "ད་དུང་ང་ཚོ་དང་མཉམ་དུ་འགྲོ་འདོད་ཡོད་དམ།",
  "trans-d_bo_454": "འདི་ནི་དོན་དངོས་ཤེས་རྟོགས་བྱེད་པ་ཞིག་ཡིན་པ་དང་།་དེ་ནི་ང་ཚོ་དངོས་གནས་སྤྱོད་པ་ཞིག་ཡིན་པ་དང་།",
  "trans-d_bo_571": "རེད།་ང་ཚོ་ཟ་མ་ཟས་ཡོད་དམ།་ཟ་མ་ཟས་ཡོད་དམ།་ཟ་མ་ཟས་ཡོད་དམ།་ཟ་མ་ཟས་ཡོད་དམ།",
  "trans-d_bo_555": "དེ་ལྟར་བསྒྲུབ་པ་ཡིན་ན་དེ་ལ་དུས་ཚོད་བཟོ་བཞིན་ཡོད་དམ།་དེ་ལ་དུས་ཚོད་བཟོ་བཞིན་ཡོད་དམ།",
  "trans-d_bo_604": "སྒོ་ཕྱུགས་ལ་ཤུགས་རྐྱེན་བཟོ་བའི་རྒྱུ་རྐྱེན་གཞན་རེད།",
  "trans-d_bo_151": "དེ་ལ་ང་ཚོ་དང་མཉམ་དུ་སྐྱོན་བརྗོད་བྱེད་དགོས་པ་དང་།་ང་ཚོ་དང་མཉམ་དུ་སྐྱོན་བརྗོད་བྱེད་དགོས་པ་དེ་དག་ལ་དོ་སྣང་བྱེད་དག",
  "trans-d_bo_296": "འོ་ན་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།་དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ནམ།",
  "trans-d_bo_530": "སྐབས་དེ་དུས་ང་ཚོ་དང་མཉམ་དུ་བསྒྲུབ་པ་དེ་དག་ལ་བསྟུན་ནས་དེ་ལ་བསྟུན་ནས་དེ་ལ་བསྟུན་ནས་དེ་ལ་བསྟུན་ནས་དེ་ལ་བསྟུན་ནས་དེ་ལ་བ",
  "trans-d_bo_316": "དེ་ལ་ང་ཚོ་མི་འགྲོ་བ་དང་།་དེ་ལ་ང་ཚོ་མི་འགྲོ་བ་དང་།་དེ་ལ་ང་ཚོ་མི་འགྲོ་བ་དང་།",
  "trans-d_bo_762": "སྤྱི་བདེ་ལས་ཁུངས་ཀྱི་འགྲོ་སྐྱོད་ལས་ཁུངས་ལ་བསྐྱོད་དེ་སྤྱི་བདེ་ལས་ཁུངས་ཀྱི་འགྲོ་སྐྱོད་ལས་ཁུངས་ལ་བསྐྱོ",
  "trans-d_bo_200": "སྤྱི་ཚོགས་ཀྱི་དུས་རབས་དང་པོ་ཡིན་པ་དང་།་ང་ཚོ་དུས་རབས་གཉིས་པ་ཡིན་པ་དང་།་ང་ཚོ་དུས་རབས་གསུམ་པ་ཡིན་པ་དང་།་ང་ཚོ་དུས་རབས་བཞི་པ་ཡི",
  "trans-d_bo_469": "འདི་ནི་ང་ཚོ་དང་མཉམ་དུ་སྒོར་མོ་གསོག་པ་དང་ལེན་པ་ཡིན་པ་དེ་ཡིན་ནམ།",
  "trans-d_bo_661": "རེད།་ཡིན།",
  "trans-d_bo_147": "དེ་ལ་ད་དུང་དུས་ཚོད་དེ་ལ་ཐོག་མར་སློབ་གྲྭ་དེ་ལ་ཐོག་མར་སློབ་གྲྭ་དེ་ལ་ཐོག་མར་སློབ་གྲྭ་དེ་ལ་ཐོག་མར་སློབ་གྲྭ་ད",
  "trans-d_bo_56": "༡༢ ལོ་ནས་བཟུང་ང་ཚོ་དུས་རབས་གསར་པའི་དུས་འགོའི་ལས་དོན་ལ་བསྒྱུར་བ་དང་།་དུས་རབས་གསར་པའི་དུས་འགོའི་ལས་དོན་ལ་བསྒྱུར་བ་དེ་དག་ག�",
  "trans-d_bo_543": "ལྷ་ས་ནས་བོད་ལྗོངས་ལ་འགྲོ་འདོད་ཡོད་པ་དང་།་ལྷ་ས་ནས་བོད་ལྗོངས་ལ་འགྲོ་འདོད་ཡོད་པ་དང་།་ལྷ་ས་ནས་བོད་ལྗོངས་ལ་འགྲོ་འདོད་ཡོད",
  "trans-d_bo_57": "ང་ཚོ་དེ་ལ་བྱེད་པ་དང་དེ་ལ་བྱེད་པ་མིན་ནམ།",
  "trans-d_bo_401": "འདི་ནི་ང་ཚོ་བོད་ལ་ཡོང་བ་ཡིན་པ་དང་།་ང་ཚོ་བོད་ལ་ཡོང་བ་ཡིན་པ་དེ་དག་ལ་བོད་ལ་ཡོང་བ་ཡིན་པ་དེ་དག་ལ་བོད་ལ་ཡོང་བ་ཡིན་པ་དེ་དག་ལ་བོད་ལ་ཡོང",
  "trans-d_bo_471": "འདི་ནི་ང་ཚོ་བོད་ལ་ཡོང་བ་ཡིན་པ་དང་།་ང་ཚོ་བོད་ལ་ཡོང་བ་ཡིན་པ་དེ་དག་ལ་དོ་སྣང་བྱེད་དགོས།",
  "trans-d_bo_309": "མིན་ན་དེ་ལ་ཐོག་མར་གཞུང་ལས་ཁང་གི་ལས་བཟོ་བ་ཞིག་གི་ཐོག་མར་ལས་ཀ་བྱེད་དུ་འགྲོ་བ་ཡིན།",
  "trans-d_bo_728": "སློབ་ཁང་དུ་འབྱོར་བ་དེ་དུས་ཚོད་དུ་བཟུང་བ་ཡིན།",
  "trans-d_bo_34": "༢༠༡༦ལོའི་ཟླ་བ་༡༢པའི་ཚེས་༡༠ཉིན་ལ་རྒྱལ་ཁབ་ཀྱི་སྐྱེ་ཁམས་དཔལ་ཡོན་གྱི་དཔེ་སྟོན་ཁུལ་འཛུགས་སྐྲུན་བྱེད་པའི་ཐ�",
  "trans-d_bo_509": "སྐབས་དེ་དུས་ང་ཚོ་ལ་ཤིང་འབྲས་བཟང་བོ་ཞིག་བཟོས་པ་དེ་དུས་ང་ཚོ་ལ་ཤིང་འབྲས་བཟང་བོ་ཞིག་བཟོས་པ་དེ་དུས་ང་ཚོ་ལ་ཤིང་འབྲས་བཟ",
  "trans-d_bo_686": "འདི་ལ་བོད་ཡིག་གི་རྩོམ་ཡིག་གི་དོན་དངོས་དང་མི་འདྲ་བ་ཡོད་པ་ཤེས་དགོས་པ་ཡིན།",
  "trans-d_bo_326": "སྤྱི་ལོ་༢༠༡༨ལོའི་ཟླ་བ་༡༢པའི་ཚེས་༡༠ཉིན་ང་ཚོ་བོད་ལྗོངས་སྤྱི་བདེ་ལས་ཁུངས་ཀྱི་སྤྱི་ཁྱབ་རྩོམ་སྒྲིག་པ",
  "trans-d_bo_596": "འདི་ལ་བསྟུན་ནས་མི་ཤེས་པ་རེད།",
  "trans-d_bo_217": "སྐྱེ་བ་སྔ་མ་དང་དུས་ཚོད་དུ་བྱེད་པའི་སྐྱེ་བ་སྔ་མ་དང་དུས་ཚོད་དུ་བྱེད་པའི་སྐྱེ་བ་སྔ་མ་དང་དུས་ཚོད་དུ་བྱེད་པའི་ས",
  "trans-d_bo_322": "༢༠༠༠ ལྷག་གི་ཐོག་མའི་རྒྱུ་མཚན་དེ་ཡིན་ནམ།",
  "trans-d_bo_384": "སྤྱི་ཟླ་དང་པོའི་ཚེས་བཅུ་བཞི་ཉིན་གྱི་དུས་ཚོད་དང་སྐར་མ་བཅུ་གཅིག་ཡིན་པ་དང་།་དེ་ནི་དུས་ཚོད་དང་སྐར་མ་བཅུ་གཅིག་ཡིན་པ་དང",
  "trans-d_bo_251": "དེ་ལྟར་བྱེད་པ་ཡིན་ན་ང་ཚོ་དུས་རྒྱུན་དུ་བཟུང་བ་ཡིན་ན།་ང་ཚོ་དུས་རྒྱུན་དུ་བཟུང་བ་ཡིན་ན་དེ་ལྟར་བྱེད་པ་ཡིན་ན།",
  "trans-d_bo_306": "རྒྱ་གར་གྱི་སྲིད་འཛིན་ཞིག་ཡིན་པ་དང་།་ལོ་གསར་མ་ཞིག་ཡིན་པ་དང་།་དེ་ནི་ཐོག་མར་བོད་ཀྱི་ལོ་གསར་ཞིག་ཡིན་པ་དང་།་དེ་ནི་ཐོག་མ",
  "trans-d_bo_551": "ད་དུང་ང་ཚོ་ད་དུང་ཁྱོད་ལ་མི་འདུག་པ་དང་།་ང་ཚོ་ད་དུང་ཁྱོད་ལ་མི་འདུག་པ་དང་།",
  "trans-d_bo_618": "སློབ་གྲྭ་དེ་དག་གི་སློབ་མ་དེ་དག་ལ་སློབ་གྲྭ་དེ་དག་གི་སློབ་མ་དེ་དག་ལ་སློབ་གྲྭ་དེ་དག་གི་སློབ་མ་དེ་དག་ལ་སློབ་ག�",
  "trans-d_bo_230": "དཔོན་གྱིས་ང་ལ་ཤིང་རྟ་བཟོ་བཞིན་ཡོད་པ་དང་།་དེ་ནི་ད་དུང་གཞན་རེད།",
  "trans-d_bo_652": "སྒྲོལ་མ་དང་དགོང་མོ་དེ་དག་ལ་བསྡུས་པ་ཡིན།་དེ་དག་ལ་བསྡུས་པ་ཡིན།",
  "trans-d_bo_701": "དེ་ལྟར་བྱེད་དགོས་པ་ཡིན་ན།་ང་ཚོས་ད་དུང་གྲོས་བསྡུར་བྱེད་བཞིན་ཡོད།",
  "trans-d_bo_304": "འདི་ནི་ང་ཚོས་ད་དུང་གྲོས་བསྡུར་བྱེད་བཞིན་ཡོད་པ་དེ་ཡིན་ནམ།",
  "trans-d_bo_755": "དགེ་རྒན་གྱི་སློབ་ཁྲིད་དེ་དག་ལ་བརྟེན་ནས་ང་ཚོ་དང་མཉམ་དུ་སློབ་ཁྲིད་བྱེད་བཞིན་ཡོད།",
