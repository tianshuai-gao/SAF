{
 "predictions": {
  "trans-d_bo_236": "རྒྱུ་མཚན་ལ་དུས་མེད་པའི་ཆོས་གཟུགས་ཤིང་བཟོས་བཞིན་ཡོད་པ་ནི་དུས་མེད་པའི་ཆོས་གཟུགས་ཤིང་བཟོས་བཞིན་ཡོད་པ་ནི་དུས་མེད་པའི",
  "trans-d_bo_52": "འདི་ལ་བཟོ་བྱེད་རེད།",
  "trans-d_bo_454": "བྱེད་དུ་གསུང་བ་ནི་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་དུ་མེད་པ་ནི་",
  "trans-d_bo_571": "རེད།་བཅུ་ཟེར་བཟུང་བཟོ་བརྗོད་གཅིག་གཅིག་ལ་གྲོལ་བ་བཅུ་ཟེར་ལ་བཟུང་བཟོ་བརྗོད་གཅིག་གཅིག་ལ་བཟུང་བཟོ་བརྗོད་ལྟར་བཟུང་བ",
  "trans-d_bo_555": "སྤྱོད་རྒྱུ་དང་།་དེ་དུ་ང་ཚོ་བཟོ་རྒྱུ་ནི་རྒྱུ་ནི་དུས་རྒྱུ་ནི་ལུས་རྒྱུ་ནི་ལོ་རྒྱུ་ནི་འདི་རེད།",
  "trans-d_bo_604": "འདོད་ཆོ་ལུགས་ལ་བཟུང་བ་རེད།",
  "trans-d_bo_151": "ཅིའི་ལས་བདེ་ལུགས་ནི་དེ་རེད་ནི་མཐོང་ན་ཡོད་པ་ནི་མི་བདེ་ལུགས་ནི་མི་འགྲོ་བར་ཡོད་པ་མིན།",
  "trans-d_bo_296": "ལྷག་པའི་བཟང་པོ་གཞན་ལ་དུས་ཀྱི་གཞི་ལས་བརྟེན་པ་རེད།་བརྟག་ལྟར་བཅུ་གཉིས་གྲོལ་བཞིན་ཡོད།",
  "trans-d_bo_530": "འདི་བཟུང་བཟོ་སྟངས་དེ་དང་།་དེ་ལ་དོ་བཟོ་བཟོ་མེད་པ་དང་།་བཟུང་བཟོ་གཤིས་བྱེད་རེད།",
  "trans-d_bo_316": "འདུ་མོ་ལ་མེད་པ་ཞིག་རྒྱལ་མཚན་དབང་ལ་རྒྱུ་མཚན་དུ་བཟུང་བའི་མིང་ལ་བརྟེན་པ་རེད།",
  "trans-d_bo_762": "འདི་ངེས་ལུགས་ལ་བཟུང་བྱེད་ཀྱི་ལམ་ལ་བཟུང་བྱེད་ཀྱི་ལམ་ལ་བཟུང་བྱེད་ཀྱི་ལམ་ལ་བཟུང་བྱེད་ཀྱི་ལམ་ལ་བཟུང་བྱེད་ཀྱི་",
  "trans-d_bo_200": "བཟོད་པ་ཞིག་ལ་དུས་གཉིས་ཀྱི་ག་ལོ་ལ་བཟོད་པ་ཞིག་ལ་ཡིན་པ་ནི་ཤེས་པ་མ་རེད།",
  "trans-d_bo_469": "སྒོ་བྱུང་བ་ལ་དུས་ཀྱི་གསོ་བྱུང་བ་ལྟར་བཟོ་བཟོ་དུ་མིང་དུ་སྒོར་མོ་གསོག་པ་དོན་ལ་བཟོ་བཟོ་དུ་མིང་དུ་སྒོར་མོ་གསོག་པ",
  "trans-d_bo_661": "རེད།་ཡིན།",
  "trans-d_bo_147": "བཞིན་ནི་ལྟ་སྒོ་ལྟ་ལོ་གྱི་ལྔ་ལོ་མཐོང་ན་ཡོད་པ་ནི་དུས་ཀྱི་ལྔ་ལོ་མཐོང་ན་ཡོད་པ་ནི་དུས་ཀྱི་ལྔ་ལོ་མཐོང་ན་ཡོད་པ་ན�",
  "trans-d_bo_56": "༢༢ འདི་ཉི་མ་ལ་ཤེས་པ་ཞིག་གི་ཉི་མ་ཐོན་གསུམ་དུ་དུས་པ་དུ་གསུམ་གཅིག་ཤུགས་པ་ཞིག་ལ་དུས་པ་དུ་གསུམ་གཅིག་ཤུགས་པ་ཞིག་ལ་དུས་པ་ད�",
  "trans-d_bo_543": "སྒྲོལ་བྱེད་ཅིང་འབུ་ཤུ་ལུས་ལ་བརྟེན་ཐོན་ལ་བརྟེན་པ་ཞིག་དེ་རེད།",
  "trans-d_bo_57": "སྒྲ་བ་ལ་དུས་ཀྱི་དུས་ལ་བོད་བཟོ་ལ་མི་འདུག་པ་རེད།",
  "trans-d_bo_401": "སྒོམ་པ་ལྟར་བཟོས་ཀྱི་བཟོས་ལ་བཟོད་པ་རེད།་དེ་གྱི་གྲོང་གི་ལེགས་ལ་དགོས་པ་རེད།",
  "trans-d_bo_471": "སྟེང་བཞིན་དུ་བཟོ་ཆེ་ནི་མཐོང་ན།",
  "trans-d_bo_309": "མིན་ཤོག་མིན་ཤུགས་ཀྱི་མི་རིང་ལ་བཟོ་སྤྱོད་བྱེད་པའི་མཚམས་ལ་མི་འདོད་པ་མིན་ཤོག་མིན་ཤུགས་ཀྱི་ལོ་རིང་ལ་བཟོ་སྤྱོད་",
  "trans-d_bo_728": "བོད་ཡིག་ལུང་ལུང་ལ་ཡོང་ཁང་གི་ནvanished",
  "trans-d_bo_34": "༢༥། འཆང་ཤ་ལ་བཟོ་རིང་དུ་དུས་གསུམ་གསུམ་ལས་བཟོ་རིང་དུ་དུས་གསུམ་གསུམ་ལས་བཟོ་རིང་དུ་དུས་གསུམ་གསུམ་ལས་བཟོ་རིང་དུ་དུས་གསུམ་གས�",
  "trans-d_bo_509": "སྐད་མཐོང་མི་བཟོད་པ་ནི་སྤྱི་ལོ་མཐོང་མེད་པ་ཞིག་ཡོད།",
  "trans-d_bo_686": "སྤྱོད་ལྷག་གི་མེ་ལོང་གི་ལུང་གི་བཤད་ལུགས་ལ་དགོས་པ་སྤྱོད་ཅིང་ཡོད་པ་ནི་དེ་དུས་རེད།",
  "trans-d_bo_326": "སྒོ་མོ་ལོ་རིང་བཟོ་བ་དང་ལྷ་ལུང་ལ་བརྟེན་པའི་ལུང་གི་བཟོ་བ་དང་ལྷ་ལུང་ལ་བརྟེན་པ་ནི་རེད།",
  "trans-d_bo_596": "སྟེང་བཟོད་ཅིང་མི་འདུག་བཞིན་ཡོད།",
  "trans-d_bo_217": "འདི་ལ་བཟང་བཟང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུང་བཟུ",
  "trans-d_bo_322": "༢༥ བརྟེན་ལ་བཟོ་མཚམས་ཁང་མཐོང་ན་དུ་དོ་རིང་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞི་གི་གཞ",
  "trans-d_bo_384": "འདི་སྤེན་པ་སྤེན་པ་ལ་བཟུང་བ་མི་འདུག་པ་ཞིག་ཡོད་པ་ནི་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟོ་བ་ལ་བཟ",
  "trans-d_bo_251": "བཟོ་མོ་ལ་བཟུང་བ་བྱེད་ཅིང་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བཟུང་བ་ལ་བ�",
  "trans-d_bo_306": "ཀྲེི་མེད་ལ་ཞིང་ལུས་ལུས་བཅུ་ལུས་ཐོན་མིན་ནི་མེད་པ་མེད་པ་ནི་བཟོ་མེད་པ་ཞིང་ལུས་ལུས་བཅུ་ལུས་ཐོན་མིན་ནི་བཟོ་མེད་པ་ཞིང་",
  "trans-d_bo_551": "སྒྲ་བའི་ལྷག་པ་ལ་མང་པོ་མེད་པ་རེད།་དངོས་དུ་བཞིན་དུ་དུས་རྒྱུ་མཚན་དུ་བདེ་བ་དངོས་དུ་བསྒྱུར་བའི་ལས་དེ་རེད།",
  "trans-d_bo_618": "སྒྲ་མོ་མིན་ཤེས་པ་ཡིན་ནོ།་དེ་ལ་དུས་ཀྱི་ལེགས་ལྟར་གྱི་ལེགས་ལ་རེད།",
  "trans-d_bo_230": "བོད་དགོངས་ལ་ཤོ་ལོ་ལ་ཤིང་བཟོན་ལ་བཟུང་བ་རེད་ནི་དུས་ཀྱི་བོད་དགོངས་ལ་བཟུང་བ་རེད།",
  "trans-d_bo_652": "འདུ་ལོ་དུ་ངེས་པ་ནི་ངེས་པ་ལྟར་ཡིན་པའི་བཟོ་དུང་དུ་བཟོ་དུང་ལམ་ལོ་དུ་བཟོ་དུང་དུ་བཟོ་དུང་བཟོ་དུང་ཡིན།",
  "trans-d_bo_701": "དེ་རིང་རེད།་ངེ་འཛིན་བཟོ་བའི་བཟོ་བ་ལ་བསྟེན་པ་བཞིན་རེད།",
  "trans-d_bo_304": "འདོད་པ་ལྟར་བྱེད་ཀྱི་དུས་ཀྱི་དུས་ལ་དངོས་ཀྱི་དུས་ལ་བྱེད་ཀྱི་དུས་ལ་བྱེད་ཀྱི་དུས་ལ་བྱེད་ཀྱི་དུས་ལ་བྱེད་ཀྱི",
  "trans-d_bo_755": "འདི་བཟོ་བརྗོད་བྱེད་བཞིན་བོད་ལྟར་ཡོད།",
  "trans-d_bo_35": "སྟེང་ཉིན་ལ་འགྲོ་འདོད་བྱེད་པ་ཞིག་ཡོད་པ་ནི་བདུན་ཉིན་ལ་བཟོ་བརྒྱུད་པ་ཞིག་ཡོད།",
  "trans-d_bo_753": "ལུ་ཊུའི་ཁྱོད་སླར་བཟང་པོ་བཞིན་ཡོད་པ་ནི་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ་བཟོ",
